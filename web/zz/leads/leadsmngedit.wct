      <td width="34" height="25" align="center"><font FACE="Arial" size="2"><B><U><font face="Arial" onclick="Del_Open('<<ALLT(STR(MsId))>>')" style="cursor:pointer;" color="#<<IIF(DEL,'FF0000','0000FF')>>"><<IIF(DEL,'Undelete','Delete')>></font></U><<IIF(ACTIVE,'<BR>Active','<BR>Inactive')>></B></td>
     <td width="245" height="25" ><font FACE="Arial" size="2"><<MAILSERVER>><br><<USERNAME>><br><<PASSWORD>>&nbsp;&nbsp;<b><font color="#FF0000"><<IIF(DUPEMAIL,'(block duplicate email)','')>></font></b></font></td>
  </tr> 
   ENDTEXTENDSCAN TEXT
