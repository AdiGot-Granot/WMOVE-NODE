    <td width="34%" align="center" VALIGN="TOP">
<!--DATES-->
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="50%"><input class="chkon" type="radio" name="DATE" value="D0" <<IIF(pnDAY=0,'checked','')>>><font face="Arial" size="2">Today</font></td>
    <td width="15%"><i><font face="Arial" size="2">From:</font></i> </td>
    <td width="35%">
    <input name="DATE1" size="10"></td>
 </tr>
  <tr>
    <td width="50%"><input class="chkon" type="radio" name="DATE" value="D1" <<IIF(pnDAY=1,'checked','')>>><font face="Arial" size="2">Yesterday</font></td>
    <td width="15%"><font face="Arial" size="2"><i>To:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</i></font></font></td>
    <td width="35%"><input name="DATE2" size="10"></td>
 </tr>
  <tr>
    <td width="50%"><input class="chkon" type="radio" name="DATE" value="D2" <<IIF(pnDAY=3,'checked','')>>><font face="Arial" size="2">Last 3 Days</font></td>
    <td width="25%">From:</td>
    <td width="25%"><font color="#008000"><<pcDATE1>></font></td>
 </tr>
  <tr>
    <td width="50%"><input class="chkon" type="radio" name="DATE" value="D3" <<IIF(pnDAY=7,'checked','')>>><font face="Arial" size="2">Last 7 Days</font></td>
    <td width="25%">to</td>
    <td width="25%"><font color="#008000"><<pcDATE2>></font></td>
 </tr> 
  <tr>
    <td width="50%"><input class="chkon" type="radio" name="DATE" value="D4" <<IIF(pnDAY=15,'checked','')>>><font face="Arial" size="2">Last 15 Days</font></td>
    <td width="50%" colspan="2">&nbsp;</td>
 </tr>
  <tr>
    <td width="50%"><input class="chkon" type="radio" name="DATE" value="D5" <<IIF(pnDAY=30,'checked','')>>><font face="Arial" size="2">Last 30 Days</font></td>
    <td width="50%" colspan="2">
         <input id="btnSubmit" type="button" CLASS="SUBOFF" name="SUBMIT" onclick="submitFunction(1)" value="Submit"></td>
 </tr>
</table>
<!--DATES-->
