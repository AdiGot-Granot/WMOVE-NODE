FUNCTION __LEADSMNGEDIT
TEXT<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<TITLE>Leads Mng Edit</TITLE>
<SCRIPT LANGUAGE="JAVASCRIPT">
function submitFunction(i) 
  {
    if (i==1) 
     { 
       document.theForm.action="/wc.dll?mpleads~LeadsMngEditWc~<<pcSCR>>";
       document.theForm.submit();
     }
  }

function exitframe() {
	parent.location.href=('javascript:window.close()');
	}


function submitFunctionxxx(A,B) {
 //alert(A);
 //alert(B);
  document.theForm.action='/wc.dll?mpleads~LeadsManagementAdminWc~&MODULE='+A+'&VALUE='+B;
   document.theForm.submit(); 
  }    

function ViewList(V,R,P,M) {
//alert('<<pcCUSTNO>>');
//alert(V);
//alert(R);
//alert(P);

  window.open('/wc.dll?mpleads~LeadsMngViewList~<<pcSCR>>~<<pcCUSTNO>>~'+V+'~'+R+'~'+P+'~'+M,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=850,height=550');
  }    

function DelayZero(msid) {
 // alert(msid);
  window.open('/wc.dll?mpleads~DelayZero~'+msid,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=5,height=5');
 //window.location.href=('wc.dll?mpleads~DelayZero~'+msid);
  }    

function Del_Open(msid) {
 // alert(msid);
  window.open('/wc.dll?mpleads~Del_Open~'+msid,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=5,height=5');
 //window.location.href=('wc.dll?mpleads~DelayZero~'+msid);
  }    

function RecentZipCode() {
  window.open('/wc.dll?mputil~RecentNewZipcode','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=850,height=550');
  }    

function RecentDistance() {
  window.open('/wc.dll?mputil~NewDistance30Days','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=850,height=550');
  }    

</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#4E6699">
