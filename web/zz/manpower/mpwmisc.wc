<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Worker Miscellaneous Salary</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
	<% SELECT _W
		SCAN %>
       $("#Date<%=ALLT(STR(TRNO))%>").datepicker({ numberOfMonths:[1,2] });
   <%ENDSCAN%>
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    document.theForm.SUBMIT1.style.visibility="hidden";
    if (i==1) document.theForm.action="/wc.dll?mpopr~mpwmiscret~<%=pcSCR+'~'+pcID%>";
    document.theForm.submit()
    
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mv~payworkerwc~<%=pcSCR%>";
       document.theForm.submit();
      }
    }
        
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>
<body BGCOLOR="#4E6699">
<br>
<table border="0" cellpadding="0" cellspacing="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="50%">
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/topBaropr.gif" width="100%" height="14"></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#bebe99" align="center" height="20"><b><font face="Verdana" size="4" color="#993366">Worker Miscellaneous Salary</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><BR>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center">
<FORM NAME="theForm" method="post">    
<table border="0" width="98%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="100%"><b><font face="Verdana" size="2">Worker:&nbsp;&nbsp;<%=pcID%>&nbsp;&nbsp;<%=pcNAME%></b></font></td>
 </tr>
</table>   
<table border="2" width="98%" bordercolor="#C0C0C0" cellspacing="0" cellpadding="2" align="center" style="border-collapse: collapse" bordercolorlight="#6B8AAD" bordercolordark="#6B8AAD">
    <tr>
      <td width="11%" align="center" height="32"><font size="2" color="#993366" Face="Verdana"><b>Date</b></font></td>
      <td width="9%" align="center" height="32"><font size="2" color="#993366" Face="Verdana"><b>Hours</b></font></td>
      <td width="10%" align="center" height="32"><font size="2" color="#993366" Face="Verdana"><b>Per Hours</b></font></td>
      <td width="10%" align="center" height="32"><font size="2" color="#993366" face="Verdana"><b>Total</b></font></td>
      <td width="10%" align="center" height="32"><font size="2" color="#993366" Face="Verdana"><b>Others</b></font></td>
      <td width="11%" align="center" height="32"><font size="2" color="#993366" Face="Verdana"><b>Total Salary</b></font></td>
      <td width="36%" align="center" height="32"><font size="2" color="#993366" Face="Verdana"><b>Remarks</b></font></td>
    </tr>
	<% SELECT _W
		SCAN %>
    <tr>
      <td width="11%" align="center"><input id="Date<%=ALLT(STR(TRNO))%>" NAME="<%='d'+ALLT(STR(TRNO))%>" size="8" VALUE="<%=DTOC(DTE)%>"></td>
      <td width="9%" align="center"><input NAME="<%='h'+ALLT(STR(TRNO))%>" size="2" VALUE="<%=IIF(HRS=0,' ',ALLT(STR(HRS,6,2)))%>"></td>
      <td width="10%" align="center">$<input NAME="<%='p'+ALLT(STR(TRNO))%>" size="4" VALUE="<%=IIF(PERHRS=0,' ',ALLT(STR(PERHRS,6,2)))%>"></td>
      <td width="10%" align="right"><b><font face="Arial" size="2">$<%=IIF(HRS*PERHRS=0,'.',STR(HRS*PERHRS,6,2))%></font></b></td>
      <td width="10%" align="center">$<input NAME="<%='o'+ALLT(STR(TRNO))%>" size="4" VALUE="<%=IIF(COTHER=0,' ',ALLT(STR(COTHER,7,2)))%>"></td>
      <td width="11%" bgcolor="#F5F5F5" align="right"><b><font face="Arial" size="2">$<%=IIF(COMM=0,'.',STR(COMM,10,2))%></font></b></td>
      <td width="36%" align="center"><input NAME="<%='n'+ALLT(STR(TRNO))%>" size="40" VALUE="<%=ALLT(NOTES)%>"></td>
    </tr>
   <% ENDSCAN %>
 </table>
       <br>
	<table border="0" width="48%" cellpadding="0" cellspacing="0" align="center" style="border-collapse: collapse" bordercolor="#111111">
	  <tr>
	    <td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="SUBMIT1" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
	    <td width="2%" align="center">&nbsp;</td>    
       <td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="B4" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Payroll Menu"></td>
   </tr>
	</table>
 </form>
    </td></tr></table>
    </td></tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="20"><font size="2" color="#FFFFFF">User: <%=pcUser%></font></td>
  </tr>
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/botBar.gif" width="100%" height="14"></td>
  </tr>
</table>
</body>
</html>