<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Workers Payroll Report - Printable</title>

<style>
	p.pagebreak {   page-break-after: always;}				  	 	 	 	
</style>

</head>
<body>
<% SELECT DISTIN ID,WNAME,ADDR,CITY,STATECODE,ZIP FROM _MPW ORDER BY ID INTO CURSOR _A
GO TOP
SCAN 
  lcID=ALLT(ID) %>
<table border="1" align="center" style="border-collapse: collapse" bordercolor="#111111" width="100%">
   <tr>
    <td width="100%">   
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="18%" align="left">Printing: <%=DATE()%></td>
    <td width="69%" align="center"><b><font face="Verdana" size="4">Worker Payroll Report</font></b></td>
    <td width="13%" align="center">&nbsp;</td>
 </tr>
  <tr>
    <td width="100%" colspan="3">Worker ID:&nbsp;<b><font size="4"><%=lcID%></b></font></td>
 </tr>
 <% IF !EMPTY(WNAME) %>
  <tr>
    <td width="100%" colspan="3">Worker Name:&nbsp;<b><font size="4"><%=WNAME%></b></font></td>
 </tr>
 <%ENDIF%>
 <% IF !EMPTY(ADDR) %>
  <tr>
    <td width="100%" colspan="3">Address:&nbsp;<b><font size="3"><%=ALLT(ADDR)%><%=IIF(!EMPTY(CITY),', '+ALLT(PROPER(CITY)),'')%>&nbsp;<%=ALLT(STATECODE)%>&nbsp;<%=ALLT(ZIP)%></b></font></td>
 </tr>
 <%ENDIF%>   
  <tr>
    <td width="100%" colspan="3">Report Period:&nbsp;<b><%=DTOC(ldFROMDTE)%></b>&nbsp;-&nbsp;<b><%=DTOC(ldTODTE)%></b></td>
 </tr>         
</table>
  <br>
<table border="1" align="center" style="border-collapse:collapse;font-size:10pt;" bordercolor="#111111" width="99%">
  <tr>
    <td width="1%" align="center" bgcolor="#C0C0C0"><b>#</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Job Date</b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><b>Job No</b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><b>Opr. Type</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Position</td>
    <td width="7%" align="center" bgcolor="#C0C0C0"><b>Start/End</b></td>
    <td width="2%" align="center" bgcolor="#C0C0C0"><b>Hours</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Per Hour</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Total</b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><b>Line Haul</b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><b>Overload</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Material</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Others</b></td>
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Extra</b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><b>Total Job</b></td>
    <td width="2%" align="center" bgcolor="#C0C0C0"><b>Tip</b></td>    
    <td width="3%" align="center" bgcolor="#C0C0C0"><b>Salary</b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><b>Paid On</b></td>
    <td width="8%" align="center" bgcolor="#C0C0C0"><b>Remarks</b></td>
 </tr>
 <% SELECT * FROM _MPW WHERE ID==lcID INTO CURSOR _B
 	SCAN %>
    <tr>
     <td width="1%" align="center"><%=ALLT(STR(RECNO()))+'.'%>&nbsp;</td>
     <td width="3%" align="center"><%=DTOC(DTE)%>&nbsp;</td>
     <td width="4%" align="center"><%=ALLT(DEPT)+ALLT(ORDNO)%><br><%=ALLT(ETYPE)%></td>
     <td width="4%" align="center"><%=JOBCODE%>&nbsp;</td>
     <td width="3%" align="center"><%=ALLT(OPRCODE)%>&nbsp;</td>
     <td width="7%" align="center"><%=ALLT(STARTTME)%>-<%=ALLT(ENDTME)%>&nbsp;</td>
     <td width="2%" align="RIGHT"><%=IIF(HRS=0,'',ALLT(STR(HRS,7,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT"><%='$'+ALLT(STR(PERHRS,7,2))%>&nbsp;</td>
     <td width="3%" align="RIGHT"><B><%=IIF(CHRS=0,'','$'+ALLT(STR(CHRS,7,2)))%></B>&nbsp;</td>
     <td width="4%" align="RIGHT"><%IF ETYPE='D'%><%=IIF(CLH=0,"",'$'+ALLT(STR(CLH,7,2)))%><%ELSE%><%=IIF(CLOCALLH=0,"",'$'+ALLT(STR(CLOCALLH,7,2)))%><%ENDIF%>&nbsp;</td>
     <td width="4%" align="RIGHT"><%=IIF(COVERLOAD=0,'','$'+ALLT(STR(COVERLOAD,7,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT"><%=IIF(CMAT=0,"",'$'+ALLT(STR(CMAT,7,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT"><%=IIF(COTHER=0,"",'$'+ALLT(STR(COTHER,8,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT"><%=IIF(CEXTRA=0,"",'$'+ALLT(STR(CEXTRA,7,2)))%>&nbsp;</td>
     <td width="4%" align="RIGHT"><%=IIF(CACTTOTAL=0,'','$'+ALLT(STR(CACTTOTAL,7,2)))%>&nbsp;</td>
     <td width="2%" align="RIGHT"><%=IIF(TIP=0,"",'$'+ALLT(STR(TIP,7,2)))%>&nbsp;</td>     
     <td width="3%" align="RIGHT"><B><%='$'+ALLT(STR(COMM,10,2))%></B>&nbsp;</td>
     <td width="4%" align="center"><B><%=IIF(EMPTY(PAIDDTE),'',PAIDDTE)%></B>&nbsp;</td>
     <td width="8%"><B><%=ALLT(NOTES)%></B>&nbsp;</td>
    </tr>
  <% ENDSCAN
      SELECT SUM(HRS) AS HRS,SUM(CHRS) AS CHRS,SUM(CLH)+SUM(CLOCALLH) AS CLH,SUM(COVERLOAD) AS COVERLOAD,SUM(CMAT) AS CMAT, ;
      SUM(COTHER) AS COTHER,SUM(CEXTRA) AS CEXTRA,SUM(CACTTOTAL) AS CACTTOTAL,SUM(COMM) AS COMM,SUM(TIP) AS TIP ;
      FROM _B INTO CURSOR _SUM   
  %>       
    <tr>
     <td width="26%" bgcolor="#E7FFE7" colspan="6">&nbsp;</td>
     <td width="2%" bgcolor="#E7FFE7" align="RIGHT"><%=IIF(HRS=0,'',ALLT(STR(HRS,7,2)))%>&nbsp;</td>
     <td width="3%" bgcolor="#E7FFE7">&nbsp;</td>
     <td width="3%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CHRS=0,'','$'+ALLT(STR(CHRS,7,2)))%>&nbsp;</td>
     <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CLH=0,'','$'+ALLT(STR(CLH,7,2)))%>&nbsp;</td>
     <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(COVERLOAD=0,'','$'+ALLT(STR(COVERLOAD,7,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CMAT=0,"",'$'+ALLT(STR(CMAT,7,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(COTHER=0,"",'$'+ALLT(STR(COTHER,8,2)))%>&nbsp;</td>
     <td width="3%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CEXTRA=0,"",'$'+ALLT(STR(CEXTRA,7,2)))%>&nbsp;</td>
     <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CACTTOTAL=0,'','$'+ALLT(STR(CACTTOTAL,7,2)))%>&nbsp;</td>
	 <td width="2%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(TIP=0,"",'$'+ALLT(STR(TIP,7,2)))%>&nbsp;</td>     
     <td width="3%" align="RIGHT" bgcolor="#E7FFE7"><%='$'+ALLT(STR(COMM,10,2))%>&nbsp;</td>
     <td width="4%" bgcolor="#E7FFE7">&nbsp;</td>
     <td width="8%" bgcolor="#E7FFE7">&nbsp;</td>
    </tr>
   </table>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="99%">
  <tr>
    <td width="100%" height="25" valign="bottom"><font face="Verdana" size="2">I verified that this is a true and complete record of all contract time, 
    commission, tips and other amounts of salary due to me for all work</font></td>
  </tr>
  <tr>
    <td width="100%" height="25" valign="bottom"><font face="Verdana" size="2">performed during the above pay periods. 
    <% IF pcCUSTNO='PARTNERMOV'%>The time paid for includes drive time, lunch, other breaks and overtime.<%ENDIF%></font></td>
 </tr>
  <tr>
    <td width="100%" height="25" valign="bottom"><font face="Verdana" size="2">Signature: _____________________________________</font></td>
 </tr>
 
</table>    
    </td>
    </tr>
  </table>
   </td>
  </tr>
  </table>
<p class="pagebreak">&nbsp;</p>
<% ENDSCAN %>
<% SELECT _GROSSSUM %>
<br><!---Summary workers--->
<table border="3" align="center" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%">   
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="20%">Printing: <%=DATE()%></td>
    <td width="67%" align="center"><b><font face="Verdana" size="4">Summary Worker Payroll Report</font></b></td>
    <td width="13%" align="center">&nbsp;</td>
 </tr>
  <tr>
    <td width="100%" colspan="3">From:&nbsp;<b><%=DTOC(ldFROMDTE)%></b>&nbsp;To:&nbsp;<b><%=DTOC(ldTODTE)%></b>
    &nbsp;<b><%=CDOW(ldFROMDTE)%></b>&nbsp;To&nbsp;<b><%=CDOW(ldTODTE)%></b></td>
 </tr>    
</table>
  <br>
<table border="1" align="center" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="5%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total Hours</font></b></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total</font></b></td>
    <td width="5%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Line Haul</b></font></td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Overload</b></font></td>
    <td width="5%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total Materials</b></font></td>
    <td width="5%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total Others</b></font></td>
    <td width="5%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total Extra</font></b></td>
    <td width="5%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total Job</td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total 
    Salary</td>
    <td width="4%" align="center" bgcolor="#C0C0C0"><font size="2"><b>Total Tip</font></b></td>
 </tr>
  <tr>
    <td width="5%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(HRS=0,'',ALLT(STR(HRS,7,2)))%>&nbsp;</td>
    <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CHRS=0,'','$'+ALLT(STR(CHRS,7,2)))%>&nbsp;</td>
    <td width="5%" align="RIGHT" bgcolor="#E7FFE7"><%='$'+ALLT(STR(CLH+CLOCALLH,10,2))%>&nbsp;</td>
    <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%='$'+ALLT(STR(COVERLOAD,10,2))%>&nbsp;</td>
    <td width="5%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CMAT=0,"",'$'+ALLT(STR(CMAT,7,2)))%>&nbsp;</td>
    <td width="5%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(COTHER=0,"",'$'+ALLT(STR(COTHER,8,2)))%>&nbsp;</td>
    <td width="5%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CEXTRA=0,"",'$'+ALLT(STR(CEXTRA,7,2)))%>&nbsp;</td>
    <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(CACTTOTAL=0,'','$'+ALLT(STR(CACTTOTAL,7,2)))%>&nbsp;</td>
    <td width="5%" align="RIGHT" bgcolor="#E7FFE7"><%='$'+ALLT(STR(COMM,10,2))%>&nbsp;</td>
    <td width="4%" align="RIGHT" bgcolor="#E7FFE7"><%=IIF(TIP=0,"",'$'+ALLT(STR(TIP,7,2)))%>&nbsp;</td>
 </tr>
</table>
    </td></tr></table>
   <br><center><a href="/wc.dll?mv~payworkerwc~<%=pcSCR%>">Payroll Menu</a></center></td></tr></table>
</body>
</html>