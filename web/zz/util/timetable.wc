<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Time Table</title>
<SCRIPT LANGUAGE="JavaScript">


function transfer(tme) {

	var _w1 = null;
	_w1 = self.opener;
	_w1.document.<%=ALLT(pcFORM)%>.<%=ALLT(pcELEMENT)%>.value=tme;
	//_w1.document.forms[0].SNAME.value=tme;
	window.close();
	}

</SCRIPT>

<STYLE TYPE="text/css">
 	.TIMEOFFAM	 {	color: #4A659C; 
					font-weight: bold;
					font-family: Verdana;
				  	text-align: center;
					background-color: #E2E2E2;
					font-size: 10pt;
  				  	text-decoration: nounderline}
	.TIMEONAM 	{	color: #FFBE29; 
					font-weight: bold;
					font-family: Verdana;
				  	text-align: center;
					background-color: #4275A5;
					font-size: 10pt;
  				  	cursor: pointer;
  				  	text-decoration: underline}
 	.TIMEOFFPM	 {	color: #4A659C; 
					font-weight: bold;
					font-family: Verdana;
				  	text-align: center;
					background-color: #C6DBF7;
					font-size: 10pt;
  				  	text-decoration: nounderline}
	.TIMEONPM 	{	color: #FFBE29; 
					font-weight: bold;
					font-family: Verdana;
				  	text-align: center;
					background-color: #F7EFAD;
					font-size: 10pt;
  				  	cursor: pointer;
  				  	text-decoration: underline}
</style>

</head>
