			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('10-04PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">10-04PM</font></td>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('11-05PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">11-05PM</font></td>
			  </tr>
              <tr>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('12-06PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">12-06PM</font></td>
			    <td width="27%" class="TIMEOFFPM" height="19" ONCLICK="transfer('01-07PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">01-07PM</font></td>
			  </tr>
              <tr>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('02-08PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">02-08PM</font></td>
			    <td width="27%" class="TIMEOFFPM" height="19" ONCLICK="transfer('03-09PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">03-09PM</font></td>
			  </tr>			  			  			  			  
              <tr>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('04-10PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">04-10PM</font></td>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('05-11PM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">05-11PM</font></td>
			 </tr>
              <tr>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('06-12AM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">06-12AM</font></td>
			    <td width="28%" class="TIMEOFFPM" height="19" ONCLICK="transfer('07-01AM')" onmouseover="this.className='TIMEONPM'" onmouseout="this.className='TIMEOFFPM'">
			    <font color="#000000">07-01AM</font></td>
			 </tr>
			 </table>			     
    </td>
    <%ENDIF%>    
  </tr>
</table>

</body>
</html>