<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Online Moving System</title>

</head>

<body  BGCOLOR="#ADBACE" onload="window.btnBACK.focus()">
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="70%">
  <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">&nbsp;</td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#4A698C" height="27" colspan="2" align="center"><b>
    <font face="Arial Rounded MT Bold" size="4" color="#FFFFFF">System Message </font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="91" colspan="2">
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
	  <tr>
	    <td width="100%">
    <!-- Body & Column -->
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%" align="center">
  <tr>
    <td width="100%" align="center"><font face="Verdana" color="#CC0000"><B><%=ALLT(pcERRMSG)%></B></font><br><br>&nbsp;</td>
  </tr>
  <tr>
    <td width="100%" align="center">&nbsp;
    <input type="button" value="Go Back" id="btnBACK" onclick="history.go(-1)" class="BTN" style="width:80" tabindex="1">
  </tr>
  </table>    
    &nbsp;</td>
  </tr>
  </table>
</td>
</tr>
<%IF pnLEVEL<>0%>
  <tr>
    <td width="50%" BGCOLOR="#4A698C" height="15"><b><font face="Verdana" size="1" color="#FFFFFF">&nbsp;IP: <%=pcIP%>&nbsp;</font></b>&nbsp;</td>
    <td width="50%" BGCOLOR="#4A698C" height="15" align="right"><b><font face="Verdana" size="1" color="#FFFFFF"><%=DATETIME()%><font color="#FFFFFF">&nbsp;</font></td>
  </tr>
<%ENDIF%>  
   <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">&nbsp;</td>
 </tr>
  </table>
  </center>
</div>
</body>

</html>