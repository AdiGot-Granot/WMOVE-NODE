<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Print Tariff</title>

<style>
	.TD1		{	color: #OOOOOO;
					background-color: #E9E9EA;
				  	font-size: 9pt;
  				  	font-family: Arial;
				  	text-align: center;}
	.TD2		{	color: #OOOOOO;
					background-color: #FFFFFF;
				  	font-size: 9pt;
  				  	font-family: Arial;
				  	text-align: center;}
	.TD3		{	color: #OOOOOO;
					background-color: #DEFFFF;
				  	font-size: 9pt;
  				  	font-family: Arial;
				  	text-align: center;}
				  	
	p.pagebreak {   page-break-after: always;}				  	 	 	 	
</style>

</head>
<body>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="85%">
  <tr>
    <td width="46%"><b><font face="Arial" SIZE="2">&nbsp;</font></b></td>
