<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Unsubscribe Your Email</title>


<STYLE TYPE="text/css">
.SUBMIT	{font-size: 9pt;
		 font-weight: bold;
  		 font-family: Verdana;
         width: 70; 
         height: 25; 
         cursor: pointer;}
</style>

</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="35%">
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
   <form name="theForm" method="POST" action="/wc.dll?mputil~removeemailret">
    <input type="hidden" name="EMAILTO" value="<%=lcEMAILTO%>">
    <input type="hidden" name="CUSTID" value="<%=ALLT(STR(lnCUSTID))%>">
<input type="hidden" name="JOBID" value="<%=ALLT(STR(lnJOBID))%>">      
<table border="0" align="center" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #A9A9A9;font-family:Verdana;font-size:10pt;" bordercolor="#111111" width="98%">
   <tr>
     <td align="center">You selected to unsubscribe from the mailing list.<br><br>Please enter the validation numbers: <b><font size="3"><%=ALLT(STR(lnJOBID))%></font></b><br><br>
     <input type="text" NAME="VALCODE" autocomplete="off" size="8" value="">
     <br><br><input id="btnSubmit" type="submit" CLASS="SUBMIT" name="B1" value="Validate"></td>
  </tr>  
</table>
 </form>
    &nbsp;</td>
  </tr>
</table>

</body>
</html>