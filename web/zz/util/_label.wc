<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<style>
	p.pagebreak {   page-break-after: always;}
	body {margin: 5mm 10mm 10mm 10mm;}	
</style>

</head>

<body>

<%for I=pnSTART TO pnEND %>
<br><font style="font-family:Arial;"><b><font style="font-size:15pt;"><%=ALLT(_EST.ORDNO)%>----<font style="font-size:30pt;"><%=ALLT(STR(I))%></font></font><br>
<font style="font-size:15pt;"><%=ALLT(PROPER(_EST.SNAME))%></font><br>
<font style="font-size:15pt;"><%=ALLT(PROPER(_EST.SCITY))%>, <%=ALLT(_EST.SSTATE)%>&nbsp;<%=ALLT(_EST.SZIP)%><br>
<%=ALLT(PROPER(_EST.RCITY))%>, <%=ALLT(_EST.RSTATE)%>&nbsp;<%=ALLT(_EST.RZIP)%></font>
<p class="pagebreak">&nbsp;</p>
<%ENDFOR%>
</body>
</html>