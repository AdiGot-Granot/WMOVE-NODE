<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Salesperon Payroll</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->

<script type="text/javascript">
 jQuery.noConflict();
      jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });

</script>

<!--DROPDOWN USERS SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN USERS SEARCH-->

<script type="text/javascript">

  $(document).ready(function() {
      $('.user-select').select2({
          placeholder: 'Select User',
          allowClear: true
      });
  });
  
</script>


<SCRIPT LANGUAGE="JAVASCRIPT">

function submitfunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpopr~paysaleswc~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mv~oprmenuwc~<%=pcSCR%>";
       document.theForm.submit();
      }     
	}
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>
<body BGCOLOR="#4E6699">
<br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="600" align="center">
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/topBaropr.gif" width="600" height="14"></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#bebe99" height="25" align="center">&nbsp;<font size="4" color="#993366" face="Verdana"><b>Salesperson Payroll</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
     <tr>
      <td width="100%" align="center">
    <form name="theForm" method="POST"><br>
<table border="0" width="90%" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="13%"><b>Date Factor:</b></td>
	<td width="14%"><b>Date Range:</b></td>
	<td width="10%"><b>From Date:</b></td>
	<td width="15%"><b>To Date:</b></td>
 </tr>
  <tr>
	<td width="13%">
		<select size="1" name="TYPEDTE">
			<option value="MOVE" selected>Move Date</option>
			<option value="BOOK">Book Date</option>
		</select></td>
	<td width="14%">
	<select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  </select>	
	</td>
	<td width="10%"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DTOC(pdDATE1)%>"></td>
	<td width="15%"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DTOC(pdDATE2)%>"></td>
 </tr> 
</table>
 <br> 
<table border="0" cellpadding="1" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="70%">
  <tr>
    <td width="31%" bgcolor="#F5F5F5"><font face="Verdana" size="2"><b>Salesperson:</b></font></td>
    <td width="69%"><select size="1" name="REP" class="user-select" style="width: 270px;">
		  		<option selected></option>
		  		 <%	SELECT _USERS
				 	 SCAN %>
			   		<option value="<%=ALLT(REP)%>"><%=ALLT(REP)%><%=IIF(EMPTY(NAME),'',' - '+ALLT(NAME))%></option>
					 <% ENDSCAN %>
				</select></td>
 </tr>
</table>
  <br>
<table border="0" width="70%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="42%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitfunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
    <td width="42%" align="right"><input type="button" CLASS="SUBOFF" name="B5" onclick="submitfunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>    
 </tr>
</table>
    <br></td>
  </tr>
</table>
  </form>    
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15"><font size="2" color="white" align="left">User: <%=pcUser%></font></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFEFCC" align="center" height="14"><b><font color="#FF0000" face="Arial Rounded MT Bold"><%=pcMSG%></font></b></td>
  </tr>
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/botBar.gif" width="600" height="14"></td>
  </tr>
</table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->

</body>
</html>