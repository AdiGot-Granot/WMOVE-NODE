<html>
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge"><!--IE 11 Compatibility overrite-->
<meta name="viewport" content="width=*your site width*, initial-scale=0.30">

<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>INTERSTATE BILL OF LADING</title>

<style>
p.fvp {text-align:justify;}
p.pagebreak {   page-break-after: always;}
</style>

</head>

<body>
<table border="0" align="center" style="border-collapse: collapse" width="850">
  <tr>
    <td valign="top" width="189"><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcADD1,pcAGADD1)%><BR><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcADD2,pcAGADD2)%><BR>
    <%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcTOLLFREE,pcAGPHONE)%><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),'<BR>US DOT No: '+pcDOT,'<BR>US DOT No: '+pcAGDOT)%>
    <%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),'<BR>ICC/MC No: '+pcICC,'<BR>ICC/MC No: '+pcAGICC)%>
    <% IF 1=2 %>
      <%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),'<BR>Registration: '+pcREGISTER,'<BR>Registration: '+pcAGREGISTER)%>
    <%ENDIF%> </td>
    <td valign="top" align="center" width="465"><font style="font-family:Arial;font-size:16pt;"><b><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcCOMPANY,pcAGCOMPANY)%></b></font>
    <br><br><br><br><br><br><br><font style="font-family:Arial;font-size:13pt;"><b>INTERSTATE BILL OF LADING CONTRACT</b></font></td>
    <td valign="top" height="100" width="190">
<table border="1" align="right" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="100%" valign="top" height="40"><font style="font-family:Arial;font-size:10pt;">&nbsp;Order No:<br>&nbsp;<%=ALLT(_EST.DEPT)+ALLT(_EST.ORDNO)%><%=' - '+pcREVNO%></font></td>
 </tr>
  <tr>
    <td width="100%" valign="top" height="40"><font style="font-family:Arial;font-size:10pt;">&nbsp;Pick-Up Date:<br>&nbsp;<%=_EST.LBOOKDTE%><%=IIF(EMPTY(_EST.LBOOKDTE1),'','-'+DTOC(_EST.LBOOKDTE1))%></font></td>
 </tr>
  <tr>
    <td width="100%" valign="top" height="40"><font style="font-family:Arial;font-size:9pt;">&nbsp;1<SUP>ST</SUP> Available Date for Delivery:<br>&nbsp;
    <%=IIF(EMPTY(_EST.DLVDTE),'',DTOC(_EST.DLVDTE))%><%=IIF(EMPTY(_EST.DLVDTE1),'','-'+DTOC(_EST.DLVDTE1))%></font></td>
 </tr>
  <tr>
    <td width="100%" valign="top" height="30"><font style="font-family:Arial;font-size:10pt;">&nbsp;Vehicle ID:<br>&nbsp;</font></td>
 </tr>   
</table>
   </td>
 </tr>
  </table>
<table border="0" align="center" style="border-collapse: collapse" width="850">
  <tr>
    <td valign="top">
<table border="1" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-family:Arial;font-size:9pt;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" bgcolor="#DCDCDC" align="center"><font style="font-family:Arial;font-size:11pt;"><B>ORIGIN</B></font></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;SHIPPER:&nbsp;<%=ALLT(PROPER(_EST.SNAME))%></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;ADDRESS:&nbsp;<%=ALLT(_EST.SADD1)%>&nbsp;<%=ALLT(_EST.SADD2)%></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;FLOOR/APT/LEVEL:&nbsp;<%=IIF(EMPTY(_EST.SFLOOR),'','F: '+ALLT(STR(_EST.SFLOOR)))%>
    <%=IIF(EMPTY(_EST.SAPT),'',', A: '+ALLT(_EST.SAPT))%><%=IIF(EMPTY(_EST.SSUBLEVEL),'',', L: '+ALLT(_EST.SSUBLEVEL))%></td>
 </tr> 
  <tr>
    <td width="100%" height="25">&nbsp;CITY/STATE/ZIP:&nbsp;<%=ALLT(PROPER(_EST.SCITY))+', '+(_EST.SSTATE)%>&nbsp;<%=ALLT(_EST.SZIP)%></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;PHONE:&nbsp;<%=ALLT(_EST.STELH)%><%=IIF(EMPTY(_EST.STELO),'',', '+ALLT(_EST.STELO))%></td>
 </tr>
</table>    
    </td>
    <td width="15">&nbsp;</td>
    <td width="396" valign="top">
<table border="1" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-family:Arial;font-size:9pt;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" bgcolor="#DCDCDC" align="center"><font style="font-family:Arial;font-size:11pt;"><B>DESTINATION</B></font></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;CONSIGNED TO:&nbsp;<%=ALLT(PROPER(_EST.RNAME))%></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;ADDRESS:&nbsp;<%=ALLT(_EST.RADD1)%>&nbsp;<%=ALLT(_EST.RADD2)%></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;FLOOR/APT/LEVEL:&nbsp;<%=IIF(EMPTY(_EST.RFLOOR),'','F: '+ALLT(STR(_EST.RFLOOR)))%>
    <%=IIF(EMPTY(_EST.RAPT),'',', A: '+ALLT(_EST.RAPT))%><%=IIF(EMPTY(_EST.RSUBLEVEL),'',', L: '+ALLT(_EST.RSUBLEVEL))%></td>
 </tr> 
  <tr>
    <td width="100%" height="25">&nbsp;CITY/STATE/ZIP:&nbsp;<%=ALLT(PROPER(_EST.RCITY))+', '+(_EST.RSTATE)%>&nbsp;<%=ALLT(_EST.RZIP)%></td>
 </tr>
  <tr>
    <td width="100%" height="25">&nbsp;PHONE:&nbsp;<%=ALLT(_EST.RTELH)%><%=IIF(EMPTY(_EST.RTELO),'',', '+ALLT(_EST.RTELO))%></td>
 </tr>
</table>    
    </td>
  </tr>
</table>
<table border="1" align="center" style="border-collapse: collapse" bordercolor="#111111" width="850">
  <tr>
    <td width="231" valign="top" height="35">&nbsp;<FONT style="font-family:Arial;font-size:9pt;">Agent Name:</FONT></td>
    <td width="226" valign="top" height="35">&nbsp;<FONT style="font-family:Arial;font-size:9pt;">Address:</FONT></td>
    <td width="178" valign="top" height="35">&nbsp;<FONT style="font-family:Arial;font-size:9pt;">Phone:</FONT></td>
    <td width="155" valign="top" height="35">&nbsp;<FONT style="font-family:Arial;font-size:9pt;">US DOT:</FONT></td>
 </tr>
</table>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="850">
  <tr>
    <td valign="top"><FONT style="font-size:7pt;">&nbsp;</font></td>
 </tr>
</table>
<table border="1" align="center" style="border-collapse: collapse" bordercolor="#111111" width="850">
  <tr>
    <td valign="top">
<table align="center" border="0" style="border-collapse: collapse;" width="100%" cellspacing="0" cellpadding="0">
  <tr>
    <td align="center" width="100%" colspan="3"><font style="font-family:Arial;font-size:11pt;"><b>SIGN AT LEAST 3 DAYS BEFORE PICK-UP DATE:</b></font></td>
  </tr>
  <tr>
    <td valign="top" width="100%" colspan="3"><p style="text-align:justify;">
    <font style="font-family:Arial;font-size:10pt;">I, <%=ALLT(PROPER(_EST.SNAME))%>, acknowledge I have read and agree to all the terms and conditions on 
    both sides of this bill of lading contract. I have received the arbitration information and the booklet: 
    <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/RightsandResponsibilitiesBooklet_2022Update.pdf" target="_blank">Your Rights and Responsibilities When you Move</a>
    and pamphlet <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/ReadytoMoveBrochure_2022Update.pdf" target="_blank">Ready to Move</a>. I agree to pay for the total
    charges for moving services. I approved the total estimated charges prior to the moving services beginning.</p></td>
 </tr>
 <% IF plPRINT=.T. %>
  <tr style="font-family:Arial;font-size:10pt;">
    <td width="100%" colspan="3"><img src="<%=pcSIGDATA%>"><br>Sign Date:&nbsp;<%=pcEDTE+' ET'%>&nbsp;Sign Name:&nbsp;<%=pcENAME%>&nbsp;&nbsp;IP:&nbsp;<%=pcEIP%></td>
 </tr>
 <% ENDIF %>
  <tr>
    <td width="100%" style="border-top: 1px solid #000000;" align="center" colspan="2"><font style="font-family:Arial;font-size:11pt;"><B>PAYMENT TERMS:</B></font></td>
 </tr> 
  <tr>
    <td width="100%" colspan="2"><p style="text-align:justify;">
<% IF !EMPTY(pcAGBOLPAY) %>
   <%=pcAGBOLPAY%>
<%ELSE%> 
   <%IF EMPTY(pcREMPAY) %>
	<font style="font-family:Arial;font-size:10pt;">Upon booking a deposit is required to be paid. Acceptable payment forms are credit card, cashier`s check, or cash. Prior to pick-up a portion of the balance is due. 
	Acceptable payment forms are credit card, cashier`s check, cash, postal money order. Balance is due at delivery prior to unloading. Acceptable payment form post money order or Cash.</font>
   <%ELSE%>
	  <%=pcREMPAY%>
   <%ENDIF%>	    
 <%ENDIF%>	
	</p></td>
  </tr>
  <% IF plPRINT=.T. %>
  <tr style="font-family:Arial;font-size:10pt;">
    <td width="100%" colspan="2"><img src="<%=pcSIGPAY%>"><br>Sign Date:&nbsp;<%=pcEDTE+' ET'%>&nbsp;Sign Name:&nbsp;<%=pcENAME%>&nbsp;&nbsp;IP:&nbsp;<%=pcEIP%></b></td>
 </tr>
  <% ENDIF %>         
</table>	 
 </td>
 </tr>
</table>	 
 </td>
 </tr>
</table>
 <BR> 
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="850">
  <tr>
    <td valign="top">
<table border="1" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" bgcolor="#DCDCDC" align="center"><font style="font-family:Arial;font-size:11pt;"><B>VALUATION OPTIONS</B></td>
 </tr>
  <tr>
    <td width="100%">
<!--start VFP  -->
<table border="0" align="center" width="99%" style="border-collapse:collapse;">
  <tr>
    <td style="text-align:justify;font-family:Arial;font-size:9pt;line-height:1.3">      
    <p style="margin:0;"><b>THE CONSUMER MUST SELECT ONE OF THESE OPTIONS FOR THE CARRIER`S LIABILITY FOR LOSS OR DAMAGE TO YOUR HOUSEHOLD GOODS. CUSTOMER`S DECLARATION OF VALUE. 
    THIS IS A TARIFF LEVEL OF CARRIER LIABILITY -IT IS NOT INSURANCE.</b><hr color="#000000" size="1"></hr>
    <b><font style="font-size:17pt;color:#000000;"><%=IIF(_CRG.FVPLEVEL=.T.,'&#9745;','')%></font>&nbsp;<font style="font-family:Arial;font-size:9pt;">OPTION 1: FULL VALUE PROTECTION <%=pcFVPVALUE%></font></b><br>
<table border="1" align="center" bordercolor="#000000" style="border-collapse: collapse" width="99%">
  <tr>
    <td width="23%" bgcolor="#DCDCDC"><b><font face="Arial" size="2">Deductible:</font></b></td>
    <td width="13%" bgcolor="#DCDCDC"><b><font face="Arial" size="2">$<%=_DEDUCT.D0TXT%></font></b> <font size="1" color="#C90000"><%=IIF(ALLT(_CRG.FVPDEDUCT)=ALLT(_DEDUCT.D0TXT) AND _CRG.INSAMT > 0,'(selected)','')%></font></td>
    <td width="15%" bgcolor="#DCDCDC"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=_DEDUCT.D1TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D1TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></font></td>
    <td width="13%" bgcolor="#DCDCDC"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=_DEDUCT.D2TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D2TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="11%" bgcolor="#DCDCDC"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=_DEDUCT.D3TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D3TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="13%" bgcolor="#DCDCDC"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=_DEDUCT.D4TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D4TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="12%" bgcolor="#DCDCDC"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=_DEDUCT.D5TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D5TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
 </tr>
  <tr style="font-family:Arial;font-size:9pt;">
    <td width="23%"><b>Valuation:</font></td>
    <td width="13%">$<%=ALLT(STR(_CRG.D0,9,2))%></b></td>
    <td width="15%"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=ALLT(STR(_CRG.D1,9,2))%><%ENDIF%></td>
    <td width="13%"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=ALLT(STR(_CRG.D2,9,2))%><%ENDIF%></td>
    <td width="11%"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=ALLT(STR(_CRG.D3,9,2))%><%ENDIF%></td>
    <td width="13%"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=ALLT(STR(_CRG.D4,9,2))%><%ENDIF%></td>
    <td width="12%"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=ALLT(STR(_CRG.D5,9,2))%><%ENDIF%></td>
 </tr>
  <tr style="font-family:Arial;font-size:9pt;">
    <td width="23%"><b>Estimate Plus<br>Valuation:</b></td>
    <td width="13%">$<%=ALLT(STR(_CRG.D0+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%></td>
    <td width="15%"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=ALLT(STR(_CRG.D1+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></td>
    <td width="13%"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=ALLT(STR(_CRG.D2+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></td>
    <td width="11%"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=ALLT(STR(_CRG.D3+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></td>
    <td width="13%"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=ALLT(STR(_CRG.D4+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></td>
    <td width="12%"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=ALLT(STR(_CRG.D5+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></td>
 </tr>    
</table>    
    The Cost Estimate that you receive from your mover MUST INCLUDE Full (Replacement) Value Protection for the articles that are included in your shipment. 
    If you wish to waive the Full (Replacement) Value level of protection you must complete the WAIVER of Full (Replacement) Value Protection shown below.<br>
    Full (Replacement) Value Protection is the most comprehensive plan available for protection of your goods. If any article is lost, destroyed, or damaged while 
    in your mover's custody, your mover will, at its option, either 1) repair the article to the extent necessary to restore it to the same condition as when it
    was received by your mover, or pay you for the cost of such repairs; or 2) replace the article with an article of like kind and quality, or pay you for the
    cost of such a replacement. Under Full (Replacement) Value Protection, if you do not declare a higher replacement value on this form prior to the time of shipment, 
    the value of your goods will be deemed to be equal to $6.00 multiplied by the weight (in pounds) of the shipment, subject to a minimum valuation for the shipment of $6000. 
    Under this option, the cost of your move will be composed of a base rate plus an added cost reflecting the cost of providing this full value cargo liability 
    protection for your shipment. If you wish to declare a higher value for your shipment than these default amounts, you must indicate that value here. 
    Declaring a higher value may increase the valuation charge in your cost estimate.<br><br>
    <b>The Total Value of my shipment is:</b> $__________(provided by the customer)<br><br>
    <b>Dollar Estimate of the cost of your move<br>at Full (Replacement) Value Protection:</b> $___________(provided by carrier)<br><br>
    I acknowledge that for my shipment I have 1) ACCEPTED the Full (Replacement) Level of protection included in this estimate and declared a 
    higher total value of my shipment (if appropriate), and 2) received a copy of the 
    <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/RightsandResponsibilitiesBooklet_2022Update.pdf" target="_blank">Your Rights and Responsibilities When You Move</a> brochure explaining these provisions.</p></td>
  </tr>   
</table>

<% IF _CRG.FVPLEVEL=.T. %><!---FVP-->
<table border="0" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#000000" width="99%">
 <% IF plPRINT=.T. AND !EMPTY(pcSIGINSUR) %>
  <tr style="font-family:Arial;font-size:10pt;">
  <td width="100%" colspan="2"><img src="<%=pcSIGINSUR%>"><br>Sign Date:&nbsp;<%=pcEDTE+' ET'%><br>Sign Name:&nbsp;<%=pcENAME%><br>IP:&nbsp;<%=pcEIP%></b></td>
 </tr> 
 <%ENDIF%> 
</table>
<%ENDIF%>
<% IF plPRINT=.T. AND _CRG.FVPLEVEL=.F.  %>
<table border="1" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#000000" width="99%">
  <tr>
    <td width="67%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Customer's Signature</FONT></td>
    <td width="33%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Date</FONT></td>
  </tr>
</table>
<%ENDIF%>
<table border="0" align="center" width="99%" style="border-collapse:collapse;">
  <tr>
    <td style="text-align:justify;font-family:Arial;font-size:9pt;line-height:1.3">
    <hr color="#000000" size="1"></hr>      
    <p style="margin:0;"><b><font style="font-size:17pt;color:#000000;"><%=IIF(_CRG.FVPLEVEL=.F.,'&#9745;','')%></font> OPTION 2: RELEASE VALUE</b><br>WAIVER of Full (Replacement) Value Protection. 
    This lower level of protection is provided at no additional cost beyond the base rate; however, it provides only minimal protection that is considerably less 
    than the average value of household goods. Under this option, a claim for an article that may be lost, destroyed, or damaged while in your mover`s custody will
    be settled based on the weight of the individual article multiplied by 60 cents. For example, the settlement for an audio component valued at $1000 that weighs
    10 pounds would be $6.00 (10 pounds times 60 cents).<br><b>COMPLETE THIS PART ONLY</b> if you wish to WAIVE the Full (Replacement) Level of Protection included in the higher cost estimate provided  above 
    in Option 1 for your shipment and instead select the LOWER Released Value of 60 Cents Per Pound Per Article; to do so you must initial and sign on the lines below.</p>
	<table border="0" align="center" style="border-collapse: collapse" width="99%">
  	  <tr>
    	<td width="77%"><font style="font-family:Arial;font-size:9pt;"><b>I wish to Release My Shipment to a Maximum
    	Value of 60 Cents per Pound per Article. Customer Initials:</b></font></td>
    	<td width="23%" style="border-top: 2px solid #000000;border-left: 2px solid #000000;border-right: 2px solid #000000;border-bottom: 2px solid #000000;">
    	<br>&nbsp;</td>
  	  </tr>  
	</table>
    I acknowledge that for my shipment I have 1) WAIVED the Full (Replacement) Level of protection for which I have received an estimate of charges, and 2) received a 
    copy of the <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/RightsandResponsibilitiesBooklet_2022Update.pdf" target="_blank">Your Rights and Responsibilities When You Move</a>
    brochure explaining these provisions.<br><br><b>Dollar Estimate of the cost of your<br>move under the 60-cents option:</b> $___________(provided by carrier)</td>
  </tr>   
</table>
<% IF _CRG.FVPLEVEL=.F. %><!---RELEASE VALUE 0.60-->
<table border="0" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#000000" width="99%">
 <% IF plPRINT=.T. AND !EMPTY(pcSIGINSUR) %>
  <tr style="font-family:Arial;font-size:10pt;">
  <td width="100%" colspan="2"><img src="<%=pcSIGINSUR%>"><br>Sign Date:&nbsp;<%=pcEDTE+' ET'%><br>Sign Name:&nbsp;<%=pcENAME%><br>IP:&nbsp;<%=pcEIP%></b></td>
 </tr> 
 <%ENDIF%> 
</table>
<%ENDIF%>
<% IF plPRINT=.T. AND _CRG.FVPLEVEL=.T. %>
<table border="1" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#000000" width="99%">
  <tr>
    <td width="67%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Customer's Signature</FONT></td>
    <td width="33%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Date</FONT></td>
  </tr>
</table>
<%ENDIF%>
<!--end of VFP  -->
<hr color="#000000" size="1" width="99%"></hr>
<%IF _EST.VISUALTYPE=3 %>
<table border="0" align="center" style="border-collapse: collapse;font-family:Arial;" width="99%"> 
  <tr>
    <td width="100%"><p style="text-align:justify;"><font style="font-family:Arial;font-size:10pt;"><font style="font-size:11pt;"><B>PHYSICAL SURVEY:</B></font> 
    <font style="font-size:10pt;">The shipper has elected to waive the physical and virtual survey and signed the waiver agreement before the shipment is loaded in accordance with 49 CFR 375.401 (a).</font></p></td>
  </tr>
</table>
<hr color="#000000" size="1" width="99%"></hr>
<%ENDIF%>
<table border="0" align="center" style="border-collapse: collapse" width="99%">
  <tr>
    <td align="right" width="67%"><font style="font-family:Arial;font-size:11pt;"><b>TOTAL ESTIMATED CHARGES:</b></font>&nbsp;<br>
    <font style="font-size:7pt;">Estimates are not guaranteed per 49 CFR   375.403(6)</font>&nbsp;</td>
    <td width="33%" style="border-top: 2px solid #000000;border-left: 2px solid #000000;border-right: 2px solid #000000;border-bottom: 2px solid #000000;">
    &nbsp;<font style="font-family:Arial;font-size:11pt;"><b><%='$'+ALLT(STR(_EST.SUBTOTAL,8,2))%></b></font></td>
  </tr>
  <tr>
    <td align="right" width="67%">&nbsp;<span style="font-size: 11pt"><b><span style="font-family: Arial">ESTIMATED</span></b></span><font style="font-family:Arial;font-size:11pt;"><b> Cu.Ft./Lbs.:</b></font>&nbsp;</td>
    <td width="33%" height="35" style="border-top: 2px solid #000000;border-left: 2px solid #000000;border-right: 2px solid #000000;border-bottom: 2px solid #000000;">
