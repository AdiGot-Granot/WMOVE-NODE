  </tr>
</table>
<% IF pnTEMAILID=301 %>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="99%">
  <tr style="font-family:Arial;font-size:10pt;">
    <td width="100%" colspan="3"><img src="<%=pcSIGPU%>"><br>Sign Date:&nbsp;<%=pcEDTEPU+' ET'%><br>Sign Name:&nbsp;<%=pcENAMEPU%>&nbsp;&nbsp;IP:&nbsp;<%=pcEIPPU%><br>
    Print this document via <a href="javascript: window.print()"><b>Printer Friendly</a></b>.</td>
 </tr>
</table>
<%ENDIF%>
 <% IF plLINK=.T. %>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="99%"> 
  <tr>
    <td width="36%"><input type="text" autocomplete="off" name="ENAME" size="15" placeholder="Customer Name" style="border: 2px solid #ff0000;" maxlength="50"></td>
    <td width="8%"><font style="font-family:Arial;font-size:10pt;"><b>Signature:</b></font> </td>
    <td width="56%"><input type="hidden" name="sigPuk" id="sigPuk">
    <canvas id="newSignature" width="250" height="50" style="position: relative;border: 2px solid #ff0000;"></canvas></td>
 </tr>
</table>
<br><center><input type="button" onclick="signatureSave()" style="width:125;height:25;font-family:Arial;font-size:10pt;font-weight:bold;color:#0000FF;cursor:pointer;" value="Accept and Sign">&nbsp;&nbsp;&nbsp;&nbsp;<input type="button" onclick="signatureClear()" style="width:60;height:25;font-family:Arial;font-size:10pt;font-weight:bold;cursor:pointer;" value="Clear"></center>
 <%ENDIF%>
<table border="1" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#000000" width="99%">
   <% IF plPRINT=.T. AND plVIEW=.T. %>
  <tr>
    <td width="67%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Customer's Signature at Pick-Up</FONT></td>
    <td width="33%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Date</FONT></td>
  </tr>
  <%ENDIF%>
  <tr>
    <td width="67%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Carrier Signature at Pick-Up</FONT></td>
    <td width="33%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Date</FONT></td>
 </tr>
</table>
<hr color="#000000" width="99%" size="1"></hr>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="100%"><p style="text-align:justify;"><font style="font-family:Arial;font-size:10pt;"><b>Notice of Maximum amount due upon delivery:</b> 
    Final charges will be based on actual weight or cubic feet of property and services provided or time. Maximum amount to be paid to the carrier and 
    demanded at destination is the amount of the last issued non-binding estimate plus 10%; or 100% of the last binding estimate issued; plus post 
    contract services; any remaining balances due will be billed after 30 days of delivery. Payment in full of all charges is due before unloading. 
    Fees for post contract services must be paid in advance of delivery and prior to unloading.</p></font></td>
 </tr>
</table> 
   </td>
 </tr>
</table>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="850">
  <tr>
    <td width="100%"><hr color="#000000" width="99%" size="1"></td>
 </tr>
  <tr>
    <td width="100%"><p style="text-align:justify;"><font style="font-family:Arial;font-size:10pt;"><FONT style="font-family:Arial;font-size:11pt;"><B>DELIVERY ACKNOWLEDGEMENT:</B></font>
    Shipper hereby acknowledges that the shipment was received in apparently good condition except as noted on the inventory list. Shipper acknowledges that all the
    services that were ordered have been performed, have been fully satisfied, and the truck was inspected and nothing has been left behind. Shipper and/or agent has
    full authority to accept the shipment and enter into this agreement.</font></p></td>
 </tr>
</table>
<table border="1" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#000000" width="850">
  <tr>
    <td width="67%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Customer's Signature at Delivery</FONT></td>
    <td width="33%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Date</FONT></td>
  </tr>
  <tr>
    <td width="67%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Carrier Signature at Delivery</FONT></td>
    <td width="33%" valign="top" height="35"><FONT style="font-family:Arial;font-size:8pt;">&nbsp;Date</FONT></td>
 </tr>
</table>    
<script src="/zz/js/xsign-2.1.0.min.js"></script>
<script src="/zz/js/xsigndraw.js?v=1.2.3"></script>

<script>
signatureCapture();

//check data
  function checkData(){
  frm = document.theForm;
  if (frm.ENAME.value.length < 4 || frm.ENAME.value.indexOf(" ") < 1) {
      alert("Please type your full name (first & last)");
	frm.ENAME.focus();
  }else   	
  return true;
 }

function signatureSave() {
	var canvas = document.getElementById("newSignature");
   // save canvas image as data url (png format by default)
	var sigPuk = canvas.toDataURL();
	var n = sigPuk.length; 
             if ((n) < 1000) {
        	 alert("Please sign: Pick-Up Acknowledgement");
        	 return false;
       		 }else {
	if (checkData()) {
	    $("#sigPuk").val(sigPuk);
	    document.theForm.action="/wc.dll?mpopr~esignboloprret~<%=pcREFNO%>~<%=pcCUSTID%>";
	    document.theForm.submit();
	}else {   	
	return false;
      }	
  }
}

 </script>
    </td>
 </tr>
</table> 
  </center>
</div>
</form>
<p class="pagebreak">&nbsp;</p>
