      <td width="7%" align="center"><input NAME="<%='M1'+ALLT(STR(TRUCKRECID))%>" size="3" VALUE="<%=ALLT(STR(EXPENSE1,8,2))%>" style="text-align: right"></td>
      <td width="7%" align="center"><input NAME="<%='M2'+ALLT(STR(TRUCKRECID))%>" size="3" VALUE="<%=ALLT(STR(EXPENSE2,8,2))%>" style="text-align: right"></td>
      <td width="16%" align="center"><input NAME="<%='N'+ALLT(STR(TRUCKRECID))%>" size="25" VALUE="<%=ALLT(NOTES)%>" autocomplete="off"></td>
      <td width="4%" align="center"><input type="checkbox" name="<%='C'+ALLT(STR(TRUCKRECID))%>" value="ON"></td>
      <td width="6%" align="center"><input type="button" class="button" name="B1" onclick="OprSave(<%=ALLT(STR(TRUCKRECID,6))%>)" value="Save"></td>
