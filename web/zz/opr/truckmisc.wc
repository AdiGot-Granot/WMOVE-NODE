		     <% SELECT _TRUCKS
		     	 SCAN %>
			     <OPTION value="<%=ALLT(STR(TRUCKID))%>"><%=ALLT(TRUCKNO)%></OPTION>
		     <% ENDSCAN %>  
	    </select>      
