<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Trucks Miscellaneous Operation</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
	<% SELECT _TREC
		SCAN %>
       $("#Date<%=ALLT(STR(TRUCKRECID))%>").datepicker({ numberOfMonths:[1,2] });
   <%ENDSCAN%>
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function OprSave(par) { 
       document.theForm.action="/wc.dll?mpopr~truckmiscret~<%=pcSCR%>~"+par;
       document.theForm.submit();
      }

function submitFunction(i) {
//    document.theForm.SUBMIT1.style.visibility="hidden";
//    if (i==1) document.theForm.action="/wc.dll?mpopr~truckmiscret~<%=pcSCR%>";
//    document.theForm.submit()
    
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mv~oprmenuwc~<%=pcSCR%>";
       document.theForm.submit();
      }
    }
        
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.BUTTON	 	{	color: black; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 70;
					height: 25;
					font-size: 10pt;
  				  	cursor: pointer;}  				  	
</style>
</head>
<body BGCOLOR="#4E6699">
