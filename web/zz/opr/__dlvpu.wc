					font-size: 9pt;
  				  	cursor: pointer;}
	.ASSIGNON	 {	color: #000080; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #BEBE99;
					font-size: 9pt;
  				  	cursor: pointer;}
	.INPUTDROP	{ 	background-color:#FFFFFF;
					font:tahoma;
					text-align: CENTER;
					color:#000000;
					font-size: 9pt;}
	.INPUTTXT	{ 	background-color:#FFFFFF;
					font-family: Verdana;
					color:#003399;
					font-size: 8pt;
  				  	font-weight: bold;
					text-align: right;}
</style>
