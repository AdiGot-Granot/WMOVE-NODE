<html lang="en" style="width: 420px; height: 520px;">

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Claim Reason</title>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 20;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 20;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>
<body BGCOLOR="#4E6699">
<table border="0" align="center" style="border-collapse:collapse;width:440px;height:520px;" bordercolor="#111111">
  <tr>
    <td width="100%" bgcolor="#F7F0B9" align="center">&nbsp;</td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
<form name="theForm" method="POST" action="/wc.dll?mpopr~claimreasonret~<%=pcSCR%>" target="_top">
<table border="1" align="center" width="98%" cellspacing="0" cellpadding="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
   <tr>
	<td width="221">&nbsp;<font style="font-family:Arial;font-size:10pt;"><b>Claim Reason</b></font></td>
	<td width="220">&nbsp;<font style="font-family:Arial;font-size:10pt;"><b>Claim Outcome</b></font></td>
  </tr>
   <tr>
	<td width="221" valign="top">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse:collapse;line-height:23px;" bordercolor="#111111" width="100%">
 <% SELECT * FROM _REASONDESC WHERE SEQ<100 INTO CURSOR _REASONDESC1
    SELECT _REASONDESC1
 	SCAN %>
  <tr>
    <td width="100%"><input type="checkbox" name="<%='D'+ALLT(STR(DESCID))%>" value="ON" <%=IIF(ACTIVE,'checked','')%>>
	<font style="font-family:Arial;font-size:10pt;"><%=ALLT(REASONDESC)%></font></td>
 </tr>
 <%ENDSCAN%>
</table>
    </td>
	<td width="220" valign="top">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse:collapse;line-height:23px;" bordercolor="#111111" width="100%">
 <% SELECT * FROM _REASONDESC WHERE SEQ>99 INTO CURSOR _REASONDESC2 
    SELECT _REASONDESC2
 	SCAN %>
  <tr>
    <td width="100%"><input type="radio" name="STATUSID" value="<%=ALLT(STR(DESCID))%>" <%=IIF(ACTIVE,'checked','')%>>
	<font style="font-family:Arial;font-size:10pt;"><%=ALLT(REASONDESC)%></font></td>
 </tr>
 <%ENDSCAN%>
</table>	
	</td>
  </tr>
</table>

 <br>
<table border="0" align="center" width="40%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">  
  <tr>
    <td align="center"><input type="submit" CLASS="SUBOFF" name="B3" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
 </tr>
</table>
</form>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15"><font size="2" color="#FFFFFF">User:&nbsp;<%=pcUSER%></font></td>
  </tr>
</table>
</body>
</html>