	 <td width="23%" align="center" bgcolor="#336699" height="12"><input type="text" name="TME" size="9" value="<%=ALLT(_SCHED.TME)%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~TME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')"  tabindex="10" maxlength="20"></td>
	 <td width="14%" align="center" bgcolor="#336699" height="12"><input type="checkbox" name="CONF" value="ON" <%=IIF(_SCHED.CONFIRM,'checked','')%> tabindex="3"></td>
	 <td width="15%" align="center" bgcolor="#336699" height="12"><input Class="INPUTDROP" type="text" name="HRS" style="width:40px;" value="<%=ALLT(STR(_SCHED.HRS,6,2))%>" tabindex="4" size="20"></td>
	</tr>
	</table>
  </td>
 </tr>
</table>	
<table border="0" width="100%" align="center" cellspacing="0">
<% IF _EST.STATUS<>'D'%>
