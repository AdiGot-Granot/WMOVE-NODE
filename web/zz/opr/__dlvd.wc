    <td width="50%" align="center"><input type="button" CLASS="ASSIGNOFF" name="B9" onclick="submitdelivery(12)" onmouseover="javasctript: this.className='ASSIGNON'" onmouseout="javasctript: this.className='ASSIGNOFF'" value="Assign Trucks"></td>
 </tr>
<% ENDIF %> 
  <tr>
