<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title><%=IIF(pcCODE='d1','D1','D2')%>-<%=pcORDNO%></title>

<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.4.2/jquery.min.js"></script><!--DATE PICKER-->
<script type="text/javascript" src="https://ajax.microsoft.com/ajax/jquery.ui/1.8.5/jquery-ui.min.js"></script><!--DATE PICKER-->
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=2.1.2" media="screen">
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
       
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function edittrip(){
 	window.open('/wc.dll?mpopr~tripaddwc~<%=pcSCR%>~theForm~TRIPNO~<%=pcCODE%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=700,height=400')
 self.name="main"}

function locatezip() {
    window.open('/wc.dll?mputil~zipwc~NEW','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
self.name="main"}

function submitdelivery(i) {
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpopr~dlvret~<%=pcSCR%>~<%=pcCODE%>";
       document.theForm.submit();
      }
    if (i==11) {
       window.open('/wc.dll?mpopr~mpwwc~<%=pcSCR%>~<%=pcCODE%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=600');
    self.name="main"}
    if (i==12) {
       window.open('/wc.dll?mpopr~truckswc~<%=pcSCR%>~<%=pcCODE%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=720,height=600');
	self.name="main"}
}

function UpdValueB(A,B) {
	var Message = "Are you sure you want to Submit Straight Truck?";
	if (confirm (Message)){
     window.open('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~'+A+'~'+B,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=5,height=5');
}
}

function StgOut() {
	var Message = "Are you sure you want to send this job out of Storage?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpstg~InOutStg~<%=pcSCR%>~STGOUT~<%=pcCODE%>";
       document.theForm.submit();
       }
	}

</SCRIPT>

<STYLE TYPE="text/css">
	  .TD2		{	color: #000080;
				  	font-size: 8pt;
					font-weight: bold;
  				  	font-family: Verdana;
					background-color: white;
				  	text-align: left}
	 .SUBMIT1	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    cursor: pointer;
                    width: 120; 
                    height: 22;}			  	 	
	.SUBMIT		{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 145; 
                    height: 25; 
                    cursor: pointer;}					
 	.ASSIGNOFF 	{	color: BLACK; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #BEBE99;
					font-size: 9pt;
  				  	cursor: pointer;}
	.ASSIGNON	 {	color: #000080; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #BEBE99;
					font-size: 9pt;
  				  	cursor: pointer}
	.INPUTDROP	{ 	background-color:#FFFFFF;
					font:tahoma;
					text-align: CENTER;
					color:#000000;
					font-size: 9pt;}
	.INPUTTXT	{ 	background-color:#FFFFFF;
					font-family: Verdana;
					color:#003399;
					font-size: 8pt;
  				  	font-weight: bold;
					text-align: right}
</style>
</head>

<BODY bgColor="#4e6699">
<center>
<br>
<TABLE cellSpacing="0" cellPadding=0 width="750" border="0" height="16" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td bgcolor="#002259" onmouseover="this.style.background='#4A929C'" onmouseout="this.style.background='#002259'" width="130" height="25" align="center">
    <b><font face="Verdana"><a href="wc.dll?mpopr~dlvwc~<%=pcSCR%>~pu"><font color="#FFFFFF">Pickup Info.</font></b></td>
    <td height="25" width="10">&nbsp;</td>
<% IF pcCODE='d1' %>
    <td bgcolor="#800000" width="123" height="25" align="center"><b><font face="Verdana" color="#FFFFFF">Delivery 1</font></b></td>
<% ELSE %>
    <td bgcolor="#002259" onmouseover="this.style.background='#4A929C'" onmouseout="this.style.background='#002259'" width="130" height="25" align="center">
    <b><font face="Verdana"><a href="wc.dll?mpopr~dlvwc~<%=pcSCR%>~d1"><font color="#FFFFFF">Delivery 1</font></b></td>
<% ENDIF %>
    <td height="25" width="10">&nbsp;</td>
<% IF pcCODE='d2' %>
    <td bgcolor="#800000" width="132" height="25" align="center"><b><font face="Verdana" color="#FFFFFF">Delivery 2</font></b></td>
<% ELSE %>
    <td bgcolor="#002259" onmouseover="this.style.background='#4A929C'" onmouseout="this.style.background='#002259'" width="130" height="25" align="center">
    <b><font face="Verdana"><a href="wc.dll?mpopr~dlvwc~<%=pcSCR%>~d2"><font color="#FFFFFF">Delivery 2</font></b></a></font></td>
<% ENDIF %>
    <td height="25" width="298">&nbsp;</td>
  </tr>
 </TABLE>
