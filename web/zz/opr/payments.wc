  </tr>
  <% IF CCPROCESS %>
   <tr id="<%=ALLT(STR(PAYID))%>" style="position:absolute;visibility:hidden">
   <td class="TD3" height="11" colspan="9" width="674">
<TABLE CELLPADDING="0" CELLSPACING="2" BORDER="2" BORDERCOLOR="#ffffff" WIDTH="110%" align="center" bgcolor="#FFFFFF">
  <tr>
    <td width="15%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">Name</font></td>
    <td width="9%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">Type</font></td>
    <td width="10%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">Auth. code</font></td>
    <td width="9%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">Confirm</font></td>
    <td width="8%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">Merchant</font></td>
    <td width="12%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">IP</font></td>
    <td width="10%" class="TD1" style="background-color: #52657B"><font color="#FFFFFF">Proc. By</font></td>
 </tr>
  <tr>
    <td width="15%" class="TD4">&nbsp;<%=ALLT(CCNAME)%></td>
    <td width="9%" class="TD4">&nbsp;<%=ALLT(CREDITCO)%>-<%=RIGHT(ALLT(CREDITNO),4)%></td>
    <td width="10%" class="TD4">&nbsp;<%=ALLT(REF)%></td>
    <td width="9%" class="TD4">&nbsp;<a href="/wc.dll?mpopr~payconfirm~<%=pcSCR%>~<%=ALLT(STR(PAYID))%>" target="_blank"><%=ALLTRIM(CTRANSNO)%></a></td>
    <td width="8%" class="TD4">&nbsp;<%=ALLT(CNAME)%></td>
    <td width="12%" class="TD4">&nbsp;<%=ALLT(IP)%></td>
    <td width="10%" class="TD4">&nbsp;<%=ALLT(PAIDUSER)%></td>
 </tr>
</table>
   </td>
  </tr>
	<%ENDIF%>
 <%ENDSCAN%>
</table>    
    </td>
 </tr>
</table>   
    </td>
  </tr>
</table>

<script>
document.getElementById("jumpMenu").addEventListener("change", function () {
  if (!this.value) return;

  const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

  if (isMobile) {
    // Mobile: open in same tab
    window.location.href = this.value;
  } else {
    // Desktop: open in new tab
    window.open(this.value, "_blank", "noopener,noreferrer");
  }

  this.selectedIndex = 0; // optional reset
});
</script>

</body>
</html>