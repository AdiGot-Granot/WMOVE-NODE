  <tr>
    <td width="700" bgcolor="#FFFFFF" align="center" colspan="3">
<table border="1" width="860" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
    <td width="100%" bgcolor="#4E6699" align="center"><b><font face="Verdana" size="2" color="#FFFFFF">Payment Records</font></b>
 </tr>
  <tr>
    <td>
<TABLE CELLPADDING="0" CELLSPACING="2" BORDER="2" BORDERCOLOR="#ffffff" WIDTH="858" align="center" bgcolor="#FFFFFF">
  <tr>
    <td width="61" class="TD1" height="13">TRNO</td>
    <td width="80" class="TD1" height="13">Date</td>
    <td width="34" class="TD1" height="13">Type</td>
    <td width="71" class="TD1" height="13">Move</td>
   <% IF plCCPROCESS=.T. %> 
    <td width="61" class="TD1" height="13">CC Proc.<br>Fee</td>
   <%ENDIF%> 
    <td width="62" class="TD1" height="13">Storage</td>
    <td width="62" class="TD1" height="13">Agent</td>
    <td width="75" class="TD1" height="13">Confirm#</td>
    <td width="138" class="TD1" height="13">Remarks</td>
    <td width="55" class="TD1" height="13">Proc. By</td>
    <td width="55" class="TD1" height="13">Edit By</td>
    <td width="50" class="TD1" height="13">CC<br>Proc.</td>
 </tr>
	<% SELECT _PAY1
		SCAN %>
  <tr>
    <td width="61" class="TD3" height="18">
   	<%=IIF(plACCT OR pnLEVEL=5 OR pnLEVEL=2,'<a href="/wc.dll?mpopr~paymentswc~'+pcSCR+'~'+ALLT(STR(PAYID))+'">'+PADL(ALLT(STR(NO)),3,'0')+IIF(EMPTY(DEPT),'','-'+ALLT(DEPT))+'</a>',PADL(ALLT(STR(NO)),3,'0')+IIF(EMPTY(DEPT),'','-'+ALLT(DEPT)))%>&nbsp;</td>
    <td width="80" class="TD4" height="18"><%=ALLT(CPAIDDTE)%></td>
    <td width="34" class="TD4" height="18">&nbsp;<%=ALLT(CTYPE)%>&nbsp;</td>
    <td width="71" class="TD3" height="18"><%=ALLT(STR(PAYAMT,8,2))%>&nbsp;</td>
  <% IF plCCPROCESS=.T. %>  
    <td width="61" class="TD3" height="18"><%=ALLT(STR(CCPROCFEE,6,2))%>&nbsp;</td>
  <%ENDIF%>  
    <td width="62" class="TD3" height="18"><%=ALLT(STR(PAYSTG,8,2))%>&nbsp;</td>
    <td width="62" class="TD3" height="18"><%=ALLT(STR(PAYAGENT,8,2))%>&nbsp;</td>
    <td width="75" class="TD4" height="18"><%=ALLT(REF)%>&nbsp;</td>
    <td width="138" class="TD4" height="18"><%=ALLT(NOTES)%>&nbsp;</td>
