  <tr>
    <td width="100%" align="center" colspan="5"><b><u><font size="3">Job Parameters</font></u></b></td>
 </tr>
  <tr>
    <td width="23%"><b>Job Date/Time:</b></td>
    <td width="14%" ><input type="text" autocomplete="off" id="Date1" name="DTEBX" size="8" value="<%=_BX.DTE%>" tabindex="1" maxlength="15"></td>
    <td width="17%" style="border-right: 1px solid #808080;"><input type="text" name="TMEBX" size="8" value="<%=ALLT(_BX.TME)%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~TMEBX','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')"  tabindex="2" maxlength="20"></td>
    <td width="26%">Job Start Time:</td>
    <td width="20%"><input type="text" name="STARTTMEBX" size="8" value="<%=_BX.STARTTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~STARTTMEBX','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" readonly tabindex="6"></td>
 </tr> 
  <tr>
