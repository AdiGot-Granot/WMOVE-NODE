<TABLE cellSpacing="0" cellPadding="0" width="850" bgColor="#ffffff" border="0">
  <TR>
    <TD><FORM NAME="theForm" METHOD="POST"><br> 
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="99%">
  <tr>
    <td width="71%" valign="top">
<%IF !EMPTY(_BX.DTE) %>    
<table border="1" width="100%" align="center" style="border-collapse: collapse;" bordercolor="#808080">
  <tr>
    <td align="center" bgcolor="#3366CC" height="25"><font style="font-family:Verdana;font-weight:bold;color:#FFF;">Box Delivery</font></td>
 </tr>
</table>
<table border="1" width="100%" align="center" cellspacing="0" style="border-collapse: collapse" bordercolor="#808080">
  <tr>
	<td width="100%">
