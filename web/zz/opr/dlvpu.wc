    <td width="26%">Job Finish Time:</td>
    <td width="20%"><input type="text" name="ENDTMEBX" size="8" value="<%=_BX.ENDTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~ENDTMEBX','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" reaonly tabindex="7"></td>
 </tr> 
  <tr>
