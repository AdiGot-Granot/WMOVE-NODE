<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>PU-<%=pcORDNO%></title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
<link rel="stylesheet" type="text/css" href="/zz/util/checkboxslide.css?v=1.1.4" media="screen" /><!--CONF CHECKBOX-->
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
       $("#Date3").datepicker({ numberOfMonths:[1,2] });
       $("#Date4").datepicker({ numberOfMonths:[1,2] });      
             
   });
</script>

<!--DROPDOWN AGENT SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN AGENT SEARCH-->

<script type="text/javascript">
 jQuery.noConflict();
      jQuery( document ).ready(function( $ ) {  
      $('.agent-select').select2({
          placeholder: 'Select Agent',
          allowClear: true
      });
  });
</script>


<SCRIPT LANGUAGE="JAVASCRIPT">

function edittrip(){
 	window.open('/wc.dll?mpopr~tripaddwc~<%=pcSCR%>~theForm~TRIPNO~<%=pcCODE%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=700,height=400')
 }
 
function locatezip() {
    window.open('/wc.dll?mputil~zipwc~NEW','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
self.name="main"}

function submitagent() {
   	document.theForm.action="/wc.dll?mpopr~agentfee~<%=pcSCR%>~<%=pcCODE%>";
    document.theForm.submit();
    }

function submitdelivery(i) {
    if (i==1) { document.theForm.action="/wc.dll?mpopr~dlvret~<%=pcSCR%>~pu";
                document.theForm.submit();
    }
    if (i==5){
      window.open('/wc.dll?mpopr~mpwwc~<%=pcSCR%>~BX','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=600');
    self.name="main"}
    if (i==6){
      window.open('/wc.dll?mpopr~truckswc~<%=pcSCR%>~BX','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=720,height=600');
    self.name="main"}
    if (i==7){
      window.open('/wc.dll?mpopr~mpwwc~<%=pcSCR%>~PK','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=600');
    self.name="main"}
    if (i==8){
      window.open('/wc.dll?mpopr~truckswc~<%=pcSCR%>~PK','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=720,height=600');
    self.name="main"}
    if (i==9) {
      window.open('/wc.dll?mpopr~mpwwc~<%=pcSCR%>~PU','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=600');
    self.name="main"}
    if (i==10){
      window.open('/wc.dll?mpopr~truckswc~<%=pcSCR%>~PU','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=720,height=600');
	self.name="main"}
}

function showHide(BX) {
   if (document.getElementById(BX)) {
      if (document.getElementById(BX+'-show').style.display != 'none') {
          document.getElementById(BX+'-show').style.display = 'none';
          document.getElementById(BX).style.display = 'block';
      }
      else {
         document.getElementById(BX+'-show').style.display = 'inline';
         document.getElementById(BX).style.display = 'none';
      }
   }
}

function showHide(PK) {
   if (document.getElementById(PK)) {
      if (document.getElementById(PK+'-show').style.display != 'none') {
          document.getElementById(PK+'-show').style.display = 'none';
          document.getElementById(PK).style.display = 'block';
      }
      else {
         document.getElementById(PK+'-show').style.display = 'inline';
         document.getElementById(PK).style.display = 'none';
      }
   }
}

</SCRIPT>

<style type="text/css">
  .more {display: none;}
   a.showLink, a.hideLink {text-decoration: none;color: #0000FF;padding-left: 8px;}
</style>


