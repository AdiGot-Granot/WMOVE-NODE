						  <option>10</option>
		  				  <option>11</option>
		  				  <option>12</option>
		  				  <option>13</option>
		  				  <option>14</option>
		  				  <option>15</option>						  						  
				    </select> Workers</td>
			    <td width="12%" height="12" CLASS="TD4"><input name="LHRS" size="3" value="<%=ALLT(STR(LHRS,6,2))%>" style="background-color: #FFFFCC;text-align: CENTER;" <%IF pcCUSTNO='NEIGHBORWA' OR pcCUSTNO='1776MOVE'%>readonly<%ENDIF%>> hrs</td>
			    <td width="20%" height="12" CLASS="TD4"><input name="LPERHRS" size="5" value="<%=ALLT(STR(LPERHRS,7,2))%>" style="text-align: CENTER;"> per hrs</td>
			    <td width="6%" height="12" CLASS="TD5"><font size="2" FACE="Verdana" COLOR="#008000"><B><%=ALLT(STR(LTOTAL,8,2))%></B></FONT></td>
			  </tr>
              <tr>
			    <td width="16%" height="12" CLASS="TD4">Travel: 
				<select size="1" name="FTVAN">
					  <option value="<%=ALLT(STR(FTVAN))%>" selected><%=ALLT(STR(FTVAN))%></option> 
						  <option>0</option>
						  <option>1</option>
						  <option>2</option>
						  <option>3</option>
						  <option>4</option>
						  <option>5</option>
						  <option>6</option>
						  <option>7</option>
						  <option>8</option>
						  <option>9</option>
						  <option>10</option>
				    </select> Van</td>
			    <td width="14%" height="12" CLASS="TD4">
				<select size="1" name="FTMEN">
					  <option value="<%=ALLT(STR(FTMEN))%>" selected><%=ALLT(STR(FTMEN))%></option> 
						  <option>0</option>
						  <option>1</option>
						  <option>2</option>
						  <option>3</option>
						  <option>4</option>
						  <option>5</option>
