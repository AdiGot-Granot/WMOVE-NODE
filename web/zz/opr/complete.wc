<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title><%=pcORDNO%></title>

<SCRIPT LANGUAGE="JAVASCRIPT">
function FindZip() {
   frm = document.RaddForm;
      var cCITY=frm.RCITY.value;
      var cSTATE=frm.RSTATE.value;
      var cSR='R'
   window.open('/wc.dll?mputil~ZipWc~&SR='+cSR+'&cSTATE='+cSTATE+'&cCITY='+cCITY,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
   self.name="main"
}

function submitCompletion() {
    document.theForm.Completion1.style.visibility="hidden";
    document.theForm.Completion2.style.visibility="hidden";
    document.theForm.action="/wc.dll?mpopr~oprret~<%=pcSCR%>";
    document.theForm.submit()  
  }

function closeda() {
	var Message = "Are you sure you want to continue?" ;
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpopr~closedjobret~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function updradd(t) {
         window.open("", t, "width=10,height=10");
      return true;
}

function emailinvoice() {
	var Message = "Are you sure you want to email the Company Invoice?";
	if (confirm (Message)){
        window.open('/wc.dll?mpopr~oprwc~<%=pcSCR%>~EMAIL','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
     self.name="main"
       }
   }

function emailbol() {
	var Message = "Are you sure you want to email the Bill of Lading?";
	if (confirm (Message)){
        window.open('/wc.dll?mpopr~boloprwc~<%=pcSCR%>~EMAIL','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
     self.name="main"
       }
   }

 function sentinvoice() {
    window.open('/wc.dll?mpopr~sentoprinvoice~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=yes,resizable=no,copyhistory=no,scrollbars=yes,width=725,height=400');
 self.name="main"}
 
 function sentbol() {
    window.open('/wc.dll?mpopr~sentbolopr~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=yes,resizable=no,copyhistory=no,scrollbars=yes,width=725,height=400');
 self.name="main"}
 
 
 function ViewLog() {
	window.open('/wc.dll?mpest~logfilewc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=790,height=550');
 self.name="main"}
 
 <% IF pcCUSTNO='MAYZLINREL' OR pcCUSTNO='HERCMOVE' %>
 function postout() {
	window.open('/wc.dll?mpopr~oprpostout~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=500,height=350');
 self.name="main"}
 <%ENDIF%>
 

</SCRIPT>

<STYLE TYPE="text/css">
	.TDTOP1	 	{	text-align: center;
					color: White; 
					font-size: 10pt;
					font-family: Verdana;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
	.TDBODY1 	{	text-align: center;
					color: yellow; 
					font-size: 10pt;
					font-family: Verdana;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
	.TD4		{	color: #000000;
				  	font-size: 8pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: left}
	.TD5		{	color: #000000;
				  	font-size: 7pt;
					font-weight: bold;
  				  	font-family: Verdana;
					background-color: white;
				  	text-align: right}	
	.SUBMIT		{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 155; 
                    height: 25; 
          	 	 	cursor: pointer;}
 	.SAVEADD	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 110; 
                    height: 25;
                    background-color:#800000; 
                    cursor: pointer;}          	 	 	
	.POSTOUT	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 100; 
                    height: 25; 
          	 	 	cursor: pointer;}          	 	 	
</style>
</head>
<body BGCOLOR="#4E6699">
