						  <option>9</option>
						  <option>10</option>
				    </select> Van</td>
			    <td width="14%" height="12" CLASS="TD4">
				<select size="1" name="LMEN">
					  <option value="<%=ALLT(STR(LMEN))%>" selected><%=ALLT(STR(LMEN))%></option> 
						  <option>0</option>
						  <option>1</option>
						  <option>2</option>
						  <option>3</option>
						  <option>4</option>
						  <option>5</option>
						  <option>6</option>
						  <option>7</option>
