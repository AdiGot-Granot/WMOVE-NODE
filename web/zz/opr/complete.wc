    <td width="100%">    
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
   <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr>
  <tr>
    <td width="100%"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Internal Office Remarks</font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #000000;margin-bottom:8px;width:90%;" rows="4" name="REMARKSX" cols="100"></textarea>
    <% SELECT _REPNOTES
  	   IF RECCOUNT() > 0 %>
   <table border="0" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #000000;width:90%;"> 
       <% SCAN %>
   <tr>
      <td width="21%" style="border-bottom: 1px solid #808080;" valign="top" bgcolor="#F5F5F5"><font style="font-family:Arial;font-size:10pt;"><%=DATE%><br><%=USER%></font>&nbsp;</td>
      <td width="79%" style="border-left: 1px solid #C0C0C0;border-bottom: 1px solid #808080;"><font style="font-family:Arial;font-size:10pt;"><%=ALLT(NOTES)%></font>&nbsp;</td>
   </tr>
    <% ENDSCAN %>
  </table>
    <center><a href="wc.dll?mpcharge~ViewRepNotes~<%=pcSCR%>~~3"><font face="verdana" size="2"><b>View Previous Remarks</b></font></a></center>
    <%ENDIF%>    
    </td>   
 </tr>
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr> 
  <tr>
    <td width="100%"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Slip Remarks</font></b></td>
 </tr>
  <tr>
    <td width="100%" valign="top">
    <textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #000000;width:90%;" name="REMARKS" rows="3" cols="100"><%=ALLT(_OPR.REMARKS)%></textarea></td>
 </tr>
</table>    
