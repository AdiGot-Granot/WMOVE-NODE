	 <td width="109" bgcolor="#993366"><input type="text" name="STARTTME" size="8" value="<%=_SCHED.STARTTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~STARTTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" readonly></td>
 </tr>
  <tr>
     <td width="65" bgcolor="#993366"><font color="yellow" size="2" face="Verdana"><b>Loaded:</b></font></td>
	 <td width="109" bgcolor="#993366"><input type="text" name="LOADTME" size="8" value="<%=_SCHED.LOADTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~LOADTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" readonly></td>
  </tr>
  <tr>
	 <td width="65" bgcolor="#993366"><font color="yellow" size="2" face="Verdana"><b>Finish:</b></font></td>
	 <td width="109" bgcolor="#993366"><input type="text" name="ENDTME" size="8" value="<%=_SCHED.ENDTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~ENDTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" reaonly></td>
  </tr>
   <tr>
	 <td width="174" bgcolor="#993366" colspan="2"><font color="yellow" size="2" face="Verdana"><b>Total: <%=ALLT(STR(ACTHRS,8,2))%> Hours</font></b></td>
  </tr>		
   <%ELSE%>				
  <tr>
	 <td width="174" CLASS="TDBODY1" colspan="2"><input type="text" name="ACTHRS" size="4" value="<%=ALLT(STR(ACTHRS,8,2))%>" style="text-align: Right;">&nbsp;&nbsp;Hours</td>
  </tr>
   <%ENDIF%>
</table>
