			    <td width="16%" height="1" CLASS="TD4" style="background-color: #FFFFCC"><input name="DFTPERHRS" size="5" value="<%=ALLT(STR(DFTPERHRS,7,2))%>" style="text-align: CENTER;"> per hrs</td>
