						  <option>10</option>
		  				  <option>11</option>
		  				  <option>12</option>
		  				  <option>13</option>
		  				  <option>14</option>
		  				  <option>15</option>						  
				    </select> Workers</td>
			    <td width="12%" height="12" CLASS="TD4"><input name="FTHRS" size="3" value="<%=ALLT(STR(FTHRS,6,2))%>" style="background-color: #FFFFCC;text-align: CENTER;"> hrs</td>
			    <td width="20%" height="12" CLASS="TD4"><input name="FTPERHRS" size="5" value="<%=ALLT(STR(FTPERHRS,7,2))%>" style="text-align: CENTER;"> per hrs</td>
			    <td width="6%" height="12" CLASS="TD5"><font size="2" FACE="Verdana" COLOR="#008000"><%=ALLT(STR(FTTOTAL,8,2))%></B></FONT></td>
			  </tr>
			  <tr>
			    <td width="28%" CLASS="TD4" colspan="2">Overtime: <input type="text" class="INPUTTEXT" name="OVERHRS" size="4" value="<%=ALLT(STR(OVERHRS,8,2))%>" style="text-align: center;" <%IF pcCUSTNO='NEIGHBORWA' %>readonly<%ENDIF%>>hour</td>
			    <td width="30%" height="12" CLASS="TD4" colspan="2">Overtime Rate: <input type="text" class="INPUTTEXT" name="OVERPER" size="4" value="<%=ALLT(STR(OVERPER,8,2))%>" style="text-align: CENTER;"></td>
			    <td width="10%" height="12" align="right"><font size="2" FACE="Verdana" color="#008000"><B><%=ALLT(STR(OVERAMT,8,2))%></B></font></td>
			  </tr>
			  <tr>
			    <td width="58%" height="12" CLASS="TD4" colspan="4">Diesel / Fuel Surcharge: <input type="text" class="INPUTTEXT" name="DIESELP" size="4" value="<%=ALLT(STR(DIESELP,6,2))%>" style="text-align: Right">%</td>
			    <td width="10%" height="12" align="right"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(DIESEL,8,2))%></font></b></td>
			  </tr>	
              <tr>
			    <td width="62%" height="12" CLASS="TD4" colspan="4">Intrastate Mileage:</td>
			    <td width="6%" height="12" align="right"><input type="text" name="OTOTAL" size="7" value="<%=ALLT(STR(OTOTAL,8,2))%>" style="text-align: Right; color:#008000"></td>
			  </tr>
	<%ENDIF%>			  
	<%IF _EST.TYPE = 'D' %>
     		  <tr>
			    <td width="68%" colspan="5"><font size="2" face="Verdana"><b>Estimate:&nbsp;<font color="#008000"><%=IIF(plCALCCF,ALLT(STR(_EST.TOTALCF))+' cf.',ALLT(STR(_EST.TOTALLBS))+' lbs.') %>&nbsp;&nbsp;
			    <%=IIF(plCALCCF,ALLT(STR(_CRG.I1PERCF,8,2))+' per cf.',ALLT(STR(_CRG.I1PERLBS,8,2))+' per lbs.') %>&nbsp;&nbsp;<%='$'+ALLT(STR(_CRG.I1TOTAL,10,2))%></font></b></td>
			   </tr>
			  <tr>
			    <td width="28%" height="12" CLASS="TD4" colspan="2">Actual (Line Haul): <input type="text" class="INPUTTEXT" name="OPRCFLBS" size="4" value="<%=IIF(plCALCCF,ALLT(STR(OPRCF)),ALLT(STR(OPRLBS)))%>" style="text-align: center">&nbsp;<%=IIF(plCALCCF,'cf.','lbs.')%></td>
			    <td width="30%" height="12" CLASS="TD4" colspan="2">Rate: <input type="text" class="INPUTTEXT" name="OPRPERCFLBS" size="4" value="<%=IIF(plCALCCF,ALLT(STR(OPRPERCF,8,2)),ALLT(STR(OPRPERLBS,8,2)))%>" style="text-align: center">&nbsp;<%=IIF(plCALCCF,'per cf.','per lbs.')%></td>
			    <td width="10%" height="12" align="right"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(OPRTOTAL,10,2))%><%=IIF(VAL(_CRG.VZMIN) > 0,'<BR><font color=black>Minimum</font>','')%></b></td>
			  </tr>
		<%IF EXTRACF > 0 %>				  
			  <tr>
			    <td width="28%" height="12" CLASS="TD4" colspan="2">Overload: <span style="background-color: #C6DBD6">&nbsp;&nbsp;<font size="2" color="000080"><%=IIF(plCALCCF,ALLT(STR(EXTRACF)),ALLT(STR(EXTRALBS)))%>&nbsp;&nbsp;</font></span>&nbsp;<%=IIF(plCALCCF,'cf.','lbs.')%></td>
			    <td width="30%" height="12" CLASS="TD4" colspan="2">Rate: <input type="text" class="INPUTTEXT" name="EXTPERCFLBS" size="4" value="<%=IIF(plCALCCF,ALLT(STR(EXTPERCF,8,2)),ALLT(STR(EXTPERLBS,8,2)))%>" style="text-align: center">&nbsp;<%=IIF(plCALCCF,'per cf.','per lbs.')%></td>
			    <td width="10%" height="12" align="right"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(OVERAMT,10,2))%></font></b></td>
			  </tr>
		<%ENDIF%>
			  <tr>
			    <td width="58%" height="12" CLASS="TD4" colspan="4">Diesel / Fuel Surcharge: <input type="<%=IIF(pcTYPE='D','text','HIDDEN')%>" class="INPUTTEXT" name="DIESELP" size="4" value="<%=ALLT(STR(DIESELP,6,2))%>" style="text-align: Right" tabindex="1">%</td>
			    <td width="10%" height="12" align="right"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(DIESEL,8,2))%></font></b></td>
			  </tr>
   <%ENDIF%>
			</table>
			<table border="1" width="100%" bordercolor="#CCCCCC" style="border-collapse: collapse" cellspacing="1" cellpadding="2">
			  <tr>
			    <td width="59%" colspan="3" CLASS="TD4">Others 1: <input type="text" name="OTHER1TXT" size="50" value="<%=ALLT(OTHER1TXT)%>" tabindex="7"></td>
			    <td width="9%" align="right"><input type="text" name="OTHER1" size="7" value="<%=IIF(OTHER1=0,'',ALLT(STR(OTHER1,8,2)))%>" style="text-align: Right; color:#008000" tabindex="8"></td>
			  </tr>
			  <tr>
			    <td width="59%" colspan="3" CLASS="TD4">Others 2: <input type="text" name="OTHER2TXT" size="50" value="<%=ALLT(OTHER2TXT)%>" tabindex="9"></td>
			    <td width="9%" align="right"><input type="text" name="OTHER2" size="7" value="<%=IIF(OTHER2=0,'',ALLT(STR(OTHER2,8,2)))%>" style="text-align: Right; color:#008000" tabindex="10"></td>
			  </tr>
			  <tr>
			    <td width="59%" colspan="3" CLASS="TD4">Others 3: <input type="text" name="OTHER3TXT" size="50" value="<%=ALLT(OTHER3TXT)%>" tabindex="11"></td>
			    <td width="9%" align="right"><input type="text" name="OTHER3" size="7" value="<%=IIF(OTHER3=0,'',ALLT(STR(OTHER3,8,2)))%>" style="text-align: Right; color:#008000" tabindex="12"></td>
			  </tr>
