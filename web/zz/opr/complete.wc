			    <td width="12%" height="1" CLASS="TD4" style="background-color: #FFFFCC"><input name="DLHRS" size="3" value="<%=ALLT(STR(DLHRS,6,2))%>" style="text-align: CENTER;"> hrs</td>
			    <td width="16%" height="1" CLASS="TD4" style="background-color: #FFFFCC"><input name="DLPERHRS" size="5" value="<%=ALLT(STR(DLPERHRS,7,2))%>" style="text-align: CENTER;"> per hrs</td>
			    <td width="10%" height="1" CLASS="TD5" style="background-color: #FFFFCC"><font size="2" FACE="Verdana" COLOR="#008000"><B><%=ALLT(STR(DLTOTAL,8,2))%></B></FONT></td>
			  </tr>
              <tr>
			    <td width="16%" height="1" CLASS="TD4" style="background-color: #FFFFCC">Travel:
