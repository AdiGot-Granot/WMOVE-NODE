<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Job Completion-<%=RIGHT(pcORDNO,4)%></title>

<SCRIPT LANGUAGE="JAVASCRIPT">
function FindZip() {
   frm = document.RaddForm;
      var cCITY=frm.RCITY.value;
      var cSTATE=frm.RSTATE.value;
      var cSR='R'
   window.open('/wc.dll?mputil~ZipWc~&SR='+cSR+'&cSTATE='+cSTATE+'&cCITY='+cCITY,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
   self.name="main"
}

function submitCompletion() {
    document.theForm.Completion1.style.visibility="hidden";
    document.theForm.Completion2.style.visibility="hidden";
    document.theForm.action="/wc.dll?mpopr~oprret~<%=pcSCR%>";
    document.theForm.submit()  
  }

function closeda() {
	var Message = "Are you sure you want to continue?" ;
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpopr~closedjobret~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function updradd(t) {
         window.open("", t, "width=10,height=10");
      return true;
}

function others() {
    window.open('/wc.dll?mpopr~OprOthersWc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=700,height=600');
	}

function discount() {
    window.open('/wc.dll?mpopr~OprOthersWc~<%=pcSCR%>~DISCOUNT','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=700,height=600');
	}

function emailinvoice() {
	var Message = "Are you sure you want to email the Company Invoice?";
	if (confirm (Message)){
        window.open('/wc.dll?mpopr~oprwc~<%=pcSCR%>~EMAIL','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
     self.name="main"
       }
   }

function emailbol() {
	var Message = "Are you sure you want to email the Bill of Lading?";
	if (confirm (Message)){
        window.open('/wc.dll?mpopr~boloprwc~<%=pcSCR%>~EMAIL','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
     self.name="main"
       }
   }

 function sentinvoice() {
    window.open('/wc.dll?mpopr~sentoprinvoice~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=yes,resizable=no,copyhistory=no,scrollbars=yes,width=725,height=400');
 self.name="main"}
 
 function sentbol() {
    window.open('/wc.dll?mpopr~sentbolopr~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=yes,resizable=no,copyhistory=no,scrollbars=yes,width=725,height=400');
 self.name="main"}
 
 function ViewLog() {
	window.open('/wc.dll?mpest~logfilewc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=790,height=550');
 self.name="main"}
 

</SCRIPT>

<STYLE TYPE="text/css">
	.TDTOP1	 	{	text-align: center;
					color: White; 
					font-size: 10pt;
					font-family: Verdana;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
	.TDBODY1 	{	text-align: center;
					color: yellow; 
					font-size: 10pt;
					font-family: Verdana;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
	.TD4		{	color: #000000;
				  	font-size: 8pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: left}
	.TD5		{	color: #000000;
				  	font-size: 8pt;
					font-weight: bold;
  				  	font-family: Verdana;
					background-color: white;
				  	text-align: right}	
	.SUBMIT		{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 155; 
                    height: 25; 
                    cursor: pointer;}
 	.SAVEADD	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 110; 
                    height: 25;
                    background-color:#800000; 
                    cursor: pointer;}					
</style>

</head>

<body BGCOLOR="#4E6699">
<br>
<% SELECT _OPR%>
<table border="0" bgcolor="#FFFFFF" style="border-collapse: collapse" bordercolor="#111111" width="800" align="center"
<%IF _EST.STATUS='D'%> background="zz/images/closed.jpg" <%ENDIF%>>
  <tr>
    <td colspan="4"><IMG SRC="zz/images/topBaropr.gif" width="100%" height="14"></td>
  </tr>
  <tr>
    <td width="252" BGCOLOR="#BEBE99"><b><font face="Verdana" color="#FFFF00"><%=pcBALANCEX%><%=pcBALSTGX%></font></b></td>
    <td width="199" BGCOLOR="#BEBE99" align="center"><b><font face="Verdana" size="4" color="#000080">Job Completion</font></b></td>
    <td width="129" BGCOLOR="#BEBE99" align="center"><b><font face="Verdana" color="#FFFF00"><%=IIF(plCLAIMSX=.T.,'CLAIM','')%></font></b></td>
    <td width="158" BGCOLOR="#BEBE99" align="center"><b><font face="Verdana" color="#FFFF00"><%=pcCLOSEDX%></font></b></td>
  </tr>
  <tr>
    <td width="800"  colspan="4" valign="top">
    <table border="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" height="744">
	  <tr>
	    <td width="100%">
 <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
   <td width="71%" valign="top" align="center"><BR>
<table border="1" align="center" cellpadding="1" cellspacing="1" style="border-collapse: collapse" bordercolor="#CCCCCC" width="98%">
  <tr>
   <td width="48%" align="center" bgcolor="#008000"><b><FONT face="Verdana" COLOR="FFFFFF">Moving From</FONT></td>
   <td width="52%" align="center" bgcolor="#008000"><b><FONT face="Verdana" COLOR="FFFFFF">Moving To</FONT></td>
 </tr>
  <tr>
   <td width="48%" valign="top">
 <%SELECT _EST%>
<table border="0" cellpadding="0" cellspacing="1" style="border-collapse:collapse;font-family:Arial;font-size:10pt;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%"><font face="Verdana" color="#00008B" size="4"><b><%=ALLT(_EST.SNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(SPROXY)%>
  <tr>
    <td width="100%"><font color="#C71585"><%='Proxy: '+ALLT(SPROXY)%></font></td>
 </tr>
 <%ENDIF%> 
 <%IF !EMPTY(SADD1)%>
  <tr>
    <td width="100%"><%=ALLT(SADD1)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(SADD2)%>
  <tr>
    <td width="100%"><%=ALLT(SADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(SLEVEL) OR !EMPTY(SSUBLEVEL) OR !EMPTY(SFLOOR) OR !EMPTY(SAPT)%>
  <tr>
    <td width="100%"><%=ALLT(PROPER(SLEVEL))%><%=IIF(EMPTY(SSUBLEVEL),'','/'+ALLT(SSUBLEVEL))%><%=IIF(EMPTY(SFLOOR),'',' Floor: '+ALLT(STR(SFLOOR)))%>
    <%IF !EMPTY(SAPT) AND _EST.RC='C'%>
	<%=' Unit: '+ALLT(SAPT)%>
    <%ELSE%>
	<%=IIF(EMPTY(SAPT),'',' Apt: '+ALLT(SAPT))%>
	<%ENDIF%></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="100%"><b><font style="font-size:11pt;" color="#00008B"><%=ALLT(SCITY)+', '+ALLT(SSTATE)+' '+ALLT(SZIP)%>&nbsp;<%=IIF(EMPTY(SCOUNTRY),'',ALLT(SCOUNTRY))%></font></b></td>
 </tr>
 <%IF !EMPTY(STELH) OR !EMPTY(STELO)%>
  <tr>
    <td width="100%"><%=ALLT(STELH)%>&nbsp;&nbsp;/&nbsp;&nbsp;<%=ALLT(STELO)%></td>
 </tr>
 <%ENDIF%>
</table>   
   </td>
   <td width="52%" valign="top">
   <form name="RaddForm" method="post" action="/wc.dll?mpopr~UpdRadd~<%=pcSCR%>" onsubmit="return updradd(this.target)" target="formtarget">
<table border="0" width="100%" style="border-collapse:collapse;font-family:Arial;font-size:10pt;line-height:25px;" bordercolor="#111111">
  <tr>
	<td width="79">Name:</td>
	<td width="180" colspan="3"><input type="text" name="RNAME" size="25" style="font-size: 9pt" value="<%=ALLT(_SCHED.RNAME)%>"></td>
 </tr>
  <tr>
	<td width="79">Address:</td>
	<td width="180" colspan="3"><input type="text" name="RADD1" size="25" style="font-size: 9pt" value="<%=ALLT(_SCHED.RADD1)%>"></td>
 </tr>
  <tr>
	<td width="79">&nbsp;</td>
	<td width="180" colspan="3"><input type="text" name="RADD2" size="25" style="font-size: 9pt" value="<%=ALLT(_SCHED.RADD2)%>"></td>
 </tr>
  <tr>
	<td width="79">Floor/Apt:</td>
	<td width="42"><input type="text" name="RFLOOR" size="2" style="font-size: 9pt" value="<%=IIF(_SCHED.RFLOOR=0,'',ALLT(STR(_SCHED.RFLOOR)))%>" maxlength="2"></td>
	<td width="41"><input type="text" name="RAPT" size="2" style="font-size: 9pt" value="<%=ALLT(_SCHED.RAPT)%>" maxlength="9"></td>
	<td width="95">&nbsp;</td>
 </tr>   
  <tr>
	<td width="79">City/State:</td>
	<td width="180" colspan="3">
    <input type="text" name="RCITY" size="13" style="font-size: 9pt" value="<%=ALLT(_SCHED.RCITY)%>">
	<input type="text" name="RSTATE" size="2" style="font-size: 9pt" value="<%=ALLT(_SCHED.RSTATE)%>"></td>
 </tr>
  <tr>
	<td width="79"><a href="javascript:FindZip()">Zip Code:</a></td>
	<td width="180" colspan="3"><input type="text" name="RZIP" size="5" style="font-size: 9pt" value="<%=ALLT(_SCHED.RZIP)%>"></td>
 </tr>  
  <tr>
	<td width="79">Phone:</td>
	<td width="83" colspan="2"><input type="text" name="RPHONE1" size="12" style="font-size: 9pt" value="<%=ALLT(_SCHED.RPHONE1)%>"></td>
	<td width="95"><input type="text" name="RPHONE2" size="12" style="font-size: 9pt" value="<%=ALLT(_SCHED.RPHONE2)%>"></td>
 </tr>
 <%IF _EST.STATUS <> 'D'%>
  <tr>
    <td width="100%" height="10" colspan="4" style="font-size:0; line-height:0;">&nbsp;</td>
 </tr> 
  <tr>
	<td width="259" align="center" colspan="4"><input type="submit" CLASS="SAVEADD" name="btnsubmit" value="Save Address"></td>
 </tr>
 <%ENDIF%>   
</table>
  </form>
   </td>
 </tr>
  </table>
  <% SELECT _OPR%>
	<form name="theForm" method="post">
<%IF _EST.STATUS <> 'D' AND !plBLKEDITOPR%>	
<table border="0" width="80%" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td align="center" height="40"><input type="button" CLASS="SUBMIT" name="Completion1" onclick="submitCompletion()" style="background-color: #7B96B5;" value="Submit Completion"></td>
</table> 	
<%ENDIF%>             
<table border="1" align="center" width="98%" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0" cellpadding="0">
  <tr>
    <td bgcolor="#008000" align="center"><font color="#FFFFFF" face="Verdana"><b>Pricing</b></font></td>
 </tr>
  <tr>
   <td>
<table border="1" width="552" bordercolor="#CCCCCC" style="border-collapse: collapse" cellspacing="0" cellpadding="0">	  
     <tr>
		<td width="550" colspan="5"><font size="2" face="Verdana"><b>Estimate:&nbsp;<font color="#008000"><%=IIF(plCALCCF,ALLT(STR(_EST.TOTALCF))+' cf.',ALLT(STR(_EST.TOTALLBS))+' lbs.') %>&nbsp;&nbsp;
		<%=IIF(plCALCCF,'$'+ALLT(STR(_CRG.I1PERCF,8,2))+' per cf.','$'+ALLT(STR(_CRG.I1PERLBS,8,2))+' per lbs.') %>&nbsp;&nbsp;<%='$'+ALLT(STR(_CRG.I1TOTAL,10,2))%><%=IIF(VAL(_CRG.VZMIN) > 0,'&nbsp;&nbsp;<font color=black>(Minimum)</font>','')%></font></b></td>
	</tr>
	 <tr>
		<td height="12" CLASS="TD4" colspan="2" width="244">Actual (Line Haul): <input type="text" class="INPUTTEXT" name="OPRCFLBS" size="4" value="<%=IIF(plCALCCF,ALLT(STR(OPRCF)),ALLT(STR(OPRLBS)))%>" style="text-align: center">&nbsp;<%=IIF(plCALCCF,'cf.','lbs.')%></td>
		<td height="12" CLASS="TD4" colspan="2" width="210">Rate: <input type="text" class="INPUTTEXT" name="OPRPERCFLBS" size="4" value="<%=IIF(plCALCCF,ALLT(STR(OPRPERCF,8,2)),ALLT(STR(OPRPERLBS,8,2)))%>" style="text-align: center">&nbsp;<%=IIF(plCALCCF,'per cf.','per lbs.')%></td>
		<td height="12" align="right" width="94"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(OPRTOTAL,10,2))%></font></b></td>
	</tr>
   <%IF EXTRACF > 0 %>				  
	 <tr>
		<td height="12" CLASS="TD4" colspan="2" width="244">Overload: <span style="background-color: #C6DBD6">&nbsp;&nbsp;<font size="2" color="000080"><%=IIF(plCALCCF,ALLT(STR(EXTRACF)),ALLT(STR(EXTRALBS)))%>&nbsp;&nbsp;</font></span>&nbsp;<%=IIF(plCALCCF,'cf.','lbs.')%></td>
		<td height="12" CLASS="TD4" colspan="2" width="210">Rate: <input type="text" class="INPUTTEXT" name="EXTPERCFLBS" size="4" value="<%=IIF(plCALCCF,ALLT(STR(EXTPERCF,8,2)),ALLT(STR(EXTPERLBS,8,2)))%>" style="text-align: center">&nbsp;<%=IIF(plCALCCF,'per cf.','per lbs.')%></td>
		<td height="12" align="right" width="94"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(OVERAMT,10,2))%></font></b></td>
	</tr>
	<%ENDIF%>
	 <tr>
		<td height="12" CLASS="TD4" colspan="4" width="455">Diesel / Fuel Surcharge: <input type="<%=IIF(pcTYPE='D','text','HIDDEN')%>" class="INPUTTEXT" name="DIESELP" size="4" value="<%=ALLT(STR(DIESELP,6,2))%>" style="text-align: Right" tabindex="4">%</td>
		<td height="12" align="right" width="94"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(DIESEL,8,2))%></font></b></td>
	</tr>
<%IF plOTHERS %>
     <tr>
		<td height="20" colspan="4" width="455"><b>
		<% IF !plBLKEDITOPR %>
		<a href="javascript:others()"><font face="verdana" style="font-size:8pt;" color="#0000ff">Other Services</font></a>
		<%ELSE%>
		<font face="verdana" style="font-size:8pt;">Other Services</font>
		<%ENDIF%></B></td>
		<td height="20" width="94">&nbsp;</td>
	</tr>
    <%SELECT _OPRO
           SCAN %>
	 <tr>
		<td height="20" CLASS="TD4" colspan="4" width="455"><%=ALLT(CNAME)%></td>
		<td height="20" align="right" width="94"><b><font size="2" FACE="Verdana" color="#008000"><%=ALLT(STR(PRC,8,2))%></font></b></b></td>
	</tr>
    <%ENDSCAN %>
     <tr>
		<td height="20" align="right" colspan="4" width="455"><b><font face="Verdana" size="2">Subtotal:</font></b></td>
		<td height="20" align="right" bgcolor="#F5F5F5" width="94"><b><font face="Verdana" size="2"><%=TRANSFORM(pnSUB1,'$$$,$$9.99')%></font></b></td>
	</tr>
<%ENDIF%>
</table>
    <%SELECT _OPR%>
<table border="1" width="100%" bordercolor="#CCCCCC" style="border-collapse: collapse" cellspacing="0" cellpadding="0">
  <tr>
	<td width="76%" height="22" CLASS="TD4">Packing</td>
	<td width="5%" height="22" align="right"><font color="#008000"><input type="text" name="PACKING" size="7" value="<%=IIF(PACKING=0,'',ALLT(STR(PACKING,8,2)))%>" style="text-align: Right; color:#008000"></font></td>
 </tr>
  <tr>
	<td width="76%" height="22" CLASS="TD4">Unpacking</td>
	<td width="5%" height="22" align="right"><font color="#008000"><input type="text" name="UNPACKING" size="7" value="<%=IIF(UNPACKING=0,'',ALLT(STR(UNPACKING,8,2)))%>" style="text-align: Right; color:#008000"></font></td>
 </tr>              
  <tr>
	<td width="76%" height="22" CLASS="TD4">
	<% IF !plBLKEDITOPR %><a href="/wc.dll?mpopr~matsalewc~<%=pcSCR%>">Materials</a><%ELSE%>Materials<%ENDIF%></td>
	<td width="5%" height="22" align="right"><input type="text" name="MATERIAL" size="7" value="<%=IIF(MATERIAL=0,'',+ALLT(STR(MATERIAL,8,2)))%>" style="text-align: Right; color:#008000;"></td>
 </tr>
  <%IF MATTAXAMT > 0 %>		  
  <tr>
	<td width="76%" height="21" CLASS="TD4">Materials Sales Tax:&nbsp;<%=ALLT(STR(MATTAX,5,2))%>%</td>
	<td width="5%" height="21" align="right"><font size="2" FACE="Verdana" COLOR="#008000"><B><%=MATTAXAMT%></b></font></td>
 </tr>
  <%ENDIF%>
  <tr>
	<td width="76%" height="21" CLASS="TD4">Valuation:</td>
	<td width="5%" height="21" align="right"><input type="text" name="INSURANCE" size="7" value="<%=IIF(INSURANCE=0,'',ALLT(STR(INSURANCE,8,2)))%>" style="text-align: Right; color:#008000"></td>
 </tr>
  <tr>
	<td width="76%" height="21" CLASS="TD4">Extra:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<input type="text" name="EXTRATXT" size="50" value="<%=ALLT(EXTRATXT)%>" tabindex="8"></td>
	<td width="5%" height="21" align="right"><input type="text" name="EXTRA" size="7" value="<%=IIF(EXTRA=0,'',ALLT(STR(EXTRA,8,2)))%>" style="text-align: Right; color:#008000"></td>
 </tr>   	
  <tr>
	<td width="76%" CLASS="TD4" height="20">Remarks:&nbsp;<input type="text" name="OTHER1TXT" size="50" value="<%=ALLT(OTHER1TXT)%>" tabindex="9"></td>
	<td width="5%" align="right" height="13"></td>
 </tr>
  <tr>
	<td width="76%" CLASS="TD4" height="20">Remarks:&nbsp;<input type="text" name="OTHER2TXT" size="50" value="<%=ALLT(OTHER2TXT)%>" tabindex="10"></td>
	<td width="5%" align="right" height="14"></td>
 </tr>
  <tr>
    <td width="76%" CLASS="TD4" height="20">Remarks:&nbsp;<input type="text" name="OTHER3TXT" size="50" value="<%=ALLT(OTHER3TXT)%>" tabindex="11"></td>
	<td width="5%" align="right" height="15"></td>
 </tr>
  <tr>
	<td width="76%" height="20"  align="right"><b><font face="Verdana" size="2">Subtotal:</font></b></td>
	<td width="5%" height="20" align="right" bgcolor="#F5F5F5"><font face="Verdana" size="2"><b><%=TRANSFORM(ACTTOTAL+pnDISCOUNT,'$$$,$$9.99')%></b></font></td>
 </tr>
  <tr>
	<td width="68%" height="20" colspan="2"><b>
	<% IF !plBLKEDITOPR %>
		<a href="javascript:discount()"><font face="verdana" style="font-size:8pt;" color="#0000ff">Discount</font></a>
		<%ELSE%>
		<font face="verdana" style="font-size:8pt;">Discount</font>
		<%ENDIF%></b></td>
 </tr>
    <%SELECT _OPRD
           SCAN %> 
  <tr>
	<td width="52%" CLASS="TD4" height="20"><%=ALLT(CNAME)%></td>
	<td width="16%" ALIGN="RIGHT" height="20"><b><font color="#FF0000" face="Verdana" SIZE="2"><%=ALLT(STR(PRC,8,2))%></font></b></td>
 </tr>
 <%ENDSCAN 
 IF RECCOUNT() > 1 %>
  <tr>
	<td width="52%" ALIGN="RIGHT" height="20"><font face="Verdana" size="2" color="#FF0000"><b>Total Discount:</b></font></td>
	<td width="16%" ALIGN="RIGHT" height="20"><b><font face="Verdana" size="2" color="#FF0000">$-<%=pnDISCOUNT%></font></b></td>
 </tr>    
 <%ENDIF %>
</table>
<%SELECT _OPR%>
<table border="1" width="552" bordercolor="#CCCCCC" style="border-collapse: collapse" cellspacing="0" cellpadding="0">
  <tr>
	<td height="20" width="454"><b><font face="Verdana" size="2">Total Job</font></b></td>
	<td height="20" align="right" bgcolor="#F5F5F5" width="95"><font size="4"><b><%='$'+ALLT(STR(ACTTOTAL,10,2))%></b></font></td>
 </tr>
 <%IF !EMPTY(pcPAYAMT) %>
  <tr>
	<td height="20" width="454"><b><font face="Verdana" color="#008000" size="2">Total Customer Payments: Move</font></b></td>
	<td height="20" align="right" width="95"><b><font color="#008000" size="4"><%=pcPAYAMT%></font></b></td>
 </tr>
 <%ENDIF %>
 <%IF !EMPTY(pcPAYAGENT) %>	  
	<tr>
	  <td height="20" width="454"><b><font face="Verdana" color="#008000" size="2">Customer Payments to Agent/Broker</font></b></td>
	  <td height="20" align="right" width="95"><b><font color="#008000" size="4"><%=pcPAYAGENT%></font></b></td>
	</tr>
 <%ENDIF %>	
	<tr>
	  <td height="20" width="454"><b><font face="Verdana" color="#FF0000" size="2">Total Job Balance</font></b></td>
	  <td height="20" align="right" bgcolor="#F5F5F5" width="95"><font color="#FF0000" size="4"><b><%=pcBALANCE%></b></font></td>
	</tr>
 <% IF BALSTG > 0 OR PAIDSTG > 0 %>
    <tr>
	  <td height="20" width="454"><b><font face="Verdana" color="#008000" size="2">Total Customer Payments: Storage</font></b></td>
	  <td height="20" align="right" width="95"><font color="#008000" size="4"><b><%=IIF(PAIDSTG > 0,'$'+ALLT(STR(PAIDSTG,10,2)),'')%></b></font></td>
	</tr>
	<tr>
	  <td height="20" width="454"><b><font face="Verdana" color="#FF0000" size="2">Total Storage Balance</font></b></td>
	  <td height="20" align="right" bgcolor="#F5F5F5" width="95"><font color="#FF0000" size="4"><b><%=IIF(BALSTG > 0,'$'+ALLT(STR(BALSTG,10,2)),'')%></b></font></td>
	</tr>
 <%ENDIF %>
	<tr>
	  <td height="20" CLASS="TD4" colspan="2" width="550">Tips <input type="text" name="TIP" size="5" value="<%=IIF(TIP=0,'',ALLT(STR(TIP,7,2)))%>" style="text-align: Right; color:#008000" tabindex="7"></td>
	</tr>	
</table>		
	</td>
  </tr>
</table>
   </td>
    <td width="29%" valign="top"><BR>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="97%" BGCOLOR="#FFFFFF">
  <tr>
	<td width="100%" valign="top">
<table border="0" width="100%" cellspacing="0">
  <tr>
	<td CLASS="TDTOP1" height="15" width="50%">Job No.</font></td>
	<td CLASS="TDTOP1" height="15" width="50%">Status</td>
 </tr>
  <tr>
	<td CLASS="TDBODY1" height="16" width="85"><%=ALLT(_EST.DEPT)+ALLT(_EST.ORDNO)%></td>
	<td CLASS="TDBODY1" height="16" width="89"><%=ALLT(_EST.ST)%></td>
 </tr>
</table>
  <br>
<table border="0" width="100%" cellspacing="0">
   <tr>
	 <td CLASS="TDTOP1">Move Date</td>
  </tr>
   <tr>
	 <td CLASS="TDBODY1"><%=pcPUDTE%>&nbsp;<%=pcPUTME%></td>
 </tr>
</table>	
	<br>
<table border="0" width="100%" cellspacing="0">
   <tr>
	 <td CLASS="TDTOP1" colspan="2" height="19">Estimate Volume</td>
  </tr>
   <tr>
     <td CLASS="TDBODY1" height="19"><%=ALLT(STR(_EST.TOTALCF))%>&nbsp;<font size="1">cf</font></td>
	 <td CLASS="TDBODY1" height="19"><%=ALLT(STR(_EST.TOTALLBS))%>&nbsp;<font size="1">lbs</font></td>
  </tr>
</table>	
  <br>
<table border="0" width="100%" cellspacing="0">
  <tr>
    <td CLASS="TDTOP1">Total Job Volume</td>
 </tr>
  <tr>
    <td CLASS="TDBODY1" width="98%"><input type="text" name="ACTCFLBS" size="4" value="<%=ALLT(STR(IIF(plCALCCF,ACTCUFT,ACTLBS)))%>" style="text-align: Right;">&nbsp;&nbsp;<%=IIF(plCALCCF,'cf','lbs')%></td>
  </tr>
</table>	
  <br>
<table border="0" width="100%" cellspacing="0">
  <tr>
    <td CLASS="TDTOP1" colspan="2">Job Duration </td>
  </tr>
	<% IF plCALCTIME %>
  <tr>
	 <td width="65" bgcolor="#993366"><font color="yellow" size="2" face="Verdana"><b>Start:</b></font></td>
	 <td width="109" bgcolor="#993366"><input type="text" name="STARTTME" size="8" value="<%=_SCHED.STARTTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~STARTTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" readonly></td>
 </tr>
  <tr>
     <td width="65" bgcolor="#993366"><font color="yellow" size="2" face="Verdana"><b>Loaded:</b></font></td>
	 <td width="109" bgcolor="#993366"><input type="text" name="LOADTME" size="8" value="<%=_SCHED.LOADTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~LOADTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" readonly></td>
  </tr>
  <tr>
	 <td width="65" bgcolor="#993366"><font color="yellow" size="2" face="Verdana"><b>Finish:</b></font></td>
	 <td width="109" bgcolor="#993366"><input type="text" name="ENDTME" size="8" value="<%=_SCHED.ENDTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~ENDTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20" reaonly></td>
  </tr>
   <tr>
	 <td width="174" bgcolor="#993366" colspan="2"><font color="yellow" size="2" face="Verdana"><b>Total: <%=ALLT(STR(ACTHRS,8,2))%> Hours</font></b></td>
  </tr>		
   <%ELSE%>				
  <tr>
	 <td width="174" CLASS="TDBODY1" colspan="2"><input type="text" name="ACTHRS" size="4" value="<%=ALLT(STR(ACTHRS,8,2))%>" style="text-align: Right;">&nbsp;&nbsp;Hours</td>
  </tr>
   <%ENDIF%>
</table>
<%IF plBOLCSI=.F. AND plBOLMG=.F. %>
  <BR>
<table border="0" width="100%" cellspacing="0" bgcolor="#EFEFDF">
  <tr>
    <td CLASS="TDTOP1" colspan="2">Bill of Lading</td>
 </tr>		
  <tr>
    <td width="88" align="center"><img border="0" onclick="Javascript: window.open('/wc.dll?mpopr~boloprwc~<%=pcSCR%>~PRINT')" style="cursor:pointer;" src="zz/images/Printer.png" width="25" height="25"><font size="2" face="Verdana"><b>Print</b></font></td>
    <td width="125" align="center">
    <% IF plEMAIL AND (plMAILUSER OR plOUREMAIL)%><a href="javascript: emailbol()"><img border="0" src="zz/images/email1.gif" width="18" height="11"></a> <font size="2" face="Verdana"><b>Email<%ENDIF%>
	<% IF VAL(pcSENTBOL) > 0 %><br><%=pcSENTBOL%> <%=IIF(VAL(pcSENTBOL)<2,'email sent','emails sent')%></b></font><%ENDIF%>
	</td>
 </tr>
   <% IF VAL(pcSENTBOL) > 0 %>
  <tr>
	<td width="100%" colspan="2" height="25" valign="bottom"><a href="javascript: sentbol()"><FONT FACE="Arial" COLOR="#0000FF" SIZE="2"><B>View Sent Bill of Lading</b></font></a>
    <%IF plESIGNBOL %> 
	<img border="0" src="zz/images/esign.png" ALT="Bill of Lading was E-signed" width="25" height="18"><font face="Arial" size="2" color="navy">Esign</font>
	<%ENDIF%>
   </td>
  </tr>
  <%ENDIF%>
<%ENDIF%>  	  
</table>
  <BR>
<table border="0" width="100%" cellspacing="0" bgcolor="#EFEFDF">
  <tr>
