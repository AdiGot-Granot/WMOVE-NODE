 </tr>		
  <tr>
    <td width="88" align="center"><img border="0" onclick="Javascript: window.open('/wc.dll?mpopr~oprwc~<%=pcSCR%>~PRINT')" style="cursor:pointer;" src="zz/images/Printer.png" width="25" height="25">
    <font size="2" face="Verdana"><b>Print</b></font></td>
    <td width="125" align="center">
    <% IF plEMAIL AND (plMAILUSER OR plOUREMAIL)%><a href="javascript: emailinvoice()"><img border="0" src="zz/images/email1.gif" width="18" height="11"></a> <font size="2" face="Verdana"><b>Email<%ENDIF%>
    <% IF VAL(pcSENT) > 0 %><br><%=pcSENT%> <%=IIF(VAL(pcSENT)<2,'email sent','emails sent')%></b></font><%ENDIF%></td>
 </tr>
   <% IF VAL(pcSENT) >0 %>
  <tr>
    <td width="100%" colspan="2" height="25" valign="bottom"><a href="javascript: sentinvoice()"><FONT FACE="Arial" COLOR="#0000FF" SIZE="2"><B>View Sent Invoices</b></font></a>
    <%IF plESIGNOPR %> 
	<img border="0" src="zz/images/esign.png" ALT="This invoice was E-signed" width="25" height="18"><font face="Arial" size="2" color="navy">Esign</font>
	<%ENDIF%>
	</td>
  </tr>
  <%ENDIF%>	  
</table>
