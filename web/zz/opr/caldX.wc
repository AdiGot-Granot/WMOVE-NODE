<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Operations Calendar</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function blkdates() {
    window.open('/wc.dll?mpopr~blkdateswc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=yes,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=1000,height=550');
	}

function submitday(i) {
	 window.location.href=('/wc.dll?mpopr~oprcald~<%=pcSCR%>~'+i);
    }

function submitopr() {
   	document.theForm.elements['oprday'].value = eval(0);
   	document.theForm.action="/wc.dll?mpopr~oprcald~<%=pcSCR%>";
    document.theForm.submit();
    }


</SCRIPT>


<STYLE TYPE="text/css">
	.TDTOP1	 	{	text-align: center;
					color: White; 
					font-size: 10pt;
					font-family: Arial;
					background-color: #336699;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
