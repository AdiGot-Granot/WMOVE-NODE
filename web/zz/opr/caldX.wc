 					border-style: none} 
	.TD26	 	{	color: #FFFFFF; 
				  	text-align: center;
					width: 100%;
					font-size: 12pt;
                    text-decoration:line-through;
					font-family: Arial;
					background-color: #FF0000;
                    border: 2px outset #BB0000 } 
	.TD27	 	{	color: #008000; 
				  	text-align: center;
