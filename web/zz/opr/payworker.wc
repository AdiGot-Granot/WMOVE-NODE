<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Worker Payroll</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
 jQuery.noConflict();
      jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });

</script>

<!--DROPDOWN WORKER SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN WORKER SEARCH-->

<script type="text/javascript">

  $(document).ready(function() {
      $('.worker-select').select2({
          placeholder: 'Select Worker',
          allowClear: true
      });
  });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitfunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpopr~payworkerret~<%=pcSCR%>~1";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpopr~payworkerret~<%=pcSCR%>~2";
       document.theForm.submit();
      }
    if (i==3) 
      { 
       document.theForm.action="/wc.dll?mv~oprmenuwc~<%=pcSCR%>";
       document.theForm.submit();
      }      
	}

</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.ADDPAYOFF	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 150;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.ADDPAYON	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 150;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}  				  	
</style>

</head>

<body BGCOLOR="#4E6699">
<br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="700" align="center">
  <tr>
    <td width="100%" height="14"><IMG ALT="" SRC="zz/images/topBaropr.gif" width="700" height="14"></td>
  </tr>
  <tr>
    <td width="100%" align="center" BGCOLOR="#bebe99"><b><font size="4" color="#993366" face="Verdana">Workers Payroll</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center">
<form name="theForm" method="POST"><br>
<table border="0" width="96%" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="16%"><b>Date Range:</b></td>
	<td width="12%"><b>From Date:</b></td>
	<td width="12%"><b>To Date:</b></td>
	<td width="24%"><b>Worker:</b></td>
	<% IF plDEPT%>
	<td width="5%"><b>Department:</b></td>
	<%ENDIF%>
 </tr>
  <tr>
	<td width="16%">
  <select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  </select>	
	</td>
	<td width="12%"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DTOC(pdDATE1)%>"></td>
	<td width="12%"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DTOC(pdDATE2)%>"></td>
	<td width="24%">
	 <select size="1" name="ID" class="worker-select" style="width: 200px;">
	  	<option value="" selected></option>
		 <%	SELECT _WORKERS
	 	    SCAN %>
		   	<option value="<%=ALLT(ID)%>"><%=ALLT(ID)%><%=IIF(EMPTY(WNAME),'',' - '+ALLT(WNAME))%></option>
		 <% ENDSCAN %>
		</select>	
	</td>
   <% IF plDEPT%>
	<td width="5%">
	<select size="1" name="DEPT">
        <option value="" selected></option>
        <% SELECT _DEPARTMENT
        	SCAN %>
	        <option value="<%=ALLT(DEPT)%>"><%=ALLT(DEPT)%></option>
        <% ENDSCAN%>
        </select>	
	</td>
   <%ENDIF%>	
 </tr> 
</table>
<br>
<table border="1" align="center" width="90%" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
    <td>
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse:collapse;line-height:23px;font-family:Verdana;font-size:10pt;" bordercolor="#111111" width="100%">
    <tr>
      <td width="7%" height="20"><input type="radio" value="V1" checked name="TYPE"></td>
      <td width="88%" height="20"><b>All Jobs Assigned to Workers</b></td>
     </tr>
    <tr>
      <td width="7%" height="20"><input type="radio" name="TYPE" value="V3"></td>
      <td width="88%" height="20"><b>Pay Salary to a Worker</b></td>
     </tr>
    <tr>
      <td width="7%" height="20"><input type="radio" name="TYPE" value="V4"></td>
      <td width="88%" height="20"><b>Workers Payroll Printout - Unpaid Jobs</b></td>
     </tr>    
    <tr>
      <td width="7%" height="20"><input type="radio" name="TYPE" value="V5"></td>
      <td width="88%" height="20"><b>Workers Payroll Printout - Paid Jobs</b></td>
     </tr>
</table>
  </td>
 </tr>
</table>  
<br>
<table border="0" width="95%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
   <td width="33%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitfunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
   <td width="38%" align="center"><input type="button" CLASS="ADDPAYOFF" name="B4" onclick="submitfunction(2)" onmouseover="javasctript: this.className='ADDPAYON'" onmouseout="javasctript: this.className='ADDPAYOFF'" value="Add Worker Salary"></td>    
   <td width="27%" align="right"><input type="button" CLASS="SUBOFF" name="B5" onclick="submitfunction(3)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>    
 </tr>
</table>
<br>
</form>
</td>
</tr>
</table>
<!-- frame table -->
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15">&nbsp;<font face="Verdana" size="2" color="#FFF">View By: <%=pcUser%></font></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFEFCC"></td>
  </tr>
  <tr>
    <td width="100%"><IMG SRC="zz/images/botBar.gif" width="700" height="14"></td>
  </tr>
</table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->

</body>
</html>