 </tr> 
  <tr>
	<td width="284" align="center" colspan="3"><input type="submit" CLASS="SAVEADD" name="btnsubmit" value="Save Address" size="20"></td>
 </tr>
<%ENDIF%>    
</table>
  </form>   
   </td>
 </tr>
 </table>
