<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Assign Job to Trip</title>
<SCRIPT LANGUAGE="JavaScript">

function transfer(cTRIPID,cTRIPNO) {
//alert(cTRIPID)
//alert(cTRIPNO)

	var _w = null;
	_w = self.opener;
	_w.document.<%=ALLT(pcFORM)%>.<%=ALLT(pcELEMENT)%>.value=cTRIPNO;
    window.location.href=('/wc.dll?mpopr~TripAddRet~<%=pcSCR%>~<%=pcCODE%>~'+cTRIPID) ;
	}
</SCRIPT>

<STYLE TYPE="text/css">
 	.TD1	 {	background-color: #BEBE99; 
				font-weight: bold;
				font-family: Verdana;
				font-size: 10pt;
				color: black;
				text-align: center;}
 	.TRIPOFF {	color: #000000; 
				font-weight: bold;
				font-family: Verdana;
				text-align: LEFT;
				font-size: 10pt;
  				cursor: pointer;
  				text-decoration: underline}
 	.TRIPON	 {	color: #CC0000; 
				font-weight: bold;
				font-family: Verdana;
				text-align: LEFT;
				font-size: 10pt;
  				cursor: pointer;
  				text-decoration: underline}
</style>
</head>
<body bgcolor="#F7F7F7">
<center><b><font style="font-family:Verdana;font-size:13pt;">Assign Job to Trip</font></b></center>
<table border="0" align="center" width="95%" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
    <td align="left" height="30"><font style="font-family:Verdana;font-size:10pt;cursor:pointer;" color="#FF0000" ONCLICK="transfer('999',' ')"><b><u>Remove Job from Trip</u></b></font></td>
 </tr>   
</table>
<table border="1" align="center" bordercolor="#C0C0C0" width="95%" cellspacing="0" style="border-collapse: collapse" cellpadding="0">
<tr>
 <td bgcolor="#FFFFFF">
<table border="1" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:23px;" bordercolor="#C0C0C0">
  <tr>
    <td width="22%" class="TD1">Trip Name</td>
    <td width="22%" class="TD1">Depart Date/Time</td>
    <td width="3%" class="TD1">Jobs</td>
    <td width="20%" class="TD1">Volume</td>
	<td width="15%" class="TD1">Driver</td>
 </tr>
  <% SELECT _TRIPS
      SCAN %>	 
  <tr>
    <td width="22%" class="TRIPOFF" ONCLICK="transfer('<%=ALLT(STR(TRIPID))%>','<%=ALLT(TRIPNO)%>')" onmouseover="this.className='TRIPON'" onmouseout="this.className='TRIPOFF'" bgcolor="#FFFFFF">
    <b><font face="Arial" size="2"><%=ALLT(TRIPNO)%></font></b>&nbsp;</td>
    <td width="22%" bgcolor="#FFFFFF"><b><font face="Arial" size="2"><%=CTRIPDTE%>&nbsp;</font></b></td>
    <td width="3%" align="center" bgcolor="#FFFFFF"><b><font face="Arial" size="2"><%=ALLT(STR(JOBS))%></font></b>&nbsp;</td>
    <td width="20%" bgcolor="#FFFFFF"><b><font face="Arial" size="2"><%=ALLT(STR(CF))%> cf / <%=ALLT(STR(LBS))%> lbs</font></b></td>
    <td width="15%" bgcolor="#FFFFFF"><b><font face="Arial" size="2"><%=TRIPNAME%>&nbsp;</font></b></td>
 </tr>
    <%ENDSCAN%>    
</table> 
  </td>
 </tr>
</table>
<br><center><input id="btnSubmit" type="button" onclick="javascript: window.close()" style="background-color: #CCCCCC;width:100;height:25;cursor:pointer;" value="Exit"></center>
</body>
</html>