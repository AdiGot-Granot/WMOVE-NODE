                <td align="right" style="font-family:Arial,Helvetica,sans-serif; font-variant-numeric:tabular-nums; font-size:14px;font-weight:bold; color:#333330; padding-bottom:12px; width:16%;"><%='$'+ALLT(STR(UPRC*QTY))%></td>
