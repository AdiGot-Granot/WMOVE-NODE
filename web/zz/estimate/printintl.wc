              <tr>
                <td style="width:38%; padding-right:20px;"><u><i><font face="Courier New" style="font-size:11pt;"><%=pcREP%></i></font>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</u><br>Company Representative</td>
                <td style="width:20%; padding-right:20px;"><u><i><font face="Courier New" style="font-size:11pt;"><%=DATE()%></i></font>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</u><br>Date</td>
              </tr>
            </table>
           <%ENDIF%>            
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ===== FOOTER ===== -->
  <tr>
    <td style="background-color:#1a2744; padding:8px 15px; border-top:3px solid #d4a84b;">
    <%IF !EMPTY(pcEMAIL)%>
      <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif; font-size:13px; color:#fff;">If you no longer wish to receive emails from <%=pcCOMPANY%>, 
          please click on <a href="https://<%=gcSERVERIP%>/wc.dll?mputil~removeemail~&CUSTID=<%=pcCUSTID%>&EMAILTO=<%=pcEMAIL%>&JOBID=<%=pcJOBID%>" style="color:#fff;">unsubscribe</a></td>
        </tr>
      </table>
     <%ENDIF%>
    </td>
  </tr>

</table>
<!-- End main container -->

    </td>
  </tr>
</table>
<!-- End outer wrapper -->

</body>
</html>