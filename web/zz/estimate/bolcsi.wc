 </tr>   
</table>    
    </td>
    <td valign="top" align="center" width="565"><br><font style="font-size:16pt;"><b><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcCOMPANY,pcAGCOMPANY)%></b></font><br>
    <font style="font-size:10pt;"><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcADD1,pcAGADD1)%>&nbsp;<%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcADD2,pcAGADD2)%><BR>
    <%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),pcTOLLFREE,pcAGPHONE)%><%=IIF(plCARRIER=.F. OR EMPTY(pcAGENT),'<BR>'+pcCOMPEMAIL,'')%></font>
    <br><br><br><font style="font-family:Arial;font-size:14pt;"><b>INTERSTATE BILL OF LADING CONTRACT</b></font></td>
    <td valign="top" width="206">
<table border="1" align="right" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
