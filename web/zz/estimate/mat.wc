<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Material Sale</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitmat(){
    document.theForm.action="/wc.dll?mpinv~matret~<%=pcSCR%>";
    document.theForm.submit()
}

</SCRIPT>
<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#4E6699">
<table border="0" cellpadding="0" cellspacing="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="50%">
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/topBar.gif" width="100%" height="14"></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#008000" align="center" height="22"><b>
    <font face="Verdana" size="4" color="#FFFFFF">Materials Sale</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">
<table border="0" align="center" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="50%"><b><font face="Arial" size="2"><b>&nbsp;Customer:&nbsp;<%=pcSNAME%></b></font></td>
    <td width="50%" align="right"><b><font face="Arial" size="2">Job No: <%=ALLT(pcDEPT)+ALLT(pcORDNO)%>&nbsp;&nbsp;</font></b></td>
 </tr>
</table> 
   <br>
<form name="theForm" method="post">
<table border="1" width="90%" bordercolor="#000000" align="center" cellspacing="0" cellpadding="0" style="border-collapse: collapse" bordercolordark="#808080" bordercolorlight="#808080">
	<tr>
    	<td width="28%" bgcolor="#008000" align="center"><font face="Verdana" color="#FFFFFF"><b>Item</b></font></td>
    	<td width="5%" bgcolor="#008000" align="center"><font face="Verdana" color="#FFFFFF"><b>Qty</b></font></td>
    	<td width="18%" bgcolor="#008000" align="center"><font face="Verdana" color="#FFFFFF"><b><%=IIF(pcTYPE<>'D','Local Price','Long D. Price')%></b></font>&nbsp;</td>
	</tr>
 <%IF pcCUSTNO='WHITEGLOVE' %>
	<tr>
    	<td width="28%">&nbsp;<b><font face="Verdana" size="2">Reset</font></b></td>
    	<td width="5%" align="center"><input type="radio" name="SERVID" value="0.00"></td>
    	<td width="18%" align="right"><b><font face="Verdana" size="2" color="#008000">$0.00</font></b>&nbsp;</td>
	</tr>		
 <%ENDIF%>
  <% SELECT _MAT
  	 SCAN %>
	<tr>
    	<td width="28%">&nbsp;<b><font face="Verdana" size="2"><%=ALLT(ITEM)%></font></b></td>
    	<td width="5%" align="center">
    	<%IF pcCUSTNO='WHITEGLOVE' %>
    	<input type="radio" name="SERVID" value="<%=ALLT(ID)%>" <%=IIF(QTY>0,'checked','')%>>
    	<%ELSE%>
    	<input type="text" name="QTY<%=ALLT(ID)%>" size="2" value="<%=IIF(QTY=0,'',ALLT(STR(QTY)))%>" style="text-align: center; color:#000080">
    	<%ENDIF%>
    	</td>
    	<td width="18%" align="right"><b><font face="Verdana" size="2" color="#008000">$<%=ALLT(STR(PRICE,6,2))%></font></b>&nbsp;</td>
	</tr>		
  <% ENDSCAN%>
  <% IF pcCUSTNO<>'WHITEGLOVE' %>
	 <tr>
    	<td width="51%" height="30" valign="bottom" colspan="3"><b><font face="Verdana" size="2">
    	Add new material to this Estimate:</FONT></b></td>
   	</tr>    
	 <tr>
    	<td width="28%">
        <input type="text" name="ITEM_1" size="30" value="" style="font-family:Arial;" maxlength="30"></td>
    	<td width="5%" align="center"><input type="text" name="QTY_1" size="3" style="text-align: center;font-family:Arial;" value="1"></td>
    	<td width="18%" align="right"><input name="PRC_1" size="4" style="text-align: right;font-family:Arial;"></td>
   	</tr>		
	 <tr>
    	<td width="28%">
        <input type="text" name="ITEM_2" size="30" value="" style="font-family:Arial;" maxlength="30"></td>
    	<td width="5%" align="center"><input type="text" name="QTY_2" size="3" value="1" style="text-align: center;font-family:Arial;"></td>
    	<td width="18%" align="right"><input name="PRC_2" size="4" style="text-align: right;font-family:Arial;"></td>
   	</tr>		
	 <tr>
    	<td width="28%">
        <input type="text" name="ITEM_3" size="30" value="" style="font-family:Arial;" maxlength="30"></td>
    	<td width="5%" align="center"><input type="text" name="QTY_3" size="3" value="1" style="text-align: center;font-family:Arial;"></td>
    	<td width="18%" align="right"><input name="PRC_3" size="4" style="text-align: right;font-family:Arial;"></td>
   	</tr>		
	 <tr>
    	<td width="28%">
        <input type="text" name="ITEM_4" size="30" value="" style="font-family:Arial;" maxlength="30"></td>
    	<td width="5%" align="center"><input type="text" name="QTY_4" size="3" value="1" style="text-align: center;font-family:Arial;"></td>
    	<td width="18%" align="right"><input name="PRC_4" size="4" style="text-align: right;font-family:Arial;"></td>
   	</tr>		
	 <tr>
    	<td width="28%">
        <input type="text" name="ITEM_5" size="30" value="" style="font-family:Arial;" maxlength="30"></td>
    	<td width="5%" align="center"><input type="text" name="QTY_5" size="3" value="1" style="text-align: center;font-family:Arial;"></td>
    	<td width="18%" align="right"><input name="PRC_5" size="4" style="text-align: right;font-family:Arial;"></td>
   	</tr>
  <%ENDIF%>
</table>
  <br>
<table border="0" width="90%" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="19%" align="center">
    <input id="btnSubmit" type="button" CLASS="SUBOFF" onclick="submitmat()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="37" value="Submit"></td>    
    <td width="19%" align="center">
    <input id="btnSubmit" type="button" CLASS="SUBOFF" onclick="javascript:history.go(-1)" onmouseover="javasctript: this.className='SUBONEXIT'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="39" value="Exit"></td>
 </tr>
</table>
 </form>
    </td>
 </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="19">&nbsp;</td>
  </tr>
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/botBar.gif" width="100%" height="14"></td>
  </tr>
</table>
</body>
</html>