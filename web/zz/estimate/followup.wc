<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Follow-Up Menu</title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 650,
		maxHeight	: 500,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

function submitFunction(i) {
    if (i==10) 
      { document.theForm.action="/wc.dll?mprep~orderpriorwc~<%=pcSCR%>";}
    if (i==11) 
      { document.theForm.action="/wc.dll?mprep~changepriorwc~<%=pcSCR%>";}
    if (i==12) 
      { document.theForm.action="/wc.dll?mprep~priorpool~<%=pcSCR%>";}                  
    if (i==0) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P0";}      
    if (i==1) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P1";}
    if (i==2) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P2";}
    if (i==3) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P3";}
    if (i==4) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P4";}
    if (i==5) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P5";}
    if (i==6) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P6";}
    if (i==7) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P7";}
    if (i==8) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~P8";}
    if (i==9) 
      { document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>~VALL";}
        document.theForm.submit();
}

function SubmitFollowup(i) {
    if (i==1){
	   document.theForm.SUBMIT_1.style.visibility="hidden"; 
       document.theForm.action="/wc.dll?mprep~followupret~<%=pcSCR%>";
       document.theForm.submit();
      }
	}

</SCRIPT>
<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
	.dot 		{	height: 80px;
  					width: 80px;
  					border-radius: 50%; 					
  					display: inline-block;  
  					text-align: center;}
	.rect 		{	height: 70px;
  					width: 80px;
  					border-radius: 10%;
  					display: inline-block;  
  					text-align: center;}  					
</style>
</head>

<body BGCOLOR="#4E6699">
<table border="0" width="45%" align="center" style="border-collapse: collapse">
  <tr>
    <td><a class="fancybox fancybox.iframe" href="/zz/help/followup.htm"><img border="0" src="zz/util/manual.gif" width="32" height="32"></a></td>
 </tr>
</table>
<table border="0" width="45%" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="100%" height="14" colspan="2"><IMG SRC="zz/images/topBar.gif" width="100%" height="14"></td>
  </tr>
  <tr>
    <td width="96%" align="center" BGCOLOR="#008000" height="20"><b><font size="4" color="#FFFFFF" face="Verdana">Follow-Up Menu</font></b></td>
    <td width="4%" BGCOLOR="#008000" height="20"><a href="javascript:window.close()"><img border="0" src="zz/images/x.gif" align="right" width="17" height="18"></a></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" colspan="2">
 	  <form name="theForm" method="POST"><br>
<table border="0" align="center" cellpadding="2" style="border-collapse:collapse;font-family:Verdana;" bordercolor="#111111" width="820">
  <tr>
   <td align="center"><span style="background-color: #C0C0C0;cursor: pointer;" onClick="submitFunction(0)" class="dot"><br><font style="line-height:27px;font-size:10pt;"><b>Priority 0<br><font color="#FFFF00"><%=pcFUSTATUS0%></font></b></font></span></td>
   <td align="center"><span style="background-color: #B50000;cursor: pointer;" onClick="submitFunction(1)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 1<br><font color="#FFFF00"><%=pcFUSTATUS1%></font></b></font></span></td>
   <td align="center"><span style="background-color: #003842;cursor: pointer;" onClick="submitFunction(2)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 2<br><font color="#FFFF00"><%=pcFUSTATUS2%></font></b></font></span></td>
   <td align="center"><span style="background-color: #089263;cursor: pointer;" onClick="submitFunction(3)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 3<br><font color="#FFFF00"><%=pcFUSTATUS3%></font></b></font></span></td>
   <td align="center"><span style="background-color: #083484;cursor: pointer;" onClick="submitFunction(4)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 4<br><font color="#FFFF00"><%=pcFUSTATUS4%></font></b></font></span></td>
   <td align="center"><span style="background-color: #631C7B;cursor: pointer;" onClick="submitFunction(5)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 5<br><font color="#FFFF00"><%=pcFUSTATUS5%></font></b></font></span></td> 	
   <td align="center"><span style="background-color: #000080;cursor: pointer;" onClick="submitFunction(6)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 6<br><font color="#FFFF00"><%=pcFUSTATUS6%></font></b></font></span></td>
   <td align="center"><span style="background-color: #006600;cursor: pointer;" onClick="submitFunction(7)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 7<br><font color="#FFFF00"><%=pcFUSTATUS7%></font></b></font></span></td>
   <td align="center"><span style="background-color: #990099;cursor: pointer;" onClick="submitFunction(8)" class="dot"><br><font style="line-height:27px;font-size:10pt;" color="#FFFFFF"><b>Priority 8<br><font color="#FFFF00"><%=pcFUSTATUS8%></font></b></font></span></td>
  <tr>
   <td align="center" colspan="9"><font size="1">&nbsp;</font></td>
 </tr>
  <tr>
   <td align="center" colspan="9"><font size="1">&nbsp;</font></td>
 </tr> 
  <tr>
   <td align="center">&nbsp;</td> 
   <td valign="top" align="center"><span style="background-color: #BCCA51;border: 1px solid;bordercolor: #000000;cursor: pointer;" onClick="submitFunction(10)" class="rect"><font style="line-height:23px;font-size:9pt;"><b>Update Priority 0<br><%=pcFUSTATUS0%></b></font></span></td>
   <td align="center">&nbsp;</td>   
   <td align="center">&nbsp;</td>   
   <td align="center"><span style="background-color: #FFD700;border: 1px solid;bordercolor: #000000;height:90px;cursor: pointer;" onClick="submitFunction(12)" class="rect"><font style="line-height:22px;font-size:9pt;"><b>General Priority Pool<br><%=pcFUSTATUS9%></b></font></span></td>
   <td align="center">&nbsp;</td>   
   <td align="center">&nbsp;</td>
   <td valign="top" align="center"><span style="background-color: #CCCCFF;border: 1px solid;bordercolor: #000000;cursor: pointer;" onClick="submitFunction(11)" class="rect"><font style="line-height:23px;font-size:9pt;"><b>Allocate Priority Numbers</b></font></span></td>      
   <td align="center">&nbsp;</td>
 </tr>  
</table>
 	  
 <br>  
<table border="1" align="center" width="70%" cellspacing="0" style="border-collapse: collapse" cellpadding="0" bordercolorlight="#808080" bordercolordark="#808080">
  <tr>
   <td valign="top" width="66%">
 <table border="0" cellpadding="2" style="border-collapse:collapse;font-family:Arial;font-size:10pt;" bordercolor="#808080" width="100%">
  <tr>
   <td width="50%" bgcolor="#008000" align="center" colspan="2"><b><font face="Verdana" size="2" color="#FFFFFF">Follow-Up</font></b></td>
 </tr>
  <tr>
   <td width="77%" height="21"><input type="radio" name="STATUS" value="V9" tabindex="8" checked> <b>New Estimates - Untouched</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcNEWEST%></font></b></td>
 </tr> 
  <tr>
   <td width="77%" height="22"><input type="radio" name="STATUS" value="V1" tabindex="1"> <b>Today</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcTODAY%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="22"><input type="radio" name="STATUS" value="V2" tabindex="2"> <b>Tomorrow</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcTOMORROW%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="22"><input type="radio" name="STATUS" value="V3" tabindex="2"> <b>Yesterday</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcYESTERDAY%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="22"><input type="radio" name="STATUS" value="V4" tabindex="3"> <b>This Week (Sun-Sat)</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcTHISWEEK%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="22"><input type="radio" name="STATUS" value="V5" tabindex="4"> <b>Last Week (Sun-Sat)</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcLASTWEEK%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="21"><input type="radio" name="STATUS" value="V7" tabindex="6"> <b>Follow-Up with Estimator</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcESTIMATOR%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="21"><input type="radio" name="STATUS" value="V10" tabindex="9"> <b>Follow-Up on Future Booked Jobs</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcFUBOOK%></font></b></td>
 </tr>
  <tr>
   <td width="77%" height="21"><input type="radio" name="STATUS" value="V6" tabindex="5"> <b>All Follow-Up Estimates</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcALL%></font></b></td>
 </tr>
 <% IF pcCUSTNO<>'OLYMPICVAN' %>
  <tr>
   <td width="77%" height="21"><input type="radio" name="STATUS" value="V8" tabindex="7"> <b>Update Past Follow-Up Date</b></td>
   <td width="21%" height="22"><b><font size="3" color="#000080"><%=pcPASTFU%></font></b></td>
 </tr>
 <%ENDIF%>  
 </table>
	</td><td valign="top" width="34%">
 <table border="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
   <td width="50%" bgcolor="#008000" align="center"><b><font face="Verdana" color="#FFFFFF" size="2">Sort By</font></b></td>
 </tr>
  <tr>
   <td width="50%"><input type="radio" name="SORT" value="S1" checked><b><font face="Arial" size="2"> Follow-Up Date</font></b></td>
 </tr>
  <tr>
   <td width="50%"><input type="radio" name="SORT" value="S2"><b><font face="Arial" size="2"> Move Date</font></b></td>
 </tr>
  <tr>
   <td width="50%"><input type="radio" name="SORT" value="S3"><b><font face="Arial" size="2"> Job No</font></b></td>
 </tr>
  <tr>
   <td width="50%"><input type="radio" name="SORT" value="S4"><b><font face="Arial" size="2"> Volume</font></b></td>
 </tr>
  <tr>
   <td width="50%"><input type="radio" name="SORT" value="S5"><b><font face="Arial" size="2"> Priority</font></b></td>
 </tr> 
 </table>
 </td>
 </tr>
</table>
	<br>
<table border="0" width="40%" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
   <td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="SUBMIT_1" onclick="SubmitFollowup(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
 </tr>
</table>
  </form>    
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15" colspan="2">&nbsp;<font size="2" color="#FFFFFF">User: <%=pcUser%>&nbsp;( Dept <%=pcDEPTUSER%> )</font></td>
  </tr>
  <tr>
    <td width="100%" height="14" colspan="2"><IMG SRC="zz/images/botBar.gif" width="100%" height="14"></td>
  </tr>
</table>
</body>
</html>