<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Esign Moving Estimate and Bill of Lading</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function CheckBoxes(FormName, CheckValue){
   if(!document.forms[FormName])
      return;
   var objCheckBoxes = document.getElementsByTagName('input');
   if(!objCheckBoxes)
      return;
   var countCheckBoxes = objCheckBoxes.length;
   if(!countCheckBoxes)
      objCheckBoxes.checked = CheckValue;
   else
      for(var i = 0; i < countCheckBoxes; i++)
      objCheckBoxes[i].checked = CheckValue;
}
 
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 80;
					background-color: #F0F0F0;
					font-size: 10pt;
  				  	cursor: pointer;}										
</style>

</head>

<body bgcolor="#FFFFFF">
<center><font face="Arial" size="4"><a href="/wc.dll?mv~estprocesswc~<%=pcSCR%>">Exit</a><br><br>
<b>Estimates and Bill of Lading include Esign for Future Move Dates (<%=ALLT(STR(RECCOUNT('_LIST')))%>)</font><br>
<font face="Arial" size="2">(Order by Sign Date)</font></b></center>
<form name="theForm" method="POST" action="/wc.dll?mv~esignremove~<%=pcSCR%>">
<br><center><input id="btnSubmit" type="submit" name="B1" value="Remove From List" style="cursor:pointer;"></center>
<br>
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="2" bordercolor="#111111" width="80%">
  <tr>
   <td width="5%" class="TD1">Clear <input name="checkall" type="checkbox" onclick="CheckBoxes('theForm',this.checked);" value="ON" /></td>  
   <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Job No</td>
   <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Status</td>
   <td width="11%" class="TD1" style="border-left: 1px solid #A9A9A9;">Customer</td>
   <td width="12%" class="TD1" style="border-left: 1px solid #A9A9A9;">Move Date</td>
   <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sent Date</td>
   <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sent By</td>
   <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Subject</td>
   <td width="8%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sign By</td>
   <td width="11%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sign Date</td>
 </tr>
<%SELECT _LIST
	SCAN %>
  <tr>
   <td width="5%" class="TD3"><input type="checkbox" name="<%=ALLT(STR(LOGEMAILID))%>" value="ON"></td>  
   <td width="5%" class="TD4" style="border-left: 1px solid #A9A9A9;"><a href="/wc.dll?mprep~printselect~<%=pcSCR+'~'+ALLT(REFNO)%>" target="_blank"><%=ALLT(DEPT)+ALLT(ORDNO)%></a></td>
   <td width="6%" class="TD2"><font color="#<%=IIF(ST='Booked','008000','000000')%>"><b><%=ALLT(ST)%></b></font></td>
   <td width="11%" class="TD2"><%=ALLT(SNAME)%></td>
   <td width="12%" class="TD2"><b><%=LBOOKDTE%><%=IIF(EMPTY(LBOOKDTE1),'','-'+DTOC(LBOOKDTE1))%></b></td>
   <td width="9%" class="TD2"><%=SENTDTE%>&nbsp;<%=SENTTME%></td>
   <td width="6%" class="TD2">&nbsp;<%=ALLT(SENTBY)%></td>
   <td width="9%" class="TD2">&nbsp;<a href="/wc.dll?mpest~emailslog~<%=pcSCR%>~<%=ALLT(ORDNO)%>~<%=ALLT(STR(LOGEMAILID))%>" target='_blank'><font color="#<%=IIF(TEMAILID=105,'FF4500','0000FF')%>"><%=ALLT(SUBJECT)%></font></a></td>
   <td width="8%" class="TD2">&nbsp;<%=ALLT(ENAME)%></td>
   <td width="11%" class="TD2"><font color="#<%=IIF(TEMAILID=105,'FF4500','000000')%>"><%=IIF(EMPTY(EDTE),'',EDTE)%></font></td>
 </tr>
 <% ENDSCAN %>
 </table>
 <br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="30%">
  <tr>
    <td width="100%" align="center" colspan="3"><input id="btnSubmit" type="submit" name="B1" value="Remove From List" style="cursor:pointer;"></td>
 </tr>
</table>
</form>
<br><center><font face="Arial" size="4"><a href="/wc.dll?mv~estprocesswc~<%=pcSCR%>">Exit</a></font></center>

</body>
</html>