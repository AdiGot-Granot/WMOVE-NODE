	<td width="27%" height="40"><input type="text" autocomplete="off" id="Date2" name="NEXTFU" size="20" value="<%=IIF(EMPTY(_EST.NEXTFU),'',ALLT(DTOC(_EST.NEXTFU)))%>" style="width: 100px; max-width: 100%;font-weight:bold;" tabindex="31"></td>
	<td width="30%" height="40"><font face="Arial" size="2">Time:
	<input type="text" name="FUTME" size="10" value="<%=ALLT(_EST.FUTME)%>" style="cursor:pointer; font-size:9pt" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~FUTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" tabindex="32" maxlength="20"></font></td>
 </tr>
<%ENDIF%> 
  <tr>
	<td width="38%"><font face="Arial" size="2" color="#0000FF">Expected Move Date</font><font color="#FF0000">:*</font></td>
	<td width="27%">
	<% IF _EST.STATUS<>'F' AND _EST.STATUS<>'C' %>
		<font face="Arial" color="#<%=IIF(_EST.LBOOKDTE<DATE(),'FF0000','008000')%>"><B><%=_EST.LBOOKDTE%></b></font>
    <%ELSE%>
       <input type="text" autocomplete="off" id="Date1" name="LBOOKDTE" size="20" value="<%=IIF(EMPTY(_EST.LBOOKDTE),'',ALLT(DTOC(_EST.LBOOKDTE)))%>" style="width: 100px; max-width: 100%;background-color:#FFFFCC;font-weight:bold;" tabindex="33">
    <%ENDIF%>
    </td>
	<td width="30%"><font face="Arial" size="2">Time:
	<input type="text" name="LBOOKTME" size="10" value="<%=ALLT(_EST.LBOOKTME)%>" style="cursor:pointer; font-size:9pt" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~LBOOKTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')"  tabindex="34" maxlength="20"></font></td>
 </tr>
<%IF pnLEVEL > 0 AND !plBLKREFER %> 
  <tr>
    <td width="38%"><font face="Arial" size="2" color="#0000FF">How did you hear about us?</font><font color="#FF0000">*</font></td>
    <td width="62%" colspan="2">
	<select size="1" name="REF" class="ref-select" style="width: 220px;background-color: #FFFFCC;" tabindex="35">
