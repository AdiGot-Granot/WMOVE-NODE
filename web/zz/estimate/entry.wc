   <% IF VAL(_EST.ORDNO) > 99999 %>   
   <tr>
    <td><b>Job No.:&nbsp;<FONT SIZE="3" COLOR="red"><%=IIF(VAL(_EST.ORDNO)>99999,ALLT(_EST.DEPT)+ALLT(_EST.ORDNO),'')%></FONT></b></td>
  </tr>
  <% ENDIF %>
  <% IF VAL(_EST.ORDNO) > 99999 AND pnLEVEL > 0 %>
   <tr>
    <td><b>Status:&nbsp;<FONT SIZE="3" COLOR="red"><%=pcSTATUSNAME%></FONT></b></td>
  </tr>
    <% IF _EST.CONSENT=.T. AND (_EST.LEADS=.T. OR _EST.ONLINE=.T.) %>
   <tr>
    <td><b>Phone Consent:&nbsp;Yes</td>
  </tr>
    <% ENDIF %>      
