<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title><%=pcORDNO%></title>
<script language="JavaScript" src="/zz/util/formcheck.js"></SCRIPT>

<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.7" media="screen" />
<!---lightbox--->
  

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
 $(".fancybox").fancybox({
  openEffect : 'elastic',
  closeEffect : 'elastic',
  fitToView: false,
  autoSize: false,
  nextSpeed: 0, //important
  prevSpeed: 0, //important
  afterLoad: function(){
  // added 50px to avoid scrollbars inside fancybox
   this.width = ($('.fancybox-iframe').contents().find('html').width())+50;
   this.height = ($('.fancybox-iframe').contents().find('html').height())+50;
  }

 }); // fancybox
}); // ready


function sf(){
	window.theForm.SNAME.focus();
}

function FindZip(par) {
   frm = document.theForm;
   if (par=='SZIP'){      
      var cCITY=frm.SCITY.value;
      var cSTATE=frm.SSTATE.value;
      var cSR='S'
   }else{
      var cCITY=frm.RCITY.value;
      var cSTATE=frm.RSTATE.value;
      var cSR='R'
   }
//  alert(cCITY);
// alert(cSR);
   window.open('/wc.dll?mputil~ZipWc~&SR='+cSR+'&cSTATE='+cSTATE+'&cCITY='+cCITY,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
   self.name="main"
}

function checkData(){
      <%IF _EST.TYPE<>'I' %>
	frm = document.theForm;
	return  lengthValid(frm.SNAME, 2,"full name")
			&& zipValid(frm.SZIP, 5, "origin zip code - US only") 
			&& zipValid(frm.RZIP, 5, "destination zip code - US only")
			&& lengthValid(frm.STELH, 1,"phone number")
			&& lengthValid(frm.EMAIL, 1,"email")
		 <% IF pcCUSTNO='SOLOMONSON' AND pnLEVEL > 0 %>
			&& lengthValid(frm.SADD1, 5,"origin address")
		 <%ENDIF%>
		 <% IF _EST.STATUS='F' OR _EST.STATUS='C' %>	
			&& lengthValid(frm.LBOOKDTE, 1,"expected date of move");
		 <%ENDIF%>	
     <%ELSE%>
  return  true
     <%ENDIF%>
 }

<%IF pnLEVEL > 0 AND !plBLKREFER %>
function CHKREF(){
		frm = document.theForm;
		if(frm.REF[frm.REF.selectedIndex].text=='') {
			alert("Please select how did you hear about us?");
			frm.REF.focus();
			return false ;
			}
		else {
			return true ;
		}
}
<%ENDIF%>

<%IF pcCUSTNO='SOLOMONSON' AND pnLEVEL > 0 %>
function CHKSLEVEL(){
		frm = document.theForm;
		if(frm.SLEVEL[frm.SLEVEL.selectedIndex].text=='') {
			alert("Please select origin location");
			frm.SLEVEL.focus();
			return false ;
			}
		else {
			return true ;
		}
}
<%ENDIF%>


<%IF pcCUSTNO='SOLOMONSON' AND pnLEVEL > 0 %>
function CHKSSUBLEVEL(){
		frm = document.theForm;
		if(frm.SSUBLEVEL[frm.SSUBLEVEL.selectedIndex].text=='') {
			alert("Please select origin level");
			frm.SSUBLEVEL.focus();
			return false ;
			}
		else {
			return true ;
		}
}
<%ENDIF%>


function SubmitEntry(i) {
    if (checkData()<%IF pnLEVEL > 0 AND !plBLKREFER %>&&CHKREF()<% ENDIF%><%IF pcCUSTNO='SOLOMONSON' AND pnLEVEL > 0 %>&&CHKSLEVEL() &&CHKSSUBLEVEL()<% ENDIF%>) {
			if (i==1) 
		      { 
		       document.theForm.CONTINUEINV.style.visibility="hidden";
		       document.theForm.action="/wc.dll?mpest~entryret~<%=pcSCR%>~INV";
		      }
		    if (i==2) 
		      { 
		       document.theForm.CONTINUECRG.style.visibility="hidden";
		       document.theForm.action="/wc.dll?mpest~entryret~<%=pcSCR%>~CHARGES";
		      }
		   document.theForm.submit();
		    }
	}

</SCRIPT>

<STYLE TYPE="text/css">
	.TDTOP1	 	{	text-align: left;
					color: White; 
					font-size: 10pt;
					font-family: Arial;
					background-color: #993366;
  				  	font-weight: bold;}
	.TDBODY1 	{	text-align: center;
					color: yellow; 
					font-size: 10pt;
					font-family: Arial;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
 	.SUBOFF	 	{	color: white; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 160;
					height:25;
					background-color: #008000;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.SUBOFF1	{	color: white; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 230;
					height:25;
					background-color: #5A79A5;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.4.2/jquery.min.js"></script><!--DATE PICKER-->
<script type="text/javascript" src="https://ajax.microsoft.com/ajax/jquery.ui/1.8.5/jquery-ui.min.js"></script><!--DATE PICKER-->
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=2.1.2" media="screen">

<script type="text/javascript">
	jQuery.noConflict();

   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });       
   });
  
</script>

</head>

