  <tr>
	<td width="38%" height="40"><font face="Arial" size="2" color="#0000FF">Schedule Follow Up Date:</font></td>
	<td width="30%" height="40"><input type="text" autocomplete="off" id="Date2" name="NEXTFU" size="13" value="<%=IIF(EMPTY(_EST.NEXTFU),'',ALLT(DTOC(_EST.NEXTFU)))%>" style="text-align:center;font-weight:bold;" tabindex="31"></td>
	<td width="27%" height="40"><font face="Arial" size="2">Time:
	<input type="text" name="FUTME" size="10" value="<%=ALLT(_EST.FUTME)%>" style="cursor:pointer; font-size:9pt" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~FUTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" tabindex="32" maxlength="20"></font></td>
 </tr>
<%ENDIF%> 
  <tr>
	<td width="38%"><font face="Arial" size="2" color="#0000FF">Expected Move Date</font><font color="#FF0000">:*</font></td>
	<td width="30%">
	<% IF _EST.STATUS<>'F' AND _EST.STATUS<>'C' %>
		<font face="Arial" color="#<%=IIF(_EST.LBOOKDTE<DATE(),'FF0000','008000')%>"><B><%=_EST.LBOOKDTE%></b></font>
    <%ELSE%>
       <input type="text" autocomplete="off" id="Date1" name="LBOOKDTE" size="13" value="<%=IIF(EMPTY(_EST.LBOOKDTE),'',ALLT(DTOC(_EST.LBOOKDTE)))%>" style="background-color:#FFFFCC;text-align:center;font-weight:bold;" tabindex="33">
    <%ENDIF%>
    </td>
	<td width="27%"><font face="Arial" size="2">Time:
	<input type="text" name="LBOOKTME" size="10" value="<%=ALLT(_EST.LBOOKTME)%>" style="cursor:pointer; font-size:9pt" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~LBOOKTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')"  tabindex="34" maxlength="20"></font></td>
 </tr>
<%IF pnLEVEL > 0 AND !plBLKREFER %> 
  <tr>
    <td width="38%"><font face="Arial" size="2" color="#0000FF">How did you hear about us?</font><font color="#FF0000">*</font></td>
    <td width="62%" colspan="2">
	<select size="1" name="REF" style="text-align: center; background-color: #FFFFCC;" tabindex="35">
	  <option><%=_EST.REF%></option>
	   <% SELECT _TREF 
			   SCAN %>
	  <OPTION><%=_TREF.RNAME %></OPTION>
		<% ENDSCAN %>
		</select>    
    </td>
 </tr>
<%ENDIF%> 
<%IF VAL(_EST.ORDNO) < 100000 %> 
     <tr>
	  <td width="38%"><font face="Arial" size="2" color="#0000FF">Select Number of Rooms:</font></td>
	  <td width="62%" colspan="2">     
		<select size="1" name="ROOMS" tabindex="36" style="font-size:9pt;">
		  <option selected>< Select Number of Rooms ></option>		  
		  <%IF _EST.TYPE='I' %>
             <option value="20 FT">20 FT Container</option>
             <option value="40 FT">40 FT Container</option>
          <%ENDIF%>   
             <option value="STU">Studio</option>                 
             <option value="PAR">Partial Home</option>
             <option value="ONE">One Bedroom</option>
             <option value="TWO">Two Bedrooms</option>
             <option value="THR">Three Bedrooms</option>
             <option value="FOU">Four Bedrooms</option>
             <option value="FIV">Five Bedrooms</option>
             <option value="SIX">Six Bedrooms and more</option>
             <option value="OFF">Office Move</option>
	    </select>
	  </td>
	  </tr>
<%ENDIF%>
  </table>	  
	  </td>
	  <td valign="top" width="32%">
  <table border="0" width="100%" cellspacing="1" style="border-collapse: collapse;line-height:20px;font-family:Arial;font-size:10pt;" bordercolor="#111111" cellpadding="2">
   <% IF VAL(_EST.ORDNO) > 99999 %>   
   <tr>
    <td><b>Job No.:&nbsp;<FONT SIZE="3" COLOR="red"><%=IIF(VAL(_EST.ORDNO)>99999,ALLT(_EST.DEPT)+ALLT(_EST.ORDNO),'')%></FONT></b></td>
  </tr>
  <% ENDIF %>
  <% IF VAL(_EST.ORDNO) > 99999 AND pnLEVEL > 0 %>
   <tr>
    <td><b>Status:&nbsp;<FONT SIZE="3" COLOR="red"><%=pcSTATUSNAME%></FONT></b></td>
  </tr>  
  <% ENDIF %>  
   <tr>
	<td><b>Type of Move: <FONT COLOR="red"><%=pcRC%></font><br>
    &nbsp;<input type="radio" name="RC" value="R" <%=IIF(_EST.RC = 'R','checked','')%> tabindex="37">Residential<BR>	
	&nbsp;<input type="radio" name="RC" value="C" <%=IIF(_EST.RC = 'C','checked','')%> tabindex="38">Commercial
  <% IF pnCOLEVEL>3 %><BR>&nbsp;<input type="radio" name="RC" value="M" <%=IIF(_EST.RC = 'M','checked','')%> tabindex="39">Military<%ENDIF%></td>
  </tr>
</table>	  
	  </td>
	</tr>
</table>
 <br>
<table border="0" width="80%" align="center">
  <tr>
	<td width="100%"><b><font color="#FF0000"><%=pcMSG%></font></b></td>
 </tr>
</table>     
    </td>
 </tr>
  <tr>
    <td width="100%" align="center">
<table border="0" width="70%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
	 <tr>
	  <td width="49%" align="center">
      <input type="button" CLASS="SUBOFF1" name="CONTINUEINV" onclick="SubmitEntry(1)" onmouseover="this.style.background='#993366'" onmouseout="this.style.background='#5A79A5'" tabindex="36" value="<%=IIF(pnLEVEL=0,'Submit and ','')%>Continue to Inventory"></td>    
   <%IF pnLEVEL > 0 %>    
	  <td width="49%" align="center">
      <input type="button" CLASS="SUBOFF" name="CONTINUECRG" onclick="SubmitEntry(2)" onmouseover="this.style.background='#993366'" onmouseout="this.style.background='#008000'" tabindex="37" value="Continue to Charges"></td>    
	</tr>
  <% ENDIF%>
</table>
</form>
