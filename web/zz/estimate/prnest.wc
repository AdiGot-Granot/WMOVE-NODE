<table border="0" align="center" width="98%" cellspacing="1" style="border-radius:12px;border: 1px solid #083484;" bordercolor="#4E6699">
  <tr>
    <td width="100%" height="25" colspan="7" align="center" style="border-bottom: 1px solid #083484;"><b><font color="#000080" face="Verdana" size="2">
    Full Value Protection Amount of Liability: <%=pcFVPVALUE%><%IF _CRG.INSAMT < 100%></font><font color="#FF0000" size="2" face="Verdana">(Optional)</font><%ENDIF%></font></b></td>
 </tr>
  <tr>
    <td width="23%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Deductible Levels:</font></b></td>
    <td width="13%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">
	$<%=_DEDUCT.D0TXT%></font></b> <font size="1" color="#C90000"><%=IIF(ALLT(_CRG.FVPDEDUCT)=ALLT(_DEDUCT.D0TXT) AND _CRG.INSAMT > 0,'(selected)','')%></font></td>
    <td width="15%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=_DEDUCT.D1TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D1TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></font></td>
    <td width="13%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=_DEDUCT.D2TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D2TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="11%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=_DEDUCT.D3TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D3TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="13%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=_DEDUCT.D4TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D4TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="12%" bgcolor="#E9E9EA" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=_DEDUCT.D5TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D5TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
 </tr>
  <tr>
    <td width="23%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Valuation Charge:</font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">$<%=ALLT(STR(_CRG.D0,9,2))%></font></b></td>
    <td width="15%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=ALLT(STR(_CRG.D1,9,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=ALLT(STR(_CRG.D2,9,2))%><%ENDIF%></font></b></td>
    <td width="11%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=ALLT(STR(_CRG.D3,9,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=ALLT(STR(_CRG.D4,9,2))%><%ENDIF%></font></b></td>
    <td width="12%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=ALLT(STR(_CRG.D5,9,2))%><%ENDIF%></font></b></td>
 </tr>
  <tr>
    <td width="23%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Total Estimate Plus<br>Valuation Charge:</font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2">$<%=ALLT(STR(_CRG.D0+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%></font></b></td>
    <td width="15%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=ALLT(STR(_CRG.D1+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=ALLT(STR(_CRG.D2+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="11%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=ALLT(STR(_CRG.D3+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=ALLT(STR(_CRG.D4+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="12%" style="border-bottom: 1px solid #BDBEC6;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=ALLT(STR(_CRG.D5+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
 </tr> 
  <tr>
    <td width="23%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Customer's Initials:</font></b></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><font face="Arial" size="2">x_________</font></td>
    <td width="15%" style="border-bottom: 1px solid #BDBEC6;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="11%" style="border-bottom: 1px solid #BDBEC6;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="13%" style="border-bottom: 1px solid #BDBEC6;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="12%" style="border-bottom: 1px solid #BDBEC6;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>x_________<%ENDIF%></font></td>
 </tr>
  <tr>
    <td width="100%" colspan="7"><p class="fvp">
    <font style="font-family:Arial;font-size:10pt;"><b>WARNING:</b> 
	If a moving company loses or damages your goods, there are 2 different standards for the company`s liability based on the types of rates you pay. <b>BY FEDERAL LAW, THIS FORM MUST CONTAIN A FILLED-IN 
	ESTIMATE OF THE COST OF A MOVE FOR WHICH THE MOVING COMPANY IS LIABLE FOR THE FULL (REPLACEMENT) VALUE OF YOUR GOODS</b> in the event of loss of, or damage to, the goods. This form may also contain
	an estimate of the cost of a move in which the moving company is liable for <b>FAR LESS</b> than the replacement value of your goods, typically at a lower cost to you. You will select the liability 
	level later, on the bill of lading (contract) for your move. Please read <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/RightsandResponsibilitiesBooklet_2022Update.pdf" target="_blank">Your Rights and Responsibilities When You Move</a>, 
	and <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/ReadytoMoveBrochure_2022Update.pdf" target="_blank">Ready to Move Brochure</a> provided by the moving company. By accepting this estimate, 
	you acknowledge and consent to receiving these brochures electronically, in lieu of a printed booklet, as permitted by law. You confirm that you have been informed of your rights and responsibilities 
	as a shipper and that you understand these documents are available for your review at any time online. Further information at the government website <a href="http://www.protectyourmove.gov">www.protectyourmove.gov</a></font></p></td>
 </tr>   
</table>
<%ENDIF%>
