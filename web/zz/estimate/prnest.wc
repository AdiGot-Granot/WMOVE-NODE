<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Moving Estimate</title>

<style>
p.fvp {text-align:justify;}
</style>

</head>
<body>
    <%=lcEMAILHEADER%>
<% IF pcCUSTNO<>'ABCMOVINGI' AND pcCUSTNO<>'RHINORELOC' %>    
<table border="0" cellpadding="0" cellspacing="0" align="center" style="border-collapse: collapse" width="700">
  <tr>
    <td width="100%" align="center"><img border="0" src="https://eagle.hellomoving.com<%=pcIMG%>?t=<%=ALLT(STR(SECONDS(),12,3))%>" alt="" width="100%" height="100"></td>
 </tr>
</table>
<%ENDIF%>
<table border="0" width="700" ALIGN="CENTER" style="border-radius:20px;border: 1px solid #083484;">
  <tr> 
   <td><BR>
<table border="0" width="98%" align="center" cellspacing="0" style="border-radius:12px;border: 1px solid #083484;" cellpadding="0">
  <tr>
   <% DO CASE
			CASE pcCUSTNO='SPARTANMO'
				lcTITLE=IIF(_EST.STATUS='F','Relocation Rate',pcBINDING+' Agreement')
			CASE pcCUSTNO='QUALITYMIL'
				lcTITLE=IIF(_EST.STATUS='F','Estimate Of Charges','Order for Service')+' '+pcBINDING
			CASE pcCUSTNO='IMPERIAL'
				lcTITLE=pcBINDING+' '+IIF(_EST.STATUS='F','Moving Estimate','Order for Service')
			CASE pcCUSTNO='ELITEMOVCA'
				lcTITLE=IIF(_EST.STATUS='F','Moving Estimate','Order for Service - Binding Estimate')				
			CASE pcCUSTNO='SERENITYMO'
				lcTITLE='Price Guarantee'				
			CASE pcCUSTNO='OCTOMOVERS'
				lcTITLE=pcBINDING+' '+IIF(_EST.STATUS='F','Moving Estimate','Order for Service')
			CASE pcCUSTNO='KINGSMOVE'
				lcTITLE=pcBINDING+' '+IIF(_EST.STATUS='F','Moving Estimate','Moving Estimate/Invoice')
			CASE pcCUSTNO='PAYLESSM'
				lcTITLE=pcBINDING+' '+'Estimate of Charges'
			CASE pcCUSTNO='LOYALMOV'
				lcTITLE=pcBINDING+' '+'Moving Quote'																
			OTHERWISE
				lcTITLE=pcBINDING+' '+'Moving Estimate'
   ENDCASE%>
	<td width="100%" colspan="2">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="100%">
  <tr style="border-bottom: 1px solid #083484;">
    <td width="20%" height="25" align="center">&nbsp;</td>
    <td width="50%" height="25" align="center"><b><font face="Verdana" color="#000084" size="4"><%=lcTITLE%></font></b></td>
    <td width="30%" height="25" align="right"><b><font face="Verdana" size="2"><%=IIF(_EST.STATUS='F','Reference No: ','Job No: ')%><font color="#FF0000"><%=pcORDNO1%></font></font></b>&nbsp;</td>
 </tr>
</table>
   </td>
 </tr>
  <tr>
	<td width="48%" valign="top">
<table border="0" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="100%" cellpadding="3">
  <tr>
    <td width="100%"><font face="Arial"><b><%=pcCOMPANY%></b></font></td>
  </tr>
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=pcADD1%></b></font></td>
  </tr>
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=pcADD2%></b></font></td>
  </tr>  
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=IIF(EMPTY(pcDOT),"","US DOT: "+pcDOT+"&nbsp;&nbsp;&nbsp;")%><%=IIF(EMPTY(pcICC),"","MC: "+pcICC)%></b></font></td>
 </tr>
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=IIF(!EMPTY(pcREGISTER),"Registration #: "+pcREGISTER,"")%></b></font></td>
 </tr> 
</table>	
	</td>
	<td width="52%" valign="top" style="border-left: 1px solid #083484;">
<table border="0" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="100%" cellpadding="3">
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Customer<br>Rep:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b>
    <% IF plUNAME %>
       <%=pcREP%>
    <%ELSE%>
       <%=IIF(EMPTY(_EST.REP),PROPER(_EST.USER),PROPER(_EST.REP))%>
    <%ENDIF%></b></font></td>
  </tr>
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Phone:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcTOLLFREE%>&nbsp;<%=pcPHONEEXT%></b></font></td>
  </tr>
  <% IF !EMPTY(pcUSERPHONE)%>
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Direct:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcUSERPHONE%></b></font></td>
  </tr>
  <%ENDIF%>  
 <%IF !EMPTY(pcFAX)%> 
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Fax:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcFAX%></b></font></td>
  </tr>
 <%ENDIF%>     
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Email:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><a href="mailto:<%=pcOUREMAIL%>" style="text-decoration:none;"><%=pcOUREMAIL%></a></font></td>
  </tr>
  <%IF !EMPTY(pcOURWEB)%>
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Web:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><a href="<%=pcOURWEB%>" style="text-decoration:none;" target="_blank"><%=pcOURWEB%></a></font></td>
  </tr>
  <%ENDIF%>  
</table>	
	</td>
 </tr>
</table>
<br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:12px;border: 1px solid #083484;" width="98%">
  <tr>
    <td width="48%" height="25" align="center" style="border-bottom: 1px solid #083484;"><font color="#000080" face="Verdana"><b>Moving From</b></font></td>
    <td width="52%" height="25" align="center" style="border-bottom: 1px solid #083484;"><font color="#000080" face="Verdana"><b>Moving To</b></font></td>
 </tr>
  <tr>
    <td width="48%" valign="top">
<table border="0" width="100%" cellspacing="1" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td><b><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.SNAME))%>&nbsp;</b></font></td>
 </tr>
  <%IF !EMPTY(_EST.SPROXY)%>  
  <tr>
    <td><font face="Verdana" size="2"><%='Proxy: '+ALLT(_EST.SPROXY)%></font></td>
 </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.SADD1)%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(_EST.SADD1)%>&nbsp;<%=ALLT(_EST.SADD2)%></font></td>
 </tr>
  <%ENDIF%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.SLEVEL))%><%=IIF(EMPTY(_EST.SSUBLEVEL),'',' / '+ALLT(_EST.SSUBLEVEL))%><%=IIF(EMPTY(_EST.SFLOOR),'',', Floor: '+ALLT(STR(_EST.SFLOOR)))%>
	    <%IF !EMPTY(_EST.SAPT) AND _EST.RC='C'%>
	    <%=', Unit #: '+ALLT(_EST.SAPT)%>
        <%ELSE%>
	    <%=IIF(EMPTY(_EST.SAPT),'',', Apt. #: '+ALLT(_EST.SAPT))%>
	    <%ENDIF%></font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.SCITY))+', '+(_EST.SSTATE)%>&nbsp;<%=ALLT(_EST.SZIP)%>&nbsp;</font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2">Phone: <%=ALLT(_EST.STELH)%></font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.STELO),'','Phone: '+ALLT(_EST.STELO))%></font></td>
 </tr>
  <tr>
   <td><font face="Verdana" size="2"><a href="mailto:<%=ALLT(_EST.EMAIL)%>" style="text-decoration:none;"><%=ALLT(_EST.EMAIL)%></a></font></td>
 </tr>
</table>    
    </td>
    <td width="52%" valign="top" style="border-left: 1px solid #083484;">
<table border="0" width="100%" cellspacing="1" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td><b><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.RNAME))%></b></font></td>
 </tr>
  <%IF !EMPTY(_EST.RPROXY)%>  
  <tr>
    <td><font face="Verdana" size="2"><%='Proxy: '+ALLT(_EST.RPROXY)%></font></td>
 </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.RADD1)%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(_EST.RADD1)%>&nbsp;<%=ALLT(_EST.RADD2)%></font></td>
 </tr>
  <%ENDIF%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.RLEVEL))%><%=IIF(EMPTY(_EST.RSUBLEVEL),'',' / '+ALLT(_EST.RSUBLEVEL))%><%=IIF(EMPTY(_EST.RFLOOR),'',', Floor: '+ALLT(STR(_EST.RFLOOR)))%>
	    <%IF !EMPTY(_EST.RAPT) AND _EST.RC='C'%>
	    <%=', Unit #: '+ALLT(_EST.RAPT)%>
        <%ELSE%>
	    <%=IIF(EMPTY(_EST.RAPT),'',', Apt. #: '+ALLT(_EST.RAPT))%>
	    <%ENDIF%></font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.RCITY))+', '+(_EST.RSTATE)%>&nbsp;<%=ALLT(_EST.RZIP)%></font></td>
 </tr>
  <tr>
	<td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.RTELH),'','Mobile: '+ALLT(_EST.RTELH))%></font></td>
 </tr>
  <tr>
	<td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.RTELO),'','Phone: '+ALLT(_EST.RTELO))%></font></td>
 </tr> 
  <tr>
    <td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.SFAX),'','Fax: '+ALLT(_EST.SFAX))%></font></td>
 </tr>
</table>    
    </td>
 </tr>
</table>
<%IF !EMPTY(_ESTMEMO.REMAGENT) AND plEMAILTOAGENT %> 
  <br> 
<table border="0" align="center" width="98%" style="border-radius:12px;border: 1px solid #083484;" cellspacing="1">
  <tr>  
    <td align="center" height="25" style="border-bottom: 1px solid #083484;"><font face="Verdana" color="#000080"><b>Carrier Notes</b></font></td>
 </tr>
  <tr>  
    <td><%=ALLT(_ESTMEMO.REMAGENT)%></td>
 </tr> 
</table>
<%ENDIF%>
<%IF !EMPTY(_ESTMEMO.EXTSTOP)%>
<br>
<table border="0" align="center" width="98%" style="border-radius:12px;border: 1px solid #083484;" cellspacing="1">
  <tr>
    <td align="center" height="25" style="border-bottom: 1px solid #083484;"><font face="Verdana" color="#000080"><b>Extra Stop / Notes</b></font></td>
 </tr>
  <tr>
    <td valign="top"><%=ALLT(_ESTMEMO.EXTSTOP)%></td>
 </tr>
</table>
<%ENDIF%>
<br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:12px;border: 1px solid #083484;" width="98%">
  <tr>
    <td width="48%" valign="top">
<table border="0" cellspacing="1" style="border-collapse: collapse" width="100%" cellpadding="2">
  <tr>
    <td width="100%" ALIGN="CENTER" colspan="2" style="border-bottom: 1px solid #BDBEC6;"><b><font color="#000080" face="Verdana">Relocation Details</font></b></td>
 </tr> 
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Job No:</font></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="4" color="#FF0000"><%=pcORDNO1%></font></b>&nbsp;</td>
 </tr>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Estimate Date:</font></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=DATE()%></font></b>&nbsp;</td>
 </tr>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Representative:</font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">
    <% IF plUNAME %>
       <%=pcREP%>
    <%ELSE%>
       <%=IIF(EMPTY(_EST.REP),PROPER(_EST.USER),PROPER(_EST.REP))%>
    <%ENDIF%></font></b>&nbsp;</td>
 </tr>     
  <%IF !EMPTY(_EST.ESTIMDTE)%>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Visual On:</font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=CDOW(_EST.ESTIMDTE)%><br><%=(_EST.ESTIMDTE)%>&nbsp;<%=(_EST.ESTIMTME)%></font></b></td>
 </tr>
 <%ENDIF%>
 <%IF _EST.VISUALTYPE > 0 %>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Visual Type:</font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=pcVISUALTYPE%></font></b>&nbsp;</td>
 </tr>
      <%IF _EST.VISUALTYPE=3 %>
  <tr>
    <td width="100%" style="border-bottom: 1px solid #BDBEC6;" colspan="2"><font face="Arial" size="2">The shipper has elected to waive the physical and virtual survey and signed the waiver agreement 
    before the shipment is loaded in accordance with 49 CFR 375.401 (a).</FONT></td>
 </tr>
     <%ENDIF%>
 <%ENDIF%>        
 <%IF !EMPTY(_EST.ESTIMATOR)%>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Estimator:</font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=PROPER(_EST.ESTIMATOR)%></font></b>&nbsp;</td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><b>Move Type: <font size="1"><%=pcRC%></font></font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">
    <%=IIF(pcTYPE='D','Long Distance, ','Local Move, ')%><%=IIF(_CRG.MILES > 0,ALLT(STR(_CRG.MILES))+' miles','')%></font></b>&nbsp;</td>
 </tr>
<%IF pcCUSTNO='OPTIMUMV' %>
  <tr>
    <td width="46%" style="border-bottom: 1px solid #BDBEC6;"><b><font size="2" face="Arial">Estimated Volume:</font></b></td>
    <td width="54%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=ALLT(STR(_EST.TOTALCF))+' cf.'%>
    <% IF pcTYPE='D' AND pcDMIN>'0' %>
      	<%=IIF(plMINVOL=.F.,'<br>Minimum $'+pcDMIN,'<br>Minimum '+pcDMIN+' cf')%>      	
    <%ENDIF%> 	
    </font></b>&nbsp;</td>
 </tr>
<%ENDIF%>  
<%IF pcCUSTNO<>'MOVEPACK' AND pcCUSTNO<>'OPTIMUMV' %>
  <tr>
    <td width="46%" style="border-bottom: 1px solid #BDBEC6;"><b><font size="2" face="Arial">Estimated Volume:</font></b></td>
    <td width="54%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">  
    <%=IIF(plCALCCF,ALLT(STR(_EST.TOTALCF))+' cf. ('+ALLT(STR(_EST.TOTALLBS))+' lbs)',ALLT(STR(_EST.TOTALLBS))+' lbs. ('+ALLT(STR(_EST.TOTALCF))+' cf.)')%>
    <% IF pcTYPE='D' AND pcDMIN>'0' %>
      	<%=IIF(plMINVOL=.F.,'<br>Minimum $'+pcDMIN,IIF(plCALCCF,'<br>Minimum '+pcDMIN+' cf','<br>Minimum '+pcDMIN+' lbs'))%>      	
    <%ENDIF%> 	
    </font></b>&nbsp;</td>
 </tr>
<%ENDIF%>
<%IF pcTYPE='D' AND pcCUSTNO<>'C2CMOVEGA' AND pcCUSTNO<>'USAHOMEM'%>
  <tr>
    <td width="46%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Estimated Rate:</font></b></td>
    <td width="54%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=IIF(plCALCCF,'$'+ ALLT(STR(_CRG.I1PERCF,8,2))+' per cf','$'+ALLT(STR(_CRG.I1PERLBS,8,2))+' per lbs')%></font></b></td>
 </tr>
<%ENDIF%>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Move Day:</font>&nbsp;</td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="3" color="#FF0000"><%=CDOW(_EST.LBOOKDTE)%><%=IIF(EMPTY(_EST.LBOOKDTE1),'','/'+CDOW(_EST.LBOOKDTE1))%></font></b>&nbsp;</td>
  </tr>   
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=IIF(_EST.STATUS='F','Requested Move Date:','Move Date:')%></font>&nbsp;</td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="3" color="#FF0000"><%=_EST.LBOOKDTE%><%=IIF(EMPTY(_EST.LBOOKDTE1),'','-'+DTOC(_EST.LBOOKDTE1))%></font></b>&nbsp;</td>
  </tr>
 <%IF !EMPTY(_EST.LBOOKTME)%> 
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=IIF(pcCUSTNO='BLUEMOVING' OR pcCUSTNO='MOVERSCON' OR pcCUSTNO='SUPERBMOVE' OR pcCUSTNO='TODAMOVING' OR pcCUSTNO='VELOCITYVA','Arrival Window:','Move Time:')%></font>&nbsp;</td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=ALLT(_EST.LBOOKTME)%></font></b>&nbsp;</td>
  </tr>
 <%ENDIF%>   
  <%IF !EMPTY(_EST.BOXDTE)%>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Box Delivery:</font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=_EST.BOXDTE%>&nbsp;<%=(_EST.BOXTME)%></font></b></td>
 </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.PBOOKDTE)%>
    <tr>
     <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Pack Day:</font></b></td>
     <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=(_EST.PBOOKDTE)%>&nbsp;<%=(_EST.PBOOKTME)%></font></b></td>
    </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.DLVDTE)%> 
    <tr>
     <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">1<sup>st</sup> Available Delivery:</font></b></td>
     <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=_EST.DLVDTE%><%=IIF(EMPTY(_EST.DLVDTE1),'','-'+DTOC(_EST.DLVDTE1))%></font></b>&nbsp;</td>
    </tr>
   <%ENDIF%>
 <%IF _EST.DLVIMM=.T.%>
  <tr>
    <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Delivery Type:</font></b></td>
    <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Immediately</font></b></td>
 </tr>
 <%ENDIF%>    
 <%IF pnCOLEVEL=7 AND !EMPTY(pcD1DTE)%>
    <tr>
     <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Delivery:</font></b></td>
     <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=pcD1DTE%>&nbsp;&nbsp;<%=pcD1TME%></font></b></td>
    </tr>
 <%ENDIF%>
 <%IF !plBLKREF %> 
    <tr>
     <td width="40%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Reference By:</font></b></td>
     <td width="60%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=_EST.REF%></font></b>&nbsp;</td>
    </tr>
 <%ENDIF%>
    <tr>
     <td width="40%"><b><font face="Arial" size="2">Created On:</font></b></td>
     <td width="60%"><b><font face="Arial" size="2"><%=TTOD(_EST.OPENDTE)%></font></b>&nbsp;</td>
    </tr>
</table>
 <%IF plVEHICLE=.T. %>  
 <br>
<table border="0" align="center" bordercolor="#111111" width="100%">
  <tr>
    <td colspan="2" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><b>Optional Service: Auto Transport</b></font></td>
 </tr>
  <%SELECT _INVAUTO 
    SCAN %>
  <tr>
    <td width="59%" style="border-bottom: 1px solid #A9A9A9;"><font face="Arial" size="2"><b><%=ALLT(STR(QTY))+', '+ALLT(YEAR)+' '+ALLT(COLOR)+' '+ALLT(MAKE)+' '+ALLT(MODEL)%><br><%=ALLT(TYPE)%><%=IIF(EMPTY(ENGINE),'',', '+ALLT(ENGINE))%><%=IIF(RUN,'',', (not running)')%><%=IIF(COVER,', (enclosed)','')%></b></font></td>
    <td width="25%" style="border-bottom: 1px solid #A9A9A9;" align="right"><font face="Arial" size="2"><b><%='$'+ALLT(STR(UPRC*QTY))%></b></font>&nbsp;</td>
 </tr>
  <%ENDSCAN%>
</table>
  <%ENDIF%>    
    </td>
    <td width="52%" valign="top" style="border-left: 1px solid #083484;">
<table border="0" width="100%" style="border-collapse: collapse" cellspacing="1" cellpadding="2">
   <tr> 
     <td colspan="2" align="center" width="100%" style="border-bottom: 1px solid #BDBEC6;"><font color="#000080" face="Verdana"><b><%=IIF(pcTYPE<>'D','Relocation Rate','Relocation Estimate')%></b></font>&nbsp;</td>
  </tr>
<%IF pcTYPE='D' AND plOTHERS=.T. AND pnDMAINID > 999 %>        
   <tr> 
