       <a href="https://<%=pcSERVERIP%>/wc.dll?mpest~esignwc~<%=pcREFNO%>~<%=pcCUSTID%>~<%=pcEMAILID%>">Online Electronic Signature</a></b></font></td>
     </tr>
   </table>          
    <%ENDIF%>
   </td>
 </tr>
</table>
<% IF plFV=.T. AND pcTYPE='D' AND _EST.SSTATE<>_EST.RSTATE %><!--start FVP  -->
