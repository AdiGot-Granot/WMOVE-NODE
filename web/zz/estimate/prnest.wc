      <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font size="2" face="Arial">&nbsp;<%='$'+ALLT(STR(_EST.SUBTOTAL,8,2))%></font></b></td>
   </tr>
   <%ENDIF%>
   <% IF pcCUSTNO='SERENITYMO' %>      
    <tr>
      <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B>Price Guarantee</B></font></td>
      <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font size="2" face="Arial">&nbsp;<%='$'+ALLT(STR(_EST.SUBTOTAL,8,2))%></font></b></td>
   </tr>
   <%ENDIF%>               
   <% IF pcCUSTNO='1MOVERDEP' OR pcCUSTNO='LAPROMINC'%>      
    <tr>
      <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B><% IF pcTYPE='D'%>Total Moving Estimate<%ENDIF%></B></font></td>
      <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font size="2" face="Arial"><% IF pcTYPE='D'%>&nbsp;<%='$'+ALLT(STR(_EST.SUBTOTAL,8,2))%><%ENDIF%></font></b></td>
   </tr>
   <%ENDIF%>
   <% IF pcCUSTNO='MOVERSCON' %>      
    <tr>
      <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B>
      <% IF pcTYPE<>'D' AND pcDEPT=='BD'%>&nbsp;<%ELSE%>Total Moving Estimate<%ENDIF%></B></font></td>
      <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font size="2" face="Arial">
      <% IF pcTYPE<>'D' AND pcDEPT=='BD'%>&nbsp;<%ELSE%><%='$'+ALLT(STR(_EST.SUBTOTAL,8,2))%><%ENDIF%></font></b></td>
   </tr>
   <%ENDIF%>   
<%ENDIF%>
      <% IF pnPAYAMT > 0 %>
    <tr> 
      <td width="275" style="border-bottom: 1px solid #BDBEC6;"><B><font face="Arial" size="2" COLOR="#FF0000">Customer Payment</B></font></td>
      <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font size="2" face="Arial" color="#FF0000">&nbsp;<%='$'+ALLT(STR(pnPAYAMT,8,2))%></font></b></td>
    </tr>
     <% ENDIF %>
      <% IF pnCOLEVEL=7 AND _CRG.SPERMONTH > 0 %>
    <tr> 
      <td width="275" style="border-bottom: 1px solid #BDBEC6;"><B><font face="Arial" size="2" COLOR="#000080">Estimated Monthly Storage Rate</font></b>&nbsp;</td>
      <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font size="2" face="Arial" color="#000080">&nbsp;<%='$'+ALLT(STR(_CRG.SPERMONTH,8,2))%></font></b></td>
    </tr>   
     <% ENDIF %>
<% ENDIF %>
    </table>
    <%IF plESIGN%>
