            <tr>
              <td width="10%" align="center"><font face="Arial" size="1"><%=QTY%></font>&nbsp;</td>
              <td width="70%"><font face="Arial" size="1"><%=ITEM%></font>&nbsp;</td>
              <td width="20%" align="right"><font face="Arial" size="1"><%=PRICE%></font>&nbsp;</td>
            </tr>
      <%ENDSCAN %>
          </table>	
	</td>
	<td width="33%" valign="top">
          <table border="0" cellpadding="0" cellspacing="0" style="border-radius:7px;border: 1px solid #C0C0C0;" width="100%">
            <tr>
              <td width="10%" bgcolor="#E9E9EA" align="center"><b><font face="Arial" style="font-size: 9pt;">Qty</font></b></td>
              <td width="70%" bgcolor="#E9E9EA" align="center"><b><font face="Arial" style="font-size: 9pt;">Material</font></b></td>
              <td width="20%" bgcolor="#E9E9EA" align="center"><b><font face="Arial" style="font-size: 9pt;">Unit<br>Price $</font></b></td>
            </tr>
      <%SELECT _MAT3
         SCAN %>
            <tr>
              <td width="10%" align="center"><font face="Arial" size="1"><%=QTY%></font>&nbsp;</td>
              <td width="70%"><font face="Arial" size="1"><%=ITEM%></font>&nbsp;</td>
              <td width="20%" align="right"><font face="Arial" size="1"><%=PRICE%></font>&nbsp;</td>
            </tr>
      <%ENDSCAN %>
          </table>	
	</td>
 </tr>
</table>
  <%ENDIF%>
  <br>
<table border="0" width="98%" cellspacing="1" cellpadding="2" align="center" style="border-radius:12px;border: 1px solid #083484;">
<% IF pcCUSTNO<>'SPARTANMO' AND pcCUSTNO<>'LOYALMOV' %>
  <tr>
   <td width="100%" align="center" style="border-bottom: 1px solid #083484;"><font color="#000080" face="Verdana"><b>Understanding Your Estimate</b></font></td>
 </tr>
<%ENDIF%>
  <tr>
   <td width="100%"><%=pcREMFILE%></td>
 </tr>
</table>
<%IF plVIEWDIR AND !EMPTY(_ESTMEMO.DIR) %>
   <br>
<table border="0" width="98%" cellspacing="1" cellpadding="2" align="center" style="border-radius:12px;border: 1px solid #083484;">
  <tr>
	<td width="100%" align="center" style="border-bottom: 1px solid #083484;"><b><font face="Verdana" color="#000084">Direction</font></b></td>
 </tr>
  <tr>
	<td width="100%"><font face="Verdana" size="2"><%=_ESTMEMO.DIR%></font></td>
 </tr>
</table>
<%ENDIF%>
  <br> 
<table border="0" width="98%" align="center" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0">
  <%IF plESIGN%>
  <tr>
	<td width="100%" colspan="3"><font face="Verdana" size="2"><b>Click on <a href="https://<%=pcSERVERIP%>/wc.dll?mpest~esignwc~<%=pcREFNO%>~<%=pcCUSTID%>~<%=pcEMAILID%>">Online Electronic Signature</a>
	to confirm your move.</b></font></td>
 </tr>
  <%ELSE%>
  <tr>
    <td width="39%" height="15"><br>_____________________________<br><font face="Verdana" size="2">Customer Name</font></td>
    <td width="41%" height="15"><br>________________________________<br><font face="Verdana" size="2">Customer Signature</font></td>
    <td width="20%" height="15"><br>____________<br><font face="Verdana" size="2">Date</font></td>
 </tr>
 <%ENDIF%>
</table>
<%IF pcCUSTNO='MOVEXPRESS' OR pcCUSTNO='QUALITYMIL' OR pcCUSTNO='ABAMOVING' AND _EST.STATUS='O'%> 
<BR>
<table border="0" width="98%" align="center" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0">
  <tr>
    <td width="39%" height="15"><br>_____________________________<br><font face="Verdana" size="2">Carrier's Name</font></td>
    <td width="41%" height="15"><br>________________________________<br><font face="Verdana" size="2">Carrier's Signature</font></td>
    <td width="20%" height="15"><br>____________<br><font face="Verdana" size="2">Date</font></td>
 </tr>
</table>
<%ENDIF%>
<%IF plREPSIGN AND _EST.STATUS='O'%>
<BR>
<table border="0" width="98%" align="center" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0">
  <tr>
    <td width="29%" height="15"><br><u><i><font face="Courier New" style="font-size:11pt;"><%=pcREP%></i>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</u><br>Company Representative</font></td>
    <td width="30%" height="15"><br><u><i><font face="Courier New" style="font-size:11pt;"><%=DATE()%></i>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</u><br>Date</font></td>
 </tr>
</table>
<%ENDIF%>
   </td>
 </tr>
  </table>
<%IF !EMPTY(pcEMAIL)%>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" id="AutoNumber1">
  <tr>
    <td width="100%" align="center"><br><font size="1" face="Verdana">If you no longer wish to receive emails from <%=pcCOMPANY%>, please
    click on <a href="https://<%=gcSERVERIP%>/wc.dll?mputil~removeemail~&CUSTID=<%=pcCUSTID%>&EMAILTO=<%=pcEMAIL%>&JOBID=<%=pcJOBID%>">unsubscribe</a></font></td>
 </tr>
</table>
<%ENDIF%>
</center>
</body>
</html>