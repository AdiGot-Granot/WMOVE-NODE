<html>

<head>
<title>Moving System-Log File</title>
<script language="JavaScript" src="/zz/util/calendar.js"></script>
<script>

function sf(){
	frm=document.theForm;
}

function sendemail(cREFNO) {
    window.open('/wc.dll?mprep~printselect~<%=pcSCR%>~'+cREFNO+'~EMAILCENTER','EANITHING','toolbar=no,location=no,directories=no,status=yes,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=700,height=750');
	self.name="main"
}

function xxxcallPhone(par){
	//alert('https://cp52.fonality.com/call.cgi?server_id=12083&extension=<=pcEXT>&number='+par+'&username=12083_<=pcEXT>&password=<=pcPASSWORD>')
    newWin=window.open('https://cp52.fonality.com/call.cgi?server_id=12083&extension=<%=pcEXT%>&number='+par+'&username=<%=pcUSERNAME%>_<%=pcEXT%>&password=<=pcPASSWORD>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=100,height=100');
	// delay 
	window.setTimeout('newWin.close()',11000);
	//newWin.close()

}


function fonality(par){
	//alert('https://cp52.fonality.com/call.cgi?server_id=12083&extension=<%=pcEXT%>&number='+par+'&username=12083_<%=pcEXT%>&password=<%=pcPASSWORD%>')
    newWin=window.open('https://cp52.fonality.com/call.cgi?server_id=12083&extension=<%=pcEXT%>&number='+par+'&username=12083_<%=pcEXT%>&password=<%=pcPASSWORD%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=100,height=100');
	// delay 
	window.setTimeout('newWin.close()',11000);
	//newWin.close()

}


function srchDetails(nPageNo,nPRIORITY){  
	frm.action='/wc.dll?mpxml~ESTFUWC~<%=pcSCR%>~&RECPERPAGE=<%=ALLT(STR(pnRECPERPAGE))%>&PAGENO='+nPageNo+'&PRIORITY='+nPRIORITY;
	frm.submit();
}


function thisWeek(){
	var today = new Date; // get current date
	var first = today.getDate() - today.getDay(); // First day is the day of the month - the day of the week
	
	
	var last = first + 6; // last day is the first day + 6
	var firstday = new Date(today.setDate(first));
	var month1 = firstday .getMonth()+1;
	var day1 = firstday .getDate();
	var year1 = firstday .getFullYear();
	cDate1=month1+ '/' + day1 + '/' + year1;
	
	
	//var lastday = new Date(curr.setDate(last)).toUTCString(); 
	var lastday = new Date(today.setDate(last)); 
	var month2 = lastday .getMonth()+1;
	var day2 = lastday .getDate();
	var year2 = lastday .getFullYear();
	cDate2=month2+ '/' + day2 + '/' + year2;
	
	document.getElementById("DATE1").value=cDate1;
	document.getElementById("DATE2").value=cDate2;
}

function todayDate(){
	var today = new Date; // get current date
	var month = today.getMonth()+1;
	var day = today.getDate();
	var year = today.getFullYear();
	cDate=month+ '/' + day + '/' + year;
		
	document.getElementById("DATE1").value=cDate;
	document.getElementById("DATE2").value=cDate;
}

function tomorrowDate(){
	
	var today = new Date(); // Or Date.today() 
	var tomorrow = new Date(today.getTime() + (24 * 60 * 60 * 1000)); 

	var month = tomorrow.getMonth()+1;
	var day = tomorrow.getDate();
	var year = tomorrow.getFullYear();
	cDate=month+ '/' + day + '/' + year;
		
	document.getElementById("DATE1").value=cDate;
	document.getElementById("DATE2").value=cDate;
}

function yesterdayDate(){
	
	var today = new Date(); // Or Date.today() 
	var yesterday = new Date(today.getTime() - (24 * 60 * 60 * 1000)); 

	var month = yesterday.getMonth()+1;
	var day = yesterday.getDate();
	var year = yesterday.getFullYear();
	cDate=month+ '/' + day + '/' + year;
		
	document.getElementById("DATE1").value=cDate;
	document.getElementById("DATE2").value=cDate;
}

function oldDate(){
	
	var today = new Date(); // Or Date.today() 
	var yesterday = new Date(today.getTime() - (24 * 60 * 60 * 1000)); 

	var month = yesterday.getMonth()+1;
	var day = yesterday.getDate();
	var year = yesterday.getFullYear();
	cDate=month+ '/' + day + '/' + year;
		
	document.getElementById("DATE1").value='01/01/2000';
	document.getElementById("DATE2").value=cDate;
}


</script>
<STYLE TYPE="text/css">

	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}

</style>
</head>
<body onload="sf()" bgcolor="#336699">
<form name="theForm" method="POST">
