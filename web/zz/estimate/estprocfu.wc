				     &nbsp;</td>
					<td width="37">
			      	&nbsp;</td>
					<td width="12">
			      	&nbsp;</td>
					<td width="68">
			      	Sort By:</td>
					<td width="197">
			      	<select size="1" name="SORT" style="width:120; height:22">
			      		<option value="E.NEXTFU" <%IF pcSORT="NEXTFU"%>SELECTED<%ENDIF%>>Follow-Up Date</option>
						<option value="E.OPENDTE" <%IF pcSORT="OPENDTE"%>SELECTED<%ENDIF%>>Open Date</option>
						<option value="E.LBOOKDTE" <%IF pcSORT="S.DTE"%>SELECTED<%ENDIF%>>Pick-Up Date</option>
					 	<option value="E.USER" <%IF pcSORT="USER"%>SELECTED<%ENDIF%>>User</option>
					 	<option value="E.FUSTATUS" <%IF pcSORT="FUSTATUS"%>SELECTED<%ENDIF%>>Priority</option>
						</select></td>
					<td>
