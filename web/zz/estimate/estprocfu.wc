					<td width="20">To:</td>
					<td width="714"><input type="text" id="DATE2" name="DATE2" size="10" value="<%=lcTODTE%>"><a href="javascript:cal2.popup();"><img src="/zz/images/cal.gif" border="0" width="16" height="16"></a></td>
					<td width="20">&nbsp;</td>
