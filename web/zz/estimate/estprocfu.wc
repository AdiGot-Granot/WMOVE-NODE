						<option value="<%=_TY.TYPE%>" <%IF _TY.TYPE==pcSELTYPE%>selected<%ENDIF%>><%=ALLT(_TY.DESC)%></option>
					<%ENDSCAN%>		 	               
					<option value="ALL" <%IF pcSELTYPE=="ALL"%>selected<%ENDIF%>>All</option>
	    </select></td>
					<td width="32">
			      	:</td>
