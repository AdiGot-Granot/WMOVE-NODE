					<td width="119">&nbsp;</td>
					<td width="162">&nbsp;</td>
					<td width="74">&nbsp;</td>
					<td width="73">From:</td>
					<td width="182"><input type="text" id="DATE1" name="DATE1" size="10" value="<%=lcFROMDTE%>">
