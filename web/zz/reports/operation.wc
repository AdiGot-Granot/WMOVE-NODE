<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Operation Report</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mprep~operationret~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
	
</SCRIPT>

<STYLE TYPE="text/css">
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 150px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #239243;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="40%">
  <tr>
    <td BGCOLOR="#239243" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Operation</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
    <form name="theForm" method="POST">
<table border="0" width="95%" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="16%" height="25"><b>Date Range:</b></td>
	<td width="15%" height="25"><b>From Date:</b></td>
	<td width="13%" height="25"><b>To Date:</b></td>
	<td width="15%" height="25"><b>Month:</b></td>
	<td width="11%" height="25"><b>Year:</b></td>
	<% IF plDEPT %>	
	<td width="16%" height="25"><b>Department:</b></td>
	<%ENDIF%>	
 </tr>
  <tr>
	<td width="16%" height="3">
  <select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  </select>	
	</td>
	<td width="15%" height="3"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DTOC(pdDATE1)%>"></td>
	<td width="13%" height="3"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DTOC(pdDATE2)%>"></td>
	<td width="15%" height="3">
	 <select size="1" name="MONTH">
      <option selected value=""></option>
      <option value="01">January</option>
      <option value="02">February</option>
      <option value="03">March</option>
      <option value="04">April</option>
      <option value="05">May</option>
      <option value="06">June</option>
      <option value="07">July</option>
      <option value="08">August</option>
      <option value="09">September</option>
      <option value="10">October</option>
      <option value="11">November</option>
      <option value="12">December</option>
       </select></td>
	<td width="11%" height="3">
	    <select size="1" name="YEAR">
      <option selected></option>
      <option><%=ALLT(STR(YEAR(DATE())-4))%></option>
      <option><%=ALLT(STR(YEAR(DATE())-3))%></option>
      <option><%=ALLT(STR(YEAR(DATE())-2))%></option>
      <option><%=ALLT(STR(YEAR(DATE())-1))%></option>
      <option><%=ALLT(STR(YEAR(DATE())))%></option>
      <option><%=ALLT(STR(YEAR(DATE())+1))%></option>
      </select></td>
    <% IF plDEPT %>  				
	<td width="16%" height="3">
			<select size="1" name="DEPT">
			<option value="" selected></option>
			 <%	SELECT _DEPT
				 	 SCAN %>
				<option><%=ALLT(DEPT)%></option>
			 <% ENDSCAN %>
			</select></td>
	<%ENDIF%>  				
 </tr>
</table>
  <br>  
<table border="0" width="95%" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" cellspacing="0" cellpadding="0">
  <tr>
    <td valign="top" width="36%" style="border-right: 1px solid #A9A9A9;">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:25px;">
  <tr>
	<td width="100%" style="background-color:#F7F7F7; padding:3px 0;" colspan="2" align="center" ><b><font face="Verdana" size="2">Move Type</font></b></td>
 </tr>
  <tr>
	<td width="11%" height="20"><input class="chkon" type="radio" name="TYPE" value="V1" checked></td>
	<td width="89%" height="20"><font face="Arial" size="2">All</font></td>
 </tr>
  <tr>
	<td width="11%" height="20"><input type="radio" name="TYPE" value="V2"></td>
	<td width="89%" height="20"><font face="Arial" size="2">Local</font></td>
 </tr>
  <tr>
	<td width="11%" height="20"><input type="radio" name="TYPE" value="V3"></td>
	<td width="89%" height="20"><font face="Arial" size="2">Intrastate</font></td>
 </tr> 
  <tr>
	<td width="11%" height="20"><input type="radio" name="TYPE" value="V4"></td>
	<td width="89%" height="20"><font face="Arial" size="2">Long Distance</font></td>
 </tr> 
  <tr>
	<td width="11%" height="20"><input type="radio" name="TYPE" value="V5"></td>
	<td width="89%" height="20"><font face="Arial" size="2">International</font></td>
 </tr>
  <tr>
	<td width="11%" height="20"><input type="radio" name="TYPE" value="V6"></td>
	<td width="89%" height="20"><font face="Arial" size="2">Auto Transport</font></td>
 </tr>
</table>    
    </td>
    <td valign="top" width="35%">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:25px;">
  <tr>
	<td width="100%" style="background-color:#F7F7F7; padding:3px 0;" colspan="2" align="center"><b><font face="Verdana" size="2">Sort By</font></b></td>
 </tr>
  <tr>
	<td width="12%" height="20"><input type="radio" name="SORT" value="V2" checked></td>
	<td width="88%" height="20"><font face="Arial" size="2">Job No.</font></td>
 </tr>			  
  <tr>
	<td width="12%" height="20"><input class="chkon" type="radio" name="SORT" value="V1"></td>
	<td width="88%" height="20"><font face="Arial" size="2">Operation Day</font></td>
 </tr>
  <tr>
	<td width="12%" height="20"><input class="chkon" type="radio" name="SORT" value="V3"></td>
	<td width="88%" height="20"><font face="Arial" size="2">Weekly Summary</font></td>
 </tr> 
</table>    
    </td>
    <td valign="top" width="29%" style="border-left: 1px solid #A9A9A9;">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:25px;">
  <tr>
	<td width="100%" style="background-color:#F7F7F7; padding:3px 0;" colspan="2" align="center"><b><font face="Verdana" size="2">Job Phase</font></b></td>
 </tr>
  <tr>
	<td width="13%" height="20"><input type="radio" name="SHOW" value="V1" checked></td>
	<td width="87%" height="20"><font face="Arial" size="2">All</font></td>
 </tr>			   
  <tr>
	<td width="13%" height="20"><input type="radio" name="SHOW" value="V2"></td>
	<td width="87%" height="20"><font face="Arial" size="2">Pick-up</font></td>
 </tr>			  
  <tr>
	<td width="13%" height="20"><input type="radio" name="SHOW" value="V3"></td>
	<td width="87%" height="20"><font face="Arial" size="2">Delivery</font></td>
 </tr>
  <tr>
	<td width="13%" height="20"><input type="radio" name="SHOW" value="V4"></td>
	<td width="87%" height="20"><font face="Arial" size="2">Closed Jobs</font></td>
 </tr> 
</table>    
    </td>
 </tr>
</table>
  <br>
<table border="0" width="90%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(1)" value="Submit"></td>  
	<td align="center"><input type="button" CLASS="SUBOFF" name="B4" onclick="javascript:history.go(-1)" value="Exit"></td>    
 </tr>
</table>      
</form>    
    </td>
  </tr>
  <tr>
    <td bgcolor="#239243">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
  </table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->
   
</body>
</html>