<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Customer Payments</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mprep~payret~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==2) 
      {
       document.theForm.B4.style.visibility="hidden"; 
       document.theForm.action="/wc.dll?mprep~payret~<%=pcSCR%>~AGENT";
       document.theForm.submit();
      }      
      
	}
</SCRIPT>

<STYLE TYPE="text/css">
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 150px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #239243;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}
</style>

</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="45%">
  <tr>
    <td BGCOLOR="#239243" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Customer Payments</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
    <form name="theForm" method="POST">
<table border="0" width="95%" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="13%" height="25"><b>Date Range:</b></td>
	<td width="11%" height="25"><b>From Date:</b></td>
	<td width="12%" height="25"><b>To Date:</b></td>
	<% IF plDEPT %>
	<td width="11%" height="25"><b>Department:</b></td>
	<%ENDIF%>
	<% IF plADMIN=.F. %>
	<td width="25%" height="25"><b>Download:</b></td>
	<%ENDIF%>	
 </tr>
  <tr>
	<td width="13%" height="3">
  <select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  </select>	
	</td>
	<td width="11%" height="3"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DTOC(pdDATE1)%>"></td>
	<td width="12%" height="3"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DTOC(pdDATE2)%>"></td>
	<% IF plDEPT %>
	<td width="11%" height="3">
			<select size="1" name="DEPT">
			<option value="" selected></option>
			 <%	SELECT _DEPT
				 	 SCAN %>
				<option><%=ALLT(DEPT)%></option>
			 <% ENDSCAN %>
			</select></td>
	<%ENDIF%>		
	<% IF plADMIN=.F. %>		
	<td width="25%" height="3"><input type="checkbox" name="DLXLS" value="ON"></td>
	<%ENDIF%> 				
 </tr>
</table>  
  <br>  
<table border="0" width="95%" align="center" style="border-radius:6px; border:1px solid #A9A9A9; overflow:hidden;" cellspacing="0" cellpadding="0">
  <tr>
    <td valign="top" width="25%" style="border-right:1px solid #A9A9A9;">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse; line-height:25px;">
  <tr>
    <td colspan="2" align="center" style="background-color:#F7F7F7; padding:3px 0;"><b><font face="Verdana" size="2">Move Type</font></b></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input class="chkon" type="radio" name="TYPE" value="V1" checked></td>
	<td width="86%" height="20"><font face="Arial" size="2">All</font></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="TYPE" value="V2"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Local</font></td>
 </tr> 
  <tr>
	<td width="14%" height="20"><input type="radio" name="TYPE" value="V3"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Long Distance</font></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="TYPE" value="V4"></td>
	<td width="86%" height="20"><font face="Arial" size="2">International</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="TYPE" value="V5"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Auto Transport</font></td>
 </tr>
</table>
  </td>
    <td valign="top" width="23%">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:25px;">
  <tr>
	<td width="100%" style="background-color:#F7F7F7; padding:3px 0;" colspan="2" align="center"><b><font face="Verdana" size="2">Sort By</font></b></td>
 </tr>
  <tr>
	<td width="16%" height="20"><input class="chkon" type="radio" name="SORT" value="V1" checked></td>
	<td width="84%" height="20"><font face="Arial" size="2">Job No.</font></td>
 </tr>
  <tr>
	<td width="16%" height="20"><input type="radio" name="SORT" value="V2"></td>
	<td width="84%" height="20"><font face="Arial" size="2">Payment Date</font></td>
 </tr>
  <tr>
	<td width="16%" height="20"><input type="radio" name="SORT" value="V3"></td>
	<td width="84%" height="20"><font face="Arial" size="2">Move Date</font></td>
 </tr> 
</table>    
    </td>
    <td valign="top" width="25%" style="border-left:1px solid #A9A9A9;">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:25px;">
  <tr>
	<td width="100%" style="background-color:#F7F7F7; padding:3px 0;" colspan="2" align="center"><b><font face="Verdana" size="2">Payment Type</font></b></td>
 </tr>
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V1" checked></td>
	<td width="85%" height="20"><font face="Arial" size="2">All</font></td>
  </tr>
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V8"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Deposit</font></td>
  </tr>   
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V2"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Move</font></td>
  </tr>
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V3"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Storage</font></td>
  </tr>
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V6"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Broker/Agent</font></td>
  </tr>  
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V4"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Merchant Process</font></td>
  </tr>
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V5"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Office Entry</font></td>
  </tr>
  <tr>
	<td width="15%" height="20"><input type="radio" name="SHOW" value="V7"></td>
	<td width="85%" height="20"><font face="Arial" size="2">Jobs without Agent</font></td>
  </tr> 
</table>    
    </td>
    <td valign="top" width="27%" style="border-left:1px solid #A9A9A9;">
<table border="0" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;line-height:25px;">
  <tr>
	<td width="100%" style="background-color:#F7F7F7; padding:3px 0;" colspan="2" align="center"><b><font face="Verdana" size="2">Payment Method</font></b></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input class="chkon" type="radio" name="METHOD" value="V1" checked></td>
	<td width="86%" height="20"><font face="Arial" size="2">All</font></td>
 </tr> 
  <tr>
	<td width="14%" height="20"><input class="chkon" type="radio" name="METHOD" value="V2"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Check</font></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V3"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Cash</font></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V4"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Credit Card</font></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V5"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Cashier Check</font></td>
 </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V6"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Direct Deposit</font></td>
 </tr>  
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V7"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Money Order</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V8"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Wire Transfer</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V9"></td>
	<td width="86%" height="20"><font face="Arial" size="2">PayPal</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V10"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Quick Pay</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V11"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Zelle</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V12"></td>
	<td width="86%" height="20"><font face="Arial" size="2">Venmo</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V13"></td>
	<td width="86%" height="20"><font face="Arial" size="2">eCheck</font></td>
  </tr>
  <tr>
	<td width="14%" height="20"><input type="radio" name="METHOD" value="V14"></td>
	<td width="86%" height="20"><font face="Arial" size="2">CashApp</font></td>
  </tr>
</table>    
    </td>
  </tr>
</table>
  <br>
<table border="0" width="754" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td align="center" width="372"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(1)" value="Submit"></td>  
	<td align="center" width="378"><input type="button" CLASS="SUBOFF" name="B4" onclick="javascript:history.go(-1)" value="Exit"></td>    
 </tr>
</table>      
</form>    
    </td>
  </tr>
  <tr>
    <td bgcolor="#239243">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
  </table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->
   
</body>
</html>