<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Workers Payroll</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
 jQuery.noConflict();
      jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });

</script>

<!--DROPDOWN WORKER SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN WORKER SEARCH-->

<script type="text/javascript">

  $(document).ready(function() {
      $('.worker-select').select2({
          placeholder: 'Select Worker',
          allowClear: true
      });
  });
  
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
       document.theForm.action="/wc.dll?mprep~payrollret~<%=pcSCR%>~1";
    if (i==2) 
       document.theForm.action="/wc.dll?mprep~payrollret~<%=pcSCR%>~2";
    if (i==3) 
       document.theForm.action="/wc.dll?mprep~payrollret~<%=pcSCR%>~3";
    if (i==4) 
       document.theForm.action="/wc.dll?mprep~payrollret~<%=pcSCR%>~4";
    if (i==5) 
       document.theForm.action="/wc.dll?mprep~payrollret~<%=pcSCR%>~5";
       document.theForm.submit();       
	}
	
</SCRIPT>


<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					background-color: #F7F7F7;
					height:25;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;}
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 150px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #239243;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" width="40%">
  <tr>
    <td BGCOLOR="#239243" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Workers Payroll</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
    <form name="theForm" method="POST">
<table border="0" width="98%" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="13%" height="25"><b>Date Range:</b></td>
	<td width="12%" height="25"><b>From Date:</b></td>
	<td width="11%" height="25"><b>To Date:</b></td>
	<td width="30%" height="25"><b>Worker:</b></td>
	<% IF plDEPT %>
	<td width="10%" height="25"><b>Department:</b></td>
	<% ENDIF %>
 </tr>
  <tr>
	<td width="13%" height="3">
  <select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  </select>	
	</td>
	<td width="12%" height="3"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DTOC(pdDATE1)%>"></td>
	<td width="11%" height="3"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DTOC(pdDATE2)%>"></td>
	<td width="30%">
 <% IF plWORKERS=.T. %>
	<select size="1" name="ID" class="worker-select" style="width: 270px;">
        <option selected></option>
          <% SELECT _WORKERS
             SCAN %>
	    <option value="<%=_WORKERS.ID%>"><%=_WORKERS.ID%><%=IIF(EMPTY(_WORKERS.NAME),'',' - '+ALLT(PROPER(_WORKERS.NAME)))%></option>
          <% ENDSCAN%>
        </select>
 <%ENDIF%></td>
    <% IF plDEPT %>    				
	<td width="10%" height="3">
		<select size="1" name="DEPT">
		<option value="" selected></option>
		 <%	SELECT _DEPT
			SCAN %>
		<option><%=ALLT(DEPT)%></option>
		<% ENDSCAN %>
		</select></td>				
	<% ENDIF %>				
 </tr>
</table>
<br>    
<table border="0" width="90%" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1">
  <tr>
    <td width="45%" align="center" class="TD1">Report Name</td>
    <td width="23%" class="TD1" style="border-left: 1px solid #A9A9A9;">&nbsp;Date Range Reflects</td>
 </tr>
</table>
<table border="0" width="90%" align="center" style="border-collapse:collapse;line-height:28px;" cellspacing="0" cellpadding="0">
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">1.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(1)" STYLE="cursor:pointer;"><b><u>Jobs Assigned to Workers - Unpaid</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Operation Date</td>
 </tr>
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">2.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(2)" STYLE="cursor:pointer;"><b><u>Workers Paid Jobs</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Payment Date</td>
 </tr>
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">3.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(3)" STYLE="cursor:pointer;"><b><u>Workers Assigned to Jobs - All</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Operation Date</td>
 </tr>
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">4.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(4)" STYLE="cursor:pointer;"><b><u>Total Worked Hours - All Workers</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Operation Date</td>
 </tr>
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">5.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(5)" STYLE="cursor:pointer;"><b><u>Job Hours vs. Wages (Pick-Up)</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Operation Date</td>
 </tr>  
</table>
 <br>
<table border="0" width="90%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <TR>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="javascript:history.go(-1)" tabindex="6" value="Exit"></td>    
 </tr>
</table>    
</form>    
    </td>
  </tr>
  <tr>
    <td bgcolor="#239243">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
  </table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->
   
</body>
</html>