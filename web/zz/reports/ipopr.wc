<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>IP Activity</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
       document.theForm.action="/wc.dll?mprep~ipactivity~<%=pcSCR%>~1";
    if (i==2) 
       document.theForm.action="/wc.dll?mprep~ipactivity~<%=pcSCR%>~2";
       document.theForm.submit();
	}
	
</SCRIPT>


<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					background-color: #F7F7F7;
					height:25;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;}
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 150px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #239243;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="30%">
  <tr>
    <td BGCOLOR="#239243" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">IP Activity</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
    <form name="theForm" method="POST">
<table border="0" width="95%" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="12%" height="25"><b>Date Range:</b></td>
	<td width="9%" height="25"><b>From Date:</b></td>
	<td width="17%" height="25"><b>To Date:</b></td>
 </tr>
  <tr>
	<td width="12%" height="3">
  <select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  </select></td>			
	<td width="9%" height="3"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DTOC(pdDATE1)%>"></td>
	<td width="17%" height="3"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DTOC(pdDATE2)%>"></td>			
 </tr>
</table>
<br>    
<table border="0" width="95%" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111">
  <tr>
    <td width="45%" align="center" class="TD1">Report Name</td>
    <td width="23%" class="TD1" style="border-left: 1px solid #A9A9A9;">&nbsp;Date Range Reflects</td>
 </tr>
</table>
<table border="0" width="95%" align="center" style="border-collapse:collapse;line-height:28px;" cellspacing="0" cellpadding="0">
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">1.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(1)" STYLE="cursor:pointer;"><b><u>Who is working from this IP?</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Activity Date</td>
 </tr>
  <tr>
    <td width="6%" height="16"><b><font face="Verdana" size="2">2.</font></b></td>
    <td width="56%" height="16"><font color="#0000FF" size="2" face="Verdana" onClick="submitFunction(2)" STYLE="cursor:pointer;"><b><u>The IP Numbers Users work from</u></b></font></td>
    <td width="32%" class="TD2">&nbsp;Activity Date</td>
 </tr>
  </table>
  <br>
<table border="0" width="90%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <TR>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="javascript:history.go(-1)" tabindex="6" value="Exit"></td>    
 </tr>
</table>      
</form>    
    </td>
  </tr>
  <tr>
    <td bgcolor="#239243">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
  </table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->
   
</body>
</html>