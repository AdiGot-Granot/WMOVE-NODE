<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Booked Jobs - Booked By User</title>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;					
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
	.TD5		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: right;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
</style>

</head>

<body>
<br><center><b><font face="Arial"><a href="wc.dll?mprep~salesrepwc~<%=pcSCR%>">Exit</a><br><br>Book Date: <%=ldDATE1%> - <%=ldDATE2%><br><%=ALLT(STR(pnRECS))%> Booked Jobs - Booked By: <%=lcUSER%></font></b></center>

<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" width="90%">
  <tr>
    <td width="2%" class="TD1">Job No</td>
    <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Rep</td>
    <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Book Date</td>
    <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Book By</td>
    <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Move Date</td>
    <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Customer</td>
    <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Locations</td>
    <td width="8%" class="TD1" style="border-left: 1px solid #A9A9A9;">Qty, Vehicle, Price, Deposit</td>
    <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Estimate</td>
    <td width="1%" class="TD1" style="border-left: 1px solid #A9A9A9;">Payment</td>
 </tr>
  <% SELECT _EST 
     SCAN 
     lcORDNO=ALLT(ORDNO)%>
  <tr>
    <td width="2%" class="TD4" align="center"><a href="wc.dll?mprep~printselect~<%=pcSCR%>~<%=+ALLT(_EST.REFNO)%>" target="_blank"><%=ALLT(DEPT)+ALLT(ORDNO)%></a>&nbsp;</td>
    <td width="2%" class="TD2"><%=ALLT(REP)%></td>
    <td width="2%" class="TD2"><b><%=BOOKDTE%></b></td>
    <td width="2%" class="TD2"><%=ALLT(BOOKUSER)%></td>
    <td width="2%" class="TD2"><b><%=LBOOKDTE%></b></td>
    <td width="6%" class="TD2"><%=PROPER(SNAME)%></td>
    <td width="7%" class="TD2"><%=PROPER(ALLT(SCITY))+', '+SSTATE%>-<%=PROPER(ALLT(RCITY))+', '+RSTATE%></td>
    <td width="7%" class="TD2">
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="100%">
    <%  SELECT * FROM _INVAUTO WHERE ORDNO=lcORDNO INTO CURSOR __BB
        SCAN%>
    <tr>
	  <TD width="78%"><font face="Arial" style="font-size:9pt;"><%=VEHICLE%></font></TD>
	  <TD width="10%" ALIGN="RIGHT"><font face="Arial" style="font-size:9pt;COLOR:#008000"><%=TRANSFORM(PRICE,'$,$$9.99')%></font>&nbsp;</TD>
	  <TD width="10%" ALIGN="RIGHT"><font face="Arial" style="font-size:9pt;COLOR:#083484"><%=TRANSFORM(DEPOSIT,'$,$$9.99')%></font>&nbsp;</TD>
  </TR>
    <%ENDSCAN%>
</TABLE>	    	
      </td>
      <td width="2%" class="TD5"><b><%='$'+ALLT(STR(_EST.SUBTOTAL))%></b>&nbsp;</td>
      <td width="1%" class="TD5"><b><font COLOR="#008000"><%='$'+ALLT(STR(_EST.PAIDAMT))%></font></b>&nbsp;</td>
    </tr>
  <% ENDSCAN %>
      <tr style="font-family:Verdana;font-size:10pt;">
	  <td width="37%" align="right" colspan="8"><b>Total:</b>&nbsp;</td>      
      <td width="2%" align="right"><B><%=TRANSFORM(pnSUBTOTAL,'$$$,$$9.99')%></B>&nbsp;</td>
      <td width="1%" align="right"><font COLOR="#008000"><B><%=TRANSFORM(pnPAIDAMT,'$$$,$$9.99')%></B></font>&nbsp;</td>      
    </tr>        
</table>
</body>
</html>