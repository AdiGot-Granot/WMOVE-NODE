<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Reports Menu</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~1');
    if (i==2) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~2');
    if (i==3) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~3');
    if (i==5) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~5');    
    if (i==6) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~6');
    if (i==7) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~7');
    if (i==8) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~8');
    if (i==9) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~9');
    if (i==10) window.location.href=('/wc.dll?mprep~repmenuret~<%=pcSCR%>~10');    
 	if (i==16) window.location.href=('/wc.dll?mprep~sentemails~<%=pcSCR%>');

	}

</SCRIPT>

<STYLE TYPE="text/css">
	.txton		{	color: blue;
				  	font-size: 11pt;
  				  	font-family: Verdana;
					background-color: white;
					text-decoration: underline;
  				  	cursor: pointer;
				  	text-align: left;}
	.txtoffblue	{	color: #000000;
				  	font-size: 11pt;
  				  	font-family: Verdana;
  				  	cursor: pointer;
					background-color: white;
				  	text-align: left} 				  	
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="450">
  <tr>
    <td width="100%" BGCOLOR="#239243" align="center" height="20"><b><font face="Verdana" size="4" color="#FFFFFF">Reports Menu</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="7">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
   <tr>
     <td width="100%" align="center"><br>
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="95%" cellspacing="1" cellpadding="1">
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(1)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Salespersons</font></td>
  </tr>
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font  class="txtoffblue" onclick="submitFunction(2)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Estimators</font></td>
  </tr>
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(3)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Operation</font></td>
  </tr>
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(10)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Leads & Advertising</font></td>
  </tr>    
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(7)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Customer Payments</font></td>
  </tr>        
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(8)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Workers Payroll</font></td>
  </tr>
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(6)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Claims & Damages</font></td>
   </tr>
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(9)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Packing Materials</font></td>
  </tr>   
   <tr>
     <td width="13%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="87%" height="30"><font class="txtoffblue" onclick="submitFunction(5)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">IP Activity</font></td>
   </tr>
   <tr>
     <td width="11%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
     <td width="89%" height="30"><font class="txtoffblue" onclick="submitFunction(16)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoffblue'">Sent Emails - 7 Days Tally</font></td>
  </tr>        
</table>    
&nbsp;</td>
  </tr>
</table>
    </td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#239243" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>