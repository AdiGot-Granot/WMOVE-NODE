<html>
<head>
<title>Send Email</title>
</head>

<body>
<div align="center">
  <center>
  <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="72%">
    <tr>
      <td width="100%">
      <p align="center"><b><%=ALLT(pcSUBJECT)%> was sent successfully<br><br>Emailed to: <%=ALLT(pcEMAIL)%><BR>Sender: <%=ALLT(pcUSER)%></b></td>
    </tr>
  </table>
  </center>
</div>

<p align="center"><b><img border="0" src="/ZZ/images/MAILBOX.jpg"></b></p>

<p align="center"><b><a href="javascript:window.close()">Close Window</a></b></p>

</body>

</html>