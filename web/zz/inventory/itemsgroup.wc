<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Inventory Items Group</title>
</head>

<body bgcolor="#4E6699">
 <br>
<table border="1" cellpadding="2" cellspacing="1" style="border-collapse:collapse;font-family:Arial;font-size:10pt;line-height:22px;" bordercolor="#000000" width="160">
  <tr>
    <td width="100%" bgcolor="#FF9900" align="center"><b>Inventory Items Group</b></td>
 </tr>
<% SELECT _LIST
   SCAN%>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">&nbsp;<a target="MainWindow" href="/wc.dll?mpscripts~itemslistwc~<%=pcSCR%>~<%=ALLTRIM(ROOMCODE)%>"><%=ALLTRIM(CNAME)%></a></td>
 </tr>
<% ENDSCAN%>
<% IF plINVROOM %>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">&nbsp;<a target="MainWindow" href="/wc.dll?mpscripts~RoomsInvNameWc~<%=pcSCR%>">Room Name</a></td>
 </tr>
<%ENDIF%> 
</table>
 <br>
<table border="1" cellpadding="2" cellspacing="1" style="border-collapse:collapse;font-family:Arial;font-size:10pt;line-height:22px;" bordercolor="#000000" width="160">
  <tr>
    <td width="100%" bgcolor="#FFFFFF" align="center"><b>View/Print Inventory</b></td>
 </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">&nbsp;<a target="_blank" href="/wc.dll?mpmainten~tinvprint~<%=pcSCR%>~ABC">Inventory by A B C</a></td>
 </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">&nbsp;<a target="_blank" href="/wc.dll?mpmainten~tinvprint~<%=pcSCR%>">Inventory by Category</a></td>
 </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" align="center">&nbsp;<b><a target="_top" href="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>">Go Back</a></b></td>
 </tr> 
</table> 
</body>

</html>