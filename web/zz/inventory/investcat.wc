<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Inventory by Category</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

document.addEventListener('mouseup', (e) => {
  const container = document.getElementById('container');
  if (!container.contains(e.target)) {
    container.style.display = 'none';
  }
});

<% IF plNL=.F. %>
function Switch() {
       document.theForm.action="/wc.dll?mpinv~investret~<%=pcSCR%>~ABC~~1<%=SYS(3)%>";
       document.theForm.submit();
      }
<%ENDIF%>

function additem(elem) 
    {  
		document.theForm.elements[elem].value ++ ;
		theForm.elements[elem].className="QTYON";
    }

function clearall() {
	var Message = "Are you sure you want to clear all the items?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpinv~clearall~<%=pcSCR%>~~~2<%=SYS(3)%>";
       document.theForm.submit();
       }
	}   

function CheckOut() {
    document.theForm.CheckOut_1.style.visibility="hidden";
    document.theForm.CheckOut_2.style.visibility="hidden";
    document.theForm.Save_1.style.visibility="hidden";
    document.theForm.Save_2.style.visibility="hidden";
    document.theForm.action="/wc.dll?mpinv~investret~<%=pcSCR%>~~~4<%=SYS(3)%>~<%=pcNL%>";
    document.theForm.submit()  
  }

function save() {
    document.theForm.Save_1.style.visibility="hidden";
    document.theForm.Save_2.style.visibility="hidden";
    document.theForm.CheckOut_1.style.visibility="hidden";
    document.theForm.CheckOut_2.style.visibility="hidden";
    document.theForm.action="/wc.dll?mpinv~investret~<%=pcSCR%>~~Save~4<%=SYS(3)%>~<%=pcNL%>";
    document.theForm.submit()  
  }
	
</SCRIPT>


<STYLE TYPE="text/css">
	.ITEMOFF	{	color:#0000FF;
				  	font-size: 9pt;
					font-weight: bold;
				  	font-family: verdana;
				  	cursor: pointer;
				  	text-align: left;
				  	text-decoration: underline;}
	.ITEMON		{	color: red;
				  	font-size: 9pt;
 				  	font-weight: bold;
				  	font-family: verdana;
				  	cursor: pointer;
				  	text-align: left;
				  	text-decoration: underline;}
	.QTYOFF		{	text-align: Right;
					color: #0000FF; 
					font-size: 10pt;
					font-family: Arial;
					font-weight: none;
					width: 30;
					background-color: white}
	.QTYON		{	text-align: Right;
					color: #0000FF; 
					font-size: 10pt;
					font-family: Arial;
					font-weight:none;
					width: 30;
					background-color: #FFFF99}
    mark 		{   background: orange;
    				color: black;}	
				  	
</style>

</head>

<body BGCOLOR="#4E6699">
<BR>
  <table border="1" align="center" style="border-collapse: collapse" bGcolor="#FFFFFF" width="850">
   <tr>
     <td>
<a name="top"></a> 
    <FORM name="theForm" method="post">
<table border="0" cellpadding="0" cellspacing="0" width="100%" style="border-collapse:collapse;font-family:Verdana;font-size:11pt;">
<% IF pnLEVEL=0 %>
  <tr>
    <td width="100%" colspan="2">&nbsp;Hello <b><%=ALLT(PROPER(_EST.SNAME))%></b>. Click <b><i><font color="#008000">Save</font></i></b> to save your inventory or <b><i><font color="#395594">Check Out</font></i></b> once you finished.</td>
 </tr>    
<% ELSE %>
  <tr>
    <td width="50%">&nbsp;<b>Job #:&nbsp;<%=ALLT(_EST.DEPT)+ALLT(_EST.ORDNO)%></b></td>
    <td width="50%"><b>Customer:&nbsp;<%=ALLT(PROPER(_EST.SNAME))%></b></td>
 </tr>
<%ENDIF%>
</table>
 <br>
<table border="0" align="center" cellpadding="0" cellspacing="0" width="75%">
  <tr>
    <td width="17%" align="center"><input type="button" value="Save" name="Save_1" onclick="save()" style="width:100;background-color:#008000;font-family:Verdana;color:#F7F7DE;font-weight: bold;cursor:pointer;">
    &nbsp;<div id="container"><b><font face="Verdana" size="2"><%= IIF(plSAVED=.T.,'Saved','')%></font></b></div></td>
    <td width="28%" align="center"><% IF plNL=.T. %><b><font face="Verdana" size="5" color="#9400D3">Items not Moving</font></b><%ENDIF%></td>
    <td width="15%" align="center"><input type="button" value="Check Out" name="CheckOut_1" onclick="CheckOut()" style="width:100;background-color:#395594;font-family:Verdana;color:#F7F7DE;font-weight: bold;cursor:pointer;"></td>
 </tr>
</table>
    <BR>
<table border="0" cellpadding="1" cellspacing="1" align="center" style="border-radius:6px;border: 1px solid #083484;font-size:10pt;font-family:verdana;line-height:28px;" width="95%" bgcolor="#FFFFFF">   
  <tr>
    <td width="10%" align="center"><a href="#LR">Living Room</a></td>
    <td width="8%" align="center" colspan="2"><a href="#BR">Bedroom</a></td>
    <td width="9%" align="center"><a href="#DR">Dining Room</a></td>
    <td width="7%" align="center" colspan="2"><a href="#KI">Kitchen</a></td>
    <td width="8%" align="center"><a href="#AP">Appliance</a></td>
 </tr>
  <tr>
    <td width="10%" align="center"><a href="#OF">Office</a></td>
    <td width="8%" align="center" colspan="2"><a href="#PO">Patio</a></td>
    <td width="9%" align="center"><a href="#GA">Garage</a></td>
    <td width="7%" align="center" colspan="2"><a href="#MS">Misc.</a></td>
    <td width="8%" align="center"><a href="#BX">Boxes</a></td>
 </tr>
  <tr>
    <td width="9%" align="center"><a href="#NU">Nursery</a></td>
    <td width="9%" align="center" colspan="2"><a href="#ML">Military</a></td>
    <td width="9%" align="center"><a href="#PR">Play Room</a></td>
    <td width="7%" align="center" colspan="2"><a href="#BM">Basement</a></td>
    <td width="9%" align="center"><a href="#AT">Attic</a></td>
  </tr>
  <tr>
    <td width="15%" align="center" colspan="2"><%IF pcCUSTNO<>'MOVINGAPT'%>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<a href="#new">Additional Items</a><%ENDIF%></td>
    <% IF pnLEVEL > 0 %>
    <td width="14%" align="center" colspan="3"><% IF plNL=.F. %><font onclick="Switch()" style="cursor:pointer;font-family:Verdana;text-decoration:underline;font-size:10pt;color: #0000FF;">Go to list by A B C</font><%ENDIF%></td>
    <td width="14%" align="center" colspan="2"><font onclick="clearall()" style="text-decoration:underline;font-size:10pt;color:#0000FF;cursor:pointer;">Clear All</font></td>
    <%ENDIF%>
 </tr>
</table>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
