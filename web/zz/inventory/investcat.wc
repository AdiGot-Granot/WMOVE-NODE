<% IF pcCUSTNO<>'MOVINGAPT' %>			
<table border="0" align="center" cellspacing="1" style="border-collapse: collapse;font-family:verdana;font-size:11pt;" width="70%" bordercolor="083484">
  <tr>
    <td width="65%" bgcolor="#EBEBEC" align="center"><a name="new"></a><b>Add items not on the list - <a href="#top">Go Top</a>&nbsp;&nbsp;&nbsp;&nbsp;<a href="#top"><img border="0" src="zz/images/arrwtop.gif" width="11" height="15"></a></b></td>
    <td width="16%" bgcolor="#EBEBEC"><b>Qty</b></td>
    <td width="19%" bgcolor="#EBEBEC"><b>Volume</b></td>
 </tr>
   <%FOR I = 1 TO 20%>
  <tr style="line-height:28px;">
    <td width="65%" height="21"><input type="text" name="<%='I'+ALLT(STR(I))%>" size="40" maxlength="70"></td>
    <td width="16%" height="21"><input type="text" name="<%='Q'+ALLT(STR(I))%>" size="3" ></td>
    <td width="19%" height="21"><input type="text" name="<%='V'+ALLT(STR(I))%>" size="3" >&nbsp;<%=IIF(plCALCCF,'cf.','lbs.')%></td>
 </tr>
   <%ENDFOR%>
</table>
<%ENDIF%>
