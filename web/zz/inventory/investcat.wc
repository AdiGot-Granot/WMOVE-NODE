    &nbsp;<div id="container"><b><font face="Verdana" size="2"><%= IIF(plSAVED=.T.,'Saved','')%></font></b></div></td>
    <td width="24%" align="center"><input type="button" value="Check Out" name="CheckOut_2" onclick="CheckOut()" style="width:100;background-color:#395594;font-family:Verdana;color:#F7F7DE;font-weight: bold;cursor:pointer;"></td>        
 </tr>
</table>
