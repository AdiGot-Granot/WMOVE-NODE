<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Items List</title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 600,
		maxHeight	: 300,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});


function SubmitFunction(i) {
    if (i==1) window.location.href=('/wc.dll?mpmainten~itemsmenuwc~<%=pcSCR%>');
	}
    
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
					background-color: #F7F7F7;				  	
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;					
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#F7F7F7">
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="45%">
 <tr>
  <td width="46%"><a class="fancybox fancybox.iframe" href="/zz/help/invtable.htm"><img border="0" src="zz/util/manual.gif" title="Read about Inventory" width="32" height="32"></a></td>
</tr>
</table>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="45%"> 
  <tr>
    <td BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF"><%=pcCODENAME%></font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
<form method="POST" action="wc.dll?mpmainten~itemslistret~<%=pcSCR%>~<%=pcCODE%>">
<table width="98%" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111">
  <tr>
    <td width="2%" class="TD3" bgcolor="F7F7F7"><b>#</b></td>
    <td width="39%" class="TD2">Item Description</td>
    <td width="11%" class="TD2"><%=IIF(plCALCCF,"Cu.Ft.","Lbs")%></td>
    <td width="7%" class="TD2">Bulky</td>
    <td width="12%" class="TD2">Need Pack</td>
    <td width="17%" class="TD2">Category</td>    
    <td width="7%" class="TD2">Delete</td>
  </tr>
  <% SELECT _TINV 
  	 SCAN %>
  <tr style="line-height:25px;">
    <td width="2%" class="TD3"><%=ALLT(NO)%>.</td>
    <td width="39%" class="TD1">&nbsp;<input type="text" autocomplete="off" name="I-<%=ALLT(STR(TINVID))%>" size="35" value="<%=ALLT(ITEM)%>" maxlength="50"></td>
    <td width="11%" class="TD1" align="center">
    <input type="text" name="C-<%=ALLT(STR(TINVID))%>" size="3" value="<%IF plCALCCF=.T.%><%=ALLT(STR(CUFT,8,2))%><%ELSE%><%=ALLT(STR(LBS,8,2))%><% ENDIF%>" style="text-align: right;"></td>
    <td width="7%" class="TD1" align="center"><input type="checkbox" name="<%='B-'+ALLT(STR(TINVID))%>" value="ON" <%=IIF(BULKY,'checked','')%>></td>    
    <td width="12%" class="TD1" align="center"><input type="checkbox" name="<%='P-'+ALLT(STR(TINVID))%>" value="ON" <%=IIF(NEEDPACK,'checked','')%>></td>    
    <td width="17%" class="TD1" align="center">
		<select size="1" name="<%='M-'+ALLT(STR(TINVID))%>">
			<option value="<%=ALLT(_TINV.CODE)%>" selected><%=ALLT(_TINVCODE.NAME)%></option>
			<% SELECT _ALLCODES
				SCAN %>
					<option value="<%=ALLT(_ALLCODES.CODE)%>"><%=ALLT(_ALLCODES.NAME)%></option>
			<%ENDSCAN%>
		</select>&nbsp;</td>
   <% SELECT _TINV%>
   <td width="7%" class="TD1" align="center"><% IF !EMPTY(ITEM) %><input type="checkbox" name="<%='D-'+ALLT(STR(TINVID))%>" value="ON"><%ENDIF%></td>
  </tr>
  <% ENDSCAN%>
</table>
  <BR>
<table border="0" align="center" style="border-collapse: collapse" width="70%">
  <tr>
    <td align="center"><input type="submit" CLASS="SUBOFF" name="B5" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" STYLE="cursor:pointer;" value="Submit"></td>
    <td align="center"><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="SubmitFunction(1)" value="Exit"></td>
  </tr>
 </table>    
</form>    
    <br></td>
  </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
</table>

</body>

</html>