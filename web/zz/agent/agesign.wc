<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Esign Docs Sent to Agents</title>
</head>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #556677;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #0081D3;
  color: #FFF;
/*  border-color: #000; */
}
</style>

<body bgcolor="#FFFFFF">
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="50%">
  <tr>
    <td width="100%" align="center" colspan="3"><font face="Arial" size="4"><a href="/wc.dll?mpagent~agprocesswc~<%=pcSCR%>">Exit</a>
    <br><br><b>Esign Docs Sent to Agents for Future Moves (<%=ALLT(STR(RECCOUNT('_LIST')))%>)</b></font></td>
 </tr>
</table>
<form method="POST" action="/wc.dll?mpagent~agesignret~<%=pcSCR%>">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="2" bordercolor="#111111" width="95%">
  <tr>
   <td width="4%" class="TD1">Job No.</td>
   <td width="4%" class="TD1" style="border-left: 1px solid #A9A9A9;">Status</td>
   <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Customer</td>
   <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Move Date</td>
   <td width="8%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sent Date</td>
   <td width="4%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sent By</td>
   <td width="10%" class="TD1" style="border-left: 1px solid #A9A9A9;">Agent</td>
   <td width="12%" class="TD1" style="border-left: 1px solid #A9A9A9;">Emailed To</td>
   <td width="8%" class="TD1" style="border-left: 1px solid #A9A9A9;">Subject</td>
   <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Sign By</td>
   <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Signed Date</td>
   <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Remove</td>
 </tr>
<%SELECT _LIST
	SCAN %>
  <tr>
   <td width="4%" class="TD3"><a href="/wc.dll?mprep~printselect~<%=pcSCR+'~'+ALLT(_LIST.REFNO)%>" target="_blank"><%=ALLT(DEPT)+ALLT(ORDNO)%></a></td>
   <td width="4%" class="TD2"><font color="#<%=IIF(ST='Booked','008000','000000')%>"><%=ALLT(ST)%></font></td>
   <td width="7%" class="TD2"><%=ALLT(SNAME)%></td>
   <td width="9%" class="TD2"><%=LBOOKDTE%><%=IIF(EMPTY(LBOOKDTE1),'','-'+DTOC(LBOOKDTE1))%></td>
   <td width="8%" class="TD2"><%=SENTDTE%>&nbsp;<%=SENTTME%></td>
   <td width="4%" class="TD2"><%=ALLT(SENTBY)%></td>
   <td width="10%" class="TD2"><%=IIF(EMPTY(COMPANY),ALLT(AGENT),ALLT(COMPANY))%></td>
   <td width="12%" class="TD2"><%=ALLT(EMAILEDTO)%></td>
   <td width="8%" class="TD2"><a href="/wc.dll?mpest~emailslog~<%=pcSCR%>~<%=ALLT(ORDNO)%>~<%=ALLT(STR(LOGEMAILID))%>" target='_blank'><%=ALLT(SUBJECT)%></a></td>
   <td width="6%" class="TD2"><%=ALLT(ENAME)%></td>
   <td width="9%" class="TD2"><%=IIF(EMPTY(EDTE),'',EDTE)%></td>
   <td width="3%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;"><input type="checkbox" name="<%=ALLT(STR(LOGEMAILID))%>" value="ON"></td>
 </tr>
 <% ENDSCAN %>
 </table>
  <br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="30%">
  <tr>
    <td width="100%" align="center" colspan="3"><input id="btnSubmit" type="submit" CLASS="SUBOFF" name="B1" value="Submit"></td>
 </tr>
</table>
</form>
<br><center><font face="Arial" size="4"><a href="/wc.dll?mpagent~agprocesswc~<%=pcSCR%>">Exit</a></font></center>

</body>
</html>