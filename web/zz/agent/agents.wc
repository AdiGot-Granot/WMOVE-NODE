<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Agents Table</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function SubmitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpagent~agprocesswc~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpagent~agentswc~<%=pcSCR%>";
       document.theForm.submit();
      }            
	}

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD5		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}															
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #0081D3;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}

.DELETE {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #BB0000;
  color: #FFF;
  border: none;
/*  border: 3px solid #000; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.DELETE:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}

</style>

</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="90%">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" color="#FFFFFF">Agents Table</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
  <form name="theForm" method="POST">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="50%" cellspacing="0" cellpadding="0">
   <tr>
     <td width="36%">&nbsp;&nbsp;<b><font face="Verdana" size="2">Agents List Filter:</font></b>    
    <select size="1" name="AGFILTER">
        <option value="ALL">ALL</option>
      <% IF pnCOLEVEL<>3 %>         
   		<option value="INTL">International</option>
   		<option value="AUTO">Auto Transport</option>
   	  <%ENDIF%>	
   		<option value="STATE">State</option>
   		<option value="RATING">Rating</option>   		
	</select> 
     </td>  
     <td width="33%">&nbsp;&nbsp;<b><font face="Verdana" size="2">Filter by Active:</font></b>
     <select size="1" name="ACTIVE">
	    <option value="1" selected>Active</option>
	    <option value="2">Not Active</option>
	    <option value="3">Deleted</option>
	 </select>     
     </td>
    <td width="31%"><input type="button" CLASS="SUBOFF" name="B45" onclick="SubmitFunction(2)" value="Submit"></td>
  </tr>
</table>		
<table border="0" width="98%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td height="40">&nbsp;&nbsp;<a style="font-size: 10pt;font-weight: bold;font-family: Verdana;" href="/wc.dll?mpagent~AgentEditWc~<%=pcSCR%>~0">Add New Agent</a></td>    
</table>    
<table border="0" align="center" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="98%">
   <tr>
     <td class="TD1" width="5%">Action</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="6%">Agent</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="18%">Company</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="10%">City/State</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="7%">Contact</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="9%">Phone</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="8%">Docs Exp. Date</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="4%">Rating</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="10%">Pay Accept</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="3%">Active</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="3%">Del</td>
  </tr>
<% SELECT _AGENTS 
   SCAN%>  			
   <tr style="line-height:23px;">
     <td class="TD5" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="5%">
     <% IF DEL=.F. %>
        <b><a href="/wc.dll?mpagent~AgentEditWc~<%=pcSCR%>~<%=ALLT(STR(AGENTID))%>">Edit Agent</a></b>
     <%ELSE%>
        <b><a href="/wc.dll?mpagent~AgentsWc~<%=pcSCR%>~<%=ALLT(STR(AGENTID))%>~UNDEL">Undelete</a></b>        
     <%ENDIF%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="6%">&nbsp;<b><%=ALLT(AGENT)%></b></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="18%">&nbsp;<%=ALLT(PROPER(COMPANY))%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="10%">&nbsp;<% IF !EMPTY(CITY) %><%=ALLT(CITY)+', '+ALLT(STATE)%><%ELSE%><%=ALLT(STATE)%><%ENDIF%>&nbsp;<%=IIF(INTL=.T.,ALLT(COUNTRY),'')%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="7%">&nbsp;<%=ALLT(CONTACT)%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="9%"><%=IIF(EMPTY(PHONE1),'','P1: '+ALLT(PHONE1))%><%=IIF(EMPTY(PHONE2),'','<BR>P2: '+ALLT(PHONE2))%><%=IIF(EMPTY(CELL),'','<BR>M: '+ALLT(CELL))%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="8%"><font color="#<%=IIF(AGREXPDTE<DATE(),'FF0000','008000')%>"><%=IIF(EMPTY(AGREXPDTE),'','Agree: '+ALLT(DTOC(AGREXPDTE)))%></font>
     <font color="#<%=IIF(INSEXPDTE<DATE(),'FF0000','008000')%>"><%=IIF(EMPTY(INSEXPDTE),'','Insur: '+ALLT(DTOC(INSEXPDTE)))%></font></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="4%">&nbsp;<%=ALLT(RATETXT)%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="10%">&nbsp;<%=ALLT(PAYTYPE)%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="3%"><%=IIF(ACTIVE=.T.,'<b>Yes</b>','No')%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="3%"><%=IIF(ACTIVE=.F. AND DEL=.T.,'<b>Yes</b>','')%></td>
  </tr>
<% ENDSCAN %> 
</table>
 <br>
<table border="0" width="80%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="23%" align="center"><input type="button" CLASS="SUBOFF" name="B45" onclick="SubmitFunction(1)" value="Exit">
	</td>    
</table>
 </form>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>