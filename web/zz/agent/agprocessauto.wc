<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<TITLE>Carrier Jobs Process</TITLE>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->

<script type="text/javascript">
  jQuery.noConflict();
      jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });

</script>

<!--DROPDOWN AGENT/STATE SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN AGENT/STATE SEARCH-->

<script type="text/javascript">

      jQuery( document ).ready(function( $ ) {  
      $('.agent-select').select2({
          placeholder: 'Select Agent',
          allowClear: true
      });
  });
  

      jQuery( document ).ready(function( $ ) {  
      $('.state-select').select2({
          placeholder: 'Select State',
          allowClear: true
      });
  });

</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitProcess(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpagent~agprocessautoret~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       window.location.href=('/wc.dll?mpagent~agentswc~<%=pcSCR%>');
      }
    if (i==3) 
      { 
      document.theForm.action="/wc.dll?mpagent~tagentlist~<%=pcSCR%>";
       document.theForm.submit();
      }
	}

</SCRIPT>

<STYLE TYPE="text/css">
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #0081D3;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}

.AGUPDATE {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 150px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #0081D3;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.AGUPDATE:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}

</style>

</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="850">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center" height="19"><b><font size="4" color="#FFFFFF" face="Verdana">Carrier Jobs Process</font></b></td>
  </tr>
    <td width="100%" align="center" bgcolor="#FFFFFF"><br>
<form name="theForm" method="POST">    	
<table border="0" align="center" width="98%" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
	<td valign="top">	<!-- Dates-->
<table border="0" width="100%" cellspacing="1" cellpadding="1" style="border-radius:6px;border: 1px solid #A9A9A9;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="9%" height="30">&nbsp;<b>Date Factor:</b></td>	 
	<td width="9%" height="30"><b>Date Range:</b></td>
	<td width="7%" height="30"><b>From Date:</b></td>
	<td width="7%" height="30"><b>To Date:</b></td>  
	<td width="13%" height="30"><b>From State:</b></td>  
	<td width="8%" height="30"><b>To State:</b></td>  
  </tr>
  <tr>
	<td width="9%" height="30">
	   <select size="1" name="TYPEDTE">
		  <option value="MOVE" selected>Transport Date</option>	
		  <option value="OPEN">Open Date</option>
		</select>	
	</td>  	
	<td width="9%" height="30">
	<select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  	</select></td>
	<td width="7%" height="30"><input type="text" id="Date1" name="DATE1" size="8" value="<%=DATE()%>"></td>
	<td width="7%" height="30"><input type="text" id="Date2" name="DATE2" size="8" value="<%=DATE()+120%>"></td>  
	<td width="13%" height="30">
	<select size="1" name="STATE1" class="state-select" style="width: 170px;">
		<option></option>
		<% SELECT _STATE
		   SCAN %>
		<option value="<%=ALLT(STATECODE)%>"><%=ALLT(PROPER(STATE))%></option>
		<% ENDSCAN %>
		</select></td>  
	<td width="8%" height="30">
   		<select size="1" name="STATE2" class="state-select" style="width: 170px;">
			<option></option>
		    <% SELECT _STATE
		 	   SCAN %>
	   		<option value="<%=ALLT(STATECODE)%>"><%=ALLT(PROPER(STATE))%></option>
			 <% ENDSCAN %>
		</select></td>
  </tr>
  <tr>
    <td width="24%" height="30" colspan="6">&nbsp;<b>Carrier:</b></td>
 </tr>
  <tr>
    <td width="24%" height="30" colspan="6">
	<select size="1" name="AGENTID" class="agent-select" style="width: 500px;">
   		<option selected value="0">ALL</option>
		 <%	SELECT _TAGENT
		 	 SCAN %>
	   		<option value="<%=ALLT(STR(AGENTID))%>"><%=ALLT(AGENT)%>&nbsp;&nbsp;***&nbsp;&nbsp;<%=ALLT(COMPANY)%></option>
	    <% ENDSCAN %>
		</select></td>
 </tr>    
</table>
   </td>
 </tr>
</table>
 <br> 
<table border="0" align="center" width="90%" cellspacing="0" cellpadding="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;">
  <tr>
    <td valign="top" width="50%">
<table border="0" width="100%" cellspacing="1" cellpadding="1" style="border-collapse: collapse;font-family:Verdana;font-size:10pt;line-height:25px;" bordercolor="#111111">
  <tr>
	<td width="100%" bgcolor="#0081D3" colspan="2" align="center"><b><font face="Verdana" color="#FFFFFF" size="2">Status of Jobs</font></b></td>
 </tr>
  <tr>
	<td width="5%"><input class="chkon" type="radio" name="STATUS" value="V1" checked></td>
	<td width="95%"><font face="Verdana" size="2">Future Booked Jobs - No Carrier</font></td>
 </tr>
  <tr>
	<td width="5%"><input type="radio" name="STATUS" value="V2"></td>
	<td width="95%"><font face="Verdana" size="2">Jobs Assigned to Carrier</font></td>
 </tr>
</table>
   </td>
    <td valign="top" width="45%" style="border-left: 1px solid #A9A9A9;">
<table border="0" width="100%" cellspacing="1" cellpadding="1" style="border-collapse: collapse;font-family:Verdana;font-size:10pt;line-height:25px;" bordercolor="#111111">
  <tr>
	<td width="100%" bgcolor="#0081D3" colspan="2" align="center"><b><font face="Verdana" color="#FFFFFF" size="2">Sort By</font></b></td>
 </tr>
  <tr>
	<td width="5%"><input class="chkon" type="radio" name="SORT" value="V1" checked></td>
	<td width="95%"><font face="Verdana" size="2">Job No.</font></td>
 </tr>
  <tr>
	<td width="5%"><input type="radio" name="SORT" value="V2"></td>
	<td width="95%"><font face="Verdana" size="2">Transport Date</font></td>
 </tr>
  <tr>
	<td width="5%"><input type="radio" name="SORT" value="V3"></td>
	<td width="95%"><font face="Verdana" size="2">Carrier</font></td>
 </tr>
</table>
   </td>
 </tr>
</table>
  <br>
<table border="0" width="95%" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitProcess(1)" value="Submit"></td>    
	<td align="center"><input type="button" CLASS="AGUPDATE" name="B4" onclick="submitProcess(2)" value="Add/Update Agent"></td>    
	<td align="center"><input type="button" CLASS="SUBOFF" name="B5" onclick="submitProcess(3)" value="Agents List"></td>    
	<td align="center"><input type="button" CLASS="SUBOFF" name="B6" onclick="window.close()" value="Exit"></td>    
  </tr>
</table>
</form>
  </td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->

</body>
</html>