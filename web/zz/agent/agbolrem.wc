<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="ie=edge">
<link href="/zz/editor/lib/css/font-awesome.min.css" rel="stylesheet" type="text/css" />
<link href="/zz/editor/lib/css/froala_editor.pkgd.min.css" rel="stylesheet" type="text/css" />
<link href="/zz/editor/lib/css/froala_style.min.css" rel="stylesheet" type="text/css" />

<title><%=pcTITLE%></title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction() {
       document.theForm.action="/wc.dll?mpagent~agentbolremret~<%=pcSCR%>~<%=pcAGENTID%>~<%=lcBOLREM%>";
       document.theForm.submit();
	}

</SCRIPT>

<STYLE TYPE="text/css">
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #0081D3;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #556677;
  color: #FFF;
/*  border-color: #000; */
}
</style>

<script type="text/javascript" src="/zz/editor/lib/js/jquery.min.js"></script>
<script type="text/javascript" src="/zz/editor/lib/js/froala_editor.pkgd.min.js?v=2.1.6"></script>
<script>
        $(function () {
            $('textarea').froalaEditor()
        });
</script>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #A9A9A9;overflow:hidden;" bordercolor="#111111" width="95%">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF"><%=pcTITLE%></font></b></td>
  </tr>
  <tr>
    <td width="98%" bgcolor="#FFFFFF">
<table border="0" align="center" width="40%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="92%" height="30" align="center"><font face="Verdana"><b><%=pcAGCOMPANY%></font></b></td>
  </tr>
</table>
  <table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" cellspacing="1" cellpadding="1" width="98%">
    <tr>
      <td width="98%">
  <form name="theForm" method="post">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
   <tr>
     <td width="100%"><textarea rows="25" name="AGBOLREM" cols="70"><%=pcAGBOLREM%></textarea></td>
  </tr>
</table>
   <BR>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="50%">
 <tr>
   <td width="33%" align="center"><input id="btnSubmit3" type="button" CLASS="SUBOFF" onclick="submitFunction()" name="SUBMIT_1" value="Submit"></td>
   <td width="34%" align="center"><input id="btnSubmit5" type="button" CLASS="SUBOFF" onclick="javascript: window.close()" value="Exit"></td>
 </tr>
</table>
</form>      
     </td>
   </tr>
  </table>
<br>
  </td>
 </tr>
 <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>