	  <td width="100%" class="TD2" colspan="3" height="23">Distance:&nbsp;<%=ALLT(STR(_CRG.MILES))%>&nbsp;Miles</td>
	</tr>	  	 
	 <tr>
	  <td width="100%" class="TD2" colspan="3" height="23">Open Date:&nbsp;<%=TTOC(_EST.OPENDTE)%></td>
	</tr>  
  </table>
  </TD>
</TABLE>
    </TD>
  </tr>
</TABLE>
    <!--INSIDE TABLE-->    
    </TD>
 </TR>
</TABLE>
    <B class="rbottom"><B class="r4"></B><B class="r3"></B><B class="r2"></B><B class="r1 gr"></B></B></TD>
  </TR>
</TABLE>
  <%IF _EST.STATUS<>'D' AND _EST.STATUS<>'C' %> 
<table border="0" align="center" cellpadding="0" style="border-collapse: collapse" width="80%">
  <tr>
    <td width="37%" height="40" align="center"><input type="button" CLASS="SUBMIT" name="SUBMIT_3" onclick="SubmitData(1)" style="background-color: #7B96B5;" value="Submit Charges"></td>
 </tr>
</table> 
  <%ENDIF%>
    </td>
 </tr>
</table>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
   <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr>
  <tr>
    <td width="100%"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Representative's Remarks: 
    <a class="fancybox fancybox.iframe" href="/wc.dll?mpcharge~repnoteaddwc~<%=pcSCR%>">Quick Notes</a></font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #FF0000;margin-bottom:8px;width:90%;" rows="4" name="REPNOTESX" cols="100"></textarea>
    <% SELECT _REPNOTES
  	   IF RECCOUNT() > 0 %>
   <table border="0" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #000000;width:90%;"> 
       <% SCAN %>
   <tr>
      <td width="21%" style="border-bottom: 1px solid #808080;" valign="top" bgcolor="#F8F8FF"><font style="font-family:Arial;font-size:10pt;"><%=DATE%><br><%=USER%></font>
      <% IF STAR=.T. %><span style="font-size:24px;color:#FF8C00;">&#9733;</span><%ELSE%><span style="font-size:24px;color:#000000;">&#9734;</span><%ENDIF%></td>
      <td width="79%" style="border-left: 1px solid #C0C0C0;border-bottom: 1px solid #808080;"><font style="font-family:Arial;font-size:10pt;"><%=ALLT(NOTES)%></font>&nbsp;</td>
   </tr>
    <% ENDSCAN %>
  </table>
    <center><a href="wc.dll?mpcharge~ViewRepNotes~<%=pcSCR%>"><font face="verdana" size="2"><b>View Previous Remarks</b></font></a></center>
    <%ENDIF%>    
    </td>   
 </tr>
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr>
  <tr>
    <td width="100%" valign="top"><b><font style="font-family:Verdana;font-size:11pt;color:#000;"><%=IIF(_ESTMEMO.REMID=0,'Company Policy on Estimate','Add Notes to Company Policy')%></font></b></td>
  </tr>
  <tr>
    <td width="100%" valign="top">
    <textarea rows="4" name="REM" cols="100" style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #000000;width:90%;" <% IF pcCUSTNO='INTERSTA' AND pnLEVEL<5%>READONLY<%ENDIF%>><%=ALLT(_ESTMEMO.REM)%></textarea>
    <% IF _ESTMEMO.REMID>0 %><br><center><a href="wc.dll?mpcharge~crgremarkspreview~<%=pcSCR%>~<%=ALLT(STR( _ESTMEMO.REMID))%>"><font face="verdana" size="2"><b>Preview Company Policy on Estimate</b></font></a></center><%ENDIF%></td>
  </tr>
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr> 
  <tr>
    <td width="100%" valign="top"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Customer's Remarks</font></b></td>
 </tr>
  <tr>
    <td width="100%" valign="top"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #808080;margin-bottom:8px;width:90%;" rows="4" name="CUNOTESX" cols="100"></textarea>
    <% SELECT _CUNOTES
  	   IF RECCOUNT() > 0 %>
   <table border="0" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #808080;width:90%;">
     <% SCAN %>
   <tr>
      <td width="21%" style="border-bottom: 1px solid #808080;" valign="top" bgcolor="#F5F5F5"><font style="font-family:Arial;font-size:10pt;"><%=DATE%><br><%=USER%></font></td>
      <td width="79%" style="border-left: 1px solid #C0C0C0;border-bottom: 1px solid #808080;"><font style="font-family:Arial;font-size:10pt;"><%=ALLT(NOTES)%></font>&nbsp;</td>
   </tr>
    <% ENDSCAN %>
  </table>
   <center><a href="wc.dll?mpcharge~ViewRepNotes~<%=pcSCR%>~~5"><font face="verdana" size="2"><b>View Previous Remarks</b></font></a></center>
   <%ENDIF%></td>
 </tr>
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr> 
  <tr>
    <td width="100%"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Direction / Operation Details</font></b></td>
 </tr>
  <tr>
    <td width="100%" valign="top"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #000000;width:90%;" rows="4" name="DIR" cols="100"><%=ALLT(_ESTMEMO.DIR)%></textarea></td>
 </tr>   
</table>
   </td>
  </tr>
</table>
<!-- frame table -->
   <br></td>
  </tr>
  <tr>
    <td width="1000" bgcolor="#FFFFFF" colspan="3">
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="98%">
      <tr>
     <%IF CTOD(pcPUDTE) <= DATE() AND pnLEVEL=2 AND _EST.LBOOKC %>
	   <td width="15%" align="center"><input type="button" CLASS="SUBMIT" name="B36" onclick="closeda()" style="background-color: #7BB652;" value="<%=IIF(_EST.STATUS='D','Release Close','Close this Job')%>">
     <% ENDIF %>      
     <%IF (_EST.STATUS='F' OR _EST.STATUS='C') and ((!plBLKCANCEL and !plBLKCANCELU) or (plBLKCANCELU and ALLT(_EST.USER)==pcUSER))  %>
	   <td width="20%" align="center"><input type="button" CLASS="SUBMIT" name="B33" onclick="cancela()" style="background-color: #FFFF00; color:#0000FF" VALUE="<%=IIF(_est.status='C','Release Cancel','Cancel Estimate')%>"></td>
     <% ENDIF %>
     <%IF pnCOLEVEL > 3 AND (pnLEVEL=2 or pnLEVEL > 3) %>
	   <td width="16%" align="center">
	   <input type="button" CLASS="SUBMIT" name="B34" onclick="ViewLog()" style="background-color: #0075AD;font-family: Arial;" value="Activity Log"></td></td>
     <% ENDIF %>
     <%IF (_EST.STATUS='F' OR _EST.STATUS='C') AND (pnLEVEL=2 or pnLEVEL>3) %>
	   <td width="17%" align="center"><input type="button" CLASS="SUBMIT" name="B35" onclick='deletea()' style="background-color: #EF3821;" value="Delete Estimate"></td>
     <% ENDIF %>
      </tr>
    </table><br>
    </td>
  </tr>
  <tr>
    <td width="1000" bgcolor="#FFFFDF" colspan="3">
<table border="0" width="98%" align="center" cellspacing="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr STYLE="BACKGROUND-COLOR: #<%=pcBGSTYLE%>">
    <td width="100%" bgcolor="#008000" align="center"><font color="#FFFFFF" face="Verdana"><b>Items List: <FONT COLOR="#FFFFOO"><%=IIF(pnITEMS=0,'',ALLT(STR(pnITEMS))+' Items, '+ALLT(STR(pnPCS))+' Pieces')%></font></b></font></td>
 </tr>
</table>
<table border="1" width="99%" align="center" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
	<td width="33%" valign="top">
	<%  Dimension laHeader[4]
	   	laHeader[1]="Qty"
		laHeader[2]="Items"
		laHeader[3]=IIF(plCALCCF,"CuFt","Lbs")
		laHeader[4]="**"		
		SELECT _T1 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="33%" valign="top">
	<%SELECT _T2 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="34%" valign="top">
	<%SELECT _T3 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
 </tr>
  <tr>
	<td colspan="3"><font style="font-size:15pt;color:#008000;"><b>&#10003;</b></font> <font face="Arial" size="2"><b>= New item description added by User/Client (not from the inventory list).<br>
	<font style="font-size:15pt;color:#B22222;"><b>&#10003;</b></font> = Bulky item.<br>
	<font style="font-size:15pt;color:#000000;"><b>&#10003;</b></font> = Item needs packing<br>
	<font style="font-size:15pt;color:#B22222;"><b>&#10003;</b></font><font style="font-size:15pt;color:#000000;"><b>&#10003;</b></font> = Bulky item and needs packing</b></font></td>
 </tr>   
</table>
<% IF pnNOLOAD=.T. %>
<table border="0" width="99%" align="center" cellspacing="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="100%" align="center"><font face="Verdana"><b>Items Excluded from Move: <%=ALLT(STR(pnCFNOLOAD))+' cf'%> / <%=ALLT(STR(pnLBSNOLOAD))+' lbs'%><BR><%=IIF(pnITEMSNL=0,'',ALLT(STR(pnITEMSNL))+' Items, '+ALLT(STR(pnPCSNL))+' Pieces')%></b></font></td>
 </tr>
</table>
<table border="1" width="99%" align="center" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
	<td width="33%" valign="top">
	<%  Dimension laHeader[4]
	   	laHeader[1]="Qty"
		laHeader[2]="Items"
		laHeader[3]=IIF(plCALCCF,"CuFt","Lbs")
		laHeader[4]="**"		
		SELECT _N1 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="33%" valign="top">
	<%SELECT _N2 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="34%" valign="top">
	<%SELECT _N3 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
 </tr>  
</table>
<%ENDIF%> 
<!--bottom table-->
<table border="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
   <tr STYLE="BACKGROUND-COLOR: #<%=pcBGSTYLE%>">
     <td width="40%" height="25">&nbsp;<font face="Arial" style="font-size: 9pt" color="#FFFFFF"><%=pcUSER%>&nbsp;(<%=pcPARLEVEL%>)</font></td>
     <td width="20%" height="25" align="center"><font face="Arial" style="font-size: 9pt" color="#FFFFFF"><%=pcIP%></td>
     <td width="40%" height="25" align="right"><font face="Arial" style="font-size: 9pt" color="#FFFFFF"><%=DATE()%></font>&nbsp;&nbsp;</td>
  </tr>
</table>
<!--end bottom table-->
    </td>
  </tr>
</form>
  </table>
</table>
