	<input type="button" name="BOOK" onclick="SubmitData(2)" class="SUBMIT" style="background-color:<%=IIF(_EST.STATUS='F','#EF3821','#008000')%>" value="<%=IIF(plLBOOKC,'Release Booked','Book This Job')%>"><%ENDIF%>&nbsp;</td>
 </tr>
<%ENDIF %>
<%IF _EST.STATUS='F' OR _EST.STATUS='C' %>	
