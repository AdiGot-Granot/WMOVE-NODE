<!--DATE PICKER-->
  
<script type="text/javascript">
	jQuery.noConflict();
	
   jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
       $("#Date3").datepicker({ numberOfMonths:[1,2] });
       $("#Date4").datepicker({ numberOfMonths:[1,2] });
       $("#Date5").datepicker({ numberOfMonths:[1,2] });
       $("#Date6").datepicker({ numberOfMonths:[1,2] });
       $("#Date7").datepicker({ numberOfMonths:[1,2] });
       $("#Date8").datepicker({ numberOfMonths:[1,2] });
       $("#Date9").datepicker({ numberOfMonths:[1,2] });
       $("#Date10").datepicker({ numberOfMonths:[1,2] });       
   });
</script>


