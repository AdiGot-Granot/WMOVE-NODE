	<%ELSE%><a class="fancybox fancybox.iframe" href="wc.dll?mpcharge~badleadwc~<%=pcSCR%>"><img border="0" alt="Select Bad Lead Reason" src="zz/images/thumbsdown.gif" width="37" height="37"></a> <%=pcBADLEAD%>
	<%ENDIF%></td>
