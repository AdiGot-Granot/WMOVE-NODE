	  <td width="36%"><input type="text" name="PUTME" onFocus="showSubmit()" size="8" value="<%=pcPUTME%>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~PUTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" maxlength="20"></td>
