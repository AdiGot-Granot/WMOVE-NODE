  <%ENDIF%>
  <%IF pcCUSTNO='NATIONALMG' AND pcTYPE='D' %>
  	   <%='Max Binding Estimate Fee: $'+ALLT(STR(pnSUB1*0.40+_CRG.MATTOTAL*0.46,8,2))%>
  <%ENDIF%>
  <%IF pcCUSTNO='EAGLEMOG' AND pcTYPE='D' %>
  	   <%='Max Binding Estimate Fee: $'+ALLT(STR(pnSUB1*0.38,8,2))%>
  <%ENDIF%>  
  <%IF pcCUSTNO='EVERSAFE' AND pcTYPE='D' %>
  	   <%='Max Binding Estimate Fee: $'+ALLT(STR(pnSUB1*0.43,8,2))%>
  <%ENDIF%>  
  <%IF (pcCUSTNO='MANIA' OR pcCUSTNO='DEDICATED') AND pcTYPE='D' %>
  	   <%='Deposit: $'+ALLT(STR(_EST.SUBTOTAL*0.30,8,2))%>
  <%ENDIF%>
  <%IF pcCUSTNO='MARKETDG' AND pcTYPE='D' %>
  	   <%='Deposit: $'+ALLT(STR(_EST.SUBTOTAL*0.35,8,2))%>
  <%ENDIF%>  
  <%IF pcCUSTNO='MAYZLINREL' %>
  	   <%='Deposit: $'+ALLT(STR(_EST.SUBTOTAL*0.25,8,2))%>
  <%ENDIF%>
  <%IF pcCUSTNO='TRULLIARE' %>
  	   <%='Deposit: $'+ALLT(STR(_EST.SUBTOTAL*0.30,8,2))%>
  <%ENDIF%>  
  <%IF pcCUSTNO='COASTALVL' AND pcTYPE='D' %>
  	   <%='5% CC Processing Fee: $'+ALLT(STR(_EST.SUBTOTAL*0.05,8,2))%>
  <%ENDIF%>
  <%IF pcCUSTNO='ALLCOASTMO' AND pcTYPE='D' %>
  	   <%='Deposit Required: $'+ALLTRIM(STR(ROUND(_CRG.EXTRA1AMT+(pnSUB1*0.25),2)-_CRG.DISCOUNT,8,2))%>
  <%ENDIF%>
  <%IF pcCUSTNO='VALUEADD' AND pcTYPE='D' %>
  	   <%='Deposit Required: $'+ALLTRIM(STR(ROUND(_CRG.EXTRA1AMT+(pnSUB1*0.25),2)-_CRG.DISCOUNT,8,2))%>
  <%ENDIF%>  
  <%IF pcCUSTNO='UNITEDPRI' %>
  	   <%='Deposit: $'+ALLT(STR(_EST.SUBTOTAL*0.36,8,2))%><BR>
  	   <%='Pick-Up: $'+ALLTRIM(STR(ROUND(_EST.SUBTOTAL-(_EST.SUBTOTAL*0.36),2)*0.50,8,2))%><br>
  	   <%='Delivery: $'+ALLTRIM(STR(ROUND(_EST.SUBTOTAL-(_EST.SUBTOTAL*0.36),2)*0.50,8,2))%>
  <%ENDIF%>
  <%IF pcCUSTNO='PARAMOUNT' AND pcTYPE='D' %>
  	   <%='Max Binding Estimate Fee: $'+ALLT(STR(pnSUB2*0.70,8,2))%>
  <%ENDIF%>      
	   </font></b>&nbsp;</td>
  </tr>
<%ENDIF %>
