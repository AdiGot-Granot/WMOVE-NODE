<div class="tabbertab"><!--TAB 3-->
 <h2>Visual Restriction</h2>
<table border="0" align="center" BGCOLOR="#FFFFFF" style="border-collapse: collapse" bordercolor="#111111" width="1000" cellspacing="1" cellpadding="2">
  <tr>
    <td><br><center><b><font style="font-family:Verdana;font-size:11pt;">Visual Schedule Restriction</font></b></center>
<table border="1" align="center" BGCOLOR="#FFFFFF" style="border-collapse:collapse;" bordercolor="#CCCCCC" width="98%" cellspacing="1" cellpadding="2">
  <tr style="background-color:#0081D3;text-align:center;font-family:Verdana;font-size:9pt;color:#FFFFFF;">
    <td width="6%"><b>Day</b></td>
    <td width="5%"><b>Date</b></td>
    <td width="7%"><B>Estimator</B></td>
    <td width="5%"><b>All Day</b></td>
    <td width="4%"><B>Limit</B></td>
    <td width="15%"><B>Note</B></td>
    <td width="9%"><b>Added By</b></td>
    <td width="14%"><B>Last Update</B></td>
  </tr>
  <% SELECT _VISUAL
     SCAN %>
  <tr style="font-family:Verdana;font-size:9pt;">
    <td width="6%"><b><%=CDOW(_VISUAL.DTE)%></b>&nbsp;</td>
    <td width="5%"><b><%=DTOC(_VISUAL.DTE)%></b>&nbsp;</td>
    <td width="7%"><b><%=ALLT(ESTIMATOR)%></b>&nbsp;</td>
    <td width="5%" align="center"><b><%=IIF(BLKDAY=.T.,'Yes','')%></b>&nbsp;</td>
    <td width="4%" align="center"><b><%=IIF(LIMIT>0,ALLT(STR(LIMIT)),'')%></b>&nbsp;</td>
    <td width="15%">&nbsp;<%=ALLT(NOTE)%></td>
    <td width="9%">&nbsp;<%=IIF(EMPTY(UNAME),ALLT(USERNAME),ALLT(UNAME))%></td>
    <td width="14%">&nbsp;<%=ADDDTE%></td>
  </tr>
  <%ENDSCAN%>
</table>     
    </td>
  </tr>
</table> 
 </div>
<%ENDIF%>  
</div>
  </td>
 </tr>
</table>   
</body>
</html>