<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
 $(".fancybox").fancybox({
  openEffect : 'elastic',
  closeEffect : 'elastic',
  fitToView: false,
  autoSize: false,
  nextSpeed: 0, //important
  prevSpeed: 0, //important
  afterLoad: function(){
  // added 50px to avoid scrollbars inside fancybox
   this.width = ($('.fancybox-iframe').contents().find('html').width())+50;
   this.height = ($('.fancybox-iframe').contents().find('html').height())+50;
  }

 }); // fancybox
}); // ready

function DTariff(){
    window.location.href=('/wc.dll?mpcharge~DRecalculate~<%=pcSCR%>');
 }

function SubmitData(i) {
    if (i==1) { 
        document.theForm.SUBMIT_1.style.visibility="hidden";
          document.theForm.SUBMIT_2.style.visibility="hidden";
          document.theForm.SUBMIT_3.style.visibility="hidden";
          document.theForm.action="/wc.dll?mpcharge~chargesret~<%=pcSCR%>";
          document.theForm.submit();
     } ;

    if (i==2) 
      { 
       document.theForm.BOOK.style.visibility="hidden";
       document.theForm.action="/wc.dll?mpcharge~bookingcrg~<%=pcSCR%>";
       document.theForm.submit();
      } ;
    if (i==3) 
      { 
       document.theForm.HOLD.style.visibility="hidden";
       document.theForm.action="/wc.dll?mpcharge~jobonhold~<%=pcSCR%>~<%=IIF(plONHOLD,'ONHOLD','')%>";
       document.theForm.submit();
      } ;

}

function deletea() {
	var Message = "Are you sure you want to continue?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpest~deleteest~<%=pcSCR%>";
       document.theForm.submit();
       }
	}
	
function cancela() {
	var Message = "Are you sure you want to continue?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpest~cancelest~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function sendemail() {
    window.open('/wc.dll?mpest~emailcenterwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=yes,menubar=no,resizable=yes,copyhistory=no,scrollbars=yes,width=800,height=750');
self.name="main"}

function closeda() {
	var Message = "Are you sure you want to continue?" ;
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpopr~closedjobret~<%=pcSCR%>~INT";
       document.theForm.submit();
       }
	}

function remagent() {
    window.open('/wc.dll?mpest~remagentwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=450');
	}

function extstop() {
    window.open('/wc.dll?mpest~extstopwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=450');
	}
  
function updagent(){
	document.theForm.action="/wc.dll?mpcharge~updagentwc~<%=pcSCR%>";
    document.theForm.submit();
 }

function edittrip(){
 	window.open('/wc.dll?mpopr~tripaddwc~<%=pcSCR%>~theForm~TRIPID~pu','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=700,height=400')
 }

function switchcflbs() {
	var Message = "Are you sure you want to switch calculate type of weight cf/lbs?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpcharge~switchcflbs~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

 function switchtype() {
	var Message = "Are you sure you want to switch Local/Long Distance?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpcharge~switchtype~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function FutureOpr(D,O,T) {
    window.open('/wc.dll?mpopr~futureoprret~&SCR=<%=pcSCR%>&DEPT='+D+'&OPR='+O+'&TYPE='+T+'&CRG=CRG','','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=750,height=550');
    //window.open('/wc.dll?mpopr~futureoprret~<%=pcSCR%>~'+D+'~'+O,'','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=750,height=550');
    //window.location.href=('/wc.dll?mpopr~futureoprret~<%=pcSCR%>~'+D+'~'+O);
self.name="main"}


function Direction() {
		window.open("https://maps.google.com/maps?f=d&source=s_d&saddr=<%=pcSADDR%>&daddr=<%=pcRADDR%>");
	 }

function ViewLog() {
       window.open('/wc.dll?mpest~logfilewc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=850,height=600');
      }

function UpdValueB(A, B) {
  fetch('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~' + A + '~' + B)
    .then(() => alert("Selection saved."))
    .catch(() => alert("Failed to save selection"));
}

function UpdValueRefresh(A,B) {
   <%IF _EST.STATUS <> 'D' AND  _EST.STATUS <>'C' %>
     window.open('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~'+A+'~'+B,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=5,height=5');
     window.location.href=('/wc.dll?mpcharge~chargeswc~<%=pcSCR%>');
  <%ENDIF %>
//     history.go() ;
}

<%IF plDEPT AND _EST.STATUS<>'D' AND _EST.STATUS<>'C' %>
function alterDept(c){
	document.getElementById("dept").innerText=c;	
    window.open('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~DEPT~'+c,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=5,height=5');
}
<%ENDIF %>

function QASave(par) {
	var Message = "Confirm Your Action! No Need to Submit!";
	if(par=='1'){
		document.theForm.qastart.style.visibility="hidden";
	}
	if(par=='2'){
		document.theForm.qadone.style.visibility="hidden";
	}	
	if (confirm (Message)){
		window.open('/wc.dll?mpcharge~QA_Save~<%=pcSCR%>~'+par,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=5,height=5');
	}
}


 function PostUmis() {
	window.open('/wc.dll?mpcharge~postumis~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=500,height=350');
 self.name="main"}
 
 
function showHide(shID) {
   if (document.getElementById(shID)) {
      if (document.getElementById(shID+'-show').style.display != 'none') {
          document.getElementById(shID+'-show').style.display = 'none';
          document.getElementById(shID).style.display = 'block';
      }
      else {
         document.getElementById(shID+'-show').style.display = 'inline';
         document.getElementById(shID).style.display = 'none';
      }
   }
}


</SCRIPT>

<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.4.2/jquery.min.js"></script><!--DATE PICKER-->
