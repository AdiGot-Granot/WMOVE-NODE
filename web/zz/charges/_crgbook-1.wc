<body BGCOLOR="#4E6699">
<br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="1000" align="center">
  <tr>
    <td width="1000">
<div class="tabber"><!--TAB 1-->
 <div class="tabbertab">
 <h2><%=pcTITLE%></h2> 
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="1000" align="center">
  <tr>
    <td width="1000" height="23">
<table border="0" <% IF _EST.RC='M' %> background="zz/images/Military.jpg" <%ELSE%> <% IF _EST.RC='O' %> BGCOLOR="#FF0000" <%ELSE%> BGCOLOR="#008000" <%ENDIF%><%ENDIF%> height="23" style="border-collapse: collapse" bordercolor="#111111" width="1000">
  <tr>
    <td width="180"><font face="Verdana" color="#FFFF00"><b><%=pcBALANCEX%><%=pcBALSTGX%></b></font></td>
    <td width="378" ALIGN="CENTER" height="20"><font size="4" color="#FFFFFF" face="Verdana"><b><%=pcTITLE%></font></b></td>
    <td width="186" ALIGN="right"><font face="Verdana" color="#FFFF00"><b><%=pcCLAIMSX%><%=IIF(pcCLAIMID='0','','-'+pcCLAIMID)%></b></font>&nbsp;</td>
  </tr>
</table>
    </td>
  </tr>
  <tr>
    <td width="1000" valign="top" bgcolor="#FFFFFF">	
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
	  <tr>
	    <td width="100%" valign="top" 
	    <%IF _EST.STATUS='C'%> background="zz/images/cancel.jpg" <%ENDIF%>
	    <%IF _EST.STATUS='D'%> background="zz/images/closed.jpg" <%ENDIF%>>
	<form name="theForm" method="post">
	<br>
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
      <tr>
        <td width="68%" valign="top" align="center">
<table border="1" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0" width="98%">
  <tr>
    <td width="50%"><b><FONT face="Verdana" size="2">View Map:</FONT> <a href="http://www.google.com/maps?q=<%=ALLT(_EST.SZIP)%>,+USA&sa=X&oi=map&ct=title" TARGET="_BLANK"><FONT face="Verdana" size="2">Google</font></a></td>
    <td width="50%"><b><FONT face="Verdana" size="2">View Map:</FONT> <a href="http://www.google.com/maps?q=<%=ALLT(_EST.RZIP)%>,+USA&sa=X&oi=map&ct=title" TARGET="_BLANK"><FONT face="Verdana" size="2">Google</font></a></td>
 </tr>
  <tr>
    <td width="50%" align="center" bgcolor="#008000"><b><FONT face="Verdana" COLOR="FFFFFF">Moving From</font></b></td>
    <td width="50%" align="center" bgcolor="#008000"><b><FONT face="Verdana" COLOR="FFFFFF">Moving To</FONT></b></td>
 </tr>
  <tr>
    <td width="50%" BGCOLOR="#EFEFDF" valign="top">
<!--Moving from -->         
 <%SELECT _EST%>
<table border="0" cellpadding="0" cellspacing="1" style="border-collapse: collapse;line-height:20px;" bordercolor="#111111" width="100%" bgcolor="#EFEFDF">
  <tr>
    <td width="100%" colspan="3"><font FACE="Verdana" color="#31557B" size="4"><b><%=ALLT(_EST.SNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(SPROXY)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><font color="#C71585"><%='Proxy: '+ALLT(SPROXY)%></font></td>
 </tr>
 <%ENDIF%> 
 <%IF !EMPTY(SADD1)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><%=ALLT(SADD1)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(SADD2)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><%=ALLT(SADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(SLEVEL) OR !EMPTY(SSUBLEVEL) OR !EMPTY(SFLOOR) OR !EMPTY(SAPT)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><%=ALLT(PROPER(SLEVEL))%><%=IIF(EMPTY(SSUBLEVEL),'','/'+ALLT(SSUBLEVEL))%><%=IIF(EMPTY(SFLOOR),'',' Floor: '+ALLT(STR(SFLOOR)))%>
    <%IF !EMPTY(SAPT) AND _EST.RC='C'%>
	<%=' Unit: '+ALLT(SAPT)%>
    <%ELSE%>
	<%=IIF(EMPTY(SAPT),'',' Apt: '+ALLT(SAPT))%>
	<%ENDIF%></td>
 </tr>
 <%ENDIF%>
  <tr> 
    <td width="63%" class="FROMTO"><font style="font-size:11pt;" color="#31557B"><%=ALLT(SCITY)%></font>&nbsp;</td>
    <td width="16%" class="FROMTO"><font size="4" color="#31557B"><%=ALLT(SSTATE)%></font>&nbsp;</td>
    <td width="21%" class="FROMTO"><font style="font-size:11pt;" color="#31557B"><%=ALLT(SZIP)%></font></td>
 </tr>
 <%IF !EMPTY(STELH) OR !EMPTY(STELO)%>
  <tr>
 	<td width="100%" class="FROMTO" colspan="3">
    <% IF pcCUSTNO<>'MOVINGAPT' AND pcCUSTNO<>'MARKETSL' AND pcCUSTNO<>'MARKETSS' AND pcCUSTNO<>'MISSIONMOV' AND pcCUSTNO<>'ALLCOASTMO' AND pcCUSTNO<>'NORTHAME' AND pcCUSTNO<>'USMOVE' AND pcCUSTNO<>'SHIPSLINE' AND pcCUSTNO<>'VALUEADD' %>
 	      <%=ALLT(STELH)%>&nbsp;&nbsp;&nbsp;<%=ALLT(STELO)%>
 	<%ELSE%>
     	<%IF pcCUSTNO='MOVINGAPT' OR pcCUSTNO='MARKETSS' %>
    	     <%IF !EMPTY(STELH)%><a href="rcmobile://call?number=1<%=pcSTELH%>"><%=STELH%></a>&nbsp;&nbsp;&nbsp;<%ENDIF%>
     	     <%IF !EMPTY(STELO)%><a href="rcmobile://call?number=1<%=pcSTELO%>"><%=STELO%></a><%ENDIF%>
  	    <%ENDIF%>
     	<%IF pcCUSTNO='NORTHAME' OR pcCUSTNO='MISSIONMOV' OR pcCUSTNO='ALLCOASTMO' OR pcCUSTNO='MARKETSL' OR pcCUSTNO='USMOVE' OR pcCUSTNO='SHIPSLINE' OR pcCUSTNO='VALUEADD' %>
    	     <%IF !EMPTY(STELH)%><a href="tel:<%=STELH%>"><%=STELH%></a>&nbsp;&nbsp;<%ENDIF%>
     	     <%IF !EMPTY(STELO)%><a href="tel:<%=STELO%>"><%=STELO%></a><%ENDIF%>
  	    <%ENDIF%>                      	      	      	    
  	<%ENDIF%>    
	</td>
  </tr>
 <%ENDIF%>
 <%IF !EMPTY(SFAX)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3">Fax:&nbsp;<%=ALLT(SFAX)%></td>
 </tr>
<%ENDIF%>
</table>
  <!--end Moving from -->    
    </td>
   <td width="50%" BGCOLOR="#EFEFDF" valign="top">
<!--Moving To -->         
 <%SELECT _EST%>
<table border="0" cellpadding="0" cellspacing="1" style="border-collapse: collapse;line-height:20px;" bordercolor="#111111" width="100%" bgcolor="#EFEFDF">
  <tr>
    <td width="100%" colspan="3"><font FACE="Verdana" color="#31557B" size="4"><b><%=ALLT(_EST.RNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(RPROXY)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><font color="#C71585"><%='Proxy: '+ALLT(RPROXY)%></font></td>
 </tr>
 <%ENDIF%> 
 <%IF !EMPTY(RADD1)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><%=ALLT(RADD1)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(RADD2)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><%=ALLT(RADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(RLEVEL) OR !EMPTY(RSUBLEVEL) OR !EMPTY(RFLOOR) OR !EMPTY(RAPT)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><%=ALLT(PROPER(RLEVEL))%><%=IIF(EMPTY(RSUBLEVEL),'','/'+ALLT(RSUBLEVEL))%><%=IIF(EMPTY(RFLOOR),'',' Floor: '+ALLT(STR(RFLOOR)))%>
    <%IF !EMPTY(RAPT) AND _EST.RC='C'%>
	<%=' Unit: '+ALLT(RAPT)%>
    <%ELSE%>
	<%=IIF(EMPTY(RAPT),'',' Apt: '+ALLT(RAPT))%>
	<%ENDIF%></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="60%" class="FROMTO"><font style="font-size:11pt;" color="#31557B"><%=ALLT(RCITY)%></font>&nbsp;</td>
    <td width="15%" class="FROMTO"><font SIZE="4" color="#31557B"><%=ALLT(RSTATE)%></font>&nbsp;</td>
    <td width="25%" class="FROMTO"><font style="font-size:11pt;" color="#31557B"><%=ALLT(RZIP)%></font></td>
 </tr>
 <%IF !EMPTY(RTELH) OR !EMPTY(RTELO)%>
  <tr>
    <td width="100%" colspan="3" class="FROMTO"><%=ALLT(RTELH)%>&nbsp;&nbsp;&nbsp;<%=ALLT(RTELO)%></td>
 </tr>
 <%ENDIF%>
</table>
  <!--end Moving To -->      
   </td>
 </tr>
  <tr>
   <td width="100%" BGCOLOR="#EFEFDF" colspan="2">
 <%IF plEMAIL %>
   &nbsp;<a href="javascript: sendemail()"><font face="Verdana" size="2"><B><%=ALLT(_EST.EMAIL)%>&nbsp;<img border="0" src="zz/images/email1.gif" ALT="Email Center" width="18" height="11"></b></font></a>
   &nbsp;&nbsp;<FONT face="Arial" size="2"><b><%=pcSENT%></b>&nbsp;<%=IIF(VAL(pcSENT)<2,'email sent','emails sent')%></font>
 <%ELSE%>
   &nbsp;<font color="#999999"><%=ALLT(_EST.EMAIL)%></font><%IF !EMPTY(pcEMAILTITLE)%><font size="2" color="#C90000"><%='<br>'+ALLT(pcEMAILTITLE)%></font>&nbsp;<a class="fancybox fancybox.iframe" href="wc.dll?mputil~cancelremoval~&REMOVEID=<%=lnREMOVEID%>&JOBID=<%=ALLT(STR(pnJOBID))%>&USERID=<%=ALLT(STR(pnUSERID))%>"><%=lnREMOVEID%></a><%ENDIF%>
 <%ENDIF%>
 	</td>
  </tr>
  <%IF plEMAIL%>
  <tr>
   <td width="100%" colspan="2">
   <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" BGCOLOR="#FFFFFF" bordercolor="#111111" width="100%">
  	 <tr style="font-family:Arial;font-size:10pt;">
       <td width="7%"><%IF plESIGN %><img border="0" src="zz/images/esign.png" ALT="This job was Esigned" width="25" height="18"><%ENDIF%></td>
       <td width="19%" valign="top"><%IF plESIGNNO %><font color="#8C1021"><%=pnESIGNNO%> Esign Pending</font><%ENDIF%><%IF plESIGN %><br><font color="navy"><%=pnESIGNYES%> Esign Received</font><%ENDIF%></td>
       <td width="21%" valign="top"><%IF plBOLESIGN %><font color="navy"><%=pnBOLESIGN%> BOL Received</font><%ENDIF%></td>
       <td width="26%" valign="top"><%IF plAGESIGNNO %><font color="#8C1021"><%=pnAGESIGNNO%> Agent Esign Pending</font><%ENDIF%><%IF plAGESIGNPRN %><br><font color="navy"><%=pnAGESIGNPRN%> Agent Esign Received</font><%ENDIF%></td>
       <td width="23%" valign="top"><%IF plAGESIGNJAFNO %><font color="#8C1021"><%=pnAGESIGNJAFNO%> JAF Esign Pending</font><%ENDIF%><%IF plAGESIGNJAF %><br><font color="navy"><%=pnAGESIGNJAF%> JAF Esign Received</font><%ENDIF%></td>
    </tr>
  </table>
   </td>
  </tr>
  <%ENDIF%>
