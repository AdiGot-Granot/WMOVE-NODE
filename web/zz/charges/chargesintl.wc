  	 <tr style="font-family:Arial;font-size:10pt;">
       <td width="7%" BGCOLOR="#FFFFFF"><%IF plESIGN %><img border="0" src="zz/images/esign.png" ALT="This job was Esigned" width="25" height="18"><%ENDIF%></td>
       <td width="25%" valign="top" BGCOLOR="#FFFFFF"><%IF plESIGNNO %><font color="#8C1021"><%=pnESIGNNO%> Esign Pending</font><%ENDIF%><%IF plESIGN %><br><font color="navy"><%=pnESIGNYES%> Esign Received</font><%ENDIF%></td>
       <td width="33%" valign="top" BGCOLOR="#FFFFFF"><%IF plAGESIGNNO %><font color="#8C1021"><%=pnAGESIGNNO%> Agent Esign Pending</font><%ENDIF%><%IF plAGESIGNPRN %><br><font color="navy"><%=pnAGESIGNPRN%> Agent Esign Received</font><%ENDIF%></td>
       <td width="31%" valign="top" BGCOLOR="#FFFFFF"><%IF plAGESIGNJAFNO %><font color="#8C1021"><%=pnAGESIGNJAFNO%> JAF Esign Pending</font><%ENDIF%><%IF plAGESIGNJAF %><br><font color="navy"><%=pnAGESIGNJAF%> JAF Esign Received</font><%ENDIF%></td>
    </tr>
  </table>
   </td>
  </tr>
  <%ENDIF%>  
</table>
<table border="0" align="center" width="98%" style="border-collapse: collapse" bordercolor="#111111" height="40">
  <tr>
	<td width="11%" align="center"><img border="0" src="zz/images/google-map.gif" style="cursor:pointer;" onclick="Direction()" alt="Google Direction" width="78" height="26"></td>
    <td width="18%" align="center"><%=IIF(!EMPTY(_ESTMEMO.EXTSTOP),'<font size="4" color="#008000">&#10003;</font>','')%>        
    <input type="button" CLASS="NOTES" name="btnDir" onclick="extstop()"  style="background-color: #A54939;" value="Extra Stop/Notes"></td>
  <% IF pnLEVEL>=2 AND _EST.STATUS='O' AND _EST.LBOOKDTE>= DATE() %>  
    <td width="21%" align="center"><input type="button" name="HOLD" onclick="SubmitData(3)" class="ONHOLD" style="background-color:<%=IIF(plONHOLD=.F.,'#FF0000','#008000')%>" value="<%=IIF(plONHOLD=.F.,'Move On Hold','Release Hold')%>"></td>
  <%ENDIF%>
  <%IF _EST.STATUS<>'D' AND _EST.STATUS<>'C' %>
    <td width="18%" align="center"><input type="button" CLASS="SUBMIT" name="SUBMIT_1" onclick="SubmitData(1)" style="background-color: #7B96B5;" value="Submit Charges"></td>
  <%ENDIF%>  
 </tr>
</table>
<table border="1" width="98%" cellspacing="0" align="center" bordercolor="#CCCCCC">
  <tr>
    <td bgcolor="#008000" align="center"><font color="#FFFFFF" face="Verdana"><b>Pricing</b></font></td>
 </tr>
  <tr>
	<td><!--- Pricing -->
<table border="1" width="100%" cellspacing="1" cellpadding="2" bordercolor="#CCCCCC" style="border-collapse: collapse">
 <tr>
	<td width="79%" height="16" CLASS="TD4"><%IF pnCOLEVEL >3 %><a href="wc.dll?mpinv~matwc~<%=pcSCR%>">Packing Services:</a><%ELSE%>Packing Services:<%ENDIF%></td>
	<td width="20%" height="16" align="right"><input name="MATTOTAL" size="7" value="<%=ALLT(STR(_CRG.MATTOTAL,8,2))%>" style="text-align: Right; color:#008000"></td>
 </tr>
 <tr>
	<td width="99%" height="30" CLASS="TD4" colspan="2"><a href="wc.dll?mpcharge~serviceswc~<%=pcSCR%>">Add Service:</a></td>
 </tr>
 <% SELECT _SERV 
    SCAN %> 
  <tr>
	<td width="79%" height="19" CLASS="TD4"><%=ALLT(_SERV.SERVICE)%></td>
	<td width="20%" height="19" CLASS="TD3" align="right"><font color="#008000"><%='$'+ALLT(STR(_SERV.SERVAMT,8,2))%></font></td>
 </tr>
 <%ENDSCAN%>
  <tr>
	<td width="79%" height="16" align="right"><b><font face="Verdana" size="2">Total Services:</font></b></td>
	<td width="20%" height="16" align="right"><font face="Verdana" color="#008000"><b><%='$'+ALLT(STR(pnSERV,10,2))%></b></font></td>
 </tr>   
  <tr>
	<td width="99%" height="30" CLASS="TD4" colspan="2"><a href="wc.dll?mpcharge~serviceswc~<%=pcSCR%>~DISCOUNT">Add Discount:</a></td>
 </tr>
 <% SELECT _DISC 
    SCAN %> 
  <tr>
	<td width="79%" height="19" CLASS="TD4"><%=ALLT(_DISC.SERVICE)%></td>
	<td width="20%" height="19" CLASS="TD3" align="right"><font color="#FF0000"><%='$'+ALLT(STR(_DISC.SERVAMT,8,2))%></font></td>
 </tr>
