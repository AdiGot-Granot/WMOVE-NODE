    <td width="1000" bgcolor="#993366" height="8">&nbsp;</td>
  </tr>
</form>
  <tr>
    <td width="1000" bgcolor="#EFEFDF">
<table border="0" width="98%" align="center" cellspacing="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="100%" bgcolor="#008000" align="center"><font color="#FFFFFF" face="Verdana"><b>Items List: <FONT COLOR="#FFFFOO"><%=IIF(pnITEMS=0,'',ALLT(STR(pnITEMS))+' Items, '+ALLT(STR(pnPCS))+' Pieces')%></font></b></font></td>
 </tr>
</table>
<table border="1" width="99%" align="center" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
	<td width="33%" valign="top">
	<%  Dimension laHeader[4]
	   	laHeader[1]="Qty"
		laHeader[2]="Items"
		laHeader[3]=IIF(plCALCCF,"CuFt","Lbs")
		laHeader[4]="**"		
		SELECT _T1 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="33%" valign="top">
	<%SELECT _T2 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="34%" valign="top">
	<%SELECT _T3 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
 </tr>
  <tr>
	<td colspan="3"><font style="font-size:15pt;color:#008000;"><b>&#10003;</b></font> <font face="Arial" size="2"><b>= New item description added by User/Client (not from the inventory list).<br>
	<font style="font-size:15pt;color:#B22222;"><b>&#10003;</b></font> = Bulky item.<br>
	<font style="font-size:15pt;color:#000000;"><b>&#10003;</b></font> = Item needs packing<br>
	<font style="font-size:15pt;color:#B22222;"><b>&#10003;</b></font><font style="font-size:15pt;color:#000000;"><b>&#10003;</b></font> = Bulky item and needs packing</b></font></td>
 </tr>   
</table>
<% IF pnNOLOAD=.T. %>
<table border="0" width="99%" align="center" cellspacing="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="100%" align="center"><font face="Verdana"><b>Items Excluded from Move: <%=ALLT(STR(pnCFNOLOAD))+' cf'%> / <%=ALLT(STR(pnLBSNOLOAD))+' lbs'%><BR><%=IIF(pnITEMSNL=0,'',ALLT(STR(pnITEMSNL))+' Items, '+ALLT(STR(pnPCSNL))+' Pieces')%></b></font></td>
 </tr>
</table>
<table border="1" width="99%" align="center" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
	<td width="33%" valign="top">
	<%  Dimension laHeader[4]
	   	laHeader[1]="Qty"
		laHeader[2]="Items"
		laHeader[3]=IIF(plCALCCF,"CuFt","Lbs")
		laHeader[4]="**"		
		SELECT _N1 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="33%" valign="top">
	<%SELECT _N2 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
	<td width="34%" valign="top">
	<%SELECT _N3 
		Response.ShowCursor(@laHeader,,,,"style='font-family:Arial;font-size:8pt;border-color:#C0C0C0'")%>&nbsp;</td>
 </tr>  
</table>
<%ENDIF%> 
	</td>
  </tr>
  <tr>
    <td width="1000" bgcolor="#EFEFDF">&nbsp;<font face="Arial" style="font-size: 9pt"><%=pcUser%>&nbsp;(<%=pcPARLEVEL%>)&nbsp;<%=pcIP%></font></td>
  </tr>
  </table>
</div>
<% IF plBLKDAY=.T. %>   
<div class="tabbertab"><!--TAB 3-->
 <h2>Booking Restriction</h2>
<table border="0" align="center" BGCOLOR="#FFFFFF" style="border-collapse: collapse" bordercolor="#111111" width="1000" cellspacing="1" cellpadding="2">
  <tr>
    <td><center><b><font style="font-family:Verdana;font-size:11pt;">Booking Restriction</b></font></center>
<table border="1" align="center" BGCOLOR="#FFFFFF" style="border-collapse:collapse;" bordercolor="#CCCCCC" width="99%" cellspacing="1" cellpadding="2">
  <tr style="background-color:#0081D3;text-align:center;font-family:Verdana;font-size:9pt;color:#FFFFFF;">
    <td width="6%" colspan="2"><b>Date</b></td>
    <td width="7%"><B>Move Type</B></td>
    <td width="5%"><b>All Day</b></td>
    <td width="7%"><B>Book Limit</B></td>
    <td width="18%"><B>Note</B></td>
    <td width="6%"><b>Added By</b></td>
    <td width="16%"><B>Last Update</B></td>
  </tr>
  <% SELECT _BLOCK
     SCAN %>
  <tr style="font-family:Verdana;font-size:9pt;line-height:20px;">
    <td width="3%">&nbsp;<b><%=LEFT(CDOW(_BLOCK.DTE),3)%></b></td>
    <td width="3%">&nbsp;<b><%=DTOC(_BLOCK.DTE)%></B></td>
    <td width="7%">&nbsp;<%=IIF(EMPTY(TYPE),'ALL',ALLT(TYPE))%></td>
    <td width="5%" align="center"><b><%=IIF(BLKDAY=.T.,'Yes','')%></b>&nbsp;</td>
    <td width="7%" align="center"><b><%=IIF(LIMIT>0,ALLT(STR(LIMIT)),'')%></b>&nbsp;</td>
    <td width="18%">&nbsp;<%=ALLT(NOTE)%></td>
    <td width="6%">&nbsp;<%=IIF(EMPTY(UNAME),ALLT(USERNAME),ALLT(UNAME))%></td>
    <td width="16%">&nbsp;<%=ADDDTE%></td>
  </tr>
  <%ENDSCAN%>
</table>     
    </td>
  </tr>
</table> 
 </div>
<%ENDIF%>
<% IF plBLKVISUAL=.T. %>   
<div class="tabbertab"><!--TAB 3-->
 <h2>Visual Restriction</h2>
<table border="0" align="center" BGCOLOR="#FFFFFF" style="border-collapse: collapse" bordercolor="#111111" width="1000" cellspacing="1" cellpadding="2">
  <tr>
    <td><br><center><b><font style="font-family:Verdana;font-size:11pt;">Visual Schedule Restriction</font></b></center>
<table border="1" align="center" BGCOLOR="#FFFFFF" style="border-collapse:collapse;" bordercolor="#CCCCCC" width="98%" cellspacing="1" cellpadding="2">
  <tr style="background-color:#0081D3;text-align:center;font-family:Verdana;font-size:9pt;color:#FFFFFF;">
    <td width="6%"><b>Day</b></td>
    <td width="5%"><b>Date</b></td>
    <td width="7%"><B>Estimator</B></td>
    <td width="5%"><b>All Day</b></td>
    <td width="4%"><B>Limit</B></td>
    <td width="15%"><B>Note</B></td>
    <td width="9%"><b>Added By</b></td>
    <td width="14%"><B>Last Update</B></td>
  </tr>
  <% SELECT _VISUAL
     SCAN %>
  <tr style="font-family:Verdana;font-size:9pt;">
    <td width="6%"><b><%=CDOW(_VISUAL.DTE)%></b>&nbsp;</td>
    <td width="5%"><b><%=DTOC(_VISUAL.DTE)%></b>&nbsp;</td>
    <td width="7%"><b><%=ALLT(ESTIMATOR)%></b>&nbsp;</td>
    <td width="5%" align="center"><b><%=IIF(BLKDAY=.T.,'Yes','')%></b>&nbsp;</td>
    <td width="4%" align="center"><b><%=IIF(LIMIT>0,ALLT(STR(LIMIT)),'')%></b>&nbsp;</td>
    <td width="15%">&nbsp;<%=ALLT(NOTE)%></td>
    <td width="9%">&nbsp;<%=IIF(EMPTY(UNAME),ALLT(USERNAME),ALLT(UNAME))%></td>
    <td width="14%">&nbsp;<%=ADDDTE%></td>
  </tr>
  <%ENDSCAN%>
</table>     
    </td>
  </tr>
</table> 
 </div>
<%ENDIF%>
</div>
  </td>
 </tr>
</table>  
</body>
