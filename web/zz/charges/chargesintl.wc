    <td width="100%" class="TD2" colspan="2" height="23">Reference:&nbsp;<%=_EST.REF%></td>
 </tr>
  <tr>
    <td width="100%" class="TD2" colspan="2" height="23">Type:&nbsp;<%=pcRC%></td>
 </tr>
  <tr>
    <td width="100%" class="TD2" colspan="2" height="23">Open Date:&nbsp;<%=TTOC(_EST.OPENDTE)%></td>
 </tr>
  <%IF _EST.STATUS<>'D' AND _EST.STATUS<>'C' %>	 
	 <tr>
	  <td width="100%" BGCOLOR="#FFFFFF" ALIGN="CENTER" colspan="2" height="40"><input type="button" CLASS="SUBMIT" name="SUBMIT_3" onclick="SubmitData(1)" style="background-color: #7B96B5;" value="Submit Charges"></td>
	</tr>    
  <%ENDIF%>           
</table>
   </td>
 </tr>
</table>
   <!-- Body & Column -->
    </td>
  </tr>
  <tr>
    <td width="100%" align="center" height="17">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="100%"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Representative's Remarks: 
    <a class="fancybox fancybox.iframe" href="/wc.dll?mpcharge~repnoteaddwc~<%=pcSCR%>">Quick Notes</a></font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #FF0000;margin-bottom:8px;width:90%;" rows="4" name="REPNOTESX" cols="100"></textarea>
    <% SELECT _REPNOTES
  	   IF RECCOUNT() > 0 %>
   <table border="0" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #000000;width:90%;"> 
       <% SCAN %>
   <tr>
      <td width="21%" style="border-bottom: 1px solid #808080;" valign="top" bgcolor="#F8F8FF"><font style="font-family:Arial;font-size:10pt;"><%=DATE%><br><%=USER%></font>
      <% IF STAR=.T. %><span style="font-size:24px;color:#FF8C00;">&#9733;</span><%ELSE%><span style="font-size:24px;color:#000000;">&#9734;</span><%ENDIF%></td>
      <td width="79%" style="border-left: 1px solid #C0C0C0;border-bottom: 1px solid #808080;"><font style="font-family:Arial;font-size:10pt;"><%=ALLT(NOTES)%></font>&nbsp;</td>
   </tr>
    <% ENDSCAN %>
  </table>
    <center><a href="wc.dll?mpcharge~ViewRepNotes~<%=pcSCR%>"><font face="verdana" size="2"><b>View Previous Remarks</b></font></a></center>
    <%ENDIF%>    
    </td>   
 </tr>
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr>
  <tr>
    <td width="100%" valign="top"><b><font style="font-family:Verdana;font-size:11pt;color:#000;"><%=IIF(_ESTMEMO.REMID=0,'Company Policy on Estimate','Add Notes to Company Policy')%></font></b></td>
  </tr>
  <tr>
    <td width="100%" valign="top">
    <textarea rows="4" name="REM" cols="100" style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #000000;width:90%;" <% IF pcCUSTNO='INTERSTA' AND pnLEVEL<5%>READONLY<%ENDIF%>><%=ALLT(_ESTMEMO.REM)%></textarea>
    <% IF _ESTMEMO.REMID>0 %><br><center><a href="wc.dll?mpcharge~crgremarkspreview~<%=pcSCR%>~<%=ALLT(STR( _ESTMEMO.REMID))%>"><font face="verdana" size="2"><b>Preview Company Policy on Estimate</b></font></a></center><%ENDIF%></td>
  </tr>
<%IF pnCOLEVEL > 3 %> 
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr> 
  <tr>
    <td width="100%" valign="top"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Customer's Remarks</font></b></td>
 </tr>
  <tr>
    <td width="100%" valign="top"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #808080;margin-bottom:8px;width:90%;" rows="4" name="CUNOTESX" cols="100"></textarea>
    <% SELECT _CUNOTES
  	   IF RECCOUNT() > 0 %>
   <table border="0" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #808080;width:90%;">
     <% SCAN %>
   <tr>
      <td width="21%" style="border-bottom: 1px solid #808080;" valign="top" bgcolor="#F5F5F5"><font style="font-family:Arial;font-size:10pt;"><%=DATE%><br><%=USER%></font></td>
      <td width="79%" style="border-left: 1px solid #C0C0C0;border-bottom: 1px solid #808080;"><font style="font-family:Arial;font-size:10pt;"><%=ALLT(NOTES)%></font>&nbsp;</td>
   </tr>
    <% ENDSCAN %>
  </table>
   <center><a href="wc.dll?mpcharge~ViewRepNotes~<%=pcSCR%>~~5"><font face="verdana" size="2"><b>View Previous Remarks</b></font></a></center>
   <%ENDIF%></td>
 </tr>
  <tr>
    <td width="100%" align="center"><font size="1">&nbsp;</font></td>
 </tr> 
  <tr>
    <td width="100%"><b><font style="font-family:Verdana;font-size:11pt;color:#000;">Direction / Operation Details</font></b></td>
 </tr>
  <tr>
    <td width="100%" valign="top"><textarea style="border-radius:6px;border-style: solid;border-width: 1px;border-color: #000000;width:90%;" rows="4" name="DIR" cols="100"><%=ALLT(_ESTMEMO.DIR)%></textarea></td>
 </tr>
<%ENDIF%>     
</table>
  <br>
  <table border="0" width="90%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
    <tr>
 <%IF CTOD(pcPUDTE) <= DATE() AND pnLEVEL=2 AND _EST.LBOOKC %>
	 <td width="14%" align="center"><input type="button" CLASS="SUBMIT" name="B36" onclick="closeda()" style="background-color: #7BB652;" value="<%=IIF(_EST.STATUS='D','Release Close','Close this Job')%>"></td>
 <% ENDIF %>    
     <%IF (_EST.STATUS='F' OR _EST.STATUS='C') and ((!plBLKCANCEL and !plBLKCANCELU) or (plBLKCANCELU and ALLT(_EST.USER)==pcUSER))  %>
	 <td width="19%" align="center"><input type="button" CLASS="SUBMIT" name="B33" onclick="cancela()" style="background-color: #FFFF00; color:#0000FF" VALUE="<%=IIF(_est.status='C','Release Cancel','Cancel Estimate')%>"></td>
   <% ENDIF %>
 <%IF pnLEVEL=2  or pnLEVEL > 3 %>
     <td width="17%" align="center"><input type="button" class="ACTLOG" name="B34" onclick="ViewLog()" value="Activity Log"></td>
 <% ENDIF %>
 <%IF (_EST.STATUS='F' OR _EST.STATUS='C') AND (pnLEVEL=2 OR pnLEVEL > 3) %>
	 <td width="17%" align="center"><input type="button" CLASS="SUBMIT" name="B35" onclick='deletea()' style="background-color: #EF3821;" value="Delete Estimate"></td>
 <% ENDIF %>
  </tr>
  </table>  
   </td>
 </tr>
</table>
<!-- frame table -->
    </td>
  </tr>
