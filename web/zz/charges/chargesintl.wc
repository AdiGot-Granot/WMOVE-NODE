<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title><%=pcORDNO%></title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.7" media="screen" />
<!---lightbox--->
<script type="text/javascript" src="/zz/util/tabber.js"></script><!---TAB--->
<link rel="stylesheet" href="/zz/util/tabcrg.css?v=1.2.6" TYPE="text/css" MEDIA="screen"><!---TAB--->


<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
 $(".fancybox").fancybox({
  openEffect : 'elastic',
  closeEffect : 'elastic',
  fitToView: false,
  autoSize: false,
  nextSpeed: 0, //important
  prevSpeed: 0, //important
  afterLoad: function(){
  // added 50px to avoid scrollbars inside fancybox
   this.width = ($('.fancybox-iframe').contents().find('html').width())+50;
   this.height = ($('.fancybox-iframe').contents().find('html').height())+50;
  }
 }); // fancybox
}); // ready


function SubmitData(i) {
	<%IF _EST.STATUS<>'D' AND _EST.STATUS<>'C' %>
    if (i==1) {
       document.theForm.SUBMIT_1.style.visibility="hidden";
       document.theForm.SUBMIT_2.style.visibility="hidden";
       document.theForm.SUBMIT_3.style.visibility="hidden";    
	   document.theForm.action="/wc.dll?mpcharge~chargesret~<%=pcSCR%>";
       document.theForm.submit();
      };
    <%ENDIF%>  
    <%IF _EST.STATUS='F' OR _EST.STATUS='O' %>  
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpcharge~bookingcrg~<%=pcSCR%>";
       document.theForm.submit();
      } ;
    <%ENDIF%>  
    if (i==3) 
      { 
       document.theForm.HOLD.style.visibility="hidden";
       document.theForm.action="/wc.dll?mpcharge~jobonhold~<%=pcSCR%>~<%=IIF(plONHOLD,'ONHOLD','')%>";
       document.theForm.submit();
      } ;

}

function deletea() {
	var Message = "Are you sure you want to continue?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpest~deleteest~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function cancela() {
	var Message = "Are you sure you want to continue?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpest~cancelest~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function remagent() {
    window.open('/wc.dll?mpest~remagentwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=450');
	}

function extstop() {
    window.open('/wc.dll?mpest~extstopwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=450');
	}

function updagent(){
	document.theForm.action="/wc.dll?mpcharge~updagentwc~<%=pcSCR%>";
    document.theForm.submit();
 }

function sendemail() {
    window.open('/wc.dll?mpest~emailcenterwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=yes,resizable=no,copyhistory=no,scrollbars=yes,width=800,height=750');
self.name="main"}

<%IF CTOD(pcPUDTE) <= DATE() AND pnLEVEL=2 AND _EST.LBOOKC %>
function closeda() {
	var Message = "Are you sure you want to continue?" ;
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpopr~closedjobret~<%=pcSCR%>~CRG";
       document.theForm.submit();
       }
	}
<%ENDIF%>

function ViewLog() {
       window.open('/wc.dll?mpest~logfilewc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=850,height=600');
      }
      
function Direction() {
		window.open("https://maps.google.com/maps?f=d&source=s_d&saddr=<%=pcSADDR%>&daddr=<%=pcRADDR%>");
	 }

<% IF pnCOLEVEL=7 AND !plBLKFUOPR %>
function FutureOpr(D,O,T) {
    window.open('/wc.dll?mpopr~futureoprret~&SCR=<%=pcSCR%>&DEPT='+D+'&OPR='+O+'&TYPE='+T+'&CRG=CRG','','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=750,height=550');
    //window.open('/wc.dll?mpopr~futureoprret~<%=pcSCR%>~'+D+'~'+O,'','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=750,height=550');
    //window.location.href=('/wc.dll?mpopr~futureoprret~<%=pcSCR%>~'+D+'~'+O);
self.name="main"}
<%ENDIF%>

function UpdValueB(A, B) {
  fetch('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~' + A + '~' + B)
    .then(() => alert("Selection saved."))
    .catch(() => alert("Failed to save selection"));
}
	
<%IF plDEPT AND _EST.STATUS<>'D' AND _EST.STATUS<>'C' %>
function alterDept(c){
	document.getElementById("dept").innerText=c;	
    window.open('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~DEPT~'+c,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=5,height=5');
}
<%ENDIF %>

 function switchtype() {
	var Message = "Are you sure you want to switch from Intl/Long Distance?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpcharge~switchtype~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function showHide(shID) {
   if (document.getElementById(shID)) {
      if (document.getElementById(shID+'-show').style.display != 'none') {
          document.getElementById(shID+'-show').style.display = 'none';
          document.getElementById(shID).style.display = 'block';
      }
      else {
         document.getElementById(shID+'-show').style.display = 'inline';
         document.getElementById(shID).style.display = 'none';
      }
   }
}

</SCRIPT>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
	jQuery.noConflict();
	
   jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
       $("#Date3").datepicker({ numberOfMonths:[1,2] });
       $("#Date4").datepicker({ numberOfMonths:[1,2] });
       $("#Date5").datepicker({ numberOfMonths:[1,2] });
       $("#Date6").datepicker({ numberOfMonths:[1,2] });
       $("#Date7").datepicker({ numberOfMonths:[1,2] });
       $("#Date8").datepicker({ numberOfMonths:[1,2] });
       $("#Date9").datepicker({ numberOfMonths:[1,2] });       
   });
</script>


<style type="text/css">
  .more {display: none;}
   a.showLink, a.hideLink {text-decoration: none;color: #0000FF;padding-left: 8px;}
</style>

<STYLE TYPE="text/css">
     .TD2 	    {	text-align: left;
				    color: black; 
				    font-size: 9pt;
				    font-family: Verdana;
				    font-weight: bold;}
	.TD3		{	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;}				    	
	.TD4		{	color: #000000;
				  	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
					background-color: white;
				  	text-align: left}
     .FROMTO 	{	text-align: left;
				    color: black; 
				    font-size: 10pt;
				    font-family: Arial;
				    font-weight: bold;}
	.SUBMIT	 	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 130; 
                    height: 25; 
                    cursor: pointer;}			  	
	.NOTES		{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    cursor: pointer;
                    width: 145; 
                    height: 25;}			  	
 	.SUBOFF	 	{	color: white; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 65;
                    height: 22;			  	
					background-color: #FF0000;
					font-size: 10pt;
  				  	cursor: pointer;}
  	.ACTLOG	 	{	color: white; 
					font-weight: bold;
					font-family: Verdana;
					font-size: 10pt;					
				  	text-align: center;
					width: 100;
                    height: 25;			  	
					background-color: #0075AD;
  				  	cursor: pointer;}
	.ONHOLD	   {	font-family: Verdana;
				  	font-size: 10pt;
					font-weight: bold;
  				  	color:#FFFFFF;
                    width: 120; 
                    height: 30;
                    border-color:#000000;
          	 	 	cursor: pointer;}  				  	  				  	
</style>

</head>

<body BGCOLOR="#4E6699">
<br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="1000" align="center">
  <tr>
    <td width="1000">
<div class="tabber"><!--TAB 1-->
 <div class="tabbertab">
 <h2>International Charges</h2>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="1000">
  <tr>
    <td width="1000">
<table border="0" <% IF _EST.RC='M' %> background="zz/images/Military.jpg" <%ELSE%> <% IF _EST.RC='O' %> BGCOLOR="#FF0000" <%ELSE%> BGCOLOR="#008000" <%ENDIF%><%ENDIF%> height="23" style="border-collapse: collapse" bordercolor="#111111" width="1000">
  <tr>
    <td width="259">&nbsp;<font face="Verdana" color="#FFFF00"><b><%=pcBALANCEX%><%=pcBALSTGX%></b></font></td>
    <td width="296" ALIGN="CENTER" height="20"><font size="4" color="#FFFFFF" face="Verdana"><b>International Charges</font></b></td>
    <td width="287" ALIGN="right"><font face="Verdana" color="#FFFF00"><b><%=IIF(plCLAIMSX=.T.,'CLAIM','')%></b></font>&nbsp;</td>
  </tr>
</table>    
    </td>
  </tr>
  <tr>
    <td width="1000" bgcolor="#FFFFFF">
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
	  <tr>
	    <td width="100%" valign="top"
	    <%IF _EST.STATUS='C'%> background="zz/images/cancel.jpg" <%ENDIF%>
	    <%IF _EST.STATUS='D'%> background="zz/images/closed.jpg" <%ENDIF%>>
    <!-- Body & Column -->
	<form name="theForm" method="post">
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
      <tr>
        <td width="68%" valign="top" align="center"><BR>        
<table border="1" align="center" style="border-collapse: collapse" bordercolor="#C0C0C0" width="98%">
  <tr>
    <td width="50%"><%IF !EMPTY(_EST.SZIP)%>
    <b><FONT face="Verdana" size="2">View Map:</FONT> <a target="_blank" href="http://www.google.com/maps?q=<%=ALLT(_EST.SZIP)%>,+USA&sa=X&oi=map&ct=title" TARGET="_BLANK"><FONT face="Verdana" size="2">Google</font></a>
    <%ENDIF%></td>
    <td width="50%"><%IF !EMPTY(_EST.RZIP)%>
    <b><FONT face="Verdana" size="2">View Map:</FONT> <a target="_blank" href="http://www.google.com/maps?q=<%=ALLT(_EST.RZIP)%>,+USA&sa=X&oi=map&ct=title" TARGET="_BLANK"><FONT face="Verdana" size="2">Google</font></a>
    <%ENDIF%></td>
 </tr>  
  <tr>
    <td width="50%" align="center" bgcolor="#008000"><b><FONT face="verdana" COLOR="FFFFFF">Moving From</FONT></b></td>
    <td width="50%" align="center" bgcolor="#008000"><b><FONT face="verdana" COLOR="FFFFFF">Moving To</FONT></b></td>
 </tr>
  <tr>
    <td width="50%" valign="top">
<!--Moving from -->         
 <%SELECT _EST%>
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse: collapse;line-height:22px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%"><font FACE="Verdana" color="#00008B" size="4"><b><%=ALLT(_EST.SNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(SPROXY)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><font color="#C71585"><%='Proxy: '+ALLT(SPROXY)%></font></td>
 </tr>
 <%ENDIF%>  
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(SADD1)%>&nbsp;</td>
 </tr>
 <%IF !EMPTY(SADD2)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(SADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(SLEVEL) OR !EMPTY(SSUBLEVEL) OR !EMPTY(SFLOOR) OR !EMPTY(SAPT)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(PROPER(SLEVEL))%><%=IIF(EMPTY(SSUBLEVEL),'','/'+ALLT(SSUBLEVEL))%><%=IIF(EMPTY(SFLOOR),'',' Floor: '+ALLT(STR(SFLOOR)))%>
    <%IF !EMPTY(SAPT) AND _EST.RC='C'%>
	<%=' Unit: '+ALLT(SAPT)%>
    <%ELSE%>
	<%=IIF(EMPTY(SAPT),'','Apt: '+ALLT(SAPT))%>
	<%ENDIF%>
     </td>
 </tr>
 <%ENDIF%>
  <tr> 
    <td width="100%" class="FROMTO"><font style="font-size:11pt;" color="#00008B"><%=ALLT(SCITY)+', '+ALLT(SSTATE)+' '+ALLT(SZIP)%>&nbsp;<%=IIF(EMPTY(SCOUNTRY),'',ALLT(SCOUNTRY))%></font></td>
 </tr>
 <%IF !EMPTY(STELH) %>
  <tr>
 	<td width="100%" class="FROMTO">
    <% IF pcCUSTNO<>'SHIPSLINE' %>
       <%=ALLT(STELH)%>
 	<%ELSE%>
 	   <a href="tel:<%=STELH%>"><%=STELH%></a>
    <%ENDIF%>
 	</td>
  </tr>
 <%ENDIF%>
 <%IF !EMPTY(STELO)%>
  <tr>
 	<td width="100%" class="FROMTO">
    <% IF pcCUSTNO<>'SHIPSLINE' %>
       <%=ALLT(STELO)%>
 	<%ELSE%>
 	   <a href="tel:<%=STELO%>"><%=STELO%></a>
    <%ENDIF%>
 	</td>
  </tr>
 <%ENDIF%> 
 <%IF !EMPTY(SFAX)%>
  <tr>
    <td width="100%" class="FROMTO">Fax:&nbsp;<%=ALLT(SFAX)%></td>
 </tr>
<%ENDIF%>
</table>
  <!--end Moving from -->    
    </td>
    <td width="50%" valign="top">
<!--Moving To -->         
 <%SELECT _EST%>
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse: collapse;line-height:22px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%"><font FACE="Verdana" color="#00008B" size="4"><b><%=ALLT(_EST.RNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(RPROXY)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><font color="#C71585"><%='Proxy: '+ALLT(RPROXY)%></font></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RADD1)%>&nbsp;</td>
 </tr>
 <%IF !EMPTY(RADD2)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(RLEVEL) OR !EMPTY(RSUBLEVEL) OR !EMPTY(RFLOOR) OR !EMPTY(RAPT)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(PROPER(RLEVEL))%><%=IIF(EMPTY(RSUBLEVEL),'','/'+ALLT(RSUBLEVEL))%><%=IIF(EMPTY(RFLOOR),'',' Floor: '+ALLT(STR(RFLOOR)))%>
    <%IF !EMPTY(RAPT) AND _EST.RC='C'%>
	<%=' Unit: '+ALLT(RAPT)%>
    <%ELSE%>
	<%=IIF(EMPTY(RAPT),'',' Apt: '+ALLT(RAPT))%>
	<%ENDIF%></td>
 </tr>
 <%ENDIF%>
  <tr> 
    <td width="100%" class="FROMTO"><font style="font-size:11pt;" color="#00008B"><%=ALLT(RCITY)+', '+ALLT(RSTATE)+' '+ALLT(RZIP)%>&nbsp;<%=IIF(EMPTY(RCOUNTRY),'',ALLT(RCOUNTRY))%></font></td>
 </tr>
 <%IF !EMPTY(RTELH) %>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RTELH)%></td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(RTELO)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RTELO)%></td>
 </tr>
 <%ENDIF%> 
</table>
  <!--end Moving To -->       
    </td>
 </tr>
  <tr>
    <td width="100%" valign="top" colspan="2">
 <%IF plEMAIL %>
    &nbsp;<a href="javascript: sendemail()"><FONT FACE="VERDANA" COLOR="#0000FF" SIZE="2"><B><%=ALLT(_EST.EMAIL)%>&nbsp;<img border="0" src="zz/images/email1.gif" ALT="Email Center" width="18" height="11"></b></font></a>
    &nbsp;&nbsp;<FONT face="Arial" size="2" color="#000000"><b><%=pcSENT%></b>&nbsp;<%=IIF(VAL(pcSENT)<2,'email sent','emails sent')%></font>
 <%ELSE%>
    &nbsp;<font color="#999999"><%=ALLT(_EST.EMAIL)%></font><font size="2" color="#C90000"><%='<br>'+ALLT(pcEMAILTITLE)%></font> <a class="fancybox fancybox.iframe" href="/wc.dll?mputil~cancelremoval~&REMOVEID=<%=lnREMOVEID%>&JOBID=<%=ALLT(STR(pnJOBID))%>&USERID=<%=ALLT(STR(pnUSERID))%>"><%=lnREMOVEID%></a>
 <%ENDIF%>
   </td>
  </tr>
  <%IF plEMAIL%>
  <tr>
