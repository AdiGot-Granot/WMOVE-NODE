<html lang="en" style="width: 800px; height: 700px;">

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Add Rep Note</title>

<SCRIPT LANGUAGE="JAVASCRIPT">


function RepNote(par) {
    //   alert("This photo was taken in "+par+".");
       document.theForm.action="/wc.dll?mpcharge~repnoteaddret~<%=pcSCR%>~"+par;
       document.theForm.submit();
	}


</SCRIPT>

<STYLE TYPE="text/css">
.SUBOFF	 {	color: black; 
			font-weight: none;
			font-family: Arial;
		  	text-align: center;
			width: 100;
			height: 20;
			background-color: #CCCCCC;
			font-size: 10pt;
  		  	cursor: pointer;}
.SUBON	{	color: #0000FF; 
			font-weight: bold;
			font-family: Arial;
		  	text-align: center;
			width: 100;
			height: 20;
			background-color: #FFFF00;
			font-size: 10pt;
  		  	cursor: pointer;}
.inputlogin	{width: 90%;
    	 	 padding: 3px 3px;
	    	 margin: 2px 0;
	    	 box-sizing: border-box;
	    	 border: px solid #ccc;
	    	 background-color: #EBEBEC;
	    	 border-radius: 5px;
	    	 box-shadow: 2px 2px grey;
	    	 cursor:pointer;}
  				  	
</style>
</head>
<body BGCOLOR="#4E6699">
<table border="0" align="center" style="border-collapse:collapse;width:800px;height:700px;" bordercolor="#111111">
  <tr>
    <td width="100%" bgcolor="#F7F0B9" align="center"><b><font face="Verdana" size="2">Add Rep Note</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
<form name="theForm" method="POST" target="_top">
<table border="0" align="center" width="95%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td valign="top">
 <% SELECT * FROM _REPNOTEDESC WHERE SEQ<14 INTO CURSOR _REPNOTEDESC1 
   SELECT _REPNOTEDESC1
 	SCAN %>
	<center><div class="inputlogin" name="REPNOTESX" value="<%=ALLT(DESCNAME)%>" onclick="RepNote(<%=ALLT(STR(DESCID))%>)"><font style="font-family:Arial;font-size:11pt;"><%=ALLT(DESCNAME)%></font></div></center>
	<p style="line-height:140%"></p>
 <%ENDSCAN%>    
    </td>    
    <td valign="top">
 <% SELECT * FROM _REPNOTEDESC WHERE SEQ>13 AND SEQ<26 INTO CURSOR _REPNOTEDESC1 
   SELECT _REPNOTEDESC1
 	SCAN %>
	<center><div class="inputlogin" name="REPNOTESX" value="<%=ALLT(DESCNAME)%>" onclick="RepNote(<%=ALLT(STR(DESCID))%>)"><font style="font-family:Arial;font-size:11pt;"><%=ALLT(DESCNAME)%></font></div></center>
	<p style="line-height:140%"></p>
 <%ENDSCAN%>    
    </td>    
    <td valign="top">
 <% SELECT * FROM _REPNOTEDESC WHERE SEQ>25 AND SEQ<38 INTO CURSOR _REPNOTEDESC2
   SELECT _REPNOTEDESC2
 	SCAN %>
	<center><div class="inputlogin" name="REPNOTESX" value="<%=ALLT(DESCNAME)%>" onclick="RepNote(<%=ALLT(STR(DESCID))%>)"><font style="font-family:Arial;font-size:11pt;"><%=ALLT(DESCNAME)%></font></div></center>
	<p style="line-height:140%"></p>
 <%ENDSCAN%>    
    </td>    
    <td valign="top">
 <% SELECT * FROM _REPNOTEDESC WHERE SEQ>37 INTO CURSOR _REPNOTEDESC3
   SELECT _REPNOTEDESC3
 	SCAN %>
	<center><div class="inputlogin" name="REPNOTESX" value="<%=ALLT(DESCNAME)%>" onclick="RepNote(<%=ALLT(STR(DESCID))%>)"><font style="font-family:Arial;font-size:11pt;"><%=ALLT(DESCNAME)%></font></div></center>
	<p style="line-height:140%"></p>
 <%ENDSCAN%>    
    </td>    
 </tr>
</table>
</form>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15"><font size="2" color="#FFFFFF">User:&nbsp;<%=pcUSER%></font></td>
  </tr>
  </table>
</body>
</html>