<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Services & Discounts List</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i){
  if (i==1) { 
   document.theForm.action="/wc.dll?mpcharge~EstOthersret~<%=pcSCR%>~<%=pcEmainId%>~<%=pcDISCOUNT%>";
    document.theForm.submit()
     } ;

    if (i==2) 
      { 
   document.theForm.action="/wc.dll?mpopr~OprOthersret~<%=pcSCR%>~<%=pcEmainId%>~<%=pcDISCOUNT%>";
    document.theForm.submit()
      } ;

}

</SCRIPT>
<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#4E6699">
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="600">
  <tr>
    <td width="23" height="25" align="center" background="/zz/images/bar-green.gif">
    </td>
    <td width="491" height="25" align="center" background="/zz/images/bar-green.gif"><b><font face="ARIAL" size="4" color="#FFFFFF"><%=IIF(!plDISCOUNT,'Other Services List','Discounts List')%></font></b>&nbsp;</td>
    <td width="30" height="25" align="center" background="/zz/images/bar-green.gif">
    <img border="0" src="/zz/images/x-yellow.gif" onclick="javascript: window.close()" align="right" width="17" height="18" style="cursor:pointer;"></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF" colspan="3">
  <form name="theForm" method="post">    
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="25%">&nbsp;&nbsp;<b><font face="Arial" size="2">#<%=pcEMAINID%></font></b></td>
    <td width="46%"><b><font face="Arial" size="2">Customer:&nbsp;<%=_E.SNAME%></font></b></td>
    <td width="29%" align="right"><b><font face="Arial" size="2">Job No:&nbsp;<%=ALLT(_E.DEPT)+ALLT(_E.ORDNO)%></font></b>&nbsp;&nbsp;</td>
 </tr>
</table>
  <%IF !plDISCOUNT%>
  <br>
<table border="1" align="center" width="95%" bordercolor="#C0C0C0" style="border-collapse: collapse" cellspacing="1" cellpadding="1">
  <tr>
    <td width="5%" bgcolor="#008000" align="center"><b><font face="ARIAL" color="#FFFFFF">Order</FONT></B></td>
    <td width="60%" bgcolor="#008000" align="center"><b><font face="ARIAL" color="#FFFFFF">Service Description</font></b></td>
    <td width="17%" bgcolor="#008000" align="center"><b><font face="ARIAL" color="#FFFFFF">Price</font></b></td>
    <td width="13%" bgcolor="#008000" align="center"><B><font face="ARIAL" color="#FFFFFF">Select</font></B></td>
  </tr>
  <% SELECT _O
  	 SCAN %>
 <tr>
    <td width="5%" bgcolor="#FFFFFF"><FONT FACE="ARIAL" size="2"><b><%=ALLT(STR(SEQ))%></b></font>&nbsp;</td>
    <td width="60%" bgcolor="#FFFFFF"><FONT FACE="ARIAL" size="2"><B><%=ALLT(CNAME)%></B></font>&nbsp;</td>
    <td width="17%" bgcolor="#FFFFFF" align="right"><FONT FACE="ARIAL" size="2" color="#008000"><B><%='$'+ALLT(STR(PRC,7,2))%></B></font>&nbsp;</td>
    <td width="13%" bgcolor="#FFFFFF" align="center"><input type="checkbox" name="<%=ALLT(STR(EPRCID))%>" value="ON" <%=IIF(OK,'checked','')%>></td>
  <% ENDSCAN%>  
</table>
<!--new others --><BR>
<table border="1" ALIGN="CENTER" cellpadding="1" cellspacing="1" style="border-collapse: collapse" bordercolor="#C0C0C0" width="95%">
   <tr>
     <td width="66%" align="center" bgcolor="#008000"><b><font face="Arial" size="2" color="#FFFFFF">New Service Description</font></b></td>
     <td width="12%" align="center" bgcolor="#008000"><b><font size="2" face="Arial" color="#FFFFFF">Price</font></b></td>
     <td width="17%" align="center" bgcolor="#008000"><b><font face="Arial" size="2" color="#FFFFFF">Add Price to<br>Every <%=IIF(plCALCCF,'100 cf',ALLT(STR(ROUND(pnCFRATIO*100,0)))+' lbs')%></font></b></td>
 </tr>
 <tr>
     <td width="66%" bgcolor="#FFFFFF"><input NAME="CNAME" autocomplete="off" size="45" VALUE="" style="font-size: 10pt"></td>
     <td width="12%" align="center" Bgcolor="#FFFFFF"><font face="Arial" size="2">$</font><input NAME="BASIC" autocomplete="off" size="2" VALUE="" style="font-size: 10pt" maxlength="7"></td>
     <td width="17%" align="center" bgcolor="#FFFFFF"><font face="Arial" size="2">$</font><input NAME="ADDPRC" autocomplete="off" size="1" VALUE="" style="font-size: 10pt" maxlength="5"></TD>
  </tr>
</table>			
<!--end new others -->
 <%ELSE%>
 <br>
<table border="1" align="center" width="95%" bordercolor="#C0C0C0" style="border-collapse: collapse" cellspacing="1" cellpadding="1">
  <tr>
    <td width="5%" bgcolor="#008000" align="center"><b><font face="ARIAL" color="#FFFFFF">Order</FONT></B></td>
    <td width="60%" bgcolor="#008000" align="center"><b><font face="ARIAL" color="#FFFFFF">Discount Description</font></b></td>
    <td width="17%" bgcolor="#008000" align="center"><b><font face="ARIAL" color="#FFFFFF">Price</font></b></td>
    <td width="13%" bgcolor="#008000" align="center"><B><font face="ARIAL" color="#FFFFFF">Select</font></B></td>
  </tr>
  <% SELECT _D
  	 SCAN %>
 <tr>
    <td width="5%" bgcolor="#FFFFFF"><FONT FACE="ARIAL" size="2"><b><%=ALLT(STR(SEQ))%></b></font>&nbsp;</td>
    <td width="60%" bgcolor="#FFFFFF"><FONT FACE="ARIAL" size="2"><B><%=ALLT(CNAME)%></B></font>&nbsp;</td>
    <td width="17%" bgcolor="#FFFFFF" align="right"><FONT FACE="ARIAL" size="2" color="#FF0000"><B><%='$'+ALLT(STR(PRC,7,2))%></B></font>&nbsp;</td>
    <td width="13%" bgcolor="#FFFFFF" align="center"><input type="checkbox" name="<%=ALLT(STR(EPRCID))%>" value="ON" <%=IIF(OK,'checked','')%>></td>
  <% ENDSCAN%>  
</table>
<!--new discount --><BR>
<table border="1" ALIGN="CENTER" cellpadding="1" cellspacing="1" style="border-collapse: collapse" bordercolor="#C0C0C0" width="95%">
   <tr>
     <td width="60%" align="center" bgcolor="#008000"><b><font size="2" face="Arial" color="#FFFFFF">New Discount Description</font></b></td>
     <td width="15%" align="center" bgcolor="#008000"><b><font size="2" face="Arial" color="#FFFFFF">Price</font></b></td>
     <td width="20%" align="center" bgcolor="#008000"><b><font face="Arial" size="2" color="#FFFFFF">Percent<br>Line Haul</font></b></td>
 </tr>
 <tr>
     <td width="60%" bgcolor="#FFFFFF"><input NAME="CNAME" autocomplete="off" size="40" VALUE="" style="font-size: 10pt"></td>
     <td width="15%" align="center" Bgcolor="#FFFFFF"><font face="Arial" size="2">$</font><input NAME="BASIC" autocomplete="off" size="4" VALUE="" style="font-size: 10pt" maxlength="7"></td>
     <td width="20%" align="center" bgcolor="#FFFFFF"><input NAME="ADDPRC" size="1" VALUE="" style="font-size: 10pt" maxlength="5">%</TD>
  </tr>
</table>			
<!--end new discount -->
<%ENDIF%>
<br>
<table border="0" align="center" width="80%" style="border-collapse: collapse" bordercolor="#111111" value="ON">
   <tr>
	 <td width="19%" align="center">
     <input id="btnSubmit" type="button" CLASS="SUBOFF" onclick=<%=IIF(pcACTION='EST',"submitFunction(1)","submitFunction(2)")%> onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
	 <td width="19%" align="center">
     <input id="btnSubmit" type="button" CLASS="SUBOFF" onclick="javascript: window.close()" onmouseover="javasctript: this.className='SUBONEXIT'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="39" value="Exit"></td>
  </tr>
</table>
</form>      
    &nbsp;</td>
 </tr>
  <tr>
    <td width="548" height="25" background="/zz/images/bgdown.gif" colspan="3"></td>
  </tr>
</table>
</body>
</html>