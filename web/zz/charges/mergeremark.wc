<html>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<head>
<title>Preview</title>
<SCRIPT LANGUAGE="JAVASCRIPT">

function MergeRem() {
	var Message = "Are you sure you want to Merge your Remarks?";
	if (confirm (Message)){
		window.location.href="/wc.dll?mpcharge~mergerem~<%=pcSCR%>";
       }
	}
	
</script>

</head>
<body BGCOLOR="#4E6699">
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="700">
  <tr>
    <td width="93%" BGCOLOR="#008000" ALIGN="CENTER" height="20"><b><font face="Arial" color="#FFFFFF">
    <%=CTYPE%><%=IIF(!EMPTY(DEPT),' - '+ALLT(DEPT),'')%><%=IIF(!EMPTY(lcSTS),' - '+lcSTS,'')%><%=IIF(!EMPTY(lcBINDING),' - '+lcBINDING,'')%><%=IIF(!EMPTY(SERVTYPE),' - '+CSERVTYPE,'')%></font></b></td>
    <td width="7%" BGCOLOR="#008000" height="20" align="right">
    <%IF !plMAINTEN%><a href="javascript:history.go(-1)"><img border="0" src="/zz/images/x.gif" width="17" height="18"></a><%ENDIF%></td>
  </tr>
  <tr>
    <td width="100%" valign="top" bgcolor="#FFFFFF" colspan="2"><br>
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="100%">
   <tr>
	 <td width="100%" colspan="2"><%=pcREM%><BR><%=pcREMFILE%></td>
  </tr>
  <%IF !plMAINTEN%>
  <tr>
    <td width="50%" align="center"><b><font face="Arial" color="#0000FF" onclick="javascript:history.go(-1)" STYLE="cursor:pointer;"><u>Go Back</u></b></font></td>
    <td width="50%" align="center">
     <a onclick="MergeRem()" style="cursor:pointer;font-size:10pt;font-weight: bold;font-family: Arial;text-decoration: underline;color:0000FF;">
     <b><font face="Arial" size="2">Merge Remarks</b></font></a></td>
  </tr>
  <%ENDIF%>
</table>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="1" colspan="2">&nbsp;</td>
  </tr>
  </table>
</body>

</html>