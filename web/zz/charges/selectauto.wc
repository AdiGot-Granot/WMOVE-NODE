    		SCAN%>
	    	<option value="<%=ALLT(_M.MAKE)%>"><%=ALLT(_M.MAKE)%></option>
	    <%ENDSCAN%>
    </select>	
	</td>
  </tr>
   <tr>
	<td width="25%" class="TD1">Model</td>
	<td width="75%">
	<select size="1" name="AUTOMODEL" id="automodel">
	<option><%=_INVAUTO.MODEL%></option>    
