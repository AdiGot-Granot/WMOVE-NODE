<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Add/Update Vehicle</title>
<link rel="stylesheet" type="text/css" href="/zz/util/checkboxslide.css?v=1.1.4" media="screen" /><!--CONF CHECKBOX-->

<SCRIPT type="text/javascript">

function loadXML(cURL){
    var xmlhttp = new window.XMLHttpRequest();
    xmlhttp.open("GET", cURL, false);
    xmlhttp.send(null);
    return xmlhttp.responseXML.documentElement;
}

function alertXML(oXML){
    var Xml2String = new XMLSerializer().serializeToString(oXML);
    alert(Xml2String);
}

function fillCombo(elmId, oXML, cNodeValueName, cNodeTextName){
    document.getElementById(elmId).length = null;
    var x = oXML.getElementsByTagName('BBB');
    for(i=0; i<x.length; i++){
        cValue = x[i].getElementsByTagName(cNodeValueName)[0].childNodes[0].nodeValue;
        cText = x[i].getElementsByTagName(cNodeTextName)[0].childNodes[0].nodeValue;
        document.getElementById(elmId)[i] = new Option(cText, cValue, false);
    }
}

function SubmitData(i) {
    if (i==1) 
	  {
	   document.theForm.action="/wc.dll?mpcharge~selectautoret~<%=pcSCR%>~<%=pcINVAUTOID%>";
       document.theForm.submit();
      };
}

function delcar() {
	var Message = "Are you sure you want to delete this vehicle?";
	if (confirm (Message)){
	 	window.location.href=('/wc.dll?mpcharge~deleteauto~<%=pcSCR%>~<%=pcINVAUTOID%>');
  }
}

function fetchXML(){
    m = document.theForm.AUTOMAKE.value;
    y = document.theForm.AUTOYEAR.value;
    cURL = '/wc.dll?mpauto~AUTOMODELXML~&AUTOMAKE='+m+'&AUTOYEAR='+y;
    xmlAUTO = loadXML(cURL);
    fillCombo('automodel', xmlAUTO, 'model', 'model');
}

</SCRIPT>

<STYLE TYPE="text/css">
 	.TD1	 	{	font-weight: bold;
					font-family: Verdana;
					font-size: 10pt;}	  	
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#4E6699">
<BR>
 <%SELECT _INVAUTO
   GO TOP%>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="800">
  <tr>
    <td BGCOLOR="#008000" height="20" align="center">&nbsp;</td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF" valign="top"><br>
<table border="0" width="97%" align="center" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" cellpadding="0">
  <tr>
    <td width="22%" height="10"><b><font face="Verdana" size="2">Job No: <%=ALLT(_EST.DEPT)+ALLT(_EST.ORDNO)%></b></font></td>
    <td width="75%" height="10"><b><font face="Verdana" size="2"><b>Customer:&nbsp;<%=ALLT(PROPER(_EST.SNAME))%></b></font>&nbsp;</td>
 </tr>
</table>    
<form name="theForm" method="post">   
<input type="hidden" name="AUTOSERVID" size="17" tabindex="3" value="<%=pcAUTOSERVID%>">
<table border="0" cellpadding="0" cellspacing="0" width="98%" align="center" style="border:1px solid #d4d0c8;margin-top:16px;border-radius:8px;overflow:hidden;">
  <tr>
    <td width="50%" align="center" style="border-right:1px solid #d4d0c8;"><span style="font-family:Verdana;font-size:11pt;font-weight:bold;color:#000;">Add/Update Vehicle</span></td>
    <td width="50%" align="center"><span style="font-family:Verdana;font-size:11pt;font-weight:bold;color:#000;">Add New Vehicle <span style="font-size:8pt;font-weight:bold;">(not on the list)</span></span></td>
 </tr>
  <tr>
    <td width="50%" height="10" style="border-right:1px solid #d4d0c8;font-size:0; line-height:0;"></td>
    <td width="50%" height="10" style="font-size:0; line-height:0;"></td>
 </tr> 
  <tr>
    <td valign="top" width="50%" style="border-right:1px solid #d4d0c8;"><!---SELECT VEHICLE-->
<table border="0" width="100%" style="border-collapse: collapse;line-height:25px;" bordercolor="#111111" cellspacing="1" cellpadding="3">  
   <tr>
