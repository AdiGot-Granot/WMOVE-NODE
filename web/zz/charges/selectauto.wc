	<td width="75%"><input type="text" autocomplete="off" name="NOTES" size="30" value="<%=ALLT(_INVAUTO.NOTES)%>"></td>
  </tr>
  <% IF pnINVAUTOID>999 %>
   <tr>
	<td width="100%" class="TD1" align="center" colspan="2"><a onclick="delcar()" style="color:#0000FF;cursor:pointer;"><u>Delete Vehicle</u></a></td>
  </tr>
  <%ENDIF%>    
</table>
    </td>
    <td valign="top" width="50%"><!---NEW VEHICLE-->
