<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="70%">
  <tr>
   <td align="center"><input type="button" CLASS="SUBOFF" name="B36" onclick="SubmitData(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
   <td align="center"><input type="button" CLASS="SUBOFF" name="B36" onclick="javascript:history.go(-1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
 </tr>
</table> 
</form>  
