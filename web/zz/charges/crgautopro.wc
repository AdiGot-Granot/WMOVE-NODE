<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title><%=pcORDNO%></title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.7" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
 $(".fancybox").fancybox({
  openEffect : 'elastic',
  closeEffect : 'elastic',
  fitToView: false,
  autoSize: false,
  nextSpeed: 0, //important
  prevSpeed: 0, //important
  afterLoad: function(){
  // added 50px to avoid scrollbars inside fancybox
   this.width = ($('.fancybox-iframe').contents().find('html').width())+50;
   this.height = ($('.fancybox-iframe').contents().find('html').height())+50;
  }

 }); // fancybox
}); // ready

<%IF _EST.STATUS='F' OR _EST.STATUS='O' %>
function SubmitData(i) {
    if (i==1) {
	   document.theForm.action="/wc.dll?mpcharge~CrgAutoProRet~<%=pcSCR%>";
       document.theForm.submit();
      };
    if (i==2) { 
       document.theForm.action="/wc.dll?mpcharge~bookingcrg~<%=pcSCR%>";
       document.theForm.submit();
      } ;
}
<%ENDIF%>

function deletea() {
	var Message = "Are you sure you want to continue?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpest~deleteest~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function cancela() {
	var Message = "Are you sure you want to continue?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpest~cancelest~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function extstop() {
    window.open('/wc.dll?mpest~extstopwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=450');
	}

<% IF plUID %>
function route() {
    window.open("https://www.centraldispatch.com/protected/listing-search/result?routeBased=0&corridorWidth=&routePickupCity=&routePickupState=&routePickupZip=&route_origination_valid=&routeDeliveryCity=&routeDeliveryState=&routeDeliveryZip=&route_destination_valid=&waypointCity%5B%5D=&waypointCity%5B%5D=&waypointCity%5B%5D=&waypointCity%5B%5D=&waypointCity%5B%5D=&waypointState%5B%5D=&waypointState%5B%5D=&waypointState%5B%5D=&waypointState%5B%5D=&waypointState%5B%5D=&waypointZip%5B%5D=&waypointZip%5B%5D=&waypointZip%5B%5D=&waypointZip%5B%5D=&waypointZip%5B%5D=&waypoint_valid=1&pickupCity=<%=ALLT(_EST.SCITY)%>&pickupRadius=100&pickupState=<%=ALLT(_EST.SSTATE)%>&pickupZip=&pickupAreas%5B%5D=All&origination_valid=1&deliveryCity=<%=ALLT(_EST.RCITY)%>&deliveryRadius=100&deliveryState=<%=ALLT(_EST.RSTATE)%>&deliveryZip=&deliveryAreas%5B%5D=All&destination_valid=1&FatAllowCanada=1&vehicleTypeIds%5B%5D=&trailerType=&vehiclesRun=&minVehicles=1&maxVehicles=&shipWithin=60&paymentType=&minPayPrice=&minPayPerMile=&highlightOnTop=0&postedBy=&highlightPeriod=0&listingsPerPage=100&primarySort=8&secondarySort=5&filterBlocked=0&highlightPreferred=0&pickupCitySearch=1&deliveryCitySearch=1");
	}
<%ENDIF%>

function updagent(){
	document.theForm.action="/wc.dll?mpcharge~updagentwc~<%=pcSCR%>";
    document.theForm.submit();
 }

<%IF _EST.LBOOKDTE <= DATE() AND pnLEVEL>=2 AND _EST.LBOOKC %>
function closeda() {
	var Message = "Are you sure you want to continue?" ;
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpopr~closedjobret~<%=pcSCR%>~AUTO";
       document.theForm.submit();
       }
	}
<%ENDIF%>

 function sendemail() {
    window.open('/wc.dll?mpest~emailcenterwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=yes,resizable=no,copyhistory=no,scrollbars=yes,width=800,height=750');
 self.name="main"}

function ViewLog() {
       window.open('/wc.dll?mpest~logfilewc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=850,height=600');
      }

function emailtoagent() {
	var Message = "Are you sure you want to send this order to the carrier?";
	if (confirm (Message)){
        window.open('/wc.dll?mpest~emailauto~<%=pcSCR%>~<%=pcAGENT%>~EMAILTOAGENT','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=400,height=350');
     self.name="main"
       }
   }
   
function emailquote() {
        window.open('/wc.dll?mpest~emailauto~<%=pcSCR%>~~EMAILTOCUST','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=500,height=350');
     self.name="main"
   }
 
function Direction() {
		window.open("https://maps.google.com/maps?f=d&source=s_d&saddr=<%=pcSADDR%>&daddr=<%=pcRADDR%>");
	   }


function UpdValueB(A, B) {
  fetch('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~' + A + '~' + B)
    .then(() => alert("Selection saved."))
    .catch(() => alert("Failed to save selection"));
}

<% IF plUID %>
function centralauto(c) {
    window.location.href=('/wc.dll?mpcharge~centralauto~<%=pcSCR%>~'+c);
}
<%ENDIF%>

function updcar(par) {
	 	window.location.href=('/wc.dll?mpcharge~selectautowc~<%=pcSCR%>~'+par);
  }

<%IF plAUTOZONE AND (pnLEVEL=2 OR pnLEVEL=5) %>
function UpdTariff() {
	var Message = "Are you sure you want to Update Tariff?";
	if (confirm (Message)){
	   document.theForm.action="/wc.dll?mpauto~UpdTariff~<%=pcSCR%>";
       document.theForm.submit();
       }
	}

function autozonerate() {
    window.open('/wc.dll?mpauto~AutoZoneRate~<%=pcSCR%>~<%=pcAUTOZPID%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=900,height=400');
	}
<%ENDIF%>

function remagent() {
    window.open('/wc.dll?mpest~remagentwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=450');
	}

<%IF plDEPT AND _EST.STATUS<>'D' AND _EST.STATUS<>'C' %>
function alterDept(c){
	document.getElementById("dept").innerText=c;	
    window.open('/wc.dll?mpcharge~UpdValue~<%=pcSCR%>~DEPT~'+c,'EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=5,height=5');
}
<%ENDIF %>

</SCRIPT>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
	jQuery.noConflict();
	
   jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
       $("#Date3").datepicker({ numberOfMonths:[1,2] });
       $("#Date4").datepicker({ numberOfMonths:[1,2] });
       $("#Date5").datepicker({ numberOfMonths:[1,2] });
   });
</script>



<STYLE TYPE="text/css">
	 .TD1		{	color: #FFF;
				  	font-size: 10pt;
  				  	font-weight: bold;
  				  	font-family: Verdana;
  				  	background-color:#008000;
  				  	line-height:25px;}
     .TD2 	    {	text-align: left;
				    color: black; 
				    font-size: 9pt;
				    font-family: Verdana;
				    font-weight: bold;}
	 .TD5		{	font-size: 10pt;
  				  	font-weight: bold;
  				  	font-family: Verdana;
				  	text-align: right;}				    	
     .FROMTO 	{	text-align: left;
				    color: black; 
				    font-size: 10pt;
				    font-family: Arial;
				    font-weight: bold;}				  					  	
	.SUBMIT	 	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 130; 
                    height: 25; 
                    cursor: pointer;}			  	
	.SUBMIT1	{	color: #FFFFFF;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    cursor: pointer;
                    width: 125; 
                    height: 25;}
 	.SUBOFF	 	{	color: white; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 75;
                    height: 22;			  	
					background-color: #FF0000;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.CDROUTE	{	color: white; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 110;
                    height: 25;			  	
					background-color: #F76A00;
					font-size: 10pt;
  				  	cursor: pointer;}
  	.ACTLOG	 	{	color: white; 
					font-weight: bold;
					font-family: Verdana;
					font-size: 10pt;					
				  	text-align: center;
					width: 100;
                    height: 25;			  	
					background-color: #0075AD;
  				  	cursor: pointer;}  				  	  				  	

</style>

</head>

<body BGCOLOR="#4E6699">
<br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="1000" height="25">
  <tr>
    <td BGCOLOR="#008000" width="213">&nbsp;<font face="Verdana" color="#FFFF00"><b><%=pcBALANCEX%></b></font></td>
    <td BGCOLOR="#008000" align="center" width="358"><b><font size="4" color="#FFFFFF" face="Verdana">Auto Transport Charges</font></b></td>
    <td BGCOLOR="#008000" align="right" width="273">&nbsp;</td>
  </tr>
  <tr>
    <td width="1000" bgcolor="#FFFFFF" valign="top" colspan="3" height="347" <%IF _EST.STATUS='C'%> background="zz/images/cancel.jpg" <%ENDIF%>
	    <%IF _EST.STATUS='D'%> background="zz/images/closed.jpg" <%ENDIF%>>
  <form name="theForm" method="post">    
 <%SELECT _INVAUTO
   GO TOP%>
<table border="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td valign="top" width="71%"><br> 
 <table border="1" align="center" style="border-collapse: collapse" bordercolor="#C0C0C0" width="97%">
  <tr>
    <td width="50%"><b><FONT face="Verdana" size="2">View Map:</FONT> <a target="_blank" href="http://www.google.com/maps?q=<%=ALLT(_EST.SZIP)%>,+USA&sa=X&oi=map&ct=title" TARGET="_BLANK"><FONT face="Verdana" size="2">Google</font></a></td>
    <td width="50%"><b><FONT face="Verdana" size="2">View Map:</FONT> <a target="_blank" href="http://www.google.com/maps?q=<%=ALLT(_EST.RZIP)%>,+USA&sa=X&oi=map&ct=title" TARGET="_BLANK"><FONT face="Verdana" size="2">Google</font></a></td>
 </tr>   
   <tr>
    <td width="50%" align="center" bgcolor="#008000"><b><FONT face="Verdana" COLOR="FFFFFF">Transport From</FONT></b></td>
    <td width="50%" align="center" bgcolor="#008000"><b><FONT face="Verdana" COLOR="FFFFFF">Transport To</FONT></b></td>
  </tr>
   <tr>
    <td width="50%" valign="top">
<!--Moving from -->         
 <%SELECT _EST%>
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse: collapse;line-height:22px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%"><font FACE="Verdana" color="#00008B" size="4"><b><%=ALLT(_EST.SNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(SPROXY)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><font color="#C71585"><%='Proxy: '+ALLT(SPROXY)%></font></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(SADD1)%>&nbsp;</td>
 </tr>
 <%IF !EMPTY(SADD2)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(SADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(SLEVEL)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(PROPER(SLEVEL))%>&nbsp;</td>
 </tr>
 <%ENDIF%> 
  <tr> 
    <td width="100%" class="FROMTO"><font style="font-size:11pt;" color="#00008B"><%=ALLT(SCITY)+', '+ALLT(SSTATE)+' '+ALLT(SZIP)%>&nbsp;<%=IIF(EMPTY(SCOUNTRY),'',ALLT(SCOUNTRY))%></font></td>
 </tr>
 <%IF !EMPTY(STELH) %>
  <tr>
 	<td width="100%" class="FROMTO">
    <% IF pcCUSTNO<>'SHIPSLINE' %>
       <%=ALLT(STELH)%>
 	<%ELSE%>
	   <a href="tel:<%=STELH%>"><%=STELH%></a>
    <%ENDIF%> 	
 	</td>
  </tr>
 <%ENDIF%>
 <%IF !EMPTY(STELO)%>
  <tr>
 	<td width="100%" class="FROMTO">
    <% IF pcCUSTNO<>'SHIPSLINE' %>
       <%=ALLT(STELO)%>
 	<%ELSE%>
	   <a href="tel:<%=STELO%>"><%=STELO%></a>
    <%ENDIF%> 	
 	</td>
  </tr>
 <%ENDIF%> 
 <%IF !EMPTY(SFAX)%>
  <tr>
    <td width="100%" class="FROMTO">Fax:&nbsp;<%=ALLT(SFAX)%></td>
 </tr>
<%ENDIF%>
</table>
  <!--end Moving from -->     
    </td>
    <td width="50%" valign="top">
<!--Moving To -->         
 <%SELECT _EST%>
<table border="0" cellpadding="2" cellspacing="1" style="border-collapse: collapse;line-height:22px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%"><font FACE="Verdana" color="#00008B" size="4"><b><%=ALLT(_EST.RNAME)%></b></font>&nbsp;</td>
 </tr>
 <%IF !EMPTY(RPROXY)%>
  <tr>
    <td width="100%" class="FROMTO" colspan="3"><font color="#C71585"><%='Proxy: '+ALLT(RPROXY)%></font></td>
 </tr>
 <%ENDIF%> 
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RADD1)%>&nbsp;</td>
 </tr>
 <%IF !EMPTY(RADD2)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RADD2)%>&nbsp;</td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(RLEVEL)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(PROPER(RLEVEL))%>&nbsp;</td>
 </tr>
 <%ENDIF%> 
  <tr> 
    <td width="100%" class="FROMTO"><font style="font-size:11pt;" color="#00008B"><%=ALLT(RCITY)+', '+ALLT(RSTATE)+' '+ALLT(RZIP)%>&nbsp;<%=IIF(EMPTY(RCOUNTRY),'',ALLT(RCOUNTRY))%></font></td>
 </tr>
 <%IF !EMPTY(RTELH) %>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RTELH)%></td>
 </tr>
 <%ENDIF%>
 <%IF !EMPTY(RTELO)%>
  <tr>
    <td width="100%" class="FROMTO"><%=ALLT(RTELO)%></td>
 </tr>
 <%ENDIF%> 
</table>
  <!--end Moving To -->    
    </td>
  </tr>
   <tr>
    <td width="100%" colspan="2">
   <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  	 <tr>
       <td>
   <%IF plEMAIL AND _EST.STATUS<>'D' %>
    &nbsp;<a href="javascript: sendemail()"><FONT FACE="VERDANA" COLOR="#0000FF" SIZE="2"><B><%=ALLT(_EST.EMAIL)%></b></font>&nbsp;<img border="0" src="zz/images/email1.gif" ALT="Email Center" width="18" height="11"></a>
    &nbsp;&nbsp;<FONT FACE="Arial" COLOR="#000000" SIZE="2"><B><%=pcSENT%></b>&nbsp;<%=IIF(VAL(pcSENT)<2,'email sent','emails sent')%>
   <%ELSE%>
    &nbsp;<font color="#999999"><%=ALLT(_EST.EMAIL)%></font><%IF !EMPTY(pcEMAILTITLE)%><font size="2" color="#C90000"> <%='<br>'+ALLT(pcEMAILTITLE)%></font>&nbsp;<a class="fancybox fancybox.iframe" href="wc.dll?mputil~cancelremoval~&REMOVEID=<%=lnREMOVEID%>&JOBID=<%=ALLT(STR(pnJOBID))%>&USERID=<%=ALLT(STR(pnUSERID))%>"><%=lnREMOVEID%></a><%ENDIF%>
   <%ENDIF%>       
       </td>
       <td width="138">
	<%IF plEMAIL AND _EST.STATUS<>'D'%>
	<font face="Arial" size="2" color="#0000FF">Email Quote</FONT> <a href="javascript: emailquote()"><img border="0" src="zz/images/email1.gif" width="18" height="11"></a>
    <%ENDIF%>       
       </td>
    </tr>  
   </table>    
    </td>
  </tr>  
   <%IF plEMAIL %>
   <tr>
    <td width="100%" colspan="2">
   <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  	 <tr style="font-family:Arial;font-size:10pt;">
       <td width="5%" BGCOLOR="#FFFFFF"><%IF plESIGN %><img border="0" src="zz/images/esign.png" ALT="This job was Esigned" width="25" height="18"><%ENDIF%></td>
       <td width="27%" valign="top" BGCOLOR="#FFFFFF"><%IF plESIGNNO %><font color="#8C1021"><%=pnESIGNNO%> Esign Pending</font><%ENDIF%><%IF plESIGN %><br><font color="navy"><%=pnESIGNYES%> Esign Received</font><%ENDIF%></td>
       <td width="33%" valign="top" BGCOLOR="#FFFFFF"><%IF plAGESIGNNO %><font color="#8C1021"><%=pnAGESIGNNO%> Agent Esign Pending</font><%ENDIF%><%IF plAGESIGNPRN %><br><font color="navy"><%=pnAGESIGNPRN%> Agent Esign Received</font><%ENDIF%></td>
    </tr>  
   </table>    
    </td>
  </tr>
   <%ENDIF%>  
 </table>
 <br>
  <table border="0" ALIGN="CENTER" width="685" style="border-collapse: collapse" bordercolor="#111111">
    <tr>
     <td height="40" align="center" width="132"><img border="0" src="zz/images/google-map.gif" style="cursor:pointer;" onclick="Direction()" alt="Google Direction" width="78" height="26"></td>
     <td height="40" align="center" width="240"><%=IIF(!EMPTY(_ESTMEMO.EXTSTOP),'<font size="4" color="#008000">&#10003;</font>','')%>        
     <input type="button" CLASS="SUBMIT1" name="btnDir" onclick="extstop()"  style="background-color: #A54939;" value="Estimate Notes"></td>
  <%IF _EST.STATUS='F' OR _EST.STATUS='O' %>
	 <td height="40" width="182"><input type="button" CLASS="SUBMIT" name="B3" onclick="SubmitData(1)" style="background-color: #7B96B5;" value="Submit Charges"></td>
  	 <td height="40" align="center" class="TD2" width="123"><a class="fancybox fancybox.iframe" href="wc.dll?mpauto~pricesuggest~<%=pcSCR%>~<%=ALLT(SZIP)%>">Price Suggestion</a></td>	     
  <% ENDIF %>  	     
  </tr>
 </table>
<%IF plAUTOZONE AND (pnLEVEL=2 OR pnLEVEL=5) %>
 <BR>
<table border="1" align="center" width="97%" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
    <td width="32%"><% IF !EMPTY(pcADDDTE) %><FONT COLOR="#BB0000" face="Arial" SIZE="2">Last Price Update: <b><font face="Arial" size="2"><%=pcADDDTE%></b></font></font><%ENDIF%></td>
    <td width="33%"><input type="text" style="background-color: #FFFFCC; font-size:9pt; color:#008000;font-weight:bold; text-align:right;" name="TPRC" size="3" value="">
    <input type="button" CLASS="SUBMIT" name="B37" onclick="UpdTariff()" style="background-color: #00C000;" value="Update Tariff"></td>
    <td width="34%"><font face="Arial" size="2">Zone Rate #: <b><a href="javascript:autozonerate()"><%=pcAUTOZPID%></a></font>   
    <font color="#008000" size="2" face="Arial"><b><%=pcRATEA%></b></font></td>
 </tr>
</table>
<%ENDIF %>    
 <!---VEHICLE-->
 <table border="1" width="685" align="center" style="border-collapse: collapse;" bordercolor="#CCCCCC">
   <tr>
	<td class="TD1" width="74">&nbsp;<a onclick="updcar('999')" style="cursor:pointer;"><u>Add New</u></a></td>
	<td class="TD1" width="241">&nbsp;Vehicle Details</td>
	<td class="TD1" width="158">&nbsp;Run-Enclosed-Lot No</td>
	<td class="TD1" align="center" width="64">Deposit</td>
	<td class="TD1" align="center" width="65">Price</td>
  </tr>
  <%SELECT _INVAUTO
   SCAN %>
  <tr style="font-family:Verdana;font-size:10pt;">
	<td width="315" colspan="2"><a onclick="updcar(<%=ALLT(STR(_INVAUTO.INVAUTOID))%>)" style="color:#0000FF;cursor:pointer;"><%=ALLT(_INVAUTO.YEAR)%>&nbsp;<%=ALLT(_INVAUTO.COLOR)%>&nbsp;<%=ALLT(PROPER(_INVAUTO.MAKE))%>&nbsp;<%=ALLT(PROPER(_INVAUTO.MODEL))%><%=IIF(EMPTY(_INVAUTO.TYPE),'',', '+ALLT(_INVAUTO.TYPE))%><%=IIF(EMPTY(_INVAUTO.ENGINE),'',', '+ALLT(_INVAUTO.ENGINE))%></a></td>
	<td width="158">&nbsp;<%=IIF(_INVAUTO.RUN,'Yes','No')%><%=IIF(_INVAUTO.COVER,'-Yes','-No')%><%=IIF(EMPTY(_INVAUTO.LOTNO),'','-'+ALLT(_INVAUTO.LOTNO))%></td>
	<td align="center" width="64"><input ID="QQ6" CLASS="QTYOFF" type="text" style="width: 60px; max-width: 100%;background-color:#FFFFCC;font-weight:bold;text-align:right;" name="DEPOSIT_<%=ALLT(STR(_INVAUTO.INVAUTOID))%>" size="20" value="<%=IIF(_INVAUTO.DEPOSIT=0,'',ALLT(STR(_INVAUTO.DEPOSIT,9,2)))%>"></td>
	<td align="right" width="65"><input ID="QQ5" CLASS="QTYOFF" type="text" style="width: 60px; max-width: 100%;background-color:#FFFFCC;color:#008000;font-weight:bold;text-align:right;" name="UPRC_<%=ALLT(STR(_INVAUTO.INVAUTOID))%>" size="20" value="<%=IIF(_INVAUTO.UPRC=0,'',ALLT(STR(_INVAUTO.UPRC,9,2)))%>"></td>
  </tr>
    <% IF !EMPTY(_INVAUTO.VIN) %>
  <tr style="font-family:Verdana;font-size:10pt;">
	<td width="669" colspan="5">VIN #:<%=ALLT(_INVAUTO.VIN)%>&nbsp;</td>
  </tr>
