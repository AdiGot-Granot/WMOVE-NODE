  <% ENDIF %>
  <%IF _EST.STATUS='F' OR _EST.STATUS='O' %>	 
	<td width="14%" align="center"><input type="button" CLASS="SUBMIT" name="B3" onclick="SubmitData(1)" style="background-color: #7B96B5;" value="Submit Charges"></td>    
  <% ENDIF %>      
  <%IF (_EST.STATUS='F' OR _EST.STATUS='C') and ((!plBLKCANCEL and !plBLKCANCELU) or (plBLKCANCELU and ALLT(_EST.USER)==pcUSER))  %>
	<td width="17%" align="center"><input type="button" CLASS="SUBMIT" name="B33" onclick="cancela()" style="background-color: #FFFF00; color:#0000FF" VALUE="<%=IIF(_EST.STATUS='C','Release Cancel','Cancel Estimate')%>"></td>
  <% ENDIF %>
  <%IF pnLEVEL=2  or pnLEVEL > 3 %>    
    <td width="14%" align="center"><input type="button" name="B34" CLASS="ACTLOG" onclick="ViewLog()" value="Activity Log"></td>
  <% ENDIF %>
  <%IF (_EST.STATUS='F' OR _EST.STATUS='C') AND (pnLEVEL=2 OR pnLEVEL > 3) %>  
    <td width="17%" align="center"><input type="button" CLASS="SUBMIT" name="B35" onclick='deletea()' style="background-color: #EF3821;" value="Delete Estimate"></td>
  <% ENDIF %>
 </tr>
</table>
</form>    
    </td>
  </tr>
  <tr>
    <td bgcolor="#993366" colspan="3">&nbsp;<font face="Arial" style="font-size:9pt;color:#FFF;"><%=pcUser%>&nbsp;&nbsp;<%=pcIP%></font></td>
  </tr>  
  </table>
</body>
</html>