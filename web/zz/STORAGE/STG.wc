<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title><%=pcORDNO%></title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
       $("#Date3").datepicker({ numberOfMonths:[1,2] });
       $("#Date4").datepicker({ numberOfMonths:[1,2] });
       $("#Date5").datepicker({ numberOfMonths:[1,2] });
       
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

 function manualcrg(){
 	window.open('/wc.dll?mpstg~ManualStgCrgWc~<%=pcSCR%>~<%=pcSTGID%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=800,height=600')
 }

function stginvupd(){
 	window.open('/wc.dll?mpstg~stginvupdwc~<%=pcSCR%>~<%=ALLT(STR(_STG.STGID))%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=750,height=500')
 }

function vault(){
 	window.open('/wc.dll?mpstg~vaultwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=685,height=600')
 }

function CHKSTG(){
		frm = document.theForm;
		if(frm.STORAGEID[frm.STORAGEID.selectedIndex].text=='') {
			alert("Please select Storage");
			frm.STORAGEID.focus();
			return false ;
			}
		else {
			return true ;
		}
}

function submitstg() {
    if (CHKSTG()) {
    document.theForm.action="/wc.dll?mpstg~stgret~<%=pcSCR%>~<%=ALLT(STR(_STG.STGID))%>";
    document.theForm.submit()  
    }
  }

function StgIn() {
	var Message = "Are you sure you want to resend this job back to Storage?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpstg~InOutStg~<%=pcSCR%>~STGIN";
       document.theForm.submit();
       }
	}
	
function StgOut() {
	var Message = "Are you sure you want to send this job out of Storage?";
	if (confirm (Message)){
		document.theForm.action="/wc.dll?mpstg~InOutStg~<%=pcSCR%>~STGOUT";
       document.theForm.submit();
       }
	}


</SCRIPT>
<STYLE TYPE="text/css">
	.TDTOP1	 	{	text-align: center;
					color: White; 
					font-size: 10pt;
					font-family: Arial;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none; 
 					border-color: #CCCCCC}
	.TDBODY1 	{	text-align: center;
					color: yellow; 
					font-size: 10pt;
					font-family: Arial;
					background-color: #993366;
  				  	font-weight: bold;
 					border-style: none;}
	.TDINPUT 	{	background-color: #993366;
  				  	border-style: none;} 					
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
	a:visited  {    color: blue;}
</style>
</head>

