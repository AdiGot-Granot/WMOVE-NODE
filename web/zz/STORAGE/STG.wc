 </tr>
  <tr>
    <td width="83"><font style="font-size:9pt;" face="Verdana">APT</FONT></td>
    <td colspan="2" width="213"><input type="text" name="APT" size="2" value="<%=ALLT(_BILLING.APT)%>" tabindex="6" style="font-size: 9pt"></td>
 </tr>		  
  <tr>
