<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Storage Invoice</title>

<style>

	.TD1		{	color: #31557B;
				  	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
				  	text-align: left}
	.TD2		{	color: #008000;
				  	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
				  	text-align: RIGHT} 	
	p.pagebreak {   page-break-after: always;}
</style>
</head>
<body>
<table width="700" border="1" align="center" style="border-collapse: collapse" bordercolor="#31557B">
  <tr> 
    <td width="100%" valign="top"><% IF pcCUSTNO<>'GTSSHIP'%><img border="0" src="https://eagle.hellomoving.com<%=pcIMG%>" alt="" width="700" height="100"><br><br><%ENDIF%>
<table border="0" align="center" width="95%" bordercolor="#4E6699" style="border-collapse: collapse">
<tr>
  <td align="center"><font color="#000080" face="Verdana"><b>Storage Invoice  
  <% IF pcCUSTNO<>'C2CMOVEGA' AND pcCUSTNO<>'NOBELVAN'%><%=CMONTH(_STGINV.BILLDTE)+' '+ALLT(STR(YEAR(_STGINV.BILLDTE)))%><%ENDIF%>
  <% IF pcCUSTNO='NOBELVAN'%><%=CMONTH(_STGINV.BILLDTE-10)+' '+ALLT(STR(YEAR(_STGINV.BILLDTE-10)))%><%ENDIF%></b></font></td>
</tr>
</table>        
	<div align="center">
      <center>        
	<table border="1" width="95%" style="border-collapse: collapse" bordercolor="#31557B" cellspacing="1" cellpadding="2">
	 <tr>
	  <td width="25%" align="CENTER"><b><font face="Verdana" color="#000084" size="2">Customer Billing Information</font></b>&nbsp;</td>
	  <td width="25%" align="CENTER"><font face="Verdana" color="#000080" size="2"><b>Storage Information</b></font></td>
    </tr>
	 <tr>
	  <td width="50%" valign="top"><b><font face="Verdana" size="2"><font color="#000084"><%=ALLT(_BILLING.CNAME)%></font></b><br>
	  <%=ALLT(pcADD)%><%=IIF(EMPTY(pcBILLPHONE),'','<br>'+pcBILLPHONE)%><%=IIF(EMPTY(pcBILLFAX),'','<br>Fax: '+pcBILLPHONE)%><br>
      <a href="mailto:<%=ALLT(_BILLING.EMAIL)%>"><%=IIF(EMPTY(_BILLING.EMAIL),'',ALLT(_BILLING.EMAIL))%></a></font></td>
	  <td width="50%" valign="top"><b><font face="Verdana" color="#000084" size="2"><%=ALLT(pcSTGADD)%></font></b>&nbsp;</td>	
	</tr>
	</table>
      </center>
    </div>
<br>
<table border="0" align="center" width="95%" bordercolor="#4E6699" style="border-collapse: collapse">
<tr>
  <td align="center"><font color="#000080" face="Verdana"><b>Service Charges</b></font></td>
</tr>
</table>
       <table border="1" align="center" cellpadding="3" cellspacing="0" style="border-collapse: collapse" bordercolor="#31557B" width="95%">
 <%SELECT _STGINV %>	  
         <tr>
           <td class="TD1" width="49%">Invoice No:&nbsp;<FONT SIZE="4" COLOR="#993366"><%=ALLT(CINVNO)%></FONT></td>
           <td class="TD1" width="34%">Previous Balance:</td>
           <td class="TD2" width="17%">$<%=ALLT(STR(BALSTG,8,2))%></td>
         </tr>
         <tr>
           <td class="TD1" width="49%">Invoice Date:&nbsp;<FONT COLOR="#993366"><%=CRUNDTE%></FONT></td>
           <td class="TD1" width="34%">Storage Fee:</td>
           <td class="TD2" width="17%">$<%=ALLT(STR(STGAMT,8,2))%></td>
         </tr>
         <tr>
           <td class="TD1" width="49%">Due Date:&nbsp;<FONT COLOR="#993366"><%=CBILLDTE%></FONT></td>
           <td class="TD1" width="34%">Late Fee:</td>
           <td class="TD2" width="17%">$<%=ALLT(STR(LATEAMT,6,2))%></td>
         </tr>
         <tr>
           <td class="TD1" width="49%">Last Pay Date:&nbsp;<FONT COLOR="#993366"><%=ldLASTPAYDTE%></FONT></td>
           <td class="TD1" width="26%">Sales Tax: <font color="#FF000"><%=IIF(TAX > 0,ALLT(STR(TAX,5,3))+'%','')%></FONT>&nbsp;</td>
           <td class="TD2" width="25%">$<%=pcTAXAMT%></td>
         </tr>
         <tr>
           <td class="TD1" width="49%">Last Pay Amount:&nbsp;<FONT COLOR="#993366">$<%=lnLASTPAY%></FONT></td>
           <td class="TD1" width="34%">Total Invoice:</td>
           <td class="TD2" width="17%" bgcolor="#E9E9EA">$<%=pcTOTAL%></td>
         </tr>
         </table>
<% IF !EMPTY(_STG.NOTES)%>
<br>
<table border="0" align="center" width="95%" bordercolor="#4E6699" style="border-collapse: collapse">
<tr>
  <td><center><font face="Verdana" color="#000080"><b>Storage Notes</b></center><br><FONT SIZE="2" COLOR="#000000"><%=ALLT(_STG.NOTES)%></font></FONT></td>
</tr>
</table>
<%ENDIF%>
<br>
<table border="1" width="95%" align="center" style="border-collapse: collapse" bordercolor="#31557B">
  <tr>
    <td width="100%" align="left"><font face="Verdana" size="2"><b><%=pcINVTEXT%>
    <% IF pcCUSTNO='FIRSTCHOIC'%><%='<br>'+ALLT(_STG.NOTES)%></b></font><%ENDIF%>&nbsp;</td>
 </tr>
</table>
&nbsp;</td>
 </tr>
</table>   
<p class="pagebreak">&nbsp;</p>
</body>
</html>