<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<TITLE>Storage Info</TITLE>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
<link rel="stylesheet" type="text/css" href="/zz/util/checkboxslide.css?v=1.1.4" media="screen" />
  
<script type="text/javascript">
jQuery.noConflict();

   jQuery(document).ready(function($){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) 
  {
    if (i==1) 
     { 
       document.theForm.action="/wc.dll?mpstg~storageeditret~<%=pcSCR%>~<%=pcSTORAGEID%>";
       document.theForm.submit();
     }
    if (i==2) 
	 {
		var Message = "Are you sure you want to delete this Storage?";
		if (confirm (Message))
		  {
			document.theForm.action="/wc.dll?mpstg~DeleteStorage~<%=pcSCR%>~<%=pcSTORAGEID%>";
	        document.theForm.submit();
	      }
     }

    if (i==3) 
     { 
       document.theForm.action="/wc.dll?mpstg~storagewc~<%=pcSCR%>";
       document.theForm.submit();
     }
  }

function invtext() {
    window.open('/wc.dll?mpstg~invoicetextwc~<%=pcSCR%>~<%=pcSTORAGEID%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=1000,height=550');
	}

</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.DELETE	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.DELETEON	{	color: #FFFFFF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #FF0000;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#F7F7F7"><br>

<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center" height="19"><font face="Verdana" size="4" color="#FFFFFF">Storage Information</font></b></td>
  </tr>
    <td width="100%" align="center" bgcolor="#FFFFFF"><br>	
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="61%" valign="top">
    <form name="theForm" method="POST">
    <input type="hidden" name="DEL" value="<%=plDEL%>">
<%SELECT _STORAGE%>    
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Active</font></td>
    <td width="78%" height="19" colspan="2">
    <%IF EMPTY(pcMSG) %>
    <label class="switch"><input type="checkbox" id="togBtn" name="ACTIVE" value="ON" <%=IIF(ACTIVE,'checked','')%>><div class="slider round"></div></label>
    <b><font face="Verdana" color="#<%=IIF(ACTIVE=.T.,'008000','FF0000')%>"><%=IIF(ACTIVE=.T.,'Active','Not Active')%></font></b>
	<%ELSE%>
    &nbsp;&nbsp;<b><font face="Verdana"><%=pcMSG%></font></b>
    <%ENDIF%></td>
  </tr>
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Storage ID</font></td>
    <td width="78%" height="19" colspan="2"><%IF pnSTORAGEID=0%><input type="text" autocomplete="off" name="STGNO" size="11" value="<%=ALLT(STGNO)%>" maxlength="10">&nbsp;&nbsp;<b><font face="Verdana" size="2" color="#0081D3">3 to 10 Characters</font></b>
    <%ELSE%><b><font face="Verdana" color="#008000"><B><%=ALLT(pcSTGNO)%></font></b><%ENDIF%></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">Address</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="ADD1" size="25" value="<%=ALLT(ADD1)%>" maxlength="30"></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">City</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="CITY" size="25" value="<%=ALLT(CITY)%>"></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">State</font></td>
    <td width="23%" height="18">
      <select size="1" name="STATEID" tabindex="6">
		  <option selected value="<%=pcSTATEID%>"><%=pcSTATE%></option>
		  	<% SELECT _STATE
				 	 SCAN %>
			   	<option value="<%=ALLT(STR(STATEID))%>"><%=ALLT(STATE)%></option>
				 <% ENDSCAN %>
		  </select></td>
<%	SELECT _STORAGE%>				
    <td width="55%" height="18"><font face="Verdana" size="2">Zip Code</font>&nbsp;<input name="ZIP" size="5" value="<%=ALLT(ZIP)%>"></td>
  </tr>              
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Country</font></td>
    <td width="78%" height="19" colspan="2"><input type="text" name="COUNTRY" size="20" value="<%=ALLT(COUNTRY)%>"></td>
  </tr>
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Phone</font></td>
    <td width="78%" height="19" colspan="2"><input type="text" name="PHONE" size="20" value="<%=ALLT(PHONE)%>"></td>
  </tr>  
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Fax</font></td>
    <td width="78%" height="19" colspan="2"><input type="text" name="FAX" size="20" value="<%=ALLT(FAX)%>"></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">Contact</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="CONTACT" size="25" value="<%=ALLT(CONTACT)%>"></td>
  </tr>  
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">Email</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="EMAIL" size="30" value="<%=ALLT(EMAIL)%>"></td>
  </tr>  
</table>
 <br><font face="Verdana" size="2" color="#0081D3"><b>Storage Invoice Billing Information</b></font>
 <% SELECT _STORAGE %>
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Company</font></td>
    <td width="78%" height="19" colspan="2"><input type="text" name="SCOMPANY" size="30" value="<%=ALLT(SCOMPANY)%>" maxlength="30"></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">Address</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="SADD1" size="30" value="<%=ALLT(SADD1)%>"></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">City</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="SCITY" size="25" value="<%=ALLT(SCITY)%>"></td>
  </tr>
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">State</font></td>
    <td width="23%" height="18">
               <select size="1" name="SSTATEID" tabindex="6">
		  <option selected value="<%=pcSSTATEID%>"><%=pcSSTATE%></option>
		  	<% SELECT _STATE
				 	 SCAN %>
			   	<option value="<%=ALLT(STR(STATEID))%>"><%=ALLT(STATE)%></option>
				 <% ENDSCAN %>
		  </select></td>
  <%SELECT _STORAGE%>				
    <td width="55%" height="18"><font face="Verdana" size="2">Zip Code</font>&nbsp;<input name="SZIP" size="5" value="<%=ALLT(SZIP)%>"></td>
  </tr>              
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Phone</font></td>
    <td width="78%" height="19" colspan="2"><input type="text" name="SPHONE" size="20" value="<%=ALLT(SPHONE)%>"></td>
  </tr>
  <tr>
    <td width="23%" height="19"><font face="Verdana" size="2">Fax</font></td>
    <td width="78%" height="19" colspan="2"><input type="text" name="SFAX" size="20" value="<%=ALLT(SFAX)%>"></td>
  </tr>  
  <tr>
    <td width="23%" height="18"><font face="Verdana" size="2">Email</font></td>
    <td width="78%" height="18" colspan="2"><input type="text" name="SEMAIL" size="30" value="<%=ALLT(SEMAIL)%>"></td>
  </tr>
</table>         
    </td>
    <td width="1%">&nbsp;</td>
    <td width="38%" valign="top">
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center" colspan="2"><font face="Verdana" size="2" color="#0081D3"><b>Storage Monthly Charge</b></font></td>
 </tr>
  <tr>
    <td width="54%"><font face="Verdana" size="2">Calculate $</font> <input type="text" autocomplete="off" name="PERAMT" size="3" value="<%=pcPERAMT%>"></td>
    <td width="48%">    
    <select size="1" name="PERCALC" tabindex="6">
		  <option selected value="<%=pcPERCALC%>"><%=pcPERTXT%></option>
		  <option value="C">per 100 CF</option>
		  <option value="L">per 1000 Lbs</option>
		  <option value="V">per Crate/Vault</option>
		  </select></td>
 </tr>
</table>
 <br>
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;font-family:Arial;font-size:10pt;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" height="30" align="center" colspan="2"><font face="Verdana" size="2" color="#0081D3"><b>Storage Invoice</b></font></td>
 </tr>
  <% IF 1=2 %> 
  <tr>
    <td width="72%"><font face="Verdana" size="2">Run Invoices on Day of Month</font></td>
    <td width="30%"><input type="text" name="INVRUNDAY" size="1" value="<%=ALLT(STR(INVRUNDAY))%>" maxlength="2"></td>
 </tr>
  <%ENDIF%> 
  <tr>
    <td width="72%"><font face="Verdana" size="2">Add State Sales Tax</font></td>
    <td width="30%"><input type="text" name="TAX" size="2" value="<%=ALLT(STR(TAX,6,3))%>"><font face="Verdana" size="2">%</font></td>
 </tr>
  <tr>
    <td width="72%"><font face="Verdana" size="2">Add Late Fee</font></td>
    <td width="30%"><input type="text" name="LATEFEE" size="2" value="<%=ALLT(STR(LATEFEE,6,2))%>"><font face="Verdana" size="2">$</font></td>
 </tr>
</table>
 <br>
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;font-family:Arial;font-size:10pt;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" height="30" align="center" colspan="2"><font face="Verdana" size="2" color="#0081D3"><b>Miscellaneous</b></font></td>
 </tr>
  <tr>
    <td width="49%"><font face="Verdana" size="2">Storage Open Date</font></td>
    <td width="53%"><input type="text" id="Date1" name="OPENDTE" size="7" value="<%=ALLT(DTOC(OPENDTE))%>"></td>
 </tr>
  <tr>
    <td width="49%"><font face="Verdana" size="2">Storage Close Date</font></td>
    <td width="53%"><input type="text" id="Date2" name="CLOSEDTE" size="7" value="<%=ALLT(DTOC(CLOSEDTE))%>"></td>
 </tr>
</table>
<table border="0" ALIGN="CENTER" cellpadding="0" cellspacing="0" style="border-collapse:collapse;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" height="35" align="center"><u><b><font Face="Arial" onclick="invtext()" style="cursor:pointer;" color="#0000FF">Storage Invoice Policy</font></b></u></td>
 </tr>
</table>
    </td>
 </tr>
</table>
  <BR>
<table border="0" width="90%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="16%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Submit"></td>
    <td width="19%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(3)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Exit"></td>
    <td width="13%" align="right"><%IF pnSTORAGEID > 0 %><input type="button" CLASS="DELETE" name="B31" onclick="submitFunction(2)" onmouseover="javasctript: this.className='DELETEON'" onmouseout="javasctript: this.className='DELETE'" tabindex="12" value="Delete"><%ENDIF%></td>
 </tr>   
</table>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="95%">
  <tr>
    <td width="100%" align="center" height="30" valign="bottom"><b><font face="Verdana" style="font-size:11pt;" color="#0081D3">Internal Notes</font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea rows="5" name="NOTES" cols="85"><%=ALLT(NOTES)%></textarea></td>
 </tr>
</table>
</form>
  &nbsp;</td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>

</body>
</html>