<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Manual Invoice-<%=RIGHT(pcORDNO,4)%></title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
   $(document).ready(function(){
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
   });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitA() {
      { 
       document.theForm.action="/wc.dll?mpstg~ManualStgCrgRet~<%=pcSCR%>~<%=lcSTGID%>";
       document.theForm.submit();
      } ;
	}
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 90;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 90;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 90;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>
<body BGCOLOR="#4E6699">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="95%" align="center">
   <tr>
    <td width="100%" align="center" BGCOLOR="#008200" height="18"><b><font face="Verdana" color="#FFFFFF">Create Storage Invoice</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">	
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center"><BR>
     <form name="theForm" method="POST"> 		
<table border="1" align="center" width="98%" cellspacing="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
	<td width="51%" height="20" colspan="2"><font face="Verdana" size="2">Invoice Date: <%=DATE()%></font></td>
	<td width="49%" height="20"><font face="Verdana" size="2">Last Move Payment:&nbsp;<FONT color="#008000"><%=lcLASTPAY%> - <%=lcPAYAMT%></font></td>
 </tr>
  <tr>
	<td width="51%" height="20" colspan="2"><FONT face="Verdana" size="2">Next Bill Date: </font>
	<input type="text" id="Date1" name="CBILLDTE" size="8" value="<%=ALLT(_STG.CBILLDTE)%>" tabindex="15" style="font-size: 9pt"></td>
	<td width="49%" height="20"><font face="Verdana" size="2">Move Balance:<FONT color="#FF0000"><%=lcBALANCE%></font></td>
 </tr>
  <tr>
	<td width="51%" height="20" colspan="2"><font face="Verdana" size="2">Storage Fee:</FONT>&nbsp;<input type="text" name="STGAMT" size="8" value="<%=ALLT(STR(_STGINV.STGAMT,8,2))%>" tabindex="3" style="font-size: 9pt"></td>
	<td width="49%" height="20"><font face="Verdana" size="2">Last Storage Payment:&nbsp;<FONT color="#008000"><%=lcLASTSTG%> - <%=lcPAYSTG%></font></td>
 </tr>
  <tr>
	<td width="24%" height="20"><font face="Verdana" size="2">Late Fee:</font>&nbsp;<input type="text" name="LATEAMT" size="4" maxlength="8" tabindex="4" style="font-size: 9pt" value="<%=ALLT(STR(_STGINV.LATEAMT,6,2))%>"></td>
	<td width="27%" height="20"><font face="Verdana" size="2">Tax:</font>&nbsp;<input type="text" name="TAX" size="6" maxlength="8" tabindex="5" style="font-size: 9pt" value="<%=ALLT(STR(_STGINV.TAX,6,3))%>">%</td>
	<td width="49%" height="20"><font face="Verdana" size="2">Storage Balance:<b><FONT color="#FF0000"><%=lcBALSTG%></b></font></td>
 </tr>
  <tr>
	<td width="51%" height="20" colspan="2"><font face="Verdana" size="2">Remarks:</FONT>&nbsp;<input SIZE="25" MAXLENGTH="120" name="INVNOTES" tabindex="6" style="font-size: 9pt" value="<%=ALLT(_STGINV.INVNOTES)%>"></td>
	<td width="49%" height="20">&nbsp;</td>
 </tr>
  <tr>
	<td width="100%" height="20" colspan="3">
<table border="0" align="center" width="40%" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0" cellpadding="0">
  <tr>
	<td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitA()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
	<td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="javascript: window.close()" onmouseover="javasctript: this.className='SUBONEXIT'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
 </tr>
</table>
    </td>
  </tr>
	</table>	
</form>
</td></tr>
    </tr></table></td>
  </tr>
  <tr>
  <td width="100%" bgcolor="#FFFFFF">
		<table border="1" width="98%" cellspacing="0" align="center" style="border-collapse: collapse" bordercolor="#C0C0C0">
		 <tr>
		  <td>
			<table border="0" width="100%" cellspacing="0" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
			  <tr>
		    	<td width="100%" bgcolor="#008200" align="center"><font color="#FFFFFF" face="Verdana"><b>Previous Charges</b></font></td>
			  </tr>
			</table>
			<table border="1" bgcolor="#FFFFFF" width="100%" cellspacing="0">
			  <tr style="font-family:Verdana;font-size:9pt;color:#FFFFFF;">
			    <td width="4%" bgcolor="#4E6699"><b>Invoice Date</b></td>
			    <td width="4%" bgcolor="#4E6699"><b>Due Date</b></td>
			    <td width="6%" bgcolor="#4E6699"><b>Storage Fee</b></td>
			    <td width="3%" bgcolor="#4E6699"><b>Late Fee</b></td>
			    <td width="6%" bgcolor="#4E6699"><b>Sales Tax</b></td>
			    <td width="5%" bgcolor="#4E6699"><b>User</b></td>
			    <td width="13%" bgcolor="#4E6699"><b>Remarks</b></td>
			  </tr>
	<% SELECT _STGINV1
	   SCAN %>		  
			  <tr>
			    <td width="4%"><font face="Verdana" size="2"><%=ALLT(CRUNDTE)%></font>&nbsp;</td>
			    <td width="4%"><font face="Verdana" size="2"><%=ALLT(CBILLDTE)%></font>&nbsp;</td>
			    <td width="6%" align="right"><font face="Verdana" size="2"><%=ALLT(STR(STGAMT,8,2))%></font>&nbsp;</td>
			    <td width="3%" align="right"><font face="Verdana" size="2"><%=ALLT(STR(LATEAMT,8,2))%></font>&nbsp;</td>
			    <td width="6%" align="right"><font face="Verdana" size="2"><%=ALLT(STR(TAXAMT,8,2))%></font>&nbsp;</td>
			    <td width="5%"><font face="Verdana" size="2"><%=USER%></font>&nbsp;</td>
			    <td width="13%"><font face="Verdana" size="2"><%=INVNOTES%></font>&nbsp;</td>
			  </tr>
	<% ENDSCAN %>
			</table>
	</td></tr></table>            
    </td>
  </tr>
  </table>
</body>
</html>