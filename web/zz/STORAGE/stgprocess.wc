<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Storage Process</title>

<!--DROPDOWN STORAGE SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN STORAGE SEARCH-->

<script type="text/javascript">

  $(document).ready(function() {
      $('.storage-select').select2({
          placeholder: 'Select Storage',
          allowClear: true
      });
  });
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpstg~stgprocessret~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="600">
  <tr>
    <td width="100%" BGCOLOR="#4E6699" align="center" height="20"><b><font face="Verdana" size="4" color="#FFFFFF">Storage Process</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="7">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
   <tr>
     <td width="100%" align="center"><br>
<form name="theForm" method="POST">     
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="95%" cellspacing="1" cellpadding="1">
   <tr>
     <td width="26%">&nbsp;<b><font face="Verdana" size="2">Storage:</font></b></td>
     <td width="74%">
	<select size="1" name="STORAGEID" class="storage-select" style="width: 190px;">
		<option selected></option>
		 <%	SELECT _STORAGE
	 	 	SCAN %>
	   		<option value="<%=ALLT(STR(STORAGEID))%>"><%=ALLT(STGNO)%></option>
		 <% ENDSCAN %>
		</select></td>
  </tr>
   <tr>
     <td width="100%" colspan="2">&nbsp;<b><font face="Verdana" size="2">Search Job in Storage:</font></b> <input type="text" autocomplete="off" name="ORDNO" size="10" value="" style="font-size: 9pt"></td>
  </tr>  
</table>
 <br>
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:30px;" bordercolor="#111111" width="95%" cellspacing="1" cellpadding="1">
  <tr>
	<td width="8%" align="center"><input class="chkon" type="radio" name="STATUS" value="V1"></td>
	<td width="44%"><font face="Verdana" size="2">Jobs in Storage</font></td>
	<td width="15%"><font face="Verdana" size="2">Sort By:</td>
	<td width="35%">
	<select size="1" name="SORT">
	<option selected>Job No</option>
	<option>Date In</option>
	<option>Bill Date</option>
	<option>Customer</option>
	<option>Move Type</option>
	</select></td>
 </tr>
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V2"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Storage Jobs in SIT</font></td>
 </tr>
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V4"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Storage Jobs with Delivery Date Out</font></td>
 </tr>  
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V5"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Storage Jobs Past 30 Days Without Payment</font></td>
 </tr> 
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V6"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Jobs not Assigned to Storage (30 days 
    past move date)</font></td>
 </tr>
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V7"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Jobs in Storage with Balance Due</font></td>
 </tr> 
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V8"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Customers Need Storage</font></td>
 </tr>
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V9"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Storage Jobs with Crates/Vaults</font></td>
 </tr>
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V10"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Follow-Up on Storage Customers</font></td>
 </tr> 
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V11"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">Run Monthly Invoices Cycle</font></td>
 </tr>
  <tr>
	<td width="8%" align="center"><input type="radio" name="STATUS" value="V12"></td>
	<td width="92%" colspan="3"><font face="Verdana" size="2">View Previous Invoices Cycles</font></td>
 </tr> 
</table> 
<table border="0" width="95%" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">    
  <tr>
    <td height="35"><b><font face="Verdana" size="2" color="#FF0000"><%=pcMSG%></font></b></td>
  </tr> 
</table>
<table border="0" width="90%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="submitFunction(1)"  value="Submit"></td>    
	<td width="49%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="javascript: window.close()" value="Exit"></td>
 </tr>
</table>        
&nbsp;</td>
  </tr>
</table>
</form>
    </td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#4E6699" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>
</body>
</html>