<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Posting & Active Tariff</title>
<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {

   if (i==1)
    { 
 	  var Message = "Are you sure you want to create a new tariff?";
	  if (confirm (Message)){
         document.theForm.action="/wc.dll?mpmainten~Tariffprmwc~<%=pcSCR%>";
         document.theForm.submit()
 	  }
 	}
 	
    if (i==2) 
    {
        document.theForm.action="/wc.dll?mpmainten~TariffMenuWc~<%=pcSCR%>";
        document.theForm.submit()
    }
}

function activetariff(par) {
   var Message = "Are you sure you want to Post this tariff?";
	if (confirm (Message)){
     document.theForm.action="/wc.dll?mpmainten~TariffPostWc~<%=pcSCR%>~"+par;
       document.theForm.submit();
      } 
	}


</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}					
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="870">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Posting &amp; Active Tariff </font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
  <form name="theForm" method="POST">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" width="99%">
   <tr>
     <td width="3%" class="TD1">ID</td>
     <td width="8%" class="TD1" style="border-left: 1px solid #A9A9A9;">Created By</td>
     <td width="11%" class="TD1" style="border-left: 1px solid #A9A9A9;">Posted By</td>
     <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Calculator</td>
     <td width="10%" class="TD1" style="border-left: 1px solid #A9A9A9;">Active</td>
     <td width="6%" class="TD1" colspan="2" style="border-left: 1px solid #A9A9A9;">Print</td>
     <td width="14%" class="TD1" colspan="2" style="border-left: 1px solid #A9A9A9;">CF/Lbs Ratio</td>
     <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Minimum</td>
  </tr>
  <% SELECT _DMAIN		
     SCAN%>  			
   <tr>
     <td width="3%" class="TD4" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><%=ALLT(STR(DMAINID))%>&nbsp;</td>
     <td width="8%" class="TD3" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>"><%=ALLT(PROPER(USERNAME))%>:&nbsp;<%=TTOC(DTE)%></td>
     <td width="11%" class="TD3" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>"><%IF EMPTY(POSTDTE)%>&nbsp<%ELSE%><%=ALLT(PROPER(POSTUSER))%>:&nbsp;<%=TTOC(POSTDTE)%><%ENDIF%></td>
     <td width="4%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><a href="/wc.dll?mpmainten~TariffTestRateWc~<%=pcSCR%>~<%=ALLT(STR(DMAINID))%>" target="_blank">Calculate</a></td>
     <td width="9%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center">
  <%IF EMPTY(POSTIP)%>
     <B><font COLOR="#0000FF" style="cursor:pointer;" onclick="activetariff(<%=ALLT(STR(DMAINID))%>)"><u>Post to Activate</u></font></b>
  <%ELSE%>
     <b><%=IIF(ACTIVE,'Active','      ')%></b>
  <%ENDIF%></td>
     <td width="3%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><a href="/wc.dll?mpmainten~TariffPrint~<%=pcSCR%>~<%=ALLT(STR(DMAINID))%>~CF" target="_blank">CF</a></td>
     <td width="4%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><a href="/wc.dll?mpmainten~TariffPrint~<%=pcSCR%>~<%=ALLT(STR(DMAINID))%>~LBS" target="_blank">LBS</a></td>
     <td width="5%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><b><%=IIF(CALCCF=.T.,'Cu.Ft.','Lbs')%></b>&nbsp;</td>
     <td width="5%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><b><%=ALLT(STR(CFRATIO,7,2))%></b>&nbsp;</td>
     <td width="3%" class="TD2" bgcolor="#<%=IIF(MOD(RECNO(),2)=0,'CCCCFF','FFFFFF')%>" align="center"><b><%=IIF(MINVOL=.T.,IIF(CALCCF=.T.,'volume','weight'),'$$$')%></b>&nbsp;</td>
  </tr>
<% ENDSCAN %>
</table>
 <BR>
<table border="0" width="70%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
   <%IF plCREATENEW %>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="5" value="Create New Tariff"></td>    
  <%ENDIF%>    
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="6" value="Exit"></td>    
 </tr>
</table>
    </form></td>
</tr>
  <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>