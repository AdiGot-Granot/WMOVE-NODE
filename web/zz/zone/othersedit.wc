<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Accessorial Services</title>
<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~OthersEditRet~<%=pcSCR%>~<%=pcEmainId%>~OTHERS";
       document.theForm.submit();
      }
 }

function CheckBoxes(FormName, CheckValue){
   if(!document.forms[FormName])
      return;
   var objCheckBoxes = document.getElementsByTagName('input');
   if(!objCheckBoxes)
      return;
   var countCheckBoxes = objCheckBoxes.length;
   if(!countCheckBoxes)
      objCheckBoxes.checked = CheckValue;
   else
      for(var i = 0; i < countCheckBoxes; i++)
      objCheckBoxes[i].checked = CheckValue;
}

</SCRIPT>


<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}		
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="50%"> 
  <tr>
    <td BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Accessorial Services - ID # <font color="#FBBC05"><%=pcEmainId%></font></font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
<FORM NAME="theForm" method="post">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111" width="98%">
   <tr>
     <td width="3%" class="TD1">#</td>
     <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Seq</td> 
     <td width="36%" class="TD1" style="border-left: 1px solid #A9A9A9;">Service Description</td>
     <td width="10%" class="TD1" style="border-left: 1px solid #A9A9A9;">Basic Price</td>
     <td width="16%" class="TD1" style="border-left: 1px solid #A9A9A9;">Add Price to<br>Every <%=IIF(plCOCALCCF,'100 cf',ALLT(STR(ROUND(pnCFRATIO*100,0)))+' lbs')%></td>
     <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Long Dist.</td>
     <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Local</td>
     <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Active <input name="checkall" type="checkbox" onclick="CheckBoxes('theForm',this.checked);" value="ON" /></td>
 </tr>
   <% SELECT _EPRC  
      SCAN %>
  <tr  style="line-height:22px;">
     <td width="3%" align="center" style="border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>"><font style="font-size:8pt;font-family:Verdana;"><%IF EprcId > 1000%><%=ALLT(STR(RECNO()))%>.<%ENDIF%></font></td>   
     <td width="5%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>">
     <input NAME="<%='SEQ-'+ALLT(STR(EprcId)) %>" size="1" VALUE="<%=IIF(SEQ=0,'',ALLT(STR(SEQ))) %>" style="font-size: 9pt" maxlength="3"></td>
 <% SELECT _EPRC%>     
     <td width="36%" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>">
  <%IF !POSTED OR EprcId < 20%>   
     <input NAME="<%='CNAME-'+ALLT(STR(EprcId))%>" size="35" VALUE="<%=ALLT(CNAME)%>" style="font-size: 10pt" maxlength="100">
  <%ELSE%>
     <b><font style="font-size:10pt;font-family:Verdana;"><%=ALLT(CNAME)%></font></B>
  <%ENDIF%></td>   
     <td width="10%" align="right" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>"><font style="font-size:10pt;font-family:Verdana;">
  <%IF !POSTED OR EprcId < 20 %>   
    $<input NAME="<%='BASIC-'+ALLT(STR(EprcId)) %>" size="3" VALUE="<%=ALLT(STR(BASIC,7,2))%>" style="font-size: 10pt;text-align:right;" maxlength="6">
  <%ELSE%>
     <b><font color="#008000"><%='$'+ALLT(STR(BASIC,7,2))%></FONT></b>
  <%ENDIF%></font></td>        
     <td width="16%" align="right" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>"><font style="font-size:10pt;font-family:Verdana;">
  <%IF !POSTED OR EprcId < 20 %>   
     $<input NAME="<%='ADDPRC-'+ALLT(STR(EprcId)) %>" size="3" VALUE="<%=ALLT(STR(ADDPRC,7,2))%>" style="font-size: 10pt;text-align:right;" maxlength="6">
  <%ELSE%>
     <b><font color="#008000"><%='$'+ALLT(STR(ADDPRC,7,2))%></FONT></b>
  <%ENDIF%></font></td>        
     <td width="9%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>"><input type="checkbox" name="<%='LD-'+ALLT(STR(EprcId))%>" value="ON" <%=IIF(LD=.T.,'checked','')%>></td>        
     <td width="7%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>"><input type="checkbox" name="<%='LOCAL-'+ALLT(STR(EprcId))%>" value="ON" <%=IIF(LOCAL=.T.,'checked','')%>></td>        
     <td width="9%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" bgcolor="#<%=IIF(ACTIVE,'FFFFFF','CCCCFF')%>">
     <%IF EPRCID > 5999%><input type="checkbox" name="<%='ACTIVE-'+ALLT(STR(EprcId))%>" value="ON" <%=IIF(ACTIVE=.T.,'checked','')%>><%ENDIF%></td>
  </tr>
 <% ENDSCAN %>
</table>			
 <br>  
<table border="0" align="center" style="border-collapse: collapse" width="50%">
  <tr>
    <td align="center"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="B5" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
    <td align="center"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="B5" onclick="javascript: window.close()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
  </tr>
 </table>    
</form>    
    <br></td>
  </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
</table>

</body>
</html>