<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Tariff Definitions</title>
<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
   if (i==1)
    { 
 	  var Message = "Please confirm your Tariff Definitions?";
	  if (confirm (Message)){
         document.theForm.action="/wc.dll?mpmainten~TariffNewRate~<%=pcSCR%>";
         document.theForm.submit()
 	  }
    }
 }	
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 110;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 110;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="500">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Tariff Definitions</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
  <form name="theForm" method="POST">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111" width="450">
   <tr>
     <td align="center" class="TD1" width="116">Calculate by</td>
     <td align="center" class="TD1" style="border-left: 1px solid #A9A9A9;" colspan="2" width="217" >Minimum By</td>
     <td align="center" class="TD1" style="border-left: 1px solid #A9A9A9;" width="155">Cf / Lbs Ratio</td>
  </tr>
   <tr>
     <td align="center" style="border-bottom: 1px solid #A9A9A9;" width="116"><font style="font-size:11pt;font-family:Verdana;"><b><%=IIF(plCOCALCCF,'Cu. Ft.','LBS')%></b></font>&nbsp;</td>
     <td align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" width="107"><input type="radio" value="V0" name="MINVOL" <%=IIF(!plMINVOL,'checked','')%>><font style="font-size:10pt;font-family:Verdana;">$$$</font></td>
     <td align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" width="106"><input type="radio" value="V1" name="MINVOL" <%=IIF(plMINVOL,'checked','')%>><font style="font-size:10pt;font-family:Verdana;">Volume</font></td>
     <td align="right" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" width="155">&nbsp;<input type="text" name="CFRATIO" size="2" value="<%=ALLT(STR(pnCFRATIO,5,2))%>" style="text-align: right;" READONLY></td>
  </tr>
</table>
 <BR>
<table border="0" width="65%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="5" value="Submit"></td>    
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="javascript:window.close()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="6" value="Exit"></td>    
 </tr>
</table>
    </form>&nbsp;</td>
</tr>
  <tr>
    <td width="100%" bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>