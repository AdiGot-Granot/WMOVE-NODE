 <form name="theForm" method="POST">
<table border="1" align="center" cellpadding="1" cellspacing="1" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#C0C0C0" width="98%">
  <tr>
    <td width="6%" align="center" bgcolor="#008000"><font color="#FFFFFF"><b>#</b></font></td>
    <td width="9%" align="center" bgcolor="#008000"><font color="#FFFFFF"><b>State</b></font></td>
    <td width="36%" align="center" bgcolor="#008000"><font color="#FFFFFF"><b>City</b></font></td>    
    <td width="15%" align="center" bgcolor="#008000"><font color="#FFFFFF"><b>Zip Code</b></font></td>
    <td width="18%" align="center" bgcolor="#008000"><font color="#FFFFFF"><b>Radius</b></font></td>
    <td width="22%" align="center" bgcolor="#008000"><font color="#FFFFFF"><b>
    Delete</b></font></td>
 </tr>
<% SELECT _TZONE
  SCAN %>
  <tr>
    <td width="6%" align="center"><b><%=ALLT(STR(RECNO()))%></b>&nbsp;</td>
    <td width="9%" align="center"><input NAME="<%='S-'+ALLT(STR(TzoneId))%>" size="1" VALUE="<%=ALLT(STATE)%>" tabindex="1"></td>
    <td width="42%">
    <input NAME="<%='N-'+ALLT(STR(TzoneId))%>" size="25" VALUE="<%=ALLT(CNAME)%>" tabindex="3"></td>
    <td width="5%" align="center"><input NAME="<%='Z-'+ALLT(STR(TzoneId))%>" size="3" VALUE="<%=ALLT(ZIP)%>" tabindex="2" maxlength="5"></td>    
    <td width="18%" align="center"><input NAME="<%='R-'+ALLT(STR(TzoneId))%>" size="2" VALUE="<%=ALLT(STR(RADIUS))%>" tabindex="4" maxlength="4">miles</td>
    <td width="22%" align="center"><% IF TZONEID>0 %><input type="checkbox" name="<%='D-'+ALLT(STR(TzoneId))%>" value="ON"><%ENDIF%></td>
 </tr>
<% ENDSCAN %>
    </table>			
		<BR>
<table border="0" align="center" width="60%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="22%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
	<td width="22%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>    
 </tr>
</table>
 </form>    
   </td>
 </tr>
  <tr>
    <td width="100%" colspan="2" background="/zz/images/bgdown.gif">&nbsp;</td>
  </tr>
  </table>
</body>
</html>