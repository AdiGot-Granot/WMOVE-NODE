<script language="JavaScript" src="/zz/util/statemap.js"></SCRIPT>

<title>Zone Table-Regions</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

jQuery( document ).ready(function( $ ) {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 550,
		maxHeight	: 400,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

function submitFunction(i) {

     if (i==1) 
     { 
      	document.theForm.action="/wc.dll?mpmainten~TzoneRet~<%=pcSCR%>";
       	document.theForm.submit();
     }


    if (i==2) 
    {
    	document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=+pcSCR%>";
    	document.theForm.submit()

    }
}

</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
