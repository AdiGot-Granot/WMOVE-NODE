<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Repository Menu</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~1';
    if (i==2) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~2';
    if (i==3) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~3';
    if (i==4) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~4';
    if (i==5) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~5';
    if (i==6) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~6';
    if (i==7) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~7';
    if (i==8) window.location.href='/wc.dll?mpreposit~arenamenuret~<%=pcSCR%>~8';
	}

</SCRIPT>

<STYLE TYPE="text/css">
	.txtoff		{	color: #000000;
				  	font-size: 10pt;
  				  	font-family: verdana;
					font-weight: bold;
  				  	cursor: Hand;
					background-color: white;
				  	text-align: left}
	.txton		{	color: #000000;
				  	font-size: 10pt;
				  	text-align: left;
  				  	font-family: verdana;
					font-weight: bold;
					background-color: white;
					text-decoration: underline;
  				  	cursor: Hand}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

<body BGCOLOR="#ADBACE">
<br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="500" align="center" height="284">
  <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">
    </td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#4A698C" colspan="2" height="26">
    <p align="center"><b>
    <font color="#FFFFFF" face="Verdana">Online 
    Estimates Menu</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" colspan="2" height="211">
	
	<!-- Main -->

	<!-- frame table -->
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" height="210">
	  <tr>
	    <td width="100%" height="1">

    <!-- Body & Column -->
    </td>
  </tr>
  <tr>
    <td width="100%" align="center" height="210">
	
	<!--- Main -->

		<table border="0" width="80%" cellpadding="0" cellspacing="0" align="center">
		    <tr><td valign="top" width="50%">

			  <!-- Menu A-->
				<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="148%">
<%IF !plBK_SALE%>
				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(1)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Online Estimates</font></td>
				  </tr>
				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(2)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Favorites</font></td>
				  </tr>
 				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(7)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Add Deposit</font></td>
				  </tr>
 				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(3)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Modify Favorites</font></td>
				  </tr>
 				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(8)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Movers Arena Terms</font></td>
				  </tr>
<%ENDIF%>
				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(4)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Reports</font></td>
				  </tr>
<%IF plBK_SALE and 1=2%>
				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(5)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">List of Jobs for Sale</font></td>
				  </tr>
<%ENDIF%>
<%IF plBK_SALE%>
				  <tr>
				    <td width="5%" height="30" style="text-align: center"><img border="0" src="zz/images/point.gif" width="8" height="7"></td>
				    <td width="95%" height="30"><font class="txtoff" onclick="submitFunction(6)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">
                    Alter Estimates' Prices</font></td>
				  </tr>
<%ENDIF%>
				  </table>
				
		  <!-- Menu A-->

		  </td></tr></table>
	<!-- Menu -->

	<!-- Command Buttons -->

    </td>
  </tr>
</table>
<!-- frame table -->

    </td>
  </tr>
<tr>
    <td width="50%" BGCOLOR="#4A698C" height="19">
      <b>
      <font color="#FFFFFF" face="Verdana" size="2">
      &nbsp;User:<%=pcUSER%></font></b></td>
    <td width="50%" BGCOLOR="#4A698C" height="19">
      <p align="right"><b><font color="#FFFFFF" face="Verdana" size="2"><%=datetime()%>&nbsp;&nbsp;</font></b></td>
</tr>
   <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">&nbsp;</td>
 </tr>
</table>

</body>

</html>