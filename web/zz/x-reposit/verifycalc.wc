<html xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns="http://www.w3.org/TR/REC-html40">

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Moving Leads</title>
<LINK REL="STYLESHEET" TYPE="text/css" href="/granot/mystyle.css" />
<SCRIPT LANGUAGE="JAVASCRIPT">
function sf(){
	document.theForm.btnContinue.focus();
}

function VerifyLeads(){
       frm=document.theForm ;
		<%IF _S.SERVERID=="PROD"%>
       		frm.action='https://secure.granot.com/wc.dll?isweb~verifycalcret';
		<%ELSE%>
       		frm.action='/wc.dll?isweb~verifycalcret';
		<%ENDIF%>
	
       frm.submit();
}


function recalcleads(){
	var frama=document.theForm ;
	for (var i=0; i < frama.length; i++){
		// validate zip
		if (frama.elements[i].type=="text" && frama.elements[i].name.charAt(0)=="Z" && frama.elements[i].value!="" && frama.elements[i].value<10000) {
			alert("Please provide valid five digits zip code (US only)");
			frama.elements[i].focus();
			return};

		// validate radius
		if (frama.elements[i].type=="text" && frama.elements[i].name.charAt(0)=="R" && frama.elements[i].value!="" && frama.elements[i].value<100) {
			alert("Please provide valid radius (100-300 miles)");
			frama.elements[i].focus();
			return};
			
		// check zip and radius
		//if (frama.elements[i].type=="text" && frama.elements[i].name.charAt(0)=="Z" && frama.elements[i].value=="" && frama.elements[i+1].value!="" ) {
		//	alert("Please provide valid zip code");
		//	frama.elements[i+1].focus();
		//	return};

		// check radius and zip
		if (frama.elements[i].type=="text" && frama.elements[i].name.charAt(0)=="R" && frama.elements[i].value=="" && frama.elements[i-1].value!="" ) {
			alert("Please provide valid radius (100-300 miles)");
			frama.elements[i].focus();
			return};
			
		// check zip and leads type selection
		if (frama.elements[i].type=="text" && frama.elements[i].name.charAt(0)=="Z" && frama.elements[i].value!="" && frama.elements[i+2].checked==false && frama.elements[i+3].checked==false && frama.elements[i+4].checked==false && frama.elements[i+5].checked==false) {
			alert("Please select at least one type of leads.");
			frama.elements[i+2].focus();
			return};
	}
	frama.action='/wc.dll?isweb~recalcret';
    frama.submit();

}

</SCRIPT>
</head>
<body bgcolor="#ADBACE" onload="sf()">
