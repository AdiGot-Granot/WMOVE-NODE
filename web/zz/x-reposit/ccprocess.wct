FUNCTION __CCPROCESS
TEXT<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Secure Payment</title>

<script language="JavaScript" type="text/JavaScript">

function SubmitPayment() {
		if (checkData()) {
			document.theForm.action='https://www.skipjackic.com/scripts/evolvcc.dll?Authorize';
			document.theForm.submit();
			}
      }

function checkData(){
	frm = document.theForm;
	return  lengthValid(frm.sjname, 4,"full name") 
			&& emailValid(frm.email, 4,"Email")
			&& zipValid(frm.shiptophone, 10, "phone number (10 digits)")
			&& lengthValid(frm.streetaddress, 4,"street address")
			&& lengthValid(frm.city, 2,"city")
			&& selectValid(frm.state, "state") 
			&& zipValid(frm.zipcode, 5, "zip code (US only)")
			&& zipValid(frm.accountnumber, 15, "credit card number")
			&& selectValid(frm.month, "month")
			&& selectValid(frm.year, "year");
	}

//function to validate by length
function lengthValid(field, len, text) {
    // text = Trim(text);
	if (field.value.length < len)
  	{
 	  	alert("Please enter a valid " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}

//function to validate numerical fields
function numberValid(field, text) {
    //text = Trim(text);
	if (isNaN(field.value))
  	{
 	  	alert("Please enter a valid " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}


//function to validate Zip Codes, Credit Card, and Phone Numbers fields
function zipValid(field,len, text) {
    //text = Trim(text);
	if (isNaN(field.value) || field.value.length < len)
  	{
 	  	alert("Please enter a valid " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}


//function to validate email
function emailValid(mailfield, len, text) {
   // text = Trim(text);
	if(mailfield.value.length < len || mailfield.value.indexOf("@") < 1 || mailfield.value.indexOf(".") < 2)
	{
	    alert("Please enter a valid " + text + ".");
		mailfield.focus();
		return false;
	}else{
		return true;
	}
}

//function to validate select drop-downs
function selectValid(field, text) {
    //text = Trim(text);
	if (field[0].selected)
  	{
 	  	alert("Please select a " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}
</script>
</head>

