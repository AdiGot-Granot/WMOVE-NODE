    <b><font face="Verdana" size="2">Leads Balance:&nbsp;<%=ALLT(STR(pnLEADSBAL+pnLEADSXBAL))%>&nbsp;&nbsp;&nbsp;</font></b></td>

  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="355" colspan="2">
	
	<!-- Main -->

	<!-- frame table -->
