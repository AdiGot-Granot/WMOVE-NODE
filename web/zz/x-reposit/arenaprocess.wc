			    <td width="18%" height="10" bgcolor="#FFCF63"><b><font face="Verdana" size="2">&nbsp;Move Date:</font></b></td>
			    <td width="10%" height="10" align="right"><b><font size="2" face="Verdana">From:</font></b></td>
			    <td width="33%" height="10" align="right">
                <input name="DATE1" size="10" value="<%=DATE() %>" style="float: left"></td>
			    <td width="7%" height="10" align="right"><b><font size="2" face="Verdana">To:</font></b></td>
			    <td width="33%" height="10" align="right"><input name="DATE2" size="10" value="<%=(DATE()+180) %>" style="float: left"></td>
			  </tr>
			</table>
			<!-- Dates-->
		</td></tr><tr><td width="541">
