			    <td width="135" align="right" height="32"><b><font face="Verdana" size="2">Radius in miles:</font></b></td>
			    <td width="20" height="32"><font face="Verdana" size="1"><b><input type="text" name="RADIUS" size="2" value="<%=ALLT(STR(pnRADIUS))%>" style="border: 1px solid #52657B"></b></font></td>
			    <td width="89" height="32"><p align="center"><input type="button" CLASS="SUBOFF" name="btnRegion" onclick="submitprocess(3)" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:60" tabindex="10" value="Go!"></td>
			  </form></tr>
