<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Repository Process</title>

<SCRIPT LANGUAGE="JAVASCRIPT">
function sf(){
	document.theForm.STATE1.focus();
}

function submitprocess(i) {
    if (i==1) 
      { 
        var frm=document.theForm ;
    	if (frm.STATE1[0].selected && frm.STATE2[0].selected) {
    		window.alert("Please select either origin state (from:) or destination state (to:).");
    		frm.STATE1.focus();
    		}
		else{
			frm.action="/wc.dll?mpreposit~processret~<%=pcSCR%>";
    	  	frm.submit();
    	  	}
      }
    if (i==3) 
      { 
       document.SubmitRegion.action="/wc.dll?mpreposit~processret~<%=pcSCR%>~REGION";
       document.SubmitRegion.submit();
      }

	}
	
function addleads(){
	window.open('/wc.dll?mpreposit~addleadswc~<%=ALLT(pcSCR)%>~<%=ALLT(pcCUSTNO)%>~LEADS','','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=790,height=590')	      
}

</SCRIPT>

<STYLE TYPE="text/css">
	.txtoff		{	color: #006600;
				  	font-size: 12pt;
  				  	font-family: Times new Roman;
  				  	cursor: Hand;
					background-color: white;
				  	text-align: left}
	.txton		{	color: blue;
				  	font-size: 12pt;
				  	text-align: left;
  				  	font-family: Times new Roman;
  				  	cursor: Hand;
					background-color: white;
					text-decoration: underline
  				  	cursor: Hand}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

<body onload="sf()" BGCOLOR="#ADBACE">
<br>
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="70%" height="469">
