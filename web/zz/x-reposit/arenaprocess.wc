 <br>
		<!-- Buttons --->
		<table border="0" width="75%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
		  <tr>
		    <td width="33%" align="center">
            <input id="btnSubmit" type="button" CLASS="SUBOFF" name="btnContinue" onclick="submitprocess(1)" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="9" value="Continue"></td>    
		    <td width="33%" align="center">
            <input id="btnSubmit" type="button" CLASS="SUBOFF" name="btnAdd" onclick="addleads()" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="9" value="Add Leads"></td>    
		    <td width="33%" align="center">
            <input type="button" CLASS="SUBOFF" name="btnExit" onClick="javascript: window.close()" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="10" value="Exit"></td>    
		  </tr>
		</table>
