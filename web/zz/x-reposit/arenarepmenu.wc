<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Moving System</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpreposit~arenarepmenuwc~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpreposit~arenamenuwc~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
</SCRIPT>

<STYLE TYPE="text/css">
	.txtoff		{	color: #006600;
				  	font-size: 12pt;
  				  	font-family: Times new Roman;
  				  	cursor: Hand;
					background-color: white;
				  	text-align: left}
	.txton		{	color: blue;
				  	font-size: 12pt;
				  	text-align: left;
  				  	font-family: Times new Roman;
  				  	cursor: Hand;
					background-color: white;
					text-decoration: underline
  				  	cursor: Hand}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

<body BGCOLOR="#ADBACE">
<br>
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="80%">
  <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">
    &nbsp;</td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#4A698C" height="25">
    <p align="center">
    <b>
    <font color="#FFFFFF" face="Verdana"><font color="#FFFFFF">Purchased</font> 
    Estimates Report</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="200">
	
	<!-- Main -->

	<!-- frame table -->
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
	  <tr>
	    <td width="100%">

    <!-- Body & Column -->
    <p align="center"></td>
  </tr>
  <tr>
    <td width="100%" align="center">
	
	<!--- Main -->
		<br>
        <form name="theForm" method="post">
		<table border="1" align="center" width="438" cellspacing="0" align="center">
		 <tr><td valign="top" width="438">

			<!-- Dates-->
			<table border="0" width="387" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" height="30">
			  <tr>
			    <td width="64" height="10" bgcolor="#FFCF63"><b><font face="Verdana" size="2">&nbsp;Dates:</font></b></td>
			    <td width="63" height="10" align="right"><b><font size="2" face="Verdana">From:</font></b></td>
			    <td width="95" height="10" align="right">
                <input name="DATE1" size="12" value="<%=DATE()-30%>" style="float: left"></td>
			    <td width="44" height="10" align="right"><b><font size="2" face="Verdana">To: </font></b></td>
			    <td width="121" height="10" align="right">
                <input name="DATE2" size="12" value="<%=DATE()%>" style="float: left"></td>
			  </tr>
			</table>
			<!-- Dates-->
		</td></tr></table>

		<BR>
		<table border="0" width="450" cellspacing="0" height="151">
		 <tr><td valign="top" width="58" height="149">
			<!-- Type-->
			<TABLE CELLPADDING="0" CELLSPACING="2" BORDER="2" BORDERCOLOR="#ffffff" WIDTH="238" height="131">
			  <tr>
			    <td width="228" height="30" bgcolor="#FFCF63" colspan="2" align="center" BORDERCOLOR="#708090">
				    <b><font face="Verdana" size="2">Estimate Type </font></b>
				    </td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090">
                <input class="chkon" type="radio" name="STATUS" value="V7" checked></td>
			    <td width="204" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">&nbsp;All Estimates</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090">
                <input type="radio" name="STATUS" value="V8" ></td>
			    <td width="204" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">&nbsp;Pending </font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090">
                <input type="radio" name="STATUS" value="V9"></td>
			    <td width="204" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">&nbsp;Sold Estimates</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090">
                <input type="radio" name="STATUS" value="V10"></td>
			    <td width="204" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">&nbsp;Incomplete / Duplicate</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090">
                <input type="radio" name="STATUS" value="V11"></td>
			    <td width="204" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">Purchased Estimates</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090">
                <input type="radio" name="STATUS" value="V12"></td>
			    <td width="204" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">Statement</font></b></td>
			  </tr>
			  </table>
			<!-- Type-->

		 </td><td valign="top" width="219" height="149">
			<!-- Sort-->
			<TABLE CELLPADDING="0" CELLSPACING="2" BORDER="2" BORDERCOLOR="#ffffff" WIDTH="208" height="128">
			  <tr>
			    <td width="198" height="30" bgcolor="#FFCF63" colspan="2" BORDERCOLOR="#708090" align="center">
				    <p align="center"><b><font face="Verdana" size="2">&nbsp;Sort By</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090" align="center">
                <input class="chkon" type="radio" name="SORT" value="V1" checked></td>
			    <td width="174" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">&nbsp;Transaction No.</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090" align="center">
                </b><input type="radio" name="SORT" value="V2"></td>
			    <td width="174" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">&nbsp;Move Date</font></b></td>
			  </tr>
			  <tr>
			    <td width="20" height="28" BORDERCOLOR="#708090" align="center">
                <input type="radio" name="SORT" value="V3"></td>
			    <td width="174" height="28" BORDERCOLOR="#708090"><b>
                <font face="Verdana" size="2">Estimate No.</font></b></td>
			  </tr>
			  </table>
			<!-- Sort-->

		</td>
		 </tr></table>

              </form>          &nbsp;</p>
		  </center>
        </div>
		<!-- Radio-->
		<!-- Frame Table-->
		</form>

		<!-- Buttons --->
		<div align="center">
          <center>
		<table border="0" width="50%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
		  <tr>
		    <td width="24%" align="center">
            <input id="btnSubmit" type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(1)" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="9" value="Submit"></td>    
		    <td width="2%" ></td>    
		    <td width="24%" align="center">
            <input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(2)" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="10" value="Exit"></td>    
		  </tr>
		</table>
		  </center>
    </div>
		<!-- Buttons --->


	<!-- Menu -->

	</td>
  </tr>
</table>
<!-- frame table -->

    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="15">

	&nbsp;</td>
  </tr>
<tr>
    <td width="50%" BGCOLOR="#4A698C" height="15">
      <b>
      <font color="#FFFFFF" size="2" face="Verdana">
      &nbsp;User:<%=pcUSER%></font></b></td>
</tr>
   <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">
    &nbsp;</td>
 </tr>
  </table>

  </center>
</div>

</body>

</html>