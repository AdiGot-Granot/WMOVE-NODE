      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#FFFFCC"><b><%=I1%></b>&nbsp;</td>
      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#FFCC66"><b><%=T%></b>&nbsp;</td>
      <td width="4%" align="center" bordercolor="#6B8AAD" bgcolor="#FFCC66"><b><%=T1%></b>&nbsp;</td>
      <td width="1%" align="center" bordercolor="#6B8AAD" bgcolor="#CCFFFF"><b><%=NSL%></b>&nbsp;</td>
      <td width="2%" align="center" bordercolor="#6B8AAD" bgcolor="#CCFFFF"><b><%=NSD%></b>&nbsp;</td>
