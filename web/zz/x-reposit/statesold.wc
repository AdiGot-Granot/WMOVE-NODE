      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6">
      <b><font face="Arial" size="2">Cust.</font></b></td>
      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6">
