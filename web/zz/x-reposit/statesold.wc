      </tr>
  <% SELECT _LIST
    SCAN %>
    <tr>
      <td width="11%" align="left" bordercolor="#6B8AAD" bgcolor="#FFFFFF"><b><%=STATE%></b>&nbsp;</td>
      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6"><b><%=CUST%></b>&nbsp;</td>
      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6"><b><%=S%></b>&nbsp;</td>
      <td width="4%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6"><b><%=S1%></b>&nbsp;</td>
