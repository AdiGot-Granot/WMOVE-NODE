      <td width="11%" align="left" bordercolor="#6B8AAD" bgcolor="#FFFFFF">&nbsp;</td>
      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6"><b><%=ALLT(STR(CUST))%></b>&nbsp;</td>
      <td width="3%" align="center" bordercolor="#6B8AAD" bgcolor="#ADE3C6"><b><%=ALLT(STR(S))%></b>&nbsp;</td>
