<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>States Sold Estimates</title>
<SCRIPT LANGUAGE="JAVASCRIPT">


</SCRIPT>
</head>

<body>
<p align="center"><b><font color="#6B8AAD" size="6">States Sold Estimates</font><font color="#800000" size="3"><br>
</font></b>
<form method="POST" action="/wc.dll?mpreposit~statesoldwc">
</p>
<table width="40%" bordercolor="#99CCFF" align="center" border="2" cellspacing="0" cellpadding="2" bordercolorlight="#6B8AAD" bordercolordark="#6B8AAD" style="border-collapse: collapse">
    <tr>
      <td width="10%" align="center" bordercolor="#6B8AAD">From Date:</td>
      <td width="10%" align="center" bordercolor="#6B8AAD">
      <input NAME="DATE1" size="10" tabindex="1" value="<%=LDDATE1%>"></td>
      <td width="10%" align="center" bordercolor="#6B8AAD">To Date:</td>
      <td width="12%" align="center" bordercolor="#6B8AAD">
      <input NAME="DATE2" size="10" tabindex="1" value="<%=LDDATE2%>"></td>
   </tr>
 </table>
<p align="center">
  <input type="submit" value="Submit" name="B1" tabindex="8"></p>
<table width="80%" bordercolor="#99CCFF" align="center" border="2" cellspacing="0" cellpadding="2" bordercolorlight="#6B8AAD" bordercolordark="#6B8AAD" style="border-collapse: collapse">
    <tr>
      <td width="7%" bgcolor="#6B8AAD" align="center" bordercolor="#6B8AAD">
      <font size="2" face="Arial" color="#FFFFFF"><b>States</b></font></td>
      <td width="10%" bgcolor="#6B8AAD" align="center" bordercolor="#6B8AAD" colspan="3">
      <font size="2" face="Arial" color="#FFFFFF"><b>Total</b></font></td>
      <td width="12%" bgcolor="#6B8AAD" align="center" bordercolor="#6B8AAD" colspan="2">
      <font size="2" face="Arial" color="#FFFFFF"><b>Local</b></font></td>
      <td width="13%" bgcolor="#6B8AAD" align="center" bordercolor="#6B8AAD" colspan="2">
      <font size="2" face="Arial" color="#FFFFFF"><b>Long Distance</b></font></td>
