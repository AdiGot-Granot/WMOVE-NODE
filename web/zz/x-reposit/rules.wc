    	                      <option value="WV">West Virginia</option>
        	                  <option value="WI">Wisconsin</option>
	                          <option value="WY">Wyoming</option>
    	                    </select></td>
      <td width="10%" bgcolor=#FFFFFF align="center" BORDERCOLOR="#708090">
      <input type="checkbox" name="VICEVERSA<%=ALLT(STR(RECNO()))%>" value="ON" style="font-size:8pt" tabindex="<%=ALLT(STR(RECNO()))%>3" <%=IIF(VICEVERSA,'checked','')%>></td>
      <td width="10%" bgcolor=#FFFFFF align="center" BORDERCOLOR="#708090"><b>
      <input type="text" name="DAYS<%=ALLT(STR(RECNO()))%>" size="1" style="border: 1px solid #52657B; font-size:8pt" tabindex="<%=ALLT(STR(RECNO()))%>4" VALUE="<%=ALLT(STR(DAYS))%>"><font size="1" face="Verdana"> Days</font></b></td>
      <td width="10%" bgcolor=#FFFFFF align="center" BORDERCOLOR="#708090">
      <input type="checkbox" name="ACTIVE<%=ALLT(STR(RECNO()))%>" value="ON" style="font-size:8pt" tabindex="<%=ALLT(STR(RECNO()))%>5" <%=IIF(ACTIVE,'checked','')%>></td>
      <td width="10%" bgcolor=#FFFFFF align="center" BORDERCOLOR="#708090">
      <input type="checkbox" name="DEL<%=ALLT(STR(RECNO()))%>" value="ON" style="font-size:8pt" tabindex="<%=ALLT(STR(RECNO()))%>6"></td>
