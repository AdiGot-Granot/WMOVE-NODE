   </table>
<br>
   <table border="1" align="center" width="95%" cellspacing="0" align="center" height="29"><tr><td>
	  <table border="0" cellspacing="1" width="100%" height="27">
		  <tr>
		    <td width="195" bgcolor="#FFCF63" height="24"><b>
            <font face="Verdana" size="2">International 
            Estimates</font></b><font size="2" face="Verdana"><b>:</b></font></td>
		    <td width="110" bgcolor="#FFFFFF" height="24">
            <font color="#FFFFFF">
            <input type="checkbox" name="INTL" value="ON" style="font-size:8pt" tabindex="<%=ALLT(STR(RECNO()+1))%>7" <%=IIF(plINTL,'checked','')%>></font></td>
		    <td width="130" align="right" bgcolor="#FFCF63" height="24"><b>
            <font face="Verdana" size="2">Auto Transport</font></b><font face="Verdana" size="2"><b>:&nbsp;&nbsp; </b></font></td>
		    <td width="464" bgcolor="#FFFFFF" height="24">
      <font color="#FFFFFF">
      <input type="checkbox" name="AUTO" value="ON" style="font-size:8pt" tabindex="<%=ALLT(STR(RECNO()+1))%>8" <%=IIF(plAUTO,'checked','')%>></font></td>
		  </tr>
		</table>
	</td></tr></table>
</form>
</td>
</tr>
</table>
 <br>
		<!-- Buttons --->
		<div align="center">
          <center>
		<table border="0" width="40%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
		  <tr>
		    <td width="25%" align="center">
            <input id="btnSubmit" type="button" CLASS="SUBOFF" name="B3" onclick="submitrules()" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="9" value="Update"></td>    
	   		<%IF plLOGGEDSEC%>
		    <td width="25%" align="center">
            <input type="button" CLASS="SUBOFF" name="btnExit" onclick="arenamenu()" style="border: 1px solid #52657B; font-size:9pt; font-family: Verdana; font-weight: bold; border-top-style:solid; border-right-style:solid; border-bottom-style:solid; border-left-style:solid; border-top-width:1px; border-right-width:1px; border-bottom-width:1px; border-left-width:1px; height: 24; width:120" tabindex="<%=ALLT(STR(RECNO()+1))%>9" value="Exit"></td>
	   		<%ENDIF%>
    
		  </tr>
		</table>
