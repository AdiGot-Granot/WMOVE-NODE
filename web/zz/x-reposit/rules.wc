<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Online Estimates</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitrules() {
       document.theForm.action="/wc.dll?mpreposit~rulesret~<%=pcSCR%>~<%=pcLOGGEDSEC%>";
       document.theForm.submit();
      }

function arenamenu() {
    window.location.href=('/wc.dll?mpreposit~arenamenuwc~<%=pcSCR%>');
    }
    
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style></head>

<body  BGCOLOR="#ADBACE">
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%" height="10">
  <tr>
    <td width="100%" height="14" colspan="2" bgcolor="#FFCF63">
    &nbsp;</td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#4A698C" height="20" colspan="2">
    <p align="center"><b>
    <font face="Verdana" size="4" color="#FFFFFF">Favorites</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="355" colspan="2">
	
	<!-- Main -->

	<!-- frame table -->
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
	  <tr>
	    <td width="100%">

    <!-- Body & Column -->
    </td>
  </tr>
  <tr>
    <td width="100%" align="center">
	
	<!--- Main -->
<form name="theForm" method="POST">
<BR>&nbsp;<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="95%" align="center">
  <tr>
    <td width="100%"><b><font face="Verdana" size="2">Add states to favorites and 
    receive new estimates directly to your email.<br>
&nbsp;</font></b></td>
  </tr>
</table>
   <table border="1" align="center" width="95%" cellspacing="0" align="center" height="29"><tr><td>
	  <table border="0" cellspacing="1" width="100%">
		  <tr>
		    <td width="17%" bgcolor="#FFCF63"><b><font face="Verdana" size="2">
            Email</font></b><font size="2" face="Verdana"><b> Estimates To:</b></font></td>
		    <td width="68%"><b><font face="Verdana"><input type="text" name="RULESEMAIL" size="40" style="border: 1px solid #52657B; " tabindex="<%=ALLT(STR(RECNO()))%>4" VALUE="<%=ALLT(pcRULESEMAIL)%>"></font></b></td>
		    <td width="15%" align="right" bgcolor="#CCCCCC"><b><font face="Verdana" size="2">Credit: $<%=ALLT(STR(pnBALANCE,8,2))%>&nbsp;&nbsp;</b></font></td>
		  </tr>
		</table>
	</td></tr></table>


<br>
   <TABLE CELLPADDING="0" CELLSPACING="2" BORDER="2" BORDERCOLOR="#ffffff" WIDTH="95%">
    <tr>
      <td width="4%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">#</font></b></td>
      <td width="13%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">From</font></b></td>
      <td width="13%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">To</font></b></td>
      <td width="10%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">Vice<br>Versa</font></b></td>
      <td width="10%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">Move Date<br>Within</font></b></td>
      <td width="10%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">Active</font></b></td>
      <td width="10%" bgcolor="#FFCF63" align="center" BORDERCOLOR="#708090"><b>
      <font face="Verdana" size="2">Delete</font></b></td>
   </tr>
	<% SELECT _RULES
		SCAN%>
    <tr>
      <td width="4%" bgcolor=#CECFCE align="center" BORDERCOLOR="#708090"><%=ALLT(STR(RECNO()))%>&nbsp;</td>
      <td width="13%" bgcolor=#FFFFFF align="center" BORDERCOLOR="#708090">
