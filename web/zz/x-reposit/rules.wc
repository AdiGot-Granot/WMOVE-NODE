    	                      <option value="WV">West Virginia</option>
        	                  <option value="WI">Wisconsin</option>
	                          <option value="WY">Wyoming</option>
    	                    </select></td>
      <td width="13%" bgcolor=#FFFFFF align="center" BORDERCOLOR="#708090">
                            <select size="1"  name="RSTATE<%=ALLT(STR(RECNO()))%>" style="border: 1px solid #52657B; font-size:8pt" tabindex="<%=ALLT(STR(RECNO()))%>2">
    	                      <option value="<%=ALLT(RSTATE)%>" selected><%=ALLT(RSTATENAME)%></option>
	                          <%IF ALLT(RSTATE)!="XX"%><option value="XX">All States</option><%ENDIF%>
	                          <option value="AL">Alabama</option>
