<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Movers Arena</title>
<script language="JavaScript" type="text/JavaScript">

function SubmitSignup() {
		if (checkData()) {
			document.theForm.action='/wc.dll?mpreposit~signupret';
			document.theForm.submit();
			}
      }

function checkData(){
	frm = document.theForm;
	return  lengthValid(frm.COMPANY, 4,"company full name") 
			&& lengthValid(frm.CONTACT, 2,"contact person")
			&& lengthValid(frm.USERNAME, 4,"username (4-10 characters)")
			&& emailValid(frm.RULESEMAIL, 4,"contact email")
			&& lengthValid(frm.PHONE, 10, "phone number (10 digits)")
			&& lengthValid(frm.PHONE, 10, "phone number (10 digits)")
			&& emailValid(frm.EMAIL, 4,"public email")
			&& lengthValid(frm.WEB, 6,"web site")
			&& lengthValid(frm.ADD1, 4,"street address")
			&& lengthValid(frm.CITY, 2,"city")
			&& zipValid(frm.ZIP, 5, "zip code (US only)");
	}

//function to validate by length
function lengthValid(field, len, text) {
    // text = Trim(text);
	if (field.value.length < len)
  	{
 	  	alert("Please enter " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}

//function to validate numerical fields
function numberValid(field, text) {
    //text = Trim(text);
	if (isNaN(field.value))
  	{
 	  	alert("Please enter a valid " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}


//function to validate Zip Codes, Credit Card, and Phone Numbers fields
function zipValid(field,len, text) {
    //text = Trim(text);
	if (isNaN(field.value) || field.value.length < len)
  	{
 	  	alert("Please enter a valid " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}


//function to validate email
function emailValid(mailfield, len, text) {
   // text = Trim(text);
	if(mailfield.value.length < len || mailfield.value.indexOf("@") < 1 || mailfield.value.indexOf(".") < 2)
	{
	    alert("Please enter a valid " + text + ".");
		mailfield.focus();
		return false;
	}else{
		return true;
	}
}

//function to validate select drop-downs
function selectValid(field, text) {
    //text = Trim(text);
	if (field[0].selected)
  	{
 	  	alert("Please select a " + text + ".");
		field.focus();
		return false;
	}else{
		return true;
	}
}
</script>

<STYLE TYPE="text/css">
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

<body  BGCOLOR="#ADBACE">
