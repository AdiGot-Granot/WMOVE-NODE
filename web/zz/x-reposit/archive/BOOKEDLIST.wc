<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Repository Job List</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitlist(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpreposit~joblistret~<%=pcSCR%>~BOOKED";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpreposit~processwc~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
</style>
</head>

<body BGCOLOR="#4E6699">
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%" height="10">
  <tr>
    <td width="100%" height="14" colspan="2">
    <IMG SRC="http://granot.com/zz/images/BotBar8.gif" width="100%" height="14"></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#001E4C" height="25">
    <p align="center"><font color="#FFFFFF" face="Arial Rounded MT Bold">
    <font size="4"><a href="javascript:window.close()">
    <img border="0" src="http://www.granot.com/zz/images/x.gif" align="right" width="17" height="18"></a><b><font color="#FFFFFF">Selected 
    Estimates </font></b></font></font></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="355">
	
	<!-- Main -->

	<!-- frame table -->
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
	  <tr>
	    <td width="100%">

    <!-- Body & Column -->
    </td>
  </tr>
  <tr>
    <td width="100%" align="center" bgcolor="#001E4C">
	
	<!--- Main -->
<form name="theForm" method="POST">
<% SELECT _LIST 
    GO TOP %>
    <table border="1" width="100%" bgcolor="#C0C0C0" bordercolor="#A0965A" cellspacing="0" cellpadding="2" style="border-collapse: collapse">
    <tr>
      <td width="5%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">#</font></b></td>
      <td width="11%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">Source</font></b></td>
      <td width="12%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">Move Date</font></b></td>
      <td width="16%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">From</font></b></td>
      <td width="16%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">To</font></b></td>
      <td width="10%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">CF</font></b></td>
      <td width="10%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">Miles</font></b></td>
      <td width="10%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">Price<br>Deposit</font></b></td>
      <td width="10%" bgcolor="#001E4C" align="center"><p align="center"><b>
      <font color="#FFFFFF">Select</font></b></td>
   </tr>
<%SCAN %>
    <tr>
      <td width="5%" bgcolor=#FFFFCC>
        <p><b><font size="2" ><%=ALLT(STR(NO)) %>.</font></b></td>
      <td width="11%" bgcolor=#FFFFCC>
        <p><b><font size="2" ><%=MDSOURCE %></font></b></td>
      <td width="12%" bgcolor=#FFFFCC>
        <p><b><%=LBOOKDTE %>&nbsp;<%=LEFT(CDOW(LBOOKDTE),3) %><br>DS<%=ORDNO %></b></td>
      <td width="16%" bgcolor=#FFFFCC>
        <p><b><font size="2" ><%=FROM %></font></b></td>
      <td width="16%" bgcolor=#FFFFCC>
        <p><b><font size="2" ><%=TO %></font></b></td>
      <td width="10%" bgcolor=#FFFFCC>
        <p><b><font size="2" ><a href="/wc.dll?mpreposit~invarena~<%=ALLT(REFNO)%>" TARGET="_blank"><%=ALLT(STR(TOTALCF)) %></a>&nbsp;cf.</font></b></td>
      <td width="10%" bgcolor=#FFFFCC>
        <p><b><font size="2" ><%=ALLT(STR(MILES))%>&nbsp;miles</font></b></td>
      <td width="10%" bgcolor=#FFFFCC>
        <p><b><%='$'+ALLT(STR(MDPRC1,9,2)) %><br><%=IIF(DEPOSIT > 0,'$'+ALLT(STR(DEPOSIT,9,2)),'') %></b></td>
      <td width="10%" bgcolor=#FFFFCC align="center"><p>
           <b><font color="#FFFFFF">
           <input type="checkbox" name="<%=ALLT(ORDNO)%>" value="ON"></font><br>
           $<%=MDPRC2 %></b></p></td>
    </tr>
   <% ENDSCAN %>
   </table>
</form>
</td>
</tr>
</table>
 <br>
		<!-- Buttons --->
		<div align="center">
          <center>
		<table border="0" width="40%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
		  <tr>
		    <td width="25%" align="center"><button CLASS="SUBOFF" name="B3" onclick="submitlist(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="9">Submit</button></td>    
		    <td width="25%" align="center"><button CLASS="SUBOFF" name="B4" onclick="submitlist(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="9">Cancel</button></td>    
		  </tr>
		</table>
		  </center>
    </div>
		<!-- Buttons --->
		<!-- Frame Table --->


	<!-- Menu -->

	<br>

	<!-- Command Buttons -->


<!-- frame table -->
</td>
</tr>
<tr>
    <td width="50%" BGCOLOR="#001E4C" height="15">
      <font color="#FFFFFF">
      <b>User:<%=pcUSER%></b></font></td>
</tr>
   <tr>
    <td width="100%" height="14" colspan="2">
    <IMG SRC="http://granot.com/zz/images/botBarep.gif" width="100%" height="14"></td>
 </tr>
  </table>
 </center>
</div>


</body>

</html>