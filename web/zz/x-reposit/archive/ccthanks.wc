<script language="JavaScript" type="text/JavaScript">

function SubmitPlan() {
		if (checkData()) {
			document.theForm.action="/wc.dll?mpreposit~planret";
			document.theForm.submit();
			}
		else {
			alert("Please select a plan")
			}
      }

function checkData(){
	frm = document.theForm;
	for (var i=0; i < frm.length; i=i+1){
		if (frm.elements[i].checked){
			return true
		  }
	   }
	}

</script>
