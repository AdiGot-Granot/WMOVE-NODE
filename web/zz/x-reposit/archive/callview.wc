<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>Online Estimates</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitrules() {
       document.theForm.action="/wc.dll?mpreposit~rulesret~<%=pcSCR%>~<%=pcLOGGEDSEC%>";
       document.theForm.submit();
      }

function arenamenu() {
    window.location.href=('/wc.dll?mpreposit~arenamenuwc~<%=pcSCR%>');
    }
    
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>
<body  BGCOLOR="#4E6699">
<div align="center">
