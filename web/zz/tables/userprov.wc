<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<TITLE>User Provider</TITLE>

<link rel="stylesheet" type="text/css" href="/zz/util/checkboxslide.css?v=1.1.4" media="screen" />

<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<script type="text/javascript">

jQuery( document ).ready(function( $ ) {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 700,
		maxHeight	: 200,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});
   
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

// data validation

function CHKLENGTH() {
    const frm = document.theForm;
    const usernameElem = frm.USERNAME || document.querySelector("[name='USERNAME']");
    const userpass = frm.USERPASS.value.trim();
    let username = "";
    let isInput = false;

    // check user input field
    if (usernameElem && usernameElem.tagName.toLowerCase() === "input") {
        username = usernameElem.value.trim();
        isInput = true;
    } else {
        // check user text (skip valid)
        isInput = false;
    }

    // validate user as input
    if (isInput && username.length < 3) {
        alert("Please enter User Name!");
        usernameElem.focus();
        return false;
    }

    // validate password
    if (userpass.length < 3) {
        alert("Please enter Password!");
        frm.USERPASS.focus();
        return false;
    }

    return true;
}
 
function CHKPROV() {
    const frm = document.theForm;
    const provElem = frm.PROVID || document.querySelector("[name='PROVID']");
    let provider = "";
    let isSelect = false;

    if (provElem && provElem.tagName.toLowerCase() === "select") {
        // It's a dropdown
        provider = provElem.options[provElem.selectedIndex].text.trim();
        isSelect = true;
    } else {
        // It's rendered as plain text (e.g., <font> or <b>)
        isSelect = false;
    }

    // Only validate if it's a dropdown (USERID = 0 style scenario)
    if (isSelect && provider === "") {
        alert("Please select a provider!");
        provElem.focus();
        return false;
    }

    return true;
}

// end data validation 

function submitProvider() {
	if (CHKLENGTH()&&CHKPROV()) {
       document.theForm.action="/wc.dll?mpmainten~userproviderret~<%=pcSCR%>~<%=ALLT(lcUSERID)%>";
       document.theForm.submit();
     }
  }

function submitFunction(i) {  
    if (i==1) 
	 {
		var Message = "Are you sure you want to delete this User?";
		if (confirm (Message))
		  {
			document.theForm.action="/wc.dll?mpmainten~deleteuser~<%=pcSCR%>~<%=lcUSERID%>~9";
	        document.theForm.submit();
	      }
     }
   
    if (i==2) 
     { 
       document.theForm.action="/wc.dll?mpmainten~userswc~<%=pcSCR%>";
       document.theForm.submit();
     }
  }

</SCRIPT>


<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.DELETE	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.DELETEON	{	color: #FFFFFF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #FF0000;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="550">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center" height="19"><font face="Verdana" size="4" color="#FFFFFF">User Provider</font></b></td>
  </tr>
    <td width="100%" align="center" bgcolor="#FFFFFF"><br>	
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="57%" valign="top">
    <form name="theForm" method="POST">
<%SELECT _USER%>    
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">Active</font></td>
    <td width="77%" height="19">
    <%IF EMPTY(pcMSG) AND (lnUSERID <> pnUSERID OR lnUSERID=0) %>
    <label class="switch"><input type="checkbox" id="togBtn" name="ACTIVE" value="ON" <%=IIF(ACTIVE,'checked','')%>><div class="slider round"></div></label>
    <b><font face="Verdana" color="#<%=IIF(ACTIVE=.T.,'008000','FF0000')%>"><%=IIF(ACTIVE=.T.,'Active','Not Active')%></font></b>
    <%ELSE%>
    &nbsp;&nbsp;<b><font face="Verdana"><%=pcMSG%></font></b>
    <%ENDIF%></td>
  </tr>
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">User Name</font></td>
    <td width="77%" height="19">
    <%IF lnUSERID=0 %><input type="text" autocomplete="off" name="USERNAME" size="11" value="<%=ALLT(USERNAME)%>" maxlength="10">
    &nbsp;&nbsp;<b><font face="Verdana" size="2" color="#0081D3">3 to 10 Characters</font></b>
    <%ELSE%><font face="Verdana" color="#008000"><b><%=ALLT(USERNAME)%></b></font><%ENDIF%></td>
  </tr>
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">Password</font></td>
    <td width="77%" height="19"><input type="text" autocomplete="off" name="USERPASS" size="11" onclick='this.value=""' onFocus='this.value=""' value="<%=ALLT(USERPASS)%>" maxlength="10">
    &nbsp;&nbsp;<b><font face="Verdana" size="2" color="#0081D3">3 to 10 Characters</font></b></td>
  </tr>
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">Position</font></td>
    <td width="77%" height="19"><font face="Verdana"><b>*Provider*</b></font></td>
  </tr>
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">Provider Name</font></td>
    <td width="77%" height="19">
 <% IF lnUSERID=0 %>  
	<select size="1" name="PROVID">
      <option value="" selected></option> 
         <% SELECT _LIST 
    	    SCAN %>
	  <OPTION VALUE="<%=PROVID%>"><%=ALLT(CUSTNAME)%></OPTION>
	     <% ENDSCAN %>  
	</select>
 <%ELSE%>
    <font face="Verdana" size="2"><b><%=pcPROVNAME%></b></font>
 <%ENDIF%>   	    
    </td>
  </tr>
<%SELECT _USER%>        
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">First Name</font></td>
    <td width="77%" height="19"><input type="text" name="FIRSTNAME" size="19" value="<%=ALLT(FIRSTNAME)%>"></td>
  </tr>
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">Last Name</font></td>
    <td width="77%" height="19"><input type="text" name="LASTNAME" size="19" value="<%=ALLT(LASTNAME)%>" maxlength="20"></td>
  </tr> 
  <tr>
    <td width="24%" height="18"><font face="Verdana" size="2">Contact Email</font></td>
    <td width="77%" height="18"><input type="text" name="EMAIL" size="30" value="<%=ALLT(EMAIL)%>"></td>
  </tr>      
  <tr>
    <td width="24%" height="19"><font face="Verdana" size="2">Contact Phone</font></td>
    <td width="77%" height="19"><input type="text" name="PHONE" size="30" value="<%=ALLT(PHONE)%>"></td>
  </tr>  
 <% IF lnUSERID > 1000 %>
  <tr>
    <td width="100%" height="19" colspan="2"><font face="Verdana" size="2">Allow User Access from IP: <a class="fancybox fancybox.iframe" href="/wc.dll?mpmainten~restipwc~<%=pcSCR%>~<%=ALLT(STR(lnUSERID))%>">Add/Update IP</a> 
    <% IF plRECS=.T. %><br>User has <b><%=pcRECS%></b> active IP(s)<%ENDIF%></font></td>
  </tr>
 <%ENDIF%>         
</table>        
    </td>
 </tr>
</table>
 <BR> 
<table border="0" width="95%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="16%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitProvider()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Submit" size="20"></td>
    <td width="19%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Exit" size="20"></td>
    <td width="13%" align="right"><%IF lnUSERID > 0 %><input type="button" CLASS="DELETE" name="B31" onclick="submitFunction(1)" onmouseover="javasctript: this.className='DELETEON'" onmouseout="javasctript: this.className='DELETE'" tabindex="12" value="Delete" size="20"><%ENDIF%></td>
 </tr>   
</table>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="95%">
  <tr>
    <td width="100%" align="center" height="30" valign="bottom"><b><font face="Verdana" style="font-size:11pt;" color="#0081D3">Internal Notes</font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea rows="5" name="NOTES" cols="60"><%=ALLT(NOTES)%></textarea></td>
 </tr>
</table>
</form>
  &nbsp;</td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>

</body>
</html>