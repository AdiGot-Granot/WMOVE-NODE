<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Payment Processing Gateway</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function GatewaySave(par) {
       document.theForm.action="/wc.dll?mpmainten~MerchantRet~<%=pcSCR%>~"+par;
       document.theForm.submit();
      }

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
       document.theForm.submit();
      }                    
	}
      
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					border-bottom: 1px solid #A9A9A9;}					
	.BUTTON		{	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 70; 
                    height: 25; 
                    cursor: pointer;}					
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="55%">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center">&nbsp;<b><font face="Verdana" color="#FFFFFF">Payment Processing Gateway</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center"><br>
 <form name="theForm" method="POST">    
<table border="0" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="98%">
  <tr>
    <td width="11%" class="TD1">Gateway</td>
    <% IF plDEPT %>
    <td width="4%" class="TD1" style="border-left: 1px solid #A9A9A9;">Dept</td>
    <% ENDIF %>
    <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Bank Name</td>
    <td width="11%" class="TD1" style="border-left: 1px solid #A9A9A9;">API Log</td>
    <td width="12%" class="TD1" style="border-left: 1px solid #A9A9A9;">Transaction Key</td>
    <td width="4%" class="TD1" style="border-left: 1px solid #A9A9A9;">Active</td>
    <td width="4%" class="TD1" style="border-left: 1px solid #A9A9A9;">Delete</td>
    <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Action</td>
 </tr>
 <%SELECT _MERCHANT 
 SCAN %>
  <tr style="line-height:30px;">
   <td width="11%" class="TD4">&nbsp;<b><%=ALLT(CCPROCNAME)%></b></td>
   <% IF plDEPT %>
   <td width="4%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;">
            <select size="1" name="<%='DEPT-'+ALLT(STR(MERCHANTID))%>">
	        <option selected><%=ALLT(_MERCHANT.DEPT)%></option> 
	        <option></option> 
		     <% SELECT _DEPARTMENT 
		     	 SCAN %>
			       <OPTION VALUE="<%=ALLT(_DEPARTMENT.DEPT)%>"><%=ALLT(_DEPARTMENT.DEPT)%></OPTION>
		     <% ENDSCAN %>  
		    </select></td>
  <% ENDIF %>
  <%SELECT _MERCHANT %>
  <td width="7%" class="TD2"><input type="text" autocomplete="off" name="<%='CNAME-'+ALLT(STR(MERCHANTID))%>" size="10" value="<%=ALLT(CNAME)%>"></td>
    <td width="11%" class="TD2"><input type="text" autocomplete="off" name="<%='APILOG-'+ALLT(STR(MERCHANTID))%>" size="20" value="<%=ALLT(APILOG)%>"></td>
    <td width="12%" class="TD2"><input type="text" autocomplete="off" name="<%='TRANSKEY-'+ALLT(STR(MERCHANTID))%>" size="25" value="<%=ALLT(TRANSKEY)%>"></td>
    <td width="4%" class="TD3"><input type="checkbox" name="<%='ACTIVE-'+ALLT(STR(MERCHANTID))%>" value="ON" <%=IIF(ACTIVE,'checked','')%>></td>
    <td width="4%" class="TD3"><input type="checkbox" name="<%='DEL-'+ALLT(STR(MERCHANTID))%>" value="ON"></td>
    <td width="5%" class="TD3"><input type="button" class="BUTTON" value="Save" name="B1" onclick="GatewaySave(<%=ALLT(STR(MERCHANTID,8))%>)"></td>
 </tr>
<% ENDSCAN %>
  <tr>
    <td width="58%" colspan="8"><hr color="#A9A9A9" width="99%" size="1"></hr></td>
 </tr>
  <tr>
    <td width="11%" align="center">
    <select size="1" name="CCPROCID-1">
		<option></option>
    	<option value="11">Authorize.net</option>	 
    	<option value="14">Sola (Fidelity)</option>
		</select></td>
    <% IF plDEPT %>
    <td width="4%" align="center">
            <select size="1" name="DEPT-1">
	        <option selected></option> 
		     <% SELECT _DEPARTMENT 
		     	 SCAN %>
			       <OPTION VALUE="<%=ALLT(_DEPARTMENT.DEPT)%>"><%=ALLT(_DEPARTMENT.DEPT)%></OPTION>
		     <% ENDSCAN %>  
		    </select></td>
    <% ENDIF %>
    <td width="7%"><input type="text" autocomplete="off" name="CNAME-1" size="10" value=""></td>
    <td width="11%"><input type="text" autocomplete="off" name="APILOG-1" size="20" value=""></td>
    <td width="12%"><input type="text" autocomplete="off" name="TRANSKEY-1" size="25" value=""></td>
    <td width="4%" align="center"><input type="checkbox" name="ACTIVE-1" value="ON"></td>
    <td width="9%" colspan="2"><input type="button" class="BUTTON" value="Add New" name="B1" onclick="GatewaySave(1)"></td>
 </tr>
</table>
 <br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="65%">
  <tr>
    <td width="50%"  align="center"><input type="button" CLASS="SUBOFF" name="B45"  onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
 </tr>
</table>
 </form>        
   </td>
  </tr>
</table>
   </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>
</body>
</html>