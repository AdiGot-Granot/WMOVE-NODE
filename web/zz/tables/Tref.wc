<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Advertising Table</title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">


function SaveTref(par) 
      { 
       document.theForm.action="/wc.dll?mpmainten~trefsave~<%=pcSCR%>~"+par;
       document.theForm.submit();
      }

function DelTref(par) 
   { 
	var Message = "Are you sure you want to delete?";
	if (confirm (Message))     
        document.theForm.action="/wc.dll?mpmainten~trefdel~<%=pcSCR%>~"+par;
        document.theForm.submit();
   }   

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=+pcSCR%>";
       document.theForm.submit();
      }
	}

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 650,
		maxHeight	: 500,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
	 .BUTTON	{	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 65; 
                    height: 25; 
                    cursor: pointer;}  				  	
</style>

</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="40%">
  <tr>
    <td width="100%" colspan="2"><a class="fancybox fancybox.iframe" href="/zz/help/advertising.htm">
    <img border="0" src="/zz/util/manual.gif" title="Read about Advertising Table" width="32" height="32"></a></td>
  </tr>
</table>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="40%">  
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Advertising Table</font></b></td>
  </tr>
  <tr>
    <td width="100%" align="center" bgcolor="#FFFFFF"><BR> 
 <form name="theForm" method="POST">
<table border="0" width="95%" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111">
  <tr>
    <% IF plDEPT %>
    <td width="6%" class="TD1" style="background-color: #F7F7F7;">Department</td>
	<% ENDIF %>  
    <td width="21%" class="TD2" style="background-color: #F7F7F7;">Advertiser Name</td>
    <td width="9%" class="TD2" style="background-color: #F7F7F7;">Provider</td>
    <td width="16%" class="TD2" style="background-color: #F7F7F7;" colspan="2">Action</td>
 </tr>
   <% SELECT _TREF 
      SCAN %>
  <tr style="line-height:28px;">
    <% IF plDEPT %>
    <td width="9%" class="TD1">       
        <select size="1" name="<%='DEPT'+ALLT(STR(TREFID))%>">
  		<option selected value="<%=ALLT(STR(DEPTID))%>"><%=ALLT(DEPT)%></option>
		  		 <option value=""></option>
		  		 <%	SELECT _DEPT
				 	 SCAN %>
			   	 <option value="<%=ALLT(STR(DEPTID))%>"><%=ALLT(DEPT)%></option>
				 <% ENDSCAN %>
	</select></td>
 	<%ENDIF%>  
    <td width="22%" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;">&nbsp;<input NAME="<%='NAME'+ALLT(STR(_TREF.TREFID)) %>" size="25" VALUE="<%=ALLT(_TREF.RNAME)%>" maxlength="40"></td>  
    <td width="11%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;">
   <% IF plPROVLOGIN=.T. AND _TREF.TREFID=1 %>
	<select size="1" name="<%='PROV'+ALLT(STR(_TREF.TREFID))%>">
      <option value="" selected></option> 
         <% SELECT _LIST 
    	    SCAN %>
	  <OPTION VALUE="<%=ALLT(STR(PROVID))%>"><%=ALLT(CUSTNAME)%></OPTION>
	     <% ENDSCAN %>  
	</select>
   <%ELSE%>
    <font face="Verdana" size="2"><b><%=ALLT(_TREF.CUSTNAME)%></b></font>    
   <%ENDIF%>
    </td>
    <td width="8%" class="TD2"><input type="button" class="button" name="B1" onclick="SaveTref(<%=ALLT(STR(_TREF.TREFID))%>)" value="Save"></td>
    <td width="8%" class="TD2"><% IF _TREF.TREFID > 1 %><input type="button" class="button" name="B1" onclick="DelTref(<%=ALLT(STR(_TREF.TREFID))%>)" style="background-color:#FF0000;color:#FFFFFF;" value="Delete"><%ENDIF%></td>
 </tr>
 <% ENDSCAN %>
</table>
 </form>
 <br><center><input type="button" CLASS="SUBOFF" name="B4" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="submitFunction(1)" value="Exit"></center></td>
 </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>