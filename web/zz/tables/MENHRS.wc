<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<title>States Men Per Hour Table</title>
<SCRIPT LANGUAGE="JAVASCRIPT">

function helpstateperhrs() {
    window.open('/zz/help/helpstateperhrs.htm','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=550,height=500');
	}

</SCRIPT>
</head>
<body>
<p align="center"><b><font color="#6B8AAD" face="Arial" size="5">Price per Hour by States<br>
<font color="#000000" size="3">(Local/Intrastate Move)</b></font></font>
<div align="center"><img border="0" src="zz/util/manual.gif" onclick="helpstateperhrs()" title="Read about Price per Hour by States" style="cursor:hand" width="32" height="32"></p>
<form method="POST" action="/wc.dll?mpmainten~menhrsret~<%=pcSCR%>">
<table width="85%" align="center" bordercolor="#99CCFF" border="2" cellspacing="0" cellpadding="2" bordercolorlight="#6B8AAD" bordercolordark="#6B8AAD" style="border-collapse: collapse">
  <% SELECT _STATE %>
    <tr>
      <td width="5%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">Abbr.</font></b></td>
      <td width="24%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">State</font></b></td>
      <td width="6%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">2 men</font></b></td>
      <td width="7%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">3 men</font></b></td>
      <td width="6%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">4 men</font></b></td>
      <td width="6%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">5 men</font></b></td>
      <td width="6%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">6 men</font></b></td>
      <td width="15%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">Over 6 men</font></b></td>
      <td width="9%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font color="#FFFFFF" face="Arial" size="2">Local Min.</font></b></td>
      <td width="8%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font face="Arial" size="2" color="#FFFFFF">Intrastate</font></b></td>
      <td width="8%" align="center" bgcolor="#6B8AAD" bordercolorlight="#C0C0C0" bordercolordark="#C0C0C0" bordercolor="#6B8AAD">
      <b><font face="Arial" size="2" color="#FFFFFF">Per Mile</font></b></td>
   </tr>
  <%SCAN %>
     <tr>
      <td width="5%" bgcolor="#CCCCCC" align="center"><b><font color="#000000" face="Arial" size="2"><%=ALLT(STATE)%></font></b>&nbsp;</td>
      <td width="24%" bgcolor="#CCCCCC" align="center"><b><font color="#000000" face="Arial" size="2"><%=ALLT(NAME)%></font></b>&nbsp;</td>
      <td width="6%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'2' %>" size="3" VALUE="<%=STR(MEN2,3) %>" tabindex="1"></td>
      <td width="7%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'3' %>" size="3" VALUE="<%=STR(MEN3,3) %>" tabindex="2"></td>
      <td width="6%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'4' %>" size="3" VALUE="<%=STR(MEN4,3) %>" tabindex="3"></td>
      <td width="6%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'5' %>" size="3" VALUE="<%=STR(MEN5,3) %>" tabindex="4"></td>
      <td width="6%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'6' %>" size="3" VALUE="<%=STR(MEN6,3) %>" tabindex="5"></td>
      <td width="15%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'7' %>" size="2" VALUE="<%=STR(MENOVER6,3) %>" tabindex="6">
      <font size="2">per man</font></td>
      <td width="9%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'8' %>" size="3" VALUE="<%=STR(LOCALMIN,3) %>" maxlength="3" tabindex="7"></td>
      <td width="8%" bgcolor="#CCCCCC">
      <input NAME="<%=STATE+'9' %>" size="2" VALUE="<%=STR(RMILES,3) %>" maxlength="3" tabindex="8"><font size="2">Mile</font></td>
      <td width="8%" bgcolor="#CCCCCC" align="center">$<input NAME="<%=STATE+'10' %>" size="2" VALUE="<%=STR(RPERMILE,6,2) %>" tabindex="9"></td>
    </tr>
   <% ENDSCAN %>
 </table>
<p align="center"><input type="submit" value="Submit" name="B1" STYLE="CURSOR:HAND;" tabindex="8"></p>
</form>
<p align="center"><font size="4"><a href="/wc.dll?mpmainten~maintenwc~<%=+pcSCR%>">Exit</a></font></p>
</div>
</body>
</html>