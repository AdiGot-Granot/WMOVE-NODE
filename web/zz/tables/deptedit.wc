<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<TITLE>Department Info</TITLE>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="ie=edge">
<link href="/zz/editor/lib/css/font-awesome.min.css" rel="stylesheet" type="text/css" />
<link href="/zz/editor/lib/css/froala_editor.pkgd.min.css" rel="stylesheet" type="text/css" />
<link href="/zz/editor/lib/css/froala_style.min.css" rel="stylesheet" type="text/css" />
<link rel="stylesheet" type="text/css" href="/zz/util/checkboxslide.css?v=1.1.4" media="screen" />

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
     { 
       document.theForm.action="/wc.dll?mpmainten~depteditret~<%=pcSCR%>~<%=ALLT(lcDEPTID)%>";
       document.theForm.submit();
     }
    if (i==2) 
	 {
		var Message = "Are you sure you want to delete this Department?";
		if (confirm (Message))
		  {
			document.theForm.action="/wc.dll?mpmainten~deletedept~<%=pcSCR%>~<%=ALLT(lcDEPTID)%>";
	        document.theForm.submit();
	      }
     }
    if (i==3) 
     { 
       document.theForm.action="/wc.dll?mpmainten~departmentswc~<%=pcSCR%>";
       document.theForm.submit();
     }     
  }

</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Verdana;
				  	text-align: center;
					width: 140;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Verdana;
				  	text-align: center;
					width: 140;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
 	.DELETE	 	{	color: black; 
					font-weight: none;
					font-family: Verdana;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.DELETEON	{	color: #FFFFFF; 
					font-weight: bold;
					font-family: Verdana;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #FF0000;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

<script type="text/javascript" src="/zz/editor/lib/js/jquery.min.js"></script>
<script type="text/javascript" src="/zz/editor/lib/js/froala_editor.pkgd.min.js?v=2.1.6"></script>
<script>
        $(function () {
            $('textarea').froalaEditor()
        });
</script>

</head>

<body BGCOLOR="#F7F7F7"><br>
<%SELECT _DEPARTMENT%>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="830">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center" height="19"><font face="Verdana" size="4" color="#FFFFFF">Department Information</font></b></td>
  </tr>
 <form name="theForm" method="POST">
    <td width="100%" align="center" bgcolor="#FFFFFF"><br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="63%" valign="top">
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Active</font></td>
    <td width="70%" height="19" colspan="3">
    <%IF EMPTY(pcMSG) %>
    <label class="switch"><input type="checkbox" id="togBtn" name="ACTIVE" value="ON" <%=IIF(ACTIVE,'checked','')%>><div class="slider round"></div></label>
    <b><font face="Verdana" color="#<%=IIF(ACTIVE=.T.,'008000','FF0000')%>"><%=IIF(ACTIVE=.T.,'Active','Not Active')%>&nbsp;&nbsp;<font color="#000000"><%=IIF(DEPTMAIN=.T.,'(Primary)','')%></font></font></b>
    <%ELSE%>
    &nbsp;&nbsp;<b><font face="Verdana"><%=pcMSG%></font></b>
    <%ENDIF%></td>
  </tr>
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Department Code</font></td>
    <td width="70%" height="19" colspan="3">
    <%IF lnDEPTID > 0%> 
      <FONT style="font-family: Verdana; font-size: 12pt;color:008000;"><B><%=ALLT(DEPT)%></b></font>
    <%ELSE%>  
      <input type="text" autocomplete="off" name="DEPT" size="3" value="<%=ALLT(DEPT)%>" maxlength="2">
      <b><font face="Verdana" size="2" color="#0081D3">A to Z / AA to ZZ</font></b>
    <%ENDIF%>    
    </td>
  </tr>
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Department Group</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" name="GRP" size="1" value="<%=ALLT(STR(GRP))%>" maxlength="2">
    <b><font face="Verdana" size="2" color="#0081D3">1 to 99</font></b></td>
  </tr>  
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Company Name</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" name="DEPTNAME" size="35" value="<%=ALLT(DEPTNAME)%>"></td>
  </tr>
  <tr>
    <td width="30%" height="18"><font face="Verdana" size="2">Company Address</font></td>
    <td width="70%" height="18" colspan="3"><input type="text" name="ADD1" size="35" value="<%=ALLT(ADD1)%>"></td>
  </tr>
  <tr>
    <td width="31%" height="18"><font face="Verdana" size="2">City, State, Zip Code</font></td>
    <td width="44%" height="18"><input type="text" name="CITY" size="25" value="<%=ALLT(CITY)%>"></td>
    <td width="11%" height="18">
    <select size="1" name="STATEID">
		  		<option selected value="<%=ALLT(STR(pnSTATEID))%>"><%=ALLT(_department.STATE)%></option>
		  		 <%	SELECT _STATE
				 	 SCAN %>
			   		<option value="<%=ALLT(STR(STATEID))%>"><%=ALLT(STATE)%></option>
				 <% ENDSCAN %>
				</select></td>
   <%SELECT _DEPARTMENT%>				
    <td width="15%" height="18"> <input name="ZIP" size="4" value="<%=ALLT(ZIP)%>"></td>
  </tr>
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Company Toll Free</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" name="TOLLFREE" size="29" value="<%=ALLT(TOLLFREE)%>"></td>
  </tr>
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Local Phone</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" name="PHONE" size="29" value="<%=ALLT(PHONE)%>"></td>
  </tr>  
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Company Fax</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" name="FAX" size="29" value="<%=ALLT(FAX)%>"></td>
  </tr>
  <tr>
    <td width="30%" height="18"><font face="Verdana" size="2">Company Email</font></td>
    <td width="70%" height="18" colspan="3"><input type="text" autocomplete="off" name="EMAIL" size="35" value="<%=ALLT(EMAIL)%>"></td>
  </tr>
  <tr>
    <td width="30%" height="18"><font face="Verdana" size="2">Company Website</font></td>
    <td width="70%" height="18" colspan="3"><input type="text" autocomplete="off" name="WEB" size="35" value="<%=ALLT(WEB)%>"></td>
  </tr>  
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Company Slogan</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" autocomplete="off" name="SLOGAN" size="35" value="<%=ALLT(SLOGAN)%>"></td>
  </tr>
  <% IF plESUBJECT=.T. %>
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Email Subject</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" autocomplete="off" name="ESUBJECT" size="35" value="<%=ALLT(ESUBJECT)%>"></td>
  </tr>
  <%ENDIF%>
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Owner/Manager</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" name="CONTACT" size="29" value="<%=ALLT(CONTACT)%>"></td>
  </tr>      
  <tr>
    <td width="30%" height="19"><font face="Verdana" size="2">Web Redirect*</font></td>
    <td width="70%" height="19" colspan="3"><input type="text" autocomplete="off" name="WEBREDIRECT" size="29" value="<%=ALLT(WEBREDIRECT)%>"></td>
  </tr> 
  <tr>
    <td width="100%" height="19" colspan="4"><font face="Verdana" size="2">* Redirect to your  &quot;thank you&quot; domain web page.</font></td>
  </tr>     
</table>    
    </td>
    <td width="1%">&nbsp;</td>
    <td width="36%" valign="top">
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center" colspan="2"><font face="Verdana" size="2" color="#0081D3"><b>Department License</b></font></td>
 </tr>
  <tr>
    <td width="48%"><font face="Verdana" size="2">US DOT</font></td>
    <td width="54%"><input type="text" autocomplete="off" name="DOT" size="14" value="<%=ALLT(DOT)%>"></td>
 </tr>
  <tr>
    <td width="48%"><font face="Verdana" size="2">ICC MC</font></td>
    <td width="54%"><input type="text" autocomplete="off" name="ICC" size="14" value="<%=ALLT(ICC)%>"></td>
 </tr>
  <tr>
    <td width="48%"><font face="Verdana" size="2">State Registration</font></td>
    <td width="54%"><input type="text" autocomplete="off" name="REGISTER" size="14" value="<%=ALLT(REGISTER)%>"></td>
 </tr>
</table>
<% IF pnCOLEVEL > 3 %>
 <BR>
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;font-family:Arial;font-size:10pt;line-height:22px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center" colspan="2"><font face="Verdana" size="2" color="#0081D3"><b>Department Specs</b></font></td>
 </tr> 
  <tr>
    <td width="25%"><input type="text" autocomplete="off" name="MATTAX" size="2" maxlength="7" value="<%=ALLT(STR(MATTAX,7,3))%>" tabindex="9"><font face="Verdana" size="2">%</font></td>
    <td width="75%"><font face="Verdana" size="2">Sales Tax on Materials</font></td>
 </tr>
 <%IF plMERCHANT=.T. %>
  <tr>
    <td width="25%"><input type="text" autocomplete="off" name="CCPROCP" size="2" value="<%=ALLT(STR(CCPROCP,6,2))%>" tabindex="10"><font face="Verdana" size="2">%</font></td>
    <td width="75%"><font face="Verdana" size="2">Credit Card Processing Fee*</font></td>
 </tr>
  <tr>
    <td width="100%" colspan="2"><font face="Verdana" size="2">*(Valid with active merchant)</font></td>
 </tr>
 <%ENDIF%>
</table>
<%ENDIF%>
    </td>
 </tr>
</table>
  <BR>
<table border="0" width="90%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="16%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Submit" size="20"></td>
    <td width="19%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(3)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Exit" size="20"></td>
    <% IF pnLEVEL = 5 AND lnDEPTID > 0 AND DEPTMAIN=.F. %>
    <td width="13%" align="right"><input type="button" CLASS="DELETE" name="B31" onclick="submitFunction(2)" onmouseover="javasctript: this.className='DELETEON'" onmouseout="javasctript: this.className='DELETE'" tabindex="12" value="Delete" size="20"></td>
    <%ENDIF%>    
 </tr>   
</table>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="95%">
  <tr>
    <td width="100%" align="center" height="30" valign="bottom"><b><font face="Verdana" style="font-size:11pt;" color="#0081D3">Thank You Message to Customer After Inventory</font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea rows="10" name="THANKSTXT" cols="68"><%=ALLT(THANKSTXT)%></textarea></td>
 </tr>
</table>
</form>
  &nbsp;</td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>

</body>
</html>