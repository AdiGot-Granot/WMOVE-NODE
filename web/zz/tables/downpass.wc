<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Download Back Up</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitBackup(i) {
       document.theForm.action="/wc.dll?mpmainten~download~<%=pcSCR%>";
       document.theForm.submit();
	}

function exit(i) {
    if (i==1) window.location.href=('/wc.dll?mpmainten~maintenwc~<%=pcSCR%>');
	}
		
</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="450">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" color="#FFFFFF">Download Back-Up</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
    <form name="theForm" method="POST">
<table border="0" align="center" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="80%">
  <tr style="line-height:25px;">
	<td width="42%">&nbsp;&nbsp;<b><font face="Verdana" size="2">User Name:</font></b></td>
	<td width="62%"><input name="USERNAME" size="10" value="<%=pcUSER%>" READONLY></td>
 </tr>
  <tr style="line-height:25px;">
	<td width="42%">&nbsp;&nbsp;<b><font face="Verdana" size="2">Password:</font></b></td>
	<td width="62%"><input type="password" name="PASSWORD" size="10" value=""></td>
 </tr>   
</table>
 <br><b><font face="Verdana" color="#FF0000" style="font-size: 10pt"><%=pcMSG%></B></FONT>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitBackup()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
	<td align="center"><input type="button" CLASS="SUBOFF" name="B4" onclick="exit(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
 </tr>
</table>
 </form>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUser%> - <%=pcIP%></font></b></td>
  </tr>
  </table>
</body>
</html>