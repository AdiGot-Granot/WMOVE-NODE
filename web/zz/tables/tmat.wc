<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Packing Material Table</title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

function closeform() {
	window.close()}	

function submitFunction(i) {
    if (i==1) 
    document.theForm.SUBMIT_1.style.visibility="hidden";
    document.theForm.action="/wc.dll?mpmainten~tmatret~<%=pcSCR%>";
    document.theForm.submit()

    if (i==2) document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
    document.theForm.submit()
    }

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 650,
		maxHeight	: 500,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
					background-color: #F7F7F7;				  	
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="40%">
  <tr>
    <td width="100%"><a class="fancybox fancybox.iframe" href="/zz/help/materials.htm"><img border="0" src="/zz/util/manual.gif" title="Read about Material List" width="32" height="32"></a></td>
  </tr>
</table>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="40%">   
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Packing Materials Table</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
<FORM NAME="theForm" method="post">
<table border="0" width="98%" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111">
  <tr>
    <td class="TD2" width="4%">#</td>
    <td class="TD1" width="37%">Material</td> 
    <td class="TD1" width="11%">$/Local</td>
    <td class="TD1" width="17%">$/Long Dist.</td>
    <td class="TD1" width="10%">$/PBO</td>    
    <td class="TD1" width="12%">$/Cost</td>
    <td class="TD1" width="10%">Delete</td>
  </tr>
  <% SELECT _TMAT
  	 SCAN %>
  <tr style="line-height:25px;">
    <td class="TD3" width="4%"><%=ALLT(STR(RECNO()))%>.</td>
    <td class="TD4" width="37%"><input type="text" name="ITEM<%=ALLT(STR(TMATID))%>" size="25" value="<%=ALLT(ITEM)%>" maxlength="50"></td>
    <td class="TD4" align="center" width="11%"><input type="text" name="LPRICE<%=ALLT(STR(TMATID))%>" size="2" value="<%=ALLT(STR(LPRICE,6,2))%>" style="text-align: right"></td>
    <td class="TD4" align="center" width="17%"><input type="text" name="LDPRICE<%=ALLT(STR(TMATID))%>" size="2" value="<%=ALLT(STR(LDPRICE,6,2))%>" style="text-align: right"></td>
    <td class="TD4" align="center" width="10%"><input type="text" name="PBOPRICE<%=ALLT(STR(TMATID))%>" size="2" value="<%=ALLT(STR(PBOPRICE,6,2))%>" style="text-align: right"></td>    
    <td class="TD4" align="center" width="12%"><input type="text" name="COST<%=ALLT(STR(TMATID))%>" size="2" value="<%=ALLT(STR(COST,6,2))%>" style="text-align: right"></td>
    <td class="TD4" align="center" width="10%"><input type="checkbox" name="<%='DEL'+ALLT(STR(_TMAT.TMATID))%>" value="ON" tabindex="5"></td>
 </tr>
  <% ENDSCAN%>
</table>
<br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="85%" height="1">
  <tr>
    <td width="50%" align="center" height="19"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="SUBMIT_1" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
    <td width="50%" align="center" height="19"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="B4" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
 </tr>
  </table>
</form>
    </td>
 </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>  
</body>
</html>