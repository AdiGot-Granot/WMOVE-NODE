<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>History List</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) 
  {
    if (i==1) 
     { 
       document.theForm.action="/wc.dll?mpmainten~historyret~<%=pcSCR%>";
       document.theForm.submit();
     }
    if (i==2) 
	 {
		var Message = "Confirm and continue";
		if (confirm (Message))
		  {
			document.theForm.action="/wc.dll?mpmainten~historylistret~<%=pcSCR%>~<%=pcSTATUS%>~<%=pcDTE%>";
	        document.theForm.submit();
	      }
     }
 }

function CheckBoxes(FormName, CheckValue){
   if(!document.forms[FormName])
      return;
   var objCheckBoxes = document.getElementsByTagName('input');
   if(!objCheckBoxes)
      return;
   var countCheckBoxes = objCheckBoxes.length;
   if(!countCheckBoxes)
      objCheckBoxes.checked = CheckValue;
   else
      for(var i = 0; i < countCheckBoxes; i++)
      objCheckBoxes[i].checked = CheckValue;
}
 
</SCRIPT>


<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 80;
					background-color: #F0F0F0;
					font-size: 10pt;
  				  	cursor: pointer;}										
</style>

</head>

<body><br><center><font face="Arial" size="4"><a href="wc.dll?mpmainten~historywc~<%=pcSCR%>">Exit</a></font></center><br>

<form name="theForm" method="POST">
<input type="hidden" name="DAYS" value="<%=lnDAYS%>">
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="80%">
  <tr>
    <td width="100%" align="center" colspan="2"><font face="Arial"><b><%=pcRECCOUNT+' '+ALLT(pcTITLE)%><br><font color="#008000"><%=ALLT(pcDAYS)%></b></font></font></td>
 </tr>
 <% IF pcSTATUS='V4' %>
  <tr>
    <td width="50%" valign="bottom" height="35" align="right"><font face="Arial" size="2"><b>Filter by Priority:</b></font></td>
    <td width="50%" valign="bottom" height="35" align="left">&nbsp;
	<select size="1" name="FUSTATUS">
	   <option value="0">ALL</option>
	   <option value="6">6</option>
	   <option value="7">7</option>
	   <option value="8">8</option>
	   <option value="9">Pool</option>
	</select>&nbsp;<input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(1)" value="Submit"></td>
 </tr>
 <%ENDIF%> 
</table>

<% SELECT _EST  
   GO TOP %> 
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="2" bordercolor="#111111" width="80%">
    <tr>
      <td width="6%" class="TD1">Delete <input name="checkall" type="checkbox" onclick="CheckBoxes('theForm',this.checked);" value="ON" /></td>
      <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Job No.</td>
      <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Open Date</td>
      <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Type</td>
      <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Follow up</td>
      <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Prior</td>
      <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">User</td>
      <td width="13%" class="TD1" style="border-left: 1px solid #A9A9A9;">From</td>      
      <td width="12%" class="TD1" style="border-left: 1px solid #A9A9A9;">To</td>      
      <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Move Date</td>
      <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Agent</td>      
      <td width="17%" class="TD1" style="border-left: 1px solid #A9A9A9;">Last Modified</td>
   </tr>
<%SCAN %>
     <tr>
      <td width="6%" class="TD3"><input type="checkbox" name="<%=ALLT(ORDNO) %>" value="ON" checked></td>
      <td width="6%" class="TD4" style="border-left: 1px solid #A9A9A9;"><%=ALLT(DEPT)+'-'+ALLT(ORDNO)%></td>
      <td width="7%" class="TD2"><%=ALLT(OPENDTE)%></td>
      <td width="5%" class="TD2"><%=ALLT(TYPE)%></td>
      <td width="7%" class="TD2"><%=NEXTFU%></td>
      <td width="3%" class="TD3" style="border-left: 1px solid #A9A9A9;"><%=IIF(FUSTATUS=9,'Pool',ALLT(STR(FUSTATUS)))%></td>
      <td width="7%" class="TD2"><%=ALLT(USER)%></td>
      <td width="13%" class="TD2"><%=ALLT(FROM)%></td>      
      <td width="12%" class="TD2"><%=ALLT(TO)%></td>      
      <td width="7%" class="TD3" style="border-left: 1px solid #A9A9A9;"><%=ALLT(LBOOKDTE)%>&nbsp;</td>
      <td width="7%" class="TD2"><font COLOR="#FF0000"><%=ALLT(AGENT)%></FONT>&nbsp;</td>      
      <td width="17%" class="TD2"><%=ALLT(STDAY)%><font color="red"><%=IIF(ST='C','<BR>Cancel:'+ALLT(CANCELBY),'')%></font>&nbsp;</td>
    </tr>
   <% ENDSCAN %>
</table>
<br><center><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(2)" value="Delete"></center> 
</form>
<br><center><font face="Arial" size="4"><a href="wc.dll?mpmainten~historywc~<%=pcSCR%>">Exit</a></font></center>

</body>
</html>