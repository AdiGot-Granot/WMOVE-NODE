<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Price per Hour by Cities</title>

<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 600,
		maxHeight	: 430,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

</SCRIPT>

<SCRIPT LANGUAGE="JAVASCRIPT">

function SubmitFunction(i) {
    if (i==1) window.location.href=('/wc.dll?mpmainten~maintenwc~<%=pcSCR%>~1');
	}

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	color: #000000;
				  	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD5		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}					
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="60%">
 <tr>
  <td width="46%"><a class="fancybox fancybox.iframe" href="/zz/help/cityperhrs.htm"><img border="0" src="zz/util/manual.gif" title="Read about Price per Hour by Cities" width="32" height="32"></a></td>
</tr>
</table>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="60%"> 
  <tr>
    <td BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Price per Hour by Cities: <font size="2">Local/Intrastate Move</font></font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
<form method="POST" action="wc.dll?mpmainten~citymenret~<%=pcSCR%>">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111" width="98%">
    <tr>
      <td width="5%" class="TD5">State</td>
      <td width="19%" class="TD1">City</td>
      <td width="7%" class="TD1">Zip code</td>
      <td width="6%" class="TD1">Radius</td>
      <td width="7%" class="TD1">$/2 men</td>
      <td width="7%" class="TD1">$/3 men</td>
      <td width="7%" class="TD1">$/4 men</td>
      <td width="8%" class="TD1">$/5 men</td>
      <td width="8%" class="TD1">$/6 men</td>
      <td width="8%" class="TD1">Minimum</td>
      <td width="6%" class="TD1">Delete</td>
  </tr>
   <% SELECT _CITYMEN
      SCAN 
     lcCITYMENID=ALLT(STR(CITYMENID))%>
     <tr style="line-height:25px;">
      <td width="5%" class="TD3"><b><%=ALLT(STATECODE)%></b>&nbsp;</td>
      <td width="19%" class="TD2"><input NAME="<%='C-'+lcCITYMENID%>" size="25" VALUE="<%=ALLT(CITY)%>"></td>
      <td width="7%" class="TD4"><input NAME="<%='Z-'+lcCITYMENID%>" size="4" VALUE="<%=ALLT(ZIP)%>" maxlength="5" style="text-align: right"></td>
      <td width="6%" class="TD4"><input NAME="<%='R-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(RADIUS=0,'',ALLT(STR(RADIUS,3)))%>" style="text-align: right"></td>
      <td width="7%" class="TD4"><input NAME="<%='M2-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(MEN2=0,'',ALLT(STR(MEN2,6,2)))%>" maxlength="6" style="text-align: right"></td>
      <td width="7%" class="TD4"><input NAME="<%='M3-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(MEN3=0,'',ALLT(STR(MEN3,6,2)))%>" maxlength="6" style="text-align: right"></td>
      <td width="7%" class="TD4"><input NAME="<%='M4-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(MEN4=0,'',ALLT(STR(MEN4,6,2)))%>" maxlength="6" style="text-align: right"></td>
      <td width="8%" class="TD4"><input NAME="<%='M5-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(MEN5=0,'',ALLT(STR(MEN5,6,2)))%>" maxlength="6" style="text-align: right"></td>
      <td width="8%" class="TD4"><input NAME="<%='M6-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(MEN6=0,'',ALLT(STR(MEN6,6,2)))%>" maxlength="6" style="text-align: right"></td>
      <td width="8%" class="TD4">$<input NAME="<%='MIN-'+lcCITYMENID%>" size="3" VALUE="<%=IIF(LOCALMIN=0,'',ALLT(STR(LOCALMIN,3)))%>" maxlength="3" style="text-align: right"></td>
      <td width="6%" class="TD4" align="center"><input type="checkbox" name="<%='DEL-'+lcCITYMENID%>" value="ON"></td>
    </tr>
   <% ENDSCAN %>
     <tr>
      <td width="5%" class="TD3">
      <select size="1" name="S-1">
		  	<% SELECT _STATES
				 	 SCAN %>
		<option value="<%=ALLT(STR(STATEID))%>"><%=ALLT(STATECODE)%></option>
			<% ENDSCAN %>
		</select></td>
      <td width="19%" class="TD2"><input NAME="C-1" size="25" VALUE=""></td>
      <td width="7%" class="TD4"><input NAME="Z-1" size="4" VALUE="" maxlength="5"></td>
      <td width="6%" class="TD4"><input NAME="R-1" size="3" VALUE=""></td>
      <td width="7%" class="TD4"><input NAME="M2-1" size="3" VALUE="" maxlength="6"></td>
      <td width="7%" class="TD4"><input NAME="M3-1" size="3" VALUE="" maxlength="6"></td>
      <td width="7%" class="TD4"><input NAME="M4-1" size="3" VALUE="" maxlength="6"></td>
      <td width="8%" class="TD4"><input NAME="M5-1" size="3" VALUE="" maxlength="6"></td>
      <td width="8%" class="TD4"><input NAME="M6-1" size="3" VALUE="" maxlength="6"></td>
      <td width="8%" class="TD4">$<input NAME="MIN-1" size="3" VALUE="" maxlength="3"></td>
      <td width="6%" class="TD4">&nbsp;</td>
    </tr>   
 </table>    
  <BR>
<table border="0" align="center" style="border-collapse: collapse" width="70%">
  <tr>
    <td align="center"><input type="submit" CLASS="SUBOFF" name="B5" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" STYLE="cursor:pointer;" value="Submit"></td>
    <td align="center"><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="SubmitFunction(1)" value="Exit"></td>
  </tr>
 </table>    
</form>    
    <br></td>
  </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
</table>

</body>
</html>