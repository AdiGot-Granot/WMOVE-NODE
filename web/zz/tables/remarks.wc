<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<TITLE>Company Policy Text on Estimate</TITLE>
<script type="text/javascript" src="/zz/js/showselect.js"></script>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
    $('#SERVTYPE').hide();

     $('#TYP').change(function () {
        if ($('#TYP option:selected').text() == "International"){
            $('#SERVTYPE').show();
        }
         else { 
              $('#SERVTYPE').hide();
         }
	});
	
    $('#BINDING').show();

     $('#TYP').change(function () {
        if ($('#TYP option:selected').text() == "Auto Transport"){
            $('#BINDING').hide();
        }
         else { 
              $('#BINDING').show();
         }
	});         

    $('#DEPT').show();

     $('#TYP').change(function () {
        if ($('#TYP option:selected').text() == "Bill of Lading"){
            $('#BINDING').hide();
            $('#STS').hide();
        }
         else { 
              $('#DEPT').show();
         }
	});

     $('#TYP').change(function () {
        if ($('#TYP option:selected').text() == "BOL Terms"){
            $('#BINDING').hide();
            $('#STS').hide();
        }
         else { 
              $('#DEPT').show();
         }
	});

     $('#TYP').change(function () {
        if ($('#TYP option:selected').text() == "BOL Payment"){
            $('#BINDING').hide();
            $('#STS').hide();
        }
         else { 
              $('#DEPT').show();
         }
	});

     $('#TYP').change(function () {
        if ($('#TYP option:selected').text() == "BOL Pick-Up"){
            $('#BINDING').hide();
            $('#STS').hide();
        }
         else { 
              $('#DEPT').show();
         }
	});
	         
});	


$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 750,
		maxHeight	: 700,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

	
function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~remarkswc~<%=pcSCR%>~NEW";
       document.theForm.submit();
      }

    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpmainten~remarksupd~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==3) 
      { 
       document.theForm.action="/wc.dll?mpmainten~remarkswc~<%=pcSCR%>";
       document.theForm.submit();
      }      
      
    if (i==4) 
      { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
       document.theForm.submit();
      }      

	}
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;				  	
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
					font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-bottom: 1px solid #A9A9A9;}					
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}  				  	
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="65%">
  <tr>
    <td width="100%"><a class="fancybox fancybox.iframe" href="/zz/help/remarks.htm"><img border="0" src="zz/util/manual.gif" width="32" height="32"></a></td>
 </tr>
</table>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="65%">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" SIZE="4" color="#FFFFFF">Company Policy Remarks on Estimate</font></b></td>
 </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">    
<form name="theForm" method="POST">
  
<% IF plDEPTREM %>
 <br>
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="40%" cellspacing="0" cellpadding="0">
   <tr>
     <td height="35">&nbsp;&nbsp;<b><font face="Verdana" size="2">Filter by Department:</font></b>    
       <select size="1" name="DEPTIDX">
         <option value=""></option>
		 <%	SELECT _DEPTREM
			 SCAN %>
   			<option value="<%=ALLT(STR(DEPTID))%>"><%=ALLT(DEPT)%></option>
		 <% ENDSCAN %>
	   </select>
     </td>
    <td><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="submitFunction(3)" value="Submit"></td>
  </tr>
</table>		
<%ENDIF%>
<br>&nbsp;&nbsp;&nbsp;<b><font style="font-size: 11pt;font-family:Verdana;color:red;">* Policy update will apply on <u>the next new estimate</u>!!</font></b>
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" width="98%">
   <tr>
     <td width="4%" class="TD1">Type of Move</td>
     <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Status</td>
  <% IF pnCOLEVEL<>3%>   
     <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Binding</td>
  <% ENDIF %>
  <% IF plDEPT %>   
     <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Department</td>
  <% ENDIF %>
  <% IF pnCOLEVEL<>3%>   
     <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Service</td>
  <% ENDIF %>   
     <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Action</td>
     <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Policy ID</td>
     <td width="2%" class="TD1" style="border-left: 1px solid #A9A9A9;">Last Update</td>
  </tr>
 <% SELECT _REMARKS
    SCAN%>
   <tr style="line-height:25px;">
     <td width="4%" class="TD3">&nbsp;<%=CTYPE%></td>    
     <td width="3%" class="TD2"><%=ALLT(CSTS)%></TD>
 <% IF pnCOLEVEL<>3%>        
     <td width="3%" class="TD2"><%=ALLT(CBINDING)%></TD>
 <% ENDIF %>     
 <% IF plDEPT %>    
     <td width="2%" class="TD2"><%=ALLT(DEPT)%><font style="font-weight:400;color:red;"><%=IIF(DEPTID>0 AND ACTIVEDEPT=.F.,' (not active)','')%></font></td>
 <% ENDIF %>
 <% IF pnCOLEVEL<>3%>    
     <td width="3%" class="TD2"><%=ALLT(CSERVTYPE)%></td>
 <% ENDIF %>    
     <td width="5%" class="TD2"><a href="wc.dll?mpmainten~remarksupd~<%=pcSCR%>~<%=ALLT(STR(REMID))%>">Edit Policy Remarks</a></td>
     <td width="2%" class="TD2"><%=ALLT(STR(REMID))%></td>
     <td width="2%" class="TD2"><font style="font-size:8pt;"><%=TTOD(ADDDTE)%></font>&nbsp;</td>
  </tr>
<%ENDSCAN%>
<% IF plNEW %>
   <tr>   
     <td width="4%" align="center">
            <select size="1" name="TYP" id="TYP">
      <% IF pnCOLEVEL<>3%>      
	        <option VALUE="L">Local</option>
	        <option VALUE="D">Long Distance</option> 
	        <option VALUE="I">International</option>
	        <option VALUE="B">BOL Terms</option>
	        <option VALUE="P">BOL Payment</option>
	        <option VALUE="U">BOL Pick-Up</option>	        	        	        
	  <%ENDIF%> 
	        <option VALUE="T">Auto Transport</option>
	  <%IF plAGENT%>       
	        <option VALUE="A">Auto Carrier</option> 
	  <%ENDIF%>	    
		    </select></td>    
    <td width="3%" align="center" style="border-left: 1px solid #A9A9A9;">
            <select size="1" name="STS" id="STS">
	        <option value="0">All</option>
            <option value="1">Estimate</option>
            <option value="2">Book Job</option>
		    </select></TD>
	<% IF pnCOLEVEL<>3%>	    
    <td width="3%" align="center" style="border-left: 1px solid #A9A9A9;">
   			<select size="1" name="BINDING" id="BINDING">
   			<option value="0">None</option>
      		<option value="1">Binding</option>
      		<option value="2">Non-Binding</option>
		    </select></TD>
    <% ENDIF%>		    
  <% IF plDEPT %>
     <td width="2%" align="center" style="border-left: 1px solid #A9A9A9;">
            <select size="1" name="DEPT" id="DEPT">
	        <option value=""></option> 
		     <% SELECT _DEPT
		     	 SCAN %>
			     <OPTION value="<%=ALLT(DEPT)%>"><%=ALLT(DEPT)%></OPTION>
		     <% ENDSCAN %>  
		    </select></td>
  <%ENDIF%>
   <% IF pnCOLEVEL<>3%>
     <td width="3%" align="center" style="border-left: 1px solid #A9A9A9;">
		<select size="1" name="SERVTYPE" id="SERVTYPE">
			<option></option>
    		<option value="PP">Port to Port</option>
     		<option value="PD">Port to Door</option>
     		<option value="PC">Port to Curb</option>
     		<option value="DD">Door to Door</option>
     		<option value="DP">Door to Port</option>
     		<option value="DC">Door to Curb</option>
     		<option value="TT">Terminal to Terminal</option>
     		<option value="DT">Door to Terminal</option>
     		<option value="FD">Full Destination</option>
		</select></td>
   <% ENDIF%>
     <td width="9%" colspan="3" style="border-left: 1px solid #A9A9A9;"></td>  
  </tr>
<% ENDIF %>  
</table>
 <br>
<table border="0" width="90%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <TR>
  <%IF !plNEW %>
	<td width="11%" align="center">
    <input type="button" CLASS="SUBOFF" name="B5" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Create New Policy"></td>
  <% ENDIF %>
  <%IF plNEW %>	
	<td width="12%" align="center">
    <input type="button" CLASS="SUBOFF" name="B4" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>    
  <% ENDIF %>	
	<td width="12%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(4)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="6" value="Exit"></td>    
 </tr>
</table>
    </form>&nbsp;</td>
</tr>
  <tr>
    <td bgcolor="#0081D3" colspan="2">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>