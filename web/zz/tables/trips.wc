<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Trip Table</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function SubmitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mv~oprmenuwc~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
		
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: right;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD5		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}															
	 .SUBMIT	{	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 120; 
                    height: 25; 
                    cursor: pointer;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="45%">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" color="#FFFFFF">Trip Table</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">
<table border="0" width="98%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td height="30">&nbsp;&nbsp;<a style="font-size: 10pt;font-weight: bold;font-family: Verdana;" href="/wc.dll?mpopr~TripEditWc~<%=pcSCR%>~0">Add New Trip</a></td>    
</table>       
<table border="0" align="center" width="98%" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111">
   <tr>
     <td class="TD1" width="9%">Action</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="12%">Trip Code</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="10%">Trip Name</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="11%">Trip Route</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="14%">Trip Date</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="7%">Jobs</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="10%">Volume</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="8%">Active</td>
  </tr> 
<% SELECT _TRIPS
   SCAN%>  			
   <tr style="line-height:23px;">
     <td class="TD5" width="9%"><b><a href="/wc.dll?mpopr~TripEditWc~<%=pcSCR%>~<%=ALLT(STR(TRIPID))%>">Edit Trip</a></b></td>
     <td class="TD2" width="12%">&nbsp;<b><%=ALLT(TRIPNO)%></b></td>
     <td class="TD2" width="10%">&nbsp;<%=ALLT(TRIPNAME)%></td>
     <td class="TD2" width="11%">&nbsp;<%=ALLT(TRIPROUTE)%></td>
     <td class="TD4" width="14%">&nbsp;<b><%=ALLT(CTRIPDTE)%></b></td>
     <td class="TD3" width="7%"><b><%=ALLT(STR(JOBS))%></b>&nbsp;</td>
     <td class="TD3" width="10%"><%=ALLT(STR(CF))%>&nbsp;</td>
     <td class="TD4" width="8%"><%=IIF(ACTIVE=.T.,'<b>Yes</b>','')%></td>
  </tr>
<% ENDSCAN %> 
</table>
 <br>
<form name="theForm" method="POST"> 
<table border="0" width="80%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="23%" align="center"><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="SubmitFunction(1)" value="Exit"></td>    
</table>
</form>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>