<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<TITLE>Tasks Check List Table</TITLE>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 750,
		maxHeight	: 700,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

	
function submitFunction(i) {      
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~tasklistret~<%=pcSCR%>";
       document.theForm.submit();
      }
               
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
       document.theForm.submit();
      }
 	}
     
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="38%">
  <tr>
    <td width="95%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" SIZE="4" color="#FFFFFF">Tasks Check List</font></b></td>
 </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
<form name="theForm" method="POST">
<table border="0" width="98%" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111">
   <tr>
     <td class="TD1" width="35">No</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="127">Move Type</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="356">Task Description</td>  
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="80">Required</td>  
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="58">Active</td>  
   </tr>
 <% SELECT _LIST
    SCAN %>
   <tr style="line-height:23px;">
     <td align="center" style="border-bottom: 1px solid #A9A9A9;" width="35"><% IF TASKID > 1000 %><input type="text" name="<%='S'+ALLT(STR(TASKID))%>" size="1" value="<%=ALLT(STR(SEQ))%>" style="text-align: center"><%ENDIF%></td>
     <td class="TD2" width="127"><% IF TASKID > 1000 %><%=IIF(ISNULL(TY),'',TY)%>
     <%ELSE%>
		<select size="1" name="<%='T'+ALLT(STR(TASKID))%>">
		  <option value=""></option>
		  <option value="L">Local</option>
		  <option value="R">Intrastate</option>		  
		  <option value="D">Long Distance</option>
		  <option value="I">Intenational</option>
	    </select>
	 <%ENDIF%>        
     </td>
     <td class="TD3" width="356"><% IF TASKID > 1000 %>&nbsp;<%=ALLT(DESCNAME)%><%ELSE%><input autocomplete="off" name="<%='D'+ALLT(STR(TASKID))%>" size="30" value="<%=ALLT(DESCNAME)%>" style="font-family:Verdana; font-size:10pt;"><%ENDIF%></td>
     <td class="TD2" width="80"><input type="checkbox" name="<%='N'+ALLT(STR(TASKID))%>" value="ON" <%=IIF(NEEDON,'checked','')%>></td>
     <td class="TD2" width="58"><% IF TASKID > 1000 %><input type="checkbox" name="<%='A'+ALLT(STR(TASKID))%>" value="ON" <%=IIF(ACTIVE,'checked','')%>><%ENDIF%></td>
   </tr>
 <%ENDSCAN%>  
</table>
 <br>
<table border="0" width="90%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <TR>
	<td width="9%" align="center"><input type="button" CLASS="SUBOFF" name="B5" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
	<td width="7%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="6" value="Exit"></td>    
 </tr>
</table>
    </form></td>
</tr>
  <tr>
    <td bgcolor="#0081D3" colspan="2">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>