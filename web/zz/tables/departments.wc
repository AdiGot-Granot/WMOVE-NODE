<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Departments Table</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function SubmitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==2) 
      { 
       document.theForm.action="/wc.dll?mpmainten~departmentswc~<%=pcSCR%>";
       document.theForm.submit();
      }                          
	}
		
</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD5		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}															
	 .SUBMIT	{	font-size: 9pt;
					font-weight: bold;
  				  	font-family: Verdana;
                    width: 120; 
                    height: 25; 
                    cursor: pointer;}
 	.SUBOFF	 	{	color: 000000; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="75%">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center"><b><font face="Verdana" color="#FFFFFF">Departments Table</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
  <form name="theForm" method="POST">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="40%" height="40" cellspacing="0" cellpadding="0">
   <tr> 
     <td width="30%">&nbsp;&nbsp;<b><font face="Verdana" size="2">Filter by Active:</font></b>
     <select size="1" name="ACTIVE">
	    <option value="1" selected>Active</option>
	    <option value="2">Not Active</option>
	    <option value="3">Deleted</option>
	 </select>     
     </td>
    <td width="40%"><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="SubmitFunction(2)" value="Submit"></td>
  </tr>
</table>		
<table border="0" width="98%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td height="40">&nbsp;&nbsp;<a style="font-size: 10pt;font-weight: bold;font-family: Verdana;" href="/wc.dll?mpmainten~depteditWc~<%=pcSCR%>~0">Add New Department</a></td>    
</table>  
<table border="0" align="center" cellpadding="1" cellspacing="1" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="1375">
   <tr>
     <td class="TD1" width="76">Action</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="49">Dept</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="59">Group</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="323">Company</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="126">Phone</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="290">Email</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="69">DOT</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="63">ICC</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="57">State</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="110">Esign Policy</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="62">Active</td>
     <td class="TD1" style="border-left: 1px solid #A9A9A9;" width="41">Del</td>
  </tr>
<% SELECT _DEPT 
   SCAN%>  			
   <tr style="line-height:20px;">
     <td class="TD5" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="76"><% IF DEL=.F. %><b><a href="/wc.dll?mpmainten~depteditwc~<%=pcSCR%>~<%=ALLT(STR(DEPTID))%>">Edit Dept</a></b><%ENDIF%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="49"><% IF DEPTMAIN=.T. %><span style="font-size:18px;color:#000000">&#9733;</span><%ENDIF%><b><%=ALLT(DEPT)%></b></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="59"><b><%=ALLT(STR(GRP))%></b></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="323">&nbsp;<b><%=ALLT(DEPTNAME)%></b></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="126">&nbsp;<%=ALLT(TOLLFREE)%></td>
     <td class="TD2" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="290">&nbsp;<%=ALLT(EMAIL)%><%=IIF(EMPTY(WEB),'','<br>&nbsp;'+ALLT(WEB))%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="69"><%=ALLT(DOT)%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="63"><%=ALLT(ICC)%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="57"><%=ALLT(STATE)%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="110"><% IF ACTIVE=.T. %><b><a href="/wc.dll?mpmainten~esignbodywc~<%=pcSCR%>~<%=ALLT(STR(DEPTID))%>">Edit Policy</a></b><%ENDIF%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="62"><%=IIF(ACTIVE=.T.,'<b>Yes</b>','No')%></td>
     <td class="TD4" bgcolor="#<%=IIF(ACTIVE=.F.,'E9E9EA','FFFFFF')%>" width="41"><%=IIF(ACTIVE=.F. AND DEL=.T.,'<b>Yes</b>','')%></td>
  </tr>
<% ENDSCAN %> 
</table>
 <br>
<table border="0" width="80%" align="center" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="23%" align="center"><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="SubmitFunction(1)" value="Exit"></td>    
</table>
 </form>
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
  </table>
</body>
</html>