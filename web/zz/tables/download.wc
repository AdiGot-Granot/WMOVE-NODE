<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Download Back-Up</title>

<STYLE TYPE="text/css">
	.SUBOFF	 	{	color: black; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 110;
					height: 25;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>


<script type="text/javascript">


function sf(){  
	document.getElementById("download").innerHTML="<img src=/zz/images/loading.gif></img>";
	var t=setTimeout("showDownload()",<%=pnINTERVAL%>);
}

function showDownload(){
	document.getElementById("download").innerHTML='<a href="https://<%=pcHREF%>">Download</a>';
}


</script>

</head>

<body bgcolor="#F7F7F7" onload="sf()"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" width="30%">
  <tr>
	<td width="100%">&nbsp;<font face="Verdana" size="2"><B>Please wait a minute. Back-Up in process.</B></font></td>
 </tr>		  
  <tr>
	<td  width="100%" align="center" height="25"><div id="download"></div></td>
 </tr>
</table>
<br>
<table border="0" width="20%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" align="center">
  <tr>
	<td width="100%" align="center"><INPUT TYPE="button" CLASS="SUBOFF" name="B3" onclick="javascript: window.close()" VALUE="Close Window"></td>
 </tr>
</table>
</body>
</html>