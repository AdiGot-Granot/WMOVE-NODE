<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Move Size Descriptions</title>

<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 550,
		maxHeight	: 300,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});

</SCRIPT>

<SCRIPT LANGUAGE="JAVASCRIPT">

function SubmitFunction(i) {
    if (i==1) window.location.href=('/wc.dll?mpmainten~maintenwc~<%=pcSCR%>~1');
	}

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					border-bottom: 1px solid #A9A9A9;}	
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>
<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" style="border-collapse: collapse" bordercolor="#111111" width="30%">
 <tr>
  <td width="46%"><a class="fancybox fancybox.iframe" href="/zz/help/movesize.htm"><img border="0" src="zz/util/manual.gif" title="Read about Move Size" width="32" height="32"></a></td>
</tr>
</table>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="30%"> 
  <tr>
    <td BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Move Size Descriptions</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>&nbsp;<font style="font-family: Verdana;font-size: 10pt;font-weight: bold;">CF-LBS Ratio: <%=pnCOCFRATIO%></font>
<form method="POST" action="/wc.dll?mpmainten~movesizeret~<%=pcSCR%>">	
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111" width="98%">
  <tr>
    <td width="14%" class="TD1">Description</td>
    <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;"><%=IIF(plCALCCF,'Cubic Feet','Weight')%></td>
    <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;"><%=IIF(plCALCCF,'Weight','Cubic Feet')%></td>
    <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Active</td>
 </tr>
   <% SELECT _MOVESIZE
      SCAN %> 
  <tr style="line-height:25px;">
    <td width="19%" class="TD2">&nbsp;<%=ALLT(ROOMDESC)%></td>          
    <td width="6%" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;">&nbsp;<input name="<%='V'+ALLT(STR(MOVESIZEID))%>" size="3" value="<%=IIF(plCALCCF=.T.,ALLT(STR(CUFT)),ALLT(STR(LBS)))%>" tabindex="1" style="text-align: right"></td>          
    <td width="7%" class="TD2" style="border-left: 1px solid #A9A9A9;text-align: right"><%=IIF(plCALCCF=.T.,ALLT(STR(LBS)),ALLT(STR(CUFT)))%>&nbsp;</td>
    <td width="6%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;"><input type="checkbox" name="<%='A'+ALLT(STR(MOVESIZEID))%>" value="ON" <%=IIF(ACTIVE,'checked','')%>></td>
 </tr>
  <%ENDSCAN%>
  <tr>
    <td width="19%" style="border-bottom: 1px solid #A9A9A9;"><input autocomplete="off" name="D999" size="20" value=""></td>          
    <td width="19%" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;" colspan="3">&nbsp;<input autocomplete="off" NAME="V999" size="3" value=""></td>          
 </tr> 
  </table>    
  <BR>
<table border="0" align="center" style="border-collapse: collapse" width="90%">
  <tr>
    <td align="center"><input type="submit" CLASS="SUBOFF" name="B5" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" STYLE="cursor:pointer;" value="Submit"></td>
    <td align="center"><input type="button" CLASS="SUBOFF" name="B45" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" onclick="SubmitFunction(1)" value="Exit"></td>
  </tr>
 </table>    
</form>    
    <br></td>
  </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
</table>

</body>
</html>