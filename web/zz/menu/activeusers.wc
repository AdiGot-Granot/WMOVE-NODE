<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Active Users</title>

<script language="JavaScript" src="/zz/util/formcheck.js"></SCRIPT>
<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~activeusersret~<%=pcSCR%>";
       document.theForm.submit();
      }
    if (i==3) 
      { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
       document.theForm.submit();
      }
	}

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}		
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>

<body BGCOLOR="#F7F7F7"><br>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="40%"> 
  <tr>
    <td BGCOLOR="#0081D3" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Active Users</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF"><br>
<FORM NAME="theForm" method="post">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="1" bordercolor="#111111" width="98%">
  <tr>
    <td width="5%" class="TD1">ID</td>
    <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Active</td>
    <td width="4%" class="TD1" style="border-left: 1px solid #A9A9A9;">User Name</td>
    <td width="15%" class="TD1" style="border-left: 1px solid #A9A9A9;">Full Name</td>
    <td width="9%" class="TD1" style="border-left: 1px solid #A9A9A9;">Dept/Level</td>
    <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">QA</td>
 </tr>
   <%SELECT _ACTIVE
        SCAN%>
  <tr style="line-height:22px;">
    <td width="5%" align="center" style="border-bottom: 1px solid #A9A9A9;"><font style="font-size:8pt;font-family:Verdana;"><%=ALLT(STR(USERID))%></font>&nbsp;</td> 
    <td width="5%" align="center" style="border-left: 1px solid #A9A9A9;border-bottom: 1px solid #A9A9A9;"><input type="checkbox" name="<%='t'+ALLT(STR(USERID)) %>" value="ON" <%=IIF(ACTIVE,'checked','')%>></td> 
    <td width="9%" class="TD2">&nbsp;<%=ALLT(USERNAME)%></td>          
    <td width="11%" class="TD2">&nbsp;<%=ALLT(NAME)%></td>          
    <td width="9%" class="TD2">&nbsp;<font color="<%=ALLT(FONTCOLOR)%>"><%=ALLT(CLEVEL)%></font></td>
    <td width="3%" class="TD2">&nbsp;&nbsp;<b><%=IIF(QA=.T.,'Yes','')%></b></td>
 </tr>
  <% ENDSCAN %>
</table>    
  <BR>
<table border="0" align="center" style="border-collapse: collapse" width="70%">
  <tr>
    <td align="center"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="B5" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Submit"></td>
    <td align="center"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="B4" onclick="submitFunction(3)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>
  </tr>
 </table>    
</form>    
    <br></td>
  </tr>
  <tr>
    <td bgcolor="#0081D3" height="15">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>  
</table>

</body>
</html>