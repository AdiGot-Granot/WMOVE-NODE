<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Auto Transport Estimates in Process</title>

<!--DATE PICKER-->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<!--DATE PICKER-->
  
<script type="text/javascript">
 jQuery.noConflict();
      jQuery( document ).ready(function( $ ) {
       $("#Date1").datepicker({ numberOfMonths:[1,2] });
       $("#Date2").datepicker({ numberOfMonths:[1,2] });
   });

</script>

<!--DROPDOWN STATE SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN STATE SEARCH-->

<script type="text/javascript">

  $(document).ready(function() {
      $('.state-select').select2({
          placeholder: 'Select State',
          allowClear: true
      });
  });
  
  $(document).ready(function() {
      $('.user-select').select2({
          placeholder: 'Select User',
          allowClear: true
      });
  });
  
</script>

<SCRIPT LANGUAGE="JAVASCRIPT">

function toggleVisibility(id) {
   var el = document.getElementById(id);

   if (el.style.visibility=="visible") {
          el.style.visibility="hidden";
     }
     else {
          el.style.visibility="visible";
     }
 }


function submitEstProcess(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mv~autoprocessret~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
</SCRIPT>


<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #D3D3D3;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 130;
					height: 30;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

</head>

<body BGCOLOR="#4E6699">
<br>
<div align="center">
  <center>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="45%">
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/topBar.gif" width="100%" height="14"></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#008000" height="20"><p align="center"><b><font size="4" color="#FFFFFF" face="Verdana">Auto Transport Process</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF">
<table border="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center"><br>
  <form name="theForm" method="POST">
<table border="1" align="center" width="95%" style="border-collapse: collapse" bordercolor="#C0C0C0" cellspacing="0">
  <tr>
    <td valign="top">
<table border="0" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="9%" height="30">&nbsp;<b>Date Factor:</b></td>	 
	<td width="9%" height="30"><b>Date Range:</b></td>
	<td width="7%" height="30"><b>From Date:</b></td>
	<td width="8%" height="30"><b>To Date:</b></td>
	<% IF pnLEVEL=2 %>  
	<td width="13%" height="30"><b>Users:</b></td>
	<%ENDIF%>
	<% IF plDEPT %>  
	<td width="7%" height="30"><b>Department:</b></td>
	<%ENDIF%>  
  </tr>
  <tr>
	<td width="9%" height="30">
	   <select size="1" name="TYPEDTE">
		  <option value="OPEN" selected>Open Date</option>	
		  <option value="MOVE">Move Date</option>
		</select>	
	</td>	 
	<td width="9%" height="30">
	<select id="rangeSelect">
    <option value="">-- Select --</option>
    <option value="today">Today</option>
    <option value="tomorrow">Tomorrow</option>
    <option value="yesterday">Yesterday</option>
    <option value="thisWeek">This Week</option>
    <option value="lastWeek">Last Week</option>
	<option value="nextWeek">Next Week</option>    
    <option value="thisMonth">This Month</option>
    <option value="lastMonth">Last Month</option>
    <option value="nextMonth">Next Month</option>
    <option value="lastYear">Last Year</option>
    <option value="ytd">Year to Date</option>
  	</select>	
	</td>
	<td width="7%" height="30"><input type="text" id="Date1" name="DATE1" size="10" value="<%=DATE()-15%>"></td>
	<td width="8%" height="30"><input type="text" id="Date2" name="DATE2" size="10" value="<%=DATE()%>"></td>
	<% IF pnLEVEL=2 %>  
	<td width="13%" height="30">
	<select size="1" name="USER" class="user-select" style="width: 140px;">
		<option selected></option>
		<% SELECT _USERS
		   SCAN %>
   		<option><%=ALLT(USER)%></option>
   		<% ENDSCAN %>
		</select></td>
	<%ENDIF%>
	<% IF plDEPT %> 
	<td width="7%" height="30">
	<select size="1" name="DEPT">
		<option selected></option>
		 <%	SELECT _DEPARTMENT
		    SCAN %>
	   		<option><%=ALLT(DEPT)%></option>
		 <% ENDSCAN %>
		</select></td>
	<%ENDIF%>  
  </tr>      
</table>    
    </td>
 </tr>
  <tr>
    <td width="100%">
<table border="0" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-family:Verdana;font-size:10pt;" bordercolor="#111111">
  <tr>
	<td width="11%" height="30"><b>From State:</b></td>  
	<td width="11%" height="30"><b>To State:</b></td>  
	<td width="5%" height="30">&nbsp;<b>Priority:</b></td>	 
	<td width="12%" height="30"><b>VIP:</b></td>
  </tr>
  <tr>
	<td width="11%" height="30">
	<select size="1" name="STATE1" class="state-select" style="width: 170px;">
			<option></option>
			<% SELECT _STATE
			   SCAN %>
			<option value="<%=ALLT(STATECODE)%>"><%=ALLT(PROPER(STATE))%></option>
			<% ENDSCAN %>
			</select>				
	</td>  
	<td width="11%" height="30">
	<select size="1" name="STATE2" class="state-select" style="width: 170px;">
			<option></option>
			<% SELECT _STATE
			   SCAN %>
			<option value="<%=ALLT(STATECODE)%>"><%=ALLT(PROPER(STATE))%></option>
			<% ENDSCAN %>
			</select> 	
	</td>  
	<td width="5%" height="30">
	<select size="1" name="FUSTATUS">
	  <option value="10">ALL</option>
	  <option value="0">0</option>
	  <option value="1">1</option>
	  <option value="2">2</option>
	  <option value="3">3</option>
	  <option value="4">4</option>
	  <option value="5">5</option>
	  <option value="6">6</option>
	  <option value="7">7</option>
	  <option value="8">8</option>
	  <option value="9">Pool</option></select>	
	</td>	 
	<td width="12%" height="30"><input type="checkbox" name="FUVIP" value="ON" tabindex="2"></td>
  </tr>      
</table>    
    </td>
 </tr>
</table>
  <br>
<table border="1" align="center" width="95%" style="border-collapse: collapse" bordercolor="#C0C0C0">
  <tr>
    <td valign="top" width="35%">
<table border="0" width="100%" cellspacing="0" cellpadding="3" style="border-collapse: collapse;line-height:25px;">
  <tr>
    <td width="100%" height="17" bgcolor="#008000" colspan="3" align="center"><b><font face="Verdana" color="#FFFFFF" size="2">Status of Estimate</font></b></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input class="chkon" type="radio" name="STATUS" value="V1" checked></td>
    <td width="95%" height="20" colspan="2"><font face="Arial" size="2">All Auto Estimates</font></td>
 </tr>
 <%IF pnLEVEL = 2 %>		 
  <tr>
    <td width="5%" height="20"><input type="radio" name="STATUS" value="V2" ></td>
    <td width="95%" height="20" colspan="2"><font face="Arial" size="2">Delete Old Estimates by Move Date</font></td>
 </tr>
 <%ENDIF %>			  	   		 
  <tr>
    <td width="5%" height="20"><input type="radio" name="STATUS" value="V3"></td>
    <td width="95%" height="20" colspan="2"><font face="Arial" size="2">Follow-Up Estimates</font>
  <%IF pnLEVEL = 2 %> 
    <input type="checkbox" id="dlfu" name="DLXLS" value="ON" style="visibility:hidden" />
    <img id="chkdlfu" onclick="toggleVisibility('dlfu');" src="zz/images/dl.gif" width="67" height="18" style="cursor:pointer;"/>
  <%ENDIF%></td>
 </tr>			  
  <tr>
    <td width="5%" height="20"><input type="radio" name="STATUS" value="V4"></td>
    <td width="95%" height="20" colspan="2"><font face="Arial" size="2">Booked Jobs</font>
    <%IF pnLEVEL = 2 %> 
    <input type="checkbox" id="dlbook" name="DLXLS" value="ON" style="visibility:hidden" />
    <img id="chkdlbook" onclick="toggleVisibility('dlbook');" src="zz/images/dl.gif" width="67" height="18" style="cursor:pointer;"/>
   <%ENDIF%></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input type="radio" name="STATUS" value="V5"></td>
    <td width="95%" height="20" colspan="2"><font face="Arial" size="2">Estimates with Esign By Sent Date for Future Jobs</font></td>
 </tr> 
 <%IF pnLEVEL= 2 %> 					  
  <tr>
    <td width="5%" height="20"><input type="radio" name="STATUS" value="V6"></td>
    <td width="35%" height="20"><font face="Arial" size="2">Reassign Estimates</font></td>
    <td width="60%" height="20" ALIGN="LEFT"><B><font color="#993366">(&nbsp;<%=pcREASSIGN%>&nbsp;)</font></B></td>
 </tr>
 <%ENDIF%>  
</table>    
    </td>
    <td valign="top" width="37%">
<table border="0" width="100%" cellspacing="0" cellpadding="3" style="border-collapse: collapse;line-height:25px;">
  <tr>
    <td width="100%" height="17" bgcolor="#008000" colspan="2" align="center"><b><font face="Verdana" color="#FFFFFF" size="2">&nbsp;Sort By</font></b></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input class="chkon" type="radio" name="SORT" value="V1" checked></td>
    <td width="95%" height="20"><font face="Arial" size="2">Job No.</font></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input type="radio" name="SORT" value="V2"></td>
    <td width="95%" height="20"><font face="Arial" size="2">Pick-Up Date</font></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input type="radio" name="SORT" value="V4"></td>
    <td width="95%" height="20"><font face="Arial" size="2">Estimate Amount</font></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input type="radio" name="SORT" value="V5"></td>
    <td width="95%" height="20"><font face="Arial" size="2">Follow-Up Date</font></td>
 </tr>
  <tr>
    <td width="5%" height="20"><input type="radio" name="SORT" value="V6"></td>
    <td width="95%" height="20"><font face="Arial" size="2">Priority</font></td>
 </tr>			  			  
</table>    
    </td>
 </tr>
</table>
 <br>
<table border="0" width="60%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="25%" align="center"><input type="button" CLASS="SUBOFF" name="B3" onclick="submitEstProcess(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" id="btnSubmit" value="Submit"></td>    
    <td width="24%" align="center"><input type="button" CLASS="SUBOFF" name="EXIT" onclick="window.close()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="Exit"></td>    
 </tr>
</table> 
    </form>
  </td></tr></table>
<!-- frame table -->
    </td></tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15">&nbsp;<font face="Verdana" size="2" color="#FFF">View By: <%=pcUSER%></font></td>
  </tr>
  <tr>
    <td width="100%" height="14"><IMG SRC="zz/images/botBar.gif" width="100%" height="14"></td>
  </tr>
</table>
  </center>
</div>
<script language="JavaScript" src="/zz/js/rangeselect.js"></SCRIPT><!--RANGE SELECT-->
</body>
</html>