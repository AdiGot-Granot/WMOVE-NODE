<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<TITLE>Company Info</TITLE>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="ie=edge">
<link href="/zz/editor/lib/css/font-awesome.min.css" rel="stylesheet" type="text/css" />
<link href="/zz/editor/lib/css/froala_editor.pkgd.min.css" rel="stylesheet" type="text/css" />
<link href="/zz/editor/lib/css/froala_style.min.css" rel="stylesheet" type="text/css" />

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) 
  {
    if (i==1) 
     { 
       document.theForm.action="/wc.dll?mpmainten~deptinforet~<%=pcSCR%>";
       document.theForm.submit();
     }

    if (i==2) 
     { 
       document.theForm.action="/wc.dll?mpmainten~maintenwc~<%=pcSCR%>";
       document.theForm.submit();
     }
  }

</SCRIPT>

<!--DROPDOWN STATE SEARCH-->
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!--DROPDOWN STATE SEARCH-->

<script type="text/javascript">

  $(document).ready(function() {
      $('.state-select').select2({
          placeholder: 'Select State',
          allowClear: true
      });
  });
</script>


<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>

<script type="text/javascript" src="/zz/editor/lib/js/jquery.min.js"></script>
<script type="text/javascript" src="/zz/editor/lib/js/froala_editor.pkgd.min.js?v=2.1.6"></script>
<script>
	jQuery.noConflict();	
             jQuery( document ).ready(function( $ ) {
            $('textarea').froalaEditor()
        });
</script>

</head>

<body BGCOLOR="#F7F7F7"><br>
<%SELECT _DEPARTMENT%>
<table border="0" align="center" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" BGCOLOR="#0081D3" align="center" height="19"><font face="Verdana" size="4" color="#FFFFFF">Company Information</font></b></td>
  </tr>
 <form name="theForm" method="POST">
    <td width="100%" align="center" bgcolor="#FFFFFF"><br>	
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="98%">
  <tr>
    <td width="64%" valign="top">
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="33%" height="19"><font face="Verdana" size="2">Company Name</font></td>
    <td width="68%" height="19" colspan="2"><input type="text" name="DEPTNAME" size="40" value="<%=ALLT(DEPTNAME)%>" tabindex="1"></td>
  </tr>
  <tr>
    <td width="33%" height="18"><font face="Verdana" size="2">Company Address</font></td>
    <td width="68%" height="18" colspan="2"><input type="text" name="ADD1" size="40" value="<%=ALLT(ADD1)%>" tabindex="2"></td>
  </tr>
  <tr>
    <td width="33%" height="18"><font face="Verdana" size="2">City</font></td>
    <td width="68%" height="18" colspan="2">
    <input type="text" name="CITY" size="40" value="<%=ALLT(CITY)%>" tabindex="3"></td>
  </tr>
  <tr>
    <td width="33%" height="18"><font face="Verdana" size="2">State, Zip Code</font></td>
    <td width="40%" height="18">
	<select size="1" name="STATEID" class="state-select" style="width: 170px;">
			  		<option selected value="<%=ALLT(STR(pnSTATEID))%>"><%=ALLT(PROPER(_DEPARTMENT.STATE))%></option>
			  		 <% SELECT _STATE
					 	 SCAN %>
				   		<option value="<%=ALLT(STR(STATEID))%>"><%=ALLT(PROPER(STATE))%></option>
					 <% ENDSCAN %>
					</select></td>
    <td width="28%" height="18">
    <input type="text" name="ZIP" size="7" value="<%=ALLT(_DEPARTMENT.ZIP)%>" tabindex="5"></td>
<%	SELECT _DEPARTMENT%>
  </tr>  
  <tr>
    <td width="33%" height="19"><font face="Verdana" size="2">Company Phone</font></td>
    <td width="68%" height="19" colspan="2"><input type="text" name="TOLLFREE" size="40" value="<%=ALLT(TOLLFREE)%>" tabindex="6"></td>
  </tr>
  <tr>
    <td width="33%" height="19"><font face="Verdana" size="2">Company Fax</font></td>
    <td width="68%" height="19" colspan="2"><input type="text" name="FAX" size="40" value="<%=ALLT(FAX)%>" tabindex="7"></td>
  </tr>
  <tr>
    <td width="33%" height="18"><font face="Verdana" size="2">Company Email</font></td>
    <td width="68%" height="18" colspan="2"><input type="text" name="EMAIL" size="40" value="<%=ALLT(EMAIL)%>" tabindex="8"></td>
  </tr>
  <tr>
    <td width="33%" height="18"><font face="Verdana" size="2">Company Website</font></td>
    <td width="68%" height="18" colspan="2"><input type="text" name="WEB" size="40" value="<%=ALLT(WEB)%>" tabindex="9"></td>
  </tr>
  <tr>
    <td width="33%" height="19"><font face="Verdana" size="2">Company Slogan</font></td>
    <td width="68%" height="19" colspan="2"><input type="text" name="SLOGAN" size="40" value="<%=ALLT(SLOGAN)%>" tabindex="11"></td>
  </tr>  
  <tr>
    <td width="33%" height="19"><font face="Verdana" size="2">Web Redirect</font></td>
    <td width="68%" height="19" colspan="2"><input type="text" name="WEBREDIRECT" size="40" value="<%=ALLT(WEBREDIRECT)%>" tabindex="12"></td>
  </tr>
  <% IF plESUBJECT=.T. %>
  <tr>
    <td width="33%" height="19"><font face="Verdana" size="2">Email Subject</font></td>
    <td width="68%" height="19" colspan="2"><input type="text" autocomplete="off" name="ESUBJECT" size="40" value="<%=ALLT(ESUBJECT)%>" tabindex="13"></td>
  </tr>
  <%ENDIF%>  
</table>
    </td>
    <td width="1%">&nbsp;</td>
    <td width="35%" valign="top">
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;font-family:Arial;font-size:10pt;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center" colspan="2"><font face="Verdana" size="2" color="#0081D3"><b>Company License</b></font></td>
 </tr>
  <tr>
    <td width="53%"><font face="Verdana" size="2">US DOT</font></td>
    <td width="49%"><input type="text" name="DOT" size="12" value="<%=ALLT(DOT)%>" tabindex="14"></td>
 </tr>
  <tr>
    <td width="53%"><font face="Verdana" size="2">ICC MC</font></td>
    <td width="49%"><input type="text" name="ICC" size="12" value="<%=ALLT(ICC)%>" tabindex="15"></td>
 </tr>
  <tr>
    <td width="53%"><font face="Verdana" size="2">State Registration</font></td>
    <td width="49%"><input type="text" name="REGISTER" size="12" value="<%=ALLT(REGISTER)%>" tabindex="16"></td>
 </tr>
</table>
 <BR>
<table border="0" cellpadding="1" cellspacing="2" style="border-radius:6px;border: 1px solid #A9A9A9;line-height:25px;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center"><b><font Face="Verdana" size="2"><a href="/wc.dll?mpmainten~esignbodywc~<%=pcSCR%>~<%=lcDEPTID%>">Electronic Signature Policy</a></font></b></td>
 </tr>
</table>
    </td>
 </tr>
</table>
      <BR>
<table border="0" width="60%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="32%" align="center"><input type="button" CLASS="SUBOFF" name="B31" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="12" value="Submit" size="20"></td>
    <td width="32%" align="center"><input type="submit" CLASS="SUBOFF" name="B53" onclick="submitFunction(2)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="13" value="Exit"></td>
 </tr>   
</table>
  <BR>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="95%">
  <tr>
    <td width="100%" align="center"><b><font face="Verdana" style="font-size:11pt;" color="#0081D3">Thank You Message to Customer After Inventory</font></b></td>
 </tr>
  <tr>
    <td width="100%"><textarea rows="7" name="THANKSTXT" cols="65"><%=ALLT(THANKSTXT)%></textarea></td>
 </tr>
</table>
</form>
  &nbsp;</td>
   </tr>
  <tr>
    <td width="100%" bgcolor="#0081D3" height="14">&nbsp;<b><font face="Verdana" size="2" color="#FFFFFF">View By: <%=pcUSER%></font></b></td>
  </tr>
</table>

</body>
</html>