<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Jobs in Process</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mv~oprprocessret~<%=pcSCR%>";
       document.theForm.submit();
      }
	}
</SCRIPT>

<STYLE TYPE="text/css">
	.txtoff		{	color: #006600;
				  	font-size: 12pt;
  				  	font-family: Times new Roman;
  				  	cursor: Hand;
					background-color: white;
				  	text-align: left}
	.txton		{	color: blue;
				  	font-size: 12pt;
				  	text-align: left;
  				  	font-family: Times new Roman;
  				  	cursor: Hand;
					background-color: white;
					text-decoration: underline
  				  	cursor: Hand}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBONEXIT 	{	color: red; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

<body BGCOLOR="#4E6699">
<br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="500" align="center" height="351">
  <tr>
    <td width="100%" height="14">
    <IMG ALT="" SRC="zz/images/topBarOpr.gif" width="500" height="14"></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#bebe99" height="20"><p align="center"><a href="javascript:window.close()">
    <img border="0" src="zz/images/x.gif" align="right" width="17" height="18"></a>
    <b><font size="4" color="#993366" face="Verdana">Jobs in Process</font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF" height="245">
	<!-- frame table -->
    <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" height="278">
	  <tr>
	    <td width="100%" height="1">
    </td>
  </tr>
  <tr>
    <td width="100%" align="center" height="278">
	<!--- Main -->
		<form name="theForm" method="POST">
		<br>
		<table border="1" align="center" width="90%" cellspacing="0" align="center">
		 <tr><td valign="top">
			<!-- Dates-->
	    <table border="0" width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" height="23">
		 <tr>
		  <td width="25%" height="3" bgcolor="#008000"><b><font face="Verdana" size="2" color="#FFFFFF">Date of Move:</font></b></td>
		  <td width="40%" height="3" align="right"><i><font color="#000080" size="2" face="Verdana">From:</font></i><input type="text" name="DATE1" size="10" value="<%=DATE()-14%>"></td>
		  <td width="40%" height="3" align="right"><i><font color="#000080" size="2" face="Verdana">To:</font></i><input type="text" name="DATE2" size="10" value="<%=DATE()%>"></td>
			  </tr>
			</table>
			<!-- Dates-->
		</td></tr><tr><td width="100%">
			<!-- State-->
			<table border="0" width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" height="23">
			  <tr>
			    <td width="25%" height="3" bgcolor="#008000"><b><font face="Verdana" color="#FFFFFF" size="2">States:</font></b></td>
			    <td width="40%" height="3" align="right"><i><font color="#000080" size="2" face="Verdana">From:</font></i>
			    <select size="1" name="STATE1">
			  		<option selected>ALL</option>
			  		 <%	SELECT _STATE
					 	 SCAN %>
				   		<option><%=ALLT(STATE)%></option>
					 <% ENDSCAN %>
					</select></td>
			    <td width="40%" height="3" align="right"><i>
                <font color="#000080" size="2" face="Verdana">To:</font></i>
                <select size="1" name="STATE2">
				   		<option selected>ALL</option>
				     <%	 SELECT _STATE
					 	 SCAN %>
				   		<option><%=ALLT(STATE)%></option>
					 <% ENDSCAN %>
					</select></td>
			  </tr>
			</table>
			<!-- State-->
		</td></tr><tr><td width="100%">
			<table border="0" width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
			  <tr>
			    <td width="25%" bgcolor="#008000"><b><font face="Verdana" color="#FFFFFF" size="2">Department:</font></b></td>
			    <td width="20%"><font face="Arial Narrow" size="4">
			    	<select size="1" name="DEPT">
			  		<option selected>ALL</option>
				  		 <%	SELECT _DEPARTMENT
					 	 SCAN %>
				   		<option><%=ALLT(DEPT)%></option>
					 <% ENDSCAN %>
					</select></font></td>
			    <td width="5%" bgcolor="#FFFFFF">&nbsp;</td>
			    <td width="25%" bgcolor="#FFFFFF">&nbsp;</td>
			    <td width="20%" bgcolor="#FFFFFF">&nbsp;</td>
			  </tr>
			</table>
			<!-- Dept & Rep-->
		</td></tr></table>
		<br>
		<table border="1" align="center" width="90%" cellspacing="0" align="center">
		 <tr><td valign="top">
			<!-- Status-->
			<table border="0" width="100%" align="center" cellspacing="0" cellpadding="3">
			  <tr>
			    <td width="100%" height="17" bgcolor="#008000" colspan="2" align="center"><b>
                <font face="Verdana" color="#FFFFFF" size="2">Status of Jobs</font></b></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input class="chkon" type="radio" name="STATUS" value="V1" checked></td>
			    <td width="95%" height="20"><font face="Arial" size="2">All Jobs</font></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input type="radio" name="STATUS" value="V2" ></td>
			    <td width="95%" height="20"><font face="Arial" size="2">Jobs in Operation</font></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input type="radio" name="STATUS" value="V3" ></td>
			    <td width="95%" height="20"><font face="Arial" size="2">Operation Report</font></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input type="radio" name="STATUS" value="V4"></td>
			    <td width="95%" height="20"><font face="Arial" size="2">Completed Jobs</font></td>
			  </tr>
		  </table>
			<!-- Status-->
		 </td><td valign="top">
			<!-- Sort-->
			<table border="0" width="100%" align="center" cellspacing="0" cellpadding="3">
			  <tr>
			    <td width="100%" height="17" bgcolor="#008000" colspan="2" align="center"><b>
			    <font face="Verdana" color="#FFFFFF" size="2">&nbsp;Sort By</font></b></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input class="chkon" type="radio" name="SORT" value="V1" checked></td>
			    <td width="95%" height="20"><font face="Arial" size="2">Job No.</font></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input type="radio" name="SORT" value="V2"></td>
			    <td width="95%" height="20"><font face="Arial" size="2">
                Operation Date</font></td>
			  </tr>
			  </table>
			<!-- Sort-->
		 </td><td valign="top">
			<!-- Type-->
			<table border="0" width="100%" align="center" cellspacing="0" cellpadding="3">
			  <tr>
			    <td width="100%" height="17" bgcolor="#008000" colspan="2" align="center"><b>
			    <font face="Verdana" color="#FFFFFF" size="2">Type of Jobs</font></b></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input class="chkon" type="radio" name="TYPE" value="V1" checked></td>
			    <td width="95%" height="20"><font face="Arial" size="2">All Jobs</font></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input type="radio" name="TYPE" value="V2"></td>
			    <td width="95%" height="20"><font face="Arial" size="2">Local</font></td>
			  </tr>
			  <tr>
			    <td width="5%" height="20"><input type="radio" name="TYPE" value="V3"></td>
			    <td width="95%" height="20"><font face="Arial" size="2">Long Distance</font></td>
			  </tr>
			  </table>
			<!-- Type-->
		</td></tr></table>
 <br>
		<table border="0" width="40%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
		  <tr>
		    <td width="49%" align="center"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="B3" onclick="submitFunction(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="9" value="Submit"></td>    
		  </tr>
		</table>
	</td></tr></table>
		</form>
    </td></tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15">
    <p align="left"><font size="2" color="white" align="left">User: <%=pcUser%> </font></td>
  </tr>
  <tr>
    <td width="100%" height="14">
    <IMG ALT="" SRC="zz/images/botBar.gif" width="500" height="14"></td>
  </tr>
</table>
</body>
</html>