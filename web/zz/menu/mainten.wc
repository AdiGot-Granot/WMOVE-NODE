    if (i==9) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~9');
    if (i==10) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~10');
    if (i==11) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~11');
