    if (i==17) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~17');
    if (i==18) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~18');
    if (i==19) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~19');
    if (i==20) window.location.href=('/wc.dll?mpmainten~tasklistwc~<%=pcSCR%>~20');        
    if (i==25) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~25');
    if (i==26) window.location.href=('/wc.dll?mpmainten~fullvaluewc~<%=pcSCR%>~26');

