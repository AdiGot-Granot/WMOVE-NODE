 </tr>
 <%ENDIF%>   
</table>
   </td>
  </tr>
</table>
<!-- frame table -->
    </td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#993366" height="15">&nbsp;<font size="2" color="white"><%=pcOMSTITLE%></font></td>
  </tr>
    <td width="100%" bgcolor="#FFEFCC" align="center" height="10">
   <%IF plFINANCE OR 1=1%>
	 <br>
	 <table border="0" width="40%" align="center" cellspacing="0" cellpadding="0" align="center">
  		<tr>
    	<td width="100%">
  
	      <%IF pnLEVEL=2 OR pnLEVEL>=5%>
			<%IF lnDays = 0 and !EMPTY(lnDays)%>
				<table border='1' align='center' width='100%'>
					<tr>
						<td width='100%' align='center'><font color='#FF0000' face='Verdana' size='2'><b><%=pcSTR%></b></font>&nbsp;</td>
					</tr>
				</table>
			<%ENDIF%>	


		    <%IF lnDays > 0 AND lnDays <= 10%>
				<table border='1' align='center' width='100%' height="45">
					<tr>
						<td width='100%' align='center' height="14"><b><font face='Verdana' size='2' color='#009E00'><%=pcSTR%></font></b></td>
					</tr>
					<tr>
						<td width='100%' align='right' height="19">
							<%FOR I=0 TO lnDays-1 %>
								<img src='zz/images/pointg.gif' width='10' height='15'>
							<% NEXT I %></td>
					</tr>
				</table>
			<%ENDIF%>	

	      	<%IF lnDays =< 0%>
				<table border='1' align='center' width='100%'>
					<tr>
						<td width='100%' align='center'><font color='#FF0000' face='Verdana' size='2'><b><%=pcSTR%></b></font>&nbsp;</td>
					</tr>
					<tr>
						<td width='100%' align='left'>
							<% lnDays = IIF(lnDays<-15,15,lnDays*-1 )
								FOR I=lnDays-1 TO 0 STEP -1%>
								<img src='zz/images/pointr.gif' width='10' height='15'>
							<% NEXT I %></td>
					</tr>
				</table>
			<%ENDIF%>
    		<table border='0' width='100%' align='center'>
		    		<tr>
			       	<td align="center"><a href="<%=pcOmsAccount%>" target="_blank">
			       	<font style="font-family:Verdana;font-size:9pt;color:blue;"><b>OMS Account</b></font></a></td>
				</tr>
		    		<tr>
			       	<td align="center"><a href="<%=gcINFOSYSURL%>/WMFINWCS.arnEntry?&CUSTID=<%=pcCUSTID%>&CUSTREF=<%=pcCOCUSTREF%>&USERID=<%=pcUSERID%>&PAGEID=8012" target="_blank">
			       	<font style="font-family:Verdana;font-size:9pt;color:blue;"><b>View financial records</b></font></a></td>
				</tr>
			</table>
		<%ENDIF%>	
	    </td>
	  </tr>
	</table>
   <%ENDIF%>
   <%SELECT _CC%>
<% IF RECCOUNT()>0 AND (pnLEVEL=2 OR pnLEVEL=5)%>
    <br>
<table border="1" align="center" width="70%">
  <tr>
	<td colspan="2" align="center"><font style="font-family:Verdana;font-size:10pt;"><b>
	<% IF plBLKSELFPAY=.F. %>Self Payment Processing is enabled<br><br><%ENDIF%>You Have an Unverified Credit Card on File</b></font></td>
 </tr>
   <%SCAN%>
  <tr>
	<td width="50%"><a href='<%=gcINFOSYSURL%>/WMFINWCS.arnEntry?&CUSTID=<%=pcCUSTID%>&CUSTREF=<%=pcCOCUSTREF%>&USERID=<%=pcUSERID%>&PAGEID=8012' target="_blank"><b>Print Credit Card Form</b></a>&nbsp;</td>
	<td width="50%"><b>Last Used: <%=ALLT(_CC.RECENTDTE)%></b></td>
 </tr>
  <%ENDSCAN%>
</table>
<%ENDIF%>
      </td>
  </tr>
  <tr>
    <td width="100%" height="15"><IMG SRC="/zz/images/botBar.gif" width="500" height="14"></td>
  </tr>  
  </table>
<table border="0" width="500" align="center">
  <tr>
	<td align="center"><font color="#FFFFFF" face="Verdana" size="2"><b><%=pcCOPYRIGHT%></b></font></td>
 </tr>
</table>  
</body>
</html>