<script language="JavaScript">
var msg="Right Click Disabled!";
function disableIE() {if (document.all) {alert(msg);return false;}
}
function disableNS(e) {
  if (document.layers||(document.getElementById&&!document.all)) {
    if (e.which==2||e.which==3) {alert(msg);return false;}
  }
}
if (document.layers) {
  document.captureEvents(Event.MOUSEDOWN);document.onmousedown=disableNS;
} else {
  document.onmouseup=disableNS;document.oncontextmenu=disableIE;
}
document.oncontextmenu=new Function("alert(msg);return false")
</script>
<SCRIPT LANGUAGE="JAVASCRIPT">

<!----!glDEVELOP AND--->

<%IF (pnLEVEL=2 OR pnLEVEL=>5) AND plSTOP %>
	if (self.location != top.location) top.location = self.location;
	window.location.href=('<%=gcINFOSYSURL%>/WMFINWCS.arnEntry?&CUSTID=<%=pcCUSTID%>&CUSTREF=<%=pcCOCUSTREF%>&USERID=<%=pcUSERID%>&PAGEID=8012');	      
<%ENDIF%>

function submitFunction(i) {
    if (i==1) window.open('/wc.dll?mv~selectesttype~<%=pcSCR%>','');
    if (i==2) window.open('/wc.dll?mv~estprocesswc~<%=pcSCR%>','');
    if (i==3) window.open('/wc.dll?mv~searchwc~<%=pcSCR%>','');
    if (i==4) window.open('/wc.dll?mpest~recuringwc~<%=pcSCR%>','');
	if (i==8) window.open('/wc.dll?mprep~repmenuwc~<%=pcSCR%>','');    

<%IF pnCOLEVEL > 3 %>
    if (i==5) window.open('/wc.dll?mprep~reptaskswc~<%=pcSCR%>','');    
<%ENDIF%>
<%IF pnLEVEL=2 OR pnLEVEL=5 %>
    if (i==6) window.open('/wc.dll?mpmainten~maintenwc~<%=pcSCR%>','');
<%ENDIF%>
<%IF pnLEVEL>2 %>
    if (i==7) window.open('/wc.dll?mv~oprmenuwc~<%=pcSCR%>','');
<%ENDIF%>
<%IF plAGENT AND pnLEVEL>1 %> 
    if (i==9) window.open('/wc.dll?mpagent~agprocesswc~<%=pcSCR%>','');
<%ENDIF%>
<%IF plCOSTORAGE AND pnLEVEL>2 %>
    if (i==10) window.open('/wc.dll?mpstg~stgprocesswc~<%=pcSCR%>','');
<%ENDIF%>
<%IF pnCOLEVEL > 2%>   
    if (i==11) window.open('/wc.dll?mprep~followupwc~<%=pcSCR%>','');
    if (i==17) window.open('/wc.dll?mprep~recentaccess~<%=pcSCR%>~MAINMENU','');  
<%ENDIF%>    
<%IF pnCOLEVEL <> 3 and (pnLEVEL= 2 OR pnLEVEL > 3 OR plASSIGNNEW) %>    
    if (i==12) window.open('/wc.dll?mpscripts~assignnewwc~<%=pcSCR%>','');
<%ENDIF%>    
<%IF (pcCUSTNO='BUDGETVAN' OR pcCUSTNO='ULOAD') AND pnLEVEL > 3 %>
	if (i==13) window.open('/wc.dll?mv~AssignNewMenu~<%=pcSCR%>','');
<%ENDIF%>
<%IF pcCUSTNO='BUDGETVAN' AND pnLEVEL=5 %>
    if (i==19) window.open('/wc.dll?mprep~PastFollowup~<%=pcSCR%>','');    
<%ENDIF%>
<%IF (pcCUSTNO='BUDGETVAN' AND pcUSER='CHARLIE') OR (pcCUSTNO='MOVINGAPT')%>
    if (i==14) window.open('/wc.dll?mprep~userslist~<%=pcSCR%>','');
<%ENDIF%>    
      
<%IF pnCOLEVEL=7 %>  
    if (i==20) window.open('/wc.dll?mpopr~futureoprwc~<%=pcSCR%>','');
    if (i==21) window.open('/wc.dll?mprep~salesprdwc~<%=pcSCR%>','');
<%ENDIF%>
    
<%IF (pnCOLEVEL=3 AND pnLEVEL=2) OR plASSIGNNEW %>  
    if (i==25) window.open('/wc.dll?mpauto~autoleadsprcwc~<%=pcSCR%>','');
    if (i==26) window.open('/wc.dll?mv~AssignNewList~<%=pcSCR%>','');    
<%ENDIF%>

	}
	
<% IF !plBLKCALD%>
function OprCald() {
   <% IF plNEWCALD=.T. %>
     window.open('/wc.dll?mpopr~oprcald~<%=pcSCR%>')
   <%ELSE%>  
     window.open('/wc.dll?mpopr~dailyopr~<%=pcSCR%>')
   <%ENDIF%>
  }
<% ENDIF %>
	

function newsletter() {
    window.open('https://eagle.hellomoving.com/zz/help/newsletter.htm');
	}
	
<% IF 1=2 AND plPERSONAL %>
function personal() {
     window.open('/wc.dll?mputil~personalwc~<%=pcSCR%>')
  }
<% ENDIF %>

function oprbooked() {
    window.open('/wc.dll?mpopr~oprbookedwc~<%=pcSCR%>','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=450,height=250');
	}

function ondemand() {
     window.open('<%=gcINFOSYSURL%>/WMFINWCS.arnEntry?&CUSTID=<%=pcCUSTID%>&CUSTREF=<%=pcCOCUSTREF%>&USERID=<%=pcUSERID%>&PAGEID=1019')
  }
  
function leadsclaim() {
     window.open('<%=gcINFOSYSURL%>/WMFINWCS.arnEntry?&CUSTID=<%=pcCUSTID%>&CUSTREF=<%=pcCOCUSTREF%>&USERID=<%=pcUSERID%>&PAGEID=1011')
  }
  
function leadsale() {
     window.open('<%=gcINFOSYSURL%>/QUICKLEADS1WCS.arnleads?&CUSTID=<%=pcCUSTID%>&CUSTREF=<%=pcCOCUSTREF%>&USERID=<%=pcUSERID%>')
  }
 
function chat() {
    window.open('https://chat.hellomoving.com/?key=<%=pcSCR%>~<%=pcCUSTNO%>~<%=pcUSER%>~<%=ALLT(STR(pnLEVEL))%>~<%=ALLT(pcSERVERNAME)%>');
	}

function LogOut() {
    parent.location.href=('/wc.dll?mp~LogOut~<%=pcSCR%>~<%=pcCUSTNO%>~<%=pcUSER%>');
	self.name="main"}


/// Leads


</SCRIPT>

<STYLE TYPE="text/css">
	.txtoff		{	font-size: 10pt;
  				  	font-family: verdana;
  				  	cursor: pointer;
					background-color: white;
					font-weight: bold;
				  	text-align: left}
	.txton		{	font-size: 10pt;
				  	text-align: left;
  				  	font-family: verdana;
					background-color: white;
					text-decoration: underline;
					font-weight: bold;
  				  	cursor: pointer;}
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 140;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
 	A:hover		{	text-decoration: nounderline;}
 	A			{	text-decoration: underline;
					color: blue}
	[data-letters]:before {
  	content:attr(data-letters);
  	display:inline-block;
  	font-size:1.5em;
  	width:1.9em;
  	height:1.9em;
  	line-height:1.9em;
  	text-align:center;
  	border-radius:50%;
  	background:#0078D7;
  	color:white;
  	}					
</style>

<script type="text/javascript">
  var _gaq = _gaq || [];
  _gaq.push(['_setAccount', 'UA-19871667-2']);
  _gaq.push(['_trackPageview']);


  (function() {
    var ga = document.createElement('script'); ga.type = 'text/javascript'; ga.async = true;
    ga.src = ('https:' == document.location.protocol ? 'https://ssl' : 'http://www') + '.google-analytics.com/ga.js';
    var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(ga, s);
  })();

</script>

</head>
