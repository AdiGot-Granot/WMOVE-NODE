    if (i==16) window.location.href=('/wc.dll?mpmainten~maintenret~<%=pcSCR%>~16');    	
    if (i==17) window.location.href=('/wc.dll?mpmainten~TariffMenuWc~<%=pcSCR%>');    	
    if (i==18) window.location.href=('/wc.dll?mputil~Exceptions~<%=pcSCR%>');    	
	
	}

function submitTables(i) {
    if (i==1) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~1');
    if (i==2) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~2');
    if (i==3) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~3');
    if (i==4) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~4');
    if (i==5) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~5');
    if (i==6) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~6');
    if (i==7) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~7');
    if (i==8) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~8');
    if (i==9) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~9');
    if (i==10) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~10');
    if (i==11) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~11');
    if (i==12) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~12');    
    if (i==13) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~13');
    if (i==14) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~14');
    if (i==15) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~15');
    if (i==16) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~16');
    if (i==17) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~17');
    if (i==18) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~18');
    if (i==19) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~19');
    if (i==20) window.location.href=('/wc.dll?mpmainten~tasklistwc~<%=pcSCR%>~20');        
    if (i==25) window.location.href=('/wc.dll?mpmainten~tablesret~<%=pcSCR%>~25');
    if (i==26) window.location.href=('/wc.dll?mpmainten~fullvaluewc~<%=pcSCR%>~26');

	}

</SCRIPT>

<STYLE TYPE="text/css">
	.txtoff		{	color: #006600;
				  	font-size: 12pt;
  				  	font-family: Times new Roman;
  				  	cursor: pointer;
					background-color: white;
				  	text-align: left;}
	.txton		{	color: blue;
				  	font-size: 12pt;
				  	text-align: left;
  				  	font-family: Times new Roman;
					background-color: white;
					text-decoration: underline;
  				  	cursor: pointer;}
	.txtoffblue	{	color: #083484;
				  	font-size: 12pt;
  				  	font-family: Times new Roman;
  				  	cursor: pointer;
					background-color: white;
				  	text-align: left} 				  	
 	A:hover		{	text-decoration: nounderline;
 					color: red}
 	A			{	text-decoration: underline;
					color: blue}
</style>
</head>

