<title>Maintenance Menu</title>
<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
    if (i==2) window.location.href=('/wc.dll?mpmainten~maintenret~<%=pcSCR%>~2');
    if (i==3) window.location.href=('/wc.dll?mpmainten~maintenret~<%=pcSCR%>~3');
    if (i==4) window.location.href=('/wc.dll?mpmainten~maintenret~<%=pcSCR%>~4');    
