	<td width="28%" height="30"><img border="0" src="zz/util/calendr.gif" <%IF pnLEVEL=2 OR pnLEVEL=5 %>onclick="oprbooked()" style="cursor:pointer;" title="Summary of current and future estimates"<%ENDIF%> width="23" height="26"></td>
 </tr>
<%ENDIF%>	              
<%IF pnCOLEVEL=7%>
   <% IF !plBLKFUOPR%>
