	 <br>
	 <table border="0" width="40%" align="center" cellspacing="0" cellpadding="0" align="center">
  		<tr>
    	<td width="100%">
  
			<%IF lnDays = 0 and !EMPTY(lnDays)%>
				<table border='1' align='center' width='100%'>
					<tr>
						<td width='100%' align='center'><font color='#FF0000' face='Verdana' size='2'><b><%=pcSTR%></b></font>&nbsp;</td>
					</tr>
				</table>
			<%ENDIF%>	


		    <%IF lnDays > 0 AND lnDays <= 10%>
				<table border='1' align='center' width='100%' height="45">
					<tr>
						<td width='100%' align='center' height="14"><b><font face='Verdana' size='2' color='#009E00'><%=pcSTR%></font></b></td>
					</tr>
