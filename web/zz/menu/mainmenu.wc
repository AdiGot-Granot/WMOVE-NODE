 </tr>
<%ENDIF%>						  						  
  <tr>
	<td width="9%" height="30" style="text-align: center"><img border="0" src="zz/images/n-point.gif" width="10" height="10"></td>
	<td width="91%" height="30" colspan="2"><font class="txtoff" onclick="submitFunction(3)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">Advanced Search</font></td>
