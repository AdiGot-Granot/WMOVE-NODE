 </tr>
<%ENDIF%>
<%IF pnLEVEL=2 OR pnLEVEL > 3 %>
  <tr>
	<td width="8%" height="30" style="text-align: center"><img border="0" src="zz/images/n-point.gif" width="10" height="10"></td>
	<td width="92%" height="30"><font class="txtoff" onclick="submitFunction(18)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">Handbook &amp; Workflow</td>
 </tr>
<%ENDIF%>
  <tr>
