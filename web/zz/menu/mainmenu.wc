	<td width="92%" height="30"><font class="txtoff" onclick="submitFunction(5)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">Tasks to Complete <%=pcTASKS%><font color="#EA4335"><%=pcUSERTASK%></font></font></td>
 </tr>
<%ENDIF%>  
<%IF pnCOLEVEL > 2%> 
  <tr>
	<td width="8%" height="30" style="text-align: center"><img border="0" src="zz/images/n-point.gif" width="10" height="10"></td>
	<td width="92%" height="30"><font class="txtoff" onclick="submitFunction(11)" onmouseover="javascript: this.className='txton'" onmouseout="javascript: this.className='txtoff'">Follow-Up Menu <%=pcFUCNT%></font></td>
 </tr>
  <tr>
	<td width="8%" height="30" style="text-align: center"><img border="0" src="zz/images/n-point.gif" width="10" height="10"></td>
