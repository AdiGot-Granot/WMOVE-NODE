						<td width='100%' align='center'><font color='#FF0000' face='Verdana' size='2'><b><%=pcSTR%></b></font>&nbsp;</td>
					</tr>
					<tr>
						<td width='100%' align='left'>
							<% lnDays = IIF(lnDays<-13,13,lnDays*-1 )
								FOR I=lnDays-1 TO 0 STEP -1%>
								<img src='zz/images/pointr.gif' width='10' height='15'>
							<% NEXT I %></td>
