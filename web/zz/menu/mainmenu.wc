<% IF LEFT(pcCUSTNO,4)<>'DEMO' AND (pnLEVEL=2 OR pnLEVEL=5) %>
 <BR>
  <table border='0' width='70%' align='center'>
   	<tr>
      <td align='center'><a href="<%=pcOmsAccount%>" target="_blank"><font style="font-family:Verdana;font-size:10pt;color:blue;"><b>OMS Account Finances</b></font></a></td>
	</tr>
	<% IF lnDOCS > 0 %>
   	<tr>
      <td height="50"><b><font face="Verdana" size="2">You have <font color="FF0000"><%=lnDOCS%></font> documents pending signature. Enter the <font color="0000FF">OMS Account Finances</font> link above to sign.</font></b></td>
	</tr>
	<%ENDIF%>		
 </table>   			    
