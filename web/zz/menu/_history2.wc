<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Data Cleanup</title>
<!----lightbox-->
<script type="text/javascript" src="/zz/fancybox/jquery-latest.min.js"></script>
<script type="text/javascript" src="/zz/fancybox/jquery.fancybox.js?v=2.1.5"></script>
<link rel="stylesheet" type="text/css" href="/zz/fancybox/jquery.fancybox.css?v=2.1.5" media="screen" />
<!---lightbox--->

<SCRIPT LANGUAGE="JAVASCRIPT">

$(document).ready(function() {
	$('.fancybox').fancybox({
		fitToView	: false,
		maxWidth	: 600,
		maxHeight	: 350,
		autoSize	: false,
		openEffect	: 'none',
		closeEffect	: 'none'
	});
});


function submitEstProcess(i) {
    if (i==1) 
      { 
       document.theForm.action="/wc.dll?mpmainten~historyret~<%=pcSCR%>";
       document.theForm.submit();
      }
	}

</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: pointer;}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 120;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: pointer;}
</style>
</head>

<body BGCOLOR="#4E6699"><br>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="630" align="center">
  <tr>
    <td><a class="fancybox fancybox.iframe" href="/zz/help/datacleanup.htm"><img border="0" src="zz/util/manual.gif" title="Read about Data Cleanup" width="32" height="32"></a></td>
  </tr>
</table>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="630" align="center">
  <tr>
    <td width="100%" align="center" height="25" background="/ZZ/images/bar-green.gif">
    <a href="javascript:window.close()"><img border="0" src="/zz/images/x-yellow.gif" align="right" width="17" height="18"></a><b><font face="Verdana" color="#FFFFFF">Data Clean-Up</font></b></td>
  </tr>
  <tr>
    <td bgcolor="#FFFFFF" width="630">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" align="center">
		<form name="theForm" method="POST">
      <br>
<table border="1" align="center" width="80%" cellspacing="0" align="center" bordercolor="#C0C0C0">
  <tr>
   <td width="100%">
<table border="0" width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="48%" height="3" bgcolor="#008000"><b><font face="Verdana" size="2" color="#FFFFFF">Remove Jobs older than:</font></b></td>
	<td width="67%" height="3"><input type="text" name="DAYS" size="2" value="30" maxlength="4"><i><font color="#000080" size="2" face="Verdana"> Days</font></i></td>
 </tr>
</table>
   </td>
 </tr>
</table>
 <br><b><font face="Verdana" size="2" color="red">Be responsible with your selection and back-up your data prior to data clean-up.</font></b>
<table border="1" align="center" width="98%" cellspacing="0" align="center" bordercolor="#C0C0C0">
  <tr>
	<td valign="top">	
<table border="0" width="100%" align="center" cellspacing="0" cellpadding="3">
  <tr>
	<td width="100%" height="13" bgcolor="#008000" colspan="2" align="center"><b><font face="Verdana" color="#FFFFFF" size="2">Status of Data</font></b></td>
 </tr> 
  <tr>
	<td width="5%" height="20"><input class="chkon" type="radio" name="STATUS" value="V1" checked tabindex="1"></td>
	<td width="95%" height="20"><font face="Arial" size="2">There are <font size="3" color="red"><B><%=pcCANCEL%></B></font> Canceled Estimates; Canceled date is past 30 days</font></td>
 </tr>
  <tr>
	<td width="5%" height="20"><input type="radio" name="STATUS" value="V3" tabindex="3"></td>
	<td width="95%" height="20"><font face="Arial" size="2">There are <font size="3" color="red"><B><%=pcFOLLOW%></B></font> Follow-Up Estimates; Move date is past 30 days</font></td>
 </tr>
  <tr>
	<td width="5%" height="20"><input type="radio" name="STATUS" value="V4" tabindex="3"></td>
	<td width="95%" height="20"><font face="Arial" size="2">There are <font size="3" color="red"><B><%=pcFUPRIOR%></B></font> Follow-Up Estimates; Priority 6, 7, 8 and General Pool; Move date past 30 days</font></td>
 </tr> 
  <tr>
	<td width="100%" height="16" colspan="2"><hr color="#000000" width="98%"></hr></td>
 </tr>
  <tr>
	<td width="5%" height="20"><input type="radio" name="STATUS" value="V2" tabindex="2"></td>
	<td width="95%" height="20"><font face="Arial" size="2">There are <font size="3" color="red"><B><%=pcCLOSED%></B></font> Closed Jobs; Close date is past 30 days</font></td>
 </tr>
</table>
   </td>
 </tr>
</table>
 <br>
<table border="0" width="40%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
	<td width="49%" align="center">
    <input type="button" CLASS="SUBOFF" name="B3" onclick="submitEstProcess(1)" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" value="View the List"></td>    
 </tr>
</table>
  </form>
    </td>
 </tr>
</table>
   </td>
 </tr>
  <tr>
    <td width="550" background="/zz/images/bgdown.gif" height="15"><font size="2" color="white">User: <%=pcUser%> </font></td>
  </tr>
</table>

</body>
</html>