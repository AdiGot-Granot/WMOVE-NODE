<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Vehicle Lead Pricing</title>

<SCRIPT LANGUAGE="JAVASCRIPT">

function submitFunction(i) {
			if (i==1) 
		      { 
		       document.theForm.action="/wc.dll?mpauto~autoleadsprcret~<%=pcSCR%>";
   		       document.theForm.submit();
		      }
		    }

</SCRIPT>

<STYLE TYPE="text/css">
	.TD1		{	color: #000000;
				  	font-size: 10pt;
					font-weight: bold;
  				  	font-family: Verdana;
					text-align: center;
					background-color: #F7F7F7;
					border-bottom: 1px solid #A9A9A9;}	
	.TD2		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: left;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
	.TD3		{	color: #000000;
				  	font-size: 10pt;
					font-family: Verdana;
					text-align: center;
					border-bottom: 1px solid #A9A9A9;}
	.TD4		{	font-size: 10pt;
  				  	font-family: Verdana;
					border-left: 1px solid #A9A9A9;
					border-bottom: 1px solid #A9A9A9;}
.SUBOFF {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120px;
  height: 35px;
  border-radius: 10px;
  font-size: 1.00rem;
  font-weight: 700;
  font-family: Arial, sans-serif;
  cursor: pointer;
  background: #556677;
  color: #FFF;
  border: none;
/*  border: 3px solid #1626F8; */
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.SUBOFF:hover {
  background: #0081D3;
  color: #FFF;
/*  border-color: #000; */
}					
</style>

</head>

<body>
    <%	SELECT _LIST
    	lnRecCount = RecCount() %>
<br><center><font face="Arial" color="#000000" size="4"><b>Vehicle Leads Pricing<br>
<font size="2">(Update vehicle price before assigning to Users)</font><br><br>Total Estimates: <%=ALLT(STR(lnRecCount))%></b></font><BR>
<!----END TITLE-->
<form name="theForm" method="POST">
<table border="0" align="center" style="border-radius:6px;border: 1px solid #A9A9A9;" cellspacing="1" cellpadding="2" bordercolor="#111111" width="80%">
  <tr>
    <td width="5%" class="TD1">Job No</td>
    <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Open Date</td>
    <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Type</td>
    <td width="7%" class="TD1" style="border-left: 1px solid #A9A9A9;">Customer</td>
    <td width="12%" class="TD1" style="border-left: 1px solid #A9A9A9;">Ship From</td>
    <td width="11%" class="TD1" style="border-left: 1px solid #A9A9A9;">Ship To</td>
    <td width="3%" class="TD1" style="border-left: 1px solid #A9A9A9;">Miles</td>
    <td width="6%" class="TD1" style="border-left: 1px solid #A9A9A9;">Move Date</td>
    <td width="14%" class="TD1" style="border-left: 1px solid #A9A9A9;">Make/Model</td>
    <td width="5%" class="TD1" style="border-left: 1px solid #A9A9A9;">Price</td>
    <td width="10%" class="TD1" style="border-left: 1px solid #A9A9A9;">Source</td>
 </tr>
   <% SELECT _LIST 
    	   SCAN %>
  <tr>
    <td width="5%" class="TD3"><a href="/wc.dll?mprep~printselect~<%=pcSCR%>~<%=REFNO%>" target='_blank'><%=ALLT(_LIST.DEPT)+ALLT(_LIST.ORDNO)%></a></td>
    <td width="6%" class="TD2"><%=OPENDTE%></td>
    <td width="3%" class="TD2">&nbsp;<%=IIF(ONLINE=.T.,'Web','Lead')%></td>
    <td width="7%" class="TD2">&nbsp;<%=ALLT(SNAME)%></td>
    <td width="12%" class="TD2">&nbsp;<%=ALLT(FROM)%></td>
    <td width="11%" class="TD2">&nbsp;<%=ALLT(TO)%></td>
    <td width="3%" class="TD4" align="right"><%=IIF(MILES=0,' ',ALLT(STR(MILES))) %>&nbsp;</td>
    <td width="6%" class="TD4">&nbsp;<b><font color="<%=IIF(LBOOKDTE<DATE(),'#FF0000','#008000')%>"><%=LBOOKDTE%></font></b></td>
    <td width="14%" class="TD4">&nbsp;<b><%=CARINFO%></b></td>
    <td width="5%" class="TD4" align="right">$<input type="text" name="<%=ALLT(ORDNO)%>" size="2" value="" maxlength="4"></td>
    <td width="10%" class="TD2"><%=ALLT(REF)%></td>
 </tr>
    <% ENDSCAN %>
</table>
 <% IF lnRecCount>0 %>
  <BR>
<table border="0" style="border-collapse: collapse" width="100%">
  <tr>
    <td width="100%" ALIGN="CENTER"><input id="btnSubmit" type="button" CLASS="SUBOFF" name="SUBMIT" onclick="submitFunction(1)" value="Submit"></td>
  </tr>
</table>
 <%ENDIF%>
</form>
<p align="center"><a href="javascript:window.close()"><font face="Arial" size="4">Exit</font></a></p>
</body>
</html>