<html>

<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">

<TITLE>Terminals Edit</TITLE>
<SCRIPT LANGUAGE="JAVASCRIPT">


function SubmitZone() {
       document.theForm.action="/wc.dll?mpauto~AutoTypeEditRet~<%=pcSCR%>~<%=pcID%>";
       document.theForm.submit();
	}

function DeleteZone() {
		var Message = "Are you sure you want to delete this Zone?";
		if (confirm (Message))
		  {
			document.theForm.action="/wc.dll?mpauto~AutoTypeDelete~<%=pcSCR%>~<%=pcID%>";
	        document.theForm.submit();
	      }
 
}



</SCRIPT>

<STYLE TYPE="text/css">
 	.SUBOFF	 	{	color: black; 
					font-weight: none;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #CCCCCC;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FFFF00;
					font-size: 10pt;
  				  	cursor: Hand}
	.SUBON1	 	{	color: #0000FF; 
					font-weight: bold;
					font-family: Arial;
				  	text-align: center;
					width: 100;
					background-color: #FF0000;
					font-size: 10pt;
  				  	cursor: Hand}
</style>

</head>

<body bgColor="#4E6699" <%=IIF(plCLOSE,"onload='javascript: window.close()'","")%>>

&nbsp;<%SELECT _AUTOZONE%>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="450" height="200">
  <tr>
    <td width="100%" height="18" bgcolor="#FF9900"><a onclick="javascript: window.close()">
    <img border="0" src="/zz/images/x-green.gif" style="cursor:hand;" align="right"></a></td>
  </tr>
  <tr>
    <td width="100%" BGCOLOR="#000000" align="center" height="19"><b><font color="#FFFFFF">&nbsp;<%=pcNAME%></font></b></td>
  </tr>
 <form name="theForm" method="POST">
  <td width="100%" align="center" bgcolor="#FFFFFF" height="1"  valign="top" >
<!--hidden pcID -->
<input type="hidden" name="ID" value="<%=pcID%>">
	<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" id="AutoNumber1">
      <tr>
        <td width="2%" >&nbsp;</td>
        <td width="53%" valign="top">
 <table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" id="AutoNumber2" height="123">
   <tr>
     <td width="20%" height="19" bgcolor="#ECECEC" valign="top"><b><font size="2">
     Zone ID</font></b></td>
     <td width="40%" height="19" bgcolor="#ECECEC" valign="top"><b><%=pcID%>&nbsp;</b></td>
     <td width="40%" height="19" bgcolor="#ECECEC" valign="top">
     &nbsp;</td>
  </tr>
   <tr>
     <td width="20%" height="1" bgcolor="#ECECEC" valign="top"><font size="2">
     <b>Name&nbsp; </b><font color="#FF0000">*</font></font></td>
     <td width="80%" height="1" bgcolor="#ECECEC" valign="top" colspan="2">
     <input type="text" name="NAME" size="46" value="<%=ALLT(NAME)%>" maxlength="25" style="border: 1px solid #FFFF00"> </td>
  </tr>
   <tr>
     <td width="20%" height="19" bgcolor="#ECECEC" valign="top"><b><font size="2">State</font></b></td>
     <td width="80%" height="19" bgcolor="#ECECEC" valign="top" colspan="2">
     <input type="text" name="STATE" size="11" value="<%=ALLT(STATE)%>" style="border: 1px solid #FFFF00" maxlength="2"></td>
  </tr>
   <tr>
     <td width="20%" height="19" bgcolor="#ECECEC" valign="top"><font size="2"><b>Zip.&nbsp; </b><font color="#FF0000">*</font></font></td>
     <td width="80%" height="19" bgcolor="#ECECEC" valign="top" colspan="2"><input type="text" name="ZIP" size="11" value="<%=ALLT(ZIP)%>" style="border: 1px solid #FFFF00" maxlength="5"></td>
  </tr>
   <tr>
     <td width="20%" height="19" bgcolor="#ECECEC" valign="top"><font size="2">
     <b>Radius&nbsp; </b><font color="#FF0000">*</font></font></td>
     <td width="80%" height="19" bgcolor="#ECECEC" valign="top" colspan="2">
     <input type="text" name="RADIUS" size="11" value="<%=IIF(RADIUS=0,'',ALLT(STR(RADIUS)))%>" style="border: 1px solid #FFFF00" maxlength="3"> 
     miles</td>
  </tr>
   <tr>
     <td width="20%" height="19" bgcolor="#ECECEC" valign="top">&nbsp;</td>
     <td width="80%" height="19" bgcolor="#ECECEC" valign="top" colspan="2">
     &nbsp;</td>
  </tr>
    
       </table>
        </td>
        <td width="1%">&nbsp;</td>
      </tr>
    </table>
    <br>
<table border="0" width="75%" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td width="24%" align="center">
    <input type="button" CLASS="SUBOFF" name="B54" onclick="SubmitZone()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="13" value="Submit" size="20"></td>
    <td width="3%" align="center">&nbsp;</td>
    <td width="3%" align="center">&nbsp;</td>
    <td width="31%" align="center">
    <input type="button" CLASS="SUBOFF" name="B57" onclick="DeleteZone()" onmouseover="javasctript: this.className='SUBON1'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="15" value="Delete" size="20"></td>
    <td width="2%" align="center">&nbsp;</td>
    <td width="29%" align="center">
    <input type="button" CLASS="SUBOFF" name="B56" onclick="javascript: window.close()" onmouseover="javasctript: this.className='SUBON'" onmouseout="javasctript: this.className='SUBOFF'" tabindex="15" value="Exit" size="20"></td>
 </tr>
</table>       
<!-- Buttons --->
    <br></td>
</form>
  <tr>
    <td width="100%" bgcolor="#000000" height="14">
    <p align="left"><b><font size="2" color="white" align="left">Modify By:&nbsp;&nbsp;<%=pcUser%></font></b></td>
  </tr>
  <tr>
    <td width="100%" bgcolor="#FFEFCC" align="left" height="1">
	 <b><font color="#FF0000" face="Arial Rounded MT Bold"><%=pcMSG%></font></b></td>
  </tr>
  <tr>
    <td width="100%" height="18" bgcolor="#FF9900">&nbsp;</td>
  </tr>

</table>

</body>

</html>