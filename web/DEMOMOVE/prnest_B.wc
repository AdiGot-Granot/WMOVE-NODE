            </tr>
      <%ENDSCAN %>
          </table>     
     </td>
     <td valign="top" style="padding:2px 4px; border:1px solid #e0e0e0;">
          <table border="1" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#C0C0C0" width="100%">
            <tr>
              <td width="11%" bgcolor="#D9E2F3" align="center"><b><font face="Arial" style="font-size: 9pt;">Qty</font></b></td>
              <td width="76%" bgcolor="#D9E2F3" align="center"><b><font face="Arial" style="font-size: 9pt;">Items</font></b></td>
