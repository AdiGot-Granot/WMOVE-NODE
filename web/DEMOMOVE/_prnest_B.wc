      <td width="74%">Unpack:&nbsp;<% IF _CRG.UHRS > 0%><%=ALLT(STR(_CRG.UMEN))%>
      &nbsp;Packers,&nbsp;<%=ALLT(STR(_CRG.UHRS,6,2))%>&nbsp;hrs,&nbsp;$<%=ALLT(STR(_CRG.UPERHRS,7,2))%>&nbsp;/hrs&nbsp;<% ENDIF %></td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.UTOTAL,8,2))%>&nbsp;</td>
   </tr>
    <% ENDIF %>
      <% IF _CRG.DISCOUNT > 0 %>
