<table border="0" align="center" cellspacing="0" cellpadding="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="800">
  <tr>
    <td BGCOLOR="#000D46" align="left" height="25" colspan="3">&nbsp;&nbsp;&nbsp;<font face="Arial" color="#FFFFFF"><b>Packing Material List</b></font></td>
 </tr>
  <tr>
    <td width="33%" valign="top">
          <table border="0" cellpadding="0" cellspacing="0" style="border-radius:7px;border: 1px solid #C0C0C0;font-family:Arial;font-size:9pt;" width="100%">
            <tr>
              <td width="10%" align="center"><b>Qty</b></td>
              <td width="70%" align="center"><b>Material</b></td>
              <td width="20%" align="center"><b>Unit<br>Price $</b></td>
            </tr>
      <%SELECT _MAT1
         SCAN %>
            <tr>
              <td width="10%" align="center"><%=QTY%>&nbsp;</td>
              <td width="70%"><%=UPPER(ITEM)%>&nbsp;</td>
              <td width="20%" align="right"><%=PRICE%>&nbsp;</td>
            </tr>
      <%ENDSCAN %>
          </table>    
    </td>
	<td width="33%" valign="top">
          <table border="0" cellpadding="0" cellspacing="0" style="border-radius:7px;border: 1px solid #C0C0C0;font-family:Arial;font-size:9pt;" width="100%">
            <tr>
              <td width="10%" align="center"><b>Qty</b></td>
              <td width="70%" align="center"><b>Material</b></td>
              <td width="20%" align="center"><b>Unit<br>Price $</b></td>
            </tr>
      <%SELECT _MAT2
         SCAN %>
            <tr>
              <td width="10%" align="center"><%=QTY%>&nbsp;</td>
              <td width="70%"><%=UPPER(ITEM)%>&nbsp;</td>
              <td width="20%" align="right"><%=PRICE%>&nbsp;</td>
            </tr>
      <%ENDSCAN %>
          </table>	
	</td>
	<td width="33%" valign="top">
          <table border="0" cellpadding="0" cellspacing="0" style="border-radius:7px;border: 1px solid #C0C0C0;font-family:Arial;font-size:9pt;" width="100%">
            <tr>
              <td width="10%" align="center"><b>Qty</b></td>
              <td width="70%" align="center"><b>Material</b></td>
              <td width="20%" align="center"><b>Unit<br>Price $</b></td>
            </tr>
      <%SELECT _MAT3
         SCAN %>
            <tr>
              <td width="10%" align="center"><%=QTY%>&nbsp;</td>
              <td width="70%"><%=UPPER(ITEM)%>&nbsp;</td>
              <td width="20%" align="right"><%=PRICE%>&nbsp;</td>
            </tr>
      <%ENDSCAN %>
          </table>	
	</td>
 </tr>
</table>
  <%ENDIF%>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" height="10" style="font-size:0; line-height:0;" colspan="2">&nbsp;</td>
 </tr>   
</table>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">UNDERSTANDING YOUR ESTIMATE</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" width="99%" align="center" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0">
  <tr>
	<td width="100%" height="17"><%=pcREMFILE%></td>
 </tr>
</table>    
    </td>
  </tr>  
</table>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" height="10" style="font-size:0; line-height:0;" colspan="2">&nbsp;</td>
 </tr>   
</table>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #FF0000;overflow:hidden;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" BGCOLOR="#FF0000" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">CUSTOMER CONFIRMATION</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" width="98%" align="center" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0">
  <%IF plESIGN%>
  <tr>
    <td width="100%" height="10" colspan="3" style="font-size:0; line-height:0;">&nbsp;</td>
 </tr>  
  <tr>
	<td width="100%" align="center" colspan="3"><font face="Arial"><b>Click on <a href="https://<%=pcSERVERIP%>/wc.dll?mpest~esignwc~<%=pcREFNO%>~<%=pcCUSTID%>~<%=pcEMAILID%>">Online Electronic Signature</a>
	to confirm your move.</b></font></td>
 </tr>
  <%ELSE%>
  <tr>
    <td width="39%" height="15"><br>_____________________________<br><font face="Arial" size="2">Customer Name</font></td>
    <td width="41%" height="15"><br>________________________________<br><font face="Arial" size="2">Customer Signature</font></td>
    <td width="20%" height="15"><br>____________<br><font face="Arial" size="2">Date</font></td>
 </tr>
 <%ENDIF%>
</table>    
    </td>
  </tr>  
</table>
<%IF !EMPTY(pcEMAIL)%>
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" bordercolor="#111111" width="100%" id="AutoNumber1">
  <tr>
    <td width="100%" align="center"><br><font size="1" face="Verdana">If you no longer wish to receive emails from <%=pcCOMPANY%>, please
    click on <a href="https://<%=gcSERVERIP%>/wc.dll?mputil~removeemail~&CUSTID=<%=pcCUSTID%>&EMAILTO=<%=pcEMAIL%>&JOBID=<%=pcJOBID%>">unsubscribe</a></font></td>
 </tr>
</table>
<%ENDIF%>
</body>
</html>