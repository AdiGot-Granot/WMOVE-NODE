<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Printed Estimate</title>

<style>
p.fvp {text-align:justify;}
</style>

</head>
<body>
    <%=lcEMAILHEADER%>
<center><img border="0" src="https://eagle.hellomoving.com<%=pcIMG%>" alt="" width="700" height="100"></center>    
<!----START MAIN TABLE-->    
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="center" height="30"><b><font face="Arial" size="4" color="#FFFFFF">COMPANY CREDENTIALS</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;font-family:Arial;font-size:10pt;font-weight:700;line-height:27px;" bordercolor="#111111" width="98%">
  <tr>
    <td width="100%" height="10" colspan="4" style="font-size:0; line-height:0;">&nbsp;</td>
 </tr>
  <tr>
    <td width="16%">DOT/MC:</td>
    <td width="34%"><%=IIF(EMPTY(pcDOT),"",pcDOT+"&nbsp;/&nbsp;")%><%=IIF(EMPTY(pcICC),"",pcICC)%></td>
    <td width="16%" style="border-left: 1px solid #808080;">&nbsp;Representative:</td>
    <td width="34%"><%=pcREP%></td>
  </tr>
  <tr>
    <td width="16%">Toll Free:</td>
    <td width="34%"><%=pcTOLLFREE%></td>
    <td width="16%" style="border-left: 1px solid #808080;">&nbsp;Direct Phone:</td>
    <td width="34%"><%=pcUSERPHONE%></td>
  </tr>
  <tr>
    <td width="16%">Company Email:</td>
    <td width="34%"><a href="mailto:<%=pcCOMPEMAIL%>" style="text-decoration:none;"><%=pcCOMPEMAIL%></a></td>
    <td width="16%" style="border-left: 1px solid #808080;">&nbsp;Ext:</td>
    <td width="34%"><%=pcPHONEEXT%></td>
  </tr>
  <tr>
    <td width="16%">Website:</td>
    <td width="34%"><a href="<%=pcOURWEB%>" style="text-decoration:none;" target="_blank"><%=pcOURWEB%></a></td>
    <td width="16%" style="border-left: 1px solid #808080;">&nbsp;Rep Email:</td>
    <td width="34%"><a href="mailto:<%=lcREPEMAIL%>" style="text-decoration:none;"><%=lcREPEMAIL%></a></td>
  </tr>
  <tr>
    <td width="100%" height="10" colspan="4" style="font-size:0; line-height:0;">&nbsp;</td>
 </tr>  
</table>
   </td>
  </tr>
</table><!----END MAIN TABLE-->
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="800">
  <tr>
    <td width="100%" height="10" style="font-size:0; line-height:0;" colspan="2">&nbsp;</td>
 </tr>
  <tr>
    <td width="100%" colspan="2">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" align="center" height="30"><b><font face="Verdana" color="#000D46" size="4"><%=UPPER(pcBINDING)%> MOVING ESTIMATE <%=pcORDNO1%></font></b></td>
  </tr>
</table>    
    </td>
 </tr>
  <tr>
    <td width="100%" height="10" style="font-size:0; line-height:0;" colspan="2">&nbsp;</td>
 </tr>
  <tr>
    <td width="50%" valign="top">
<table border="0" align="left" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="99%">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">ORIGIN</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;font-family:Arial;font-size:10pt;font-weight:700;line-height:25px;" bordercolor="#111111" width="99%">
  <tr>
    <td width="32%" height="10">&nbsp;Customer Name:</td>
    <td width="68%" height="10"><%=ALLT(PROPER(_EST.SNAME))%></td>
 </tr>
 <%IF !EMPTY(_EST.SPROXY)%>
  <tr>
    <td width="32%" height="10">&nbsp;Proxy:</td>
    <td width="68%" height="10"><%=ALLT(_EST.SPROXY)%></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="32%" height="10">&nbsp;Address:</td>
    <td width="68%" height="10"><%=ALLT(_EST.SADD1)%>&nbsp;<%=ALLT(_EST.SADD2)%></td>
 </tr>
  <tr>
    <td width="32%" height="10">&nbsp;Location:</td>
    <td width="68%" height="10"><%=ALLT(PROPER(_EST.SLEVEL))%><%=IIF(EMPTY(_EST.SSUBLEVEL),'',' / '+ALLT(_EST.SSUBLEVEL))%><%=IIF(EMPTY(_EST.SFLOOR),'',', F: '+ALLT(STR(_EST.SFLOOR)))%>
	<%=IIF(EMPTY(_EST.SAPT),'',', A: '+ALLT(_EST.SAPT))%></td>
 </tr> 
  <tr>
    <td width="32%" height="10">&nbsp;City, State, Zip:</td>
    <td width="68%" height="10"><%=ALLT(PROPER(_EST.SCITY))+', '+(_EST.SSTATE)%>&nbsp;<%=ALLT(_EST.SZIP)%></td>
 </tr>
  <tr>
    <td width="32%" height="10">&nbsp;Contact Phone</td>
    <td width="68%" height="10"><%=ALLT(_EST.STELH)%><%=IIF(EMPTY(_EST.STELO),'',' / '+ALLT(_EST.STELO))%></td>
 </tr>
  <tr>
    <td width="32%" height="10">&nbsp;Email:</td>
    <td width="68%" height="10"><a href="mailto:<%=ALLT(_EST.EMAIL)%>" style="text-decoration:none;"><%=ALLT(_EST.EMAIL)%></a></td>
 </tr>     
</table>    
    </td>
 </tr>
</table>    
    </td>
    <td width="50%" valign="top">
<table border="0" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">DESTINATION</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;font-family:Arial;font-size:10pt;font-weight:700;line-height:25px;" bordercolor="#111111" width="99%">
  <tr>
    <td width="32%" height="10">&nbsp;Customer Name:</td>
    <td width="68%" height="10"><%=ALLT(PROPER(_EST.RNAME))%></td>
 </tr>
 <%IF !EMPTY(_EST.RPROXY)%>
  <tr>
    <td width="32%" height="10">&nbsp;Proxy:</td>
    <td width="68%" height="10"><%=ALLT(_EST.RPROXY)%></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="32%" height="10">&nbsp;Address:</td>
    <td width="68%" height="10"><%=ALLT(_EST.RADD1)%>&nbsp;<%=ALLT(_EST.RADD2)%></td>
 </tr>
  <tr>
    <td width="32%" height="10">&nbsp;Location:</td>
    <td width="68%" height="10"><%=ALLT(PROPER(_EST.RLEVEL))%><%=IIF(EMPTY(_EST.RSUBLEVEL),'',' / '+ALLT(_EST.RSUBLEVEL))%><%=IIF(EMPTY(_EST.RFLOOR),'',', F: '+ALLT(STR(_EST.RFLOOR)))%>
	<%=IIF(EMPTY(_EST.RAPT),'',', A: '+ALLT(_EST.RAPT))%></td>
 </tr> 
  <tr>
    <td width="32%" height="10">&nbsp;City, State, Zip:</td>
    <td width="68%" height="10"><%=ALLT(PROPER(_EST.RCITY))+', '+(_EST.RSTATE)%>&nbsp;<%=ALLT(_EST.RZIP)%></td>
 </tr>
  <tr>
    <td width="32%" height="10">&nbsp;Contact Phone</td>
    <td width="68%" height="10"><%=ALLT(_EST.RTELH)%><%=IIF(EMPTY(_EST.RTELO),'',' / '+ALLT(_EST.RTELO))%></td>
 </tr>
  <tr>
    <td width="100%" height="10" colspan="2">&nbsp;</td>
 </tr>     
</table>   
    </td>
 </tr>
</table>    
    </td>
 </tr>
<%IF !EMPTY(_ESTMEMO.EXTSTOP)%>  
  <tr>
    <td width="100%" height="10" style="font-size:0; line-height:0;" colspan="2">&nbsp;</td>
 </tr>
  <tr>
    <td width="100%" colspan="2">
<table border="0" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">Notes</font></b></td>
  </tr>
  <tr>
    <td width="100%">    
<table border="0" width="99%" align="center" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111" cellspacing="0">
  <tr>
	<td width="100%" height="17"><%=ALLT(_ESTMEMO.EXTSTOP)%></td>
 </tr>
</table>    
    </td>
  </tr>  
</table>    
    </td>
 </tr>
<%ENDIF%> 
</table>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="800">
  <tr>
    <td width="100%" height="10" style="font-size:0; line-height:0;" colspan="2">&nbsp;</td>
 </tr>
  <tr>
    <td width="45%" valign="top">
<table border="0" align="left" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="99%">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">MOVE DETAILS</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;font-family:Arial;font-size:10pt;font-weight:700;line-height:25px;" bordercolor="#111111" width="99%">
  <% IF !EMPTY(_EST.ORDREF)%>
  <tr>
    <td width="49%">Reference No:</td>
    <td width="51%"><font size="3" color="#FF0000"><%=_EST.ORDREF%></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="49%">Service Type:</td>
    <td width="51%"><%=IIF(pcTYPE='D','Long Distance, ','Local Move, ')%><%=IIF(_CRG.MILES > 0,ALLT(STR(_CRG.MILES))+' miles','')%></td>
 </tr>      
  <%IF !EMPTY(_EST.ESTIMDTE)%>
  <tr>
    <td width="49%">Visual On:</td>
    <td width="51%"><%=(_EST.ESTIMDTE)%>&nbsp;<%=(_EST.ESTIMTME)%></td>
 </tr>
 <%ENDIF%>
 <%IF _EST.VISUALTYPE > 0 %>
  <tr>
    <td width="49%">Visual Type:</td>
    <td width="51%"><%=pcVISUALTYPE%></td>
 </tr>
      <%IF _EST.VISUALTYPE=3 %>
  <tr>
    <td width="100%" colspan="2" style="line-height:17px;">The shipper has elected to waive the physical and virtual survey and signed the waiver agreement 
    before the shipment is loaded in accordance with 49 CFR 375.401 (a).</td>
 </tr>
     <%ENDIF%>
 <%ENDIF%>        
 <%IF !EMPTY(_EST.ESTIMATOR)%>
  <tr>
    <td width="49%">Estimator:</td>
    <td width="51%"><%=PROPER(_EST.ESTIMATOR)%></td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="49%">Estimated Volume:</td>
    <td width="51%">  
    <%=IIF(plCALCCF,ALLT(STR(_EST.TOTALCF))+' cf. ('+ALLT(STR(_EST.TOTALLBS))+' lbs)',ALLT(STR(_EST.TOTALLBS))+' lbs. ('+ALLT(STR(_EST.TOTALCF))+' cf.)')%>
    <% IF pcTYPE='D' AND pcDMIN>'0' %>
      	<%=IIF(plMINVOL=.F.,'<br>Minimum $'+pcDMIN,IIF(plCALCCF,'<br>Minimum '+pcDMIN+' cf','<br>Minimum '+pcDMIN+' lbs'))%>      	
    <%ENDIF%> 	
    </td>
 </tr>
<%IF pcTYPE='D' %>
  <tr>
    <td width="49%">Estimated Rate:</td>
    <td width="51%"><%=IIF(plCALCCF,'$'+ ALLT(STR(_CRG.I1PERCF,8,2))+' per cf','$'+ALLT(STR(_CRG.I1PERLBS,8,2))+' per lbs')%></td>
 </tr>
<%ENDIF%>  
  <tr>
    <td width="49%">Preferred Move Date:</td>
    <td width="51%"><font size="3" color="#FF0000"><%=_EST.LBOOKDTE%></font></b>&nbsp;</td>
  </tr>
  <%IF !EMPTY(_EST.LBOOKDTE1)%>
  <tr>
    <td width="49%">Flexible Move Date:</td>
    <td width="51%"><font size="3" color="#FF0000"><%=_EST.LBOOKDTE1%></font></b>&nbsp;</td>
  </tr>
  <%ENDIF%>  
 <%IF !EMPTY(_EST.LBOOKTME)%> 
  <tr>
    <td width="49%">Arrival Time:</td>
    <td width="51%"><%=ALLT(_EST.LBOOKTME)%></td>
  </tr>
 <%ENDIF%>   
  <%IF !EMPTY(_EST.BOXDTE)%>
  <tr>
    <td width="49%">Box Delivery:</td>
    <td width="51%"><%=_EST.BOXDTE%>&nbsp;<%=(_EST.BOXTME)%></td>
 </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.PBOOKDTE)%>
    <tr>
     <td width="49%">Pack Day:</td>
     <td width="51%"><%=(_EST.PBOOKDTE)%>&nbsp;<%=(_EST.PBOOKTME)%></td>
    </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.DLVDTE)%> 
    <tr>
     <td width="49%">Requested Delivery Date:</td>
     <td width="51%"><%=_EST.DLVDTE%><%=IIF(EMPTY(_EST.DLVDTE1),'','-'+DTOC(_EST.DLVDTE1))%></td>
    </tr>
   <%ENDIF%>
 <%IF _EST.DLVIMM=.T.%>
  <tr>
    <td width="49%">Delivery Type:</td>
    <td width="51%">Immediately</td>
 </tr>
 <%ENDIF%>    
 <%IF !plBLKREF %> 
    <tr>
     <td width="49%">Reference By:</td>
     <td width="51%"><%=_EST.REF%></td>
    </tr>
 <%ENDIF%>
    <tr>
     <td width="49%">Created On:</td>
     <td width="51%"><%=TTOD(_EST.OPENDTE)%></td>
    </tr>
</table>    
    </td>
 </tr>
</table>    
    </td>
    <td width="55%" valign="top">
<table border="0" align="left" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="100%">
  <tr>
    <td width="100%" BGCOLOR="#000D46" align="left" height="25">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">PRICING SUMMARY</font></b></td>
  </tr>
  <tr>
    <td width="100%">
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-collapse: collapse;font-family:Arial;font-size:10pt;font-weight:700;line-height:25px;" bordercolor="#111111" width="99%">
<%IF pcTYPE='D' AND plOTHERS=.T. AND pnDMAINID > 999 %>        
   <tr> 
     <td width="74%">Basic Estimate Price</td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.I1TOTAL,8,2))%>&nbsp;</td>
  </tr>        
  <%IF _CRG.DIESEL > 0 %>   
   <tr>
     <td width="74%">Fuel Surcharge:&nbsp;<%=ALLT(STR(_CRG.DIESELP,6,2))+' %'%></td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.DIESEL,8,2))%>&nbsp;</td>
  </tr>
  <% ENDIF %>       
 <!--OTHERS -->
  <%SELECT _ESTO
  SCAN %>
   <tr> 
     <td width="74%"><%=ALLT(_ESTO.CNAME)%>&nbsp;</td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_ESTO.PRC,8,2))%>&nbsp;</td>
   </tr>        
  <%ENDSCAN %>
 <% IF plFV=.T. and pcTYPE='D' AND _CRG.INSAMT > 0 %>
    <tr>
     <td width="74%" style="line-height:17px;">Full Value Protection<br><font style="font-size:9pt;">Amount of Liability: <%=ALLT(TRANSFORM(_CRG.FVPVALUE,"$,$$$,$$9.99"))%> Deductible:<%=ALLT(TRANSFORM(VAL(_CRG.FVPDEDUCT),"$$,$99"))%></font>
     <% IF !EMPTY(_CRG.INS) %><BR><%=ALLTRIM(_CRG.INS)%><%ENDIF%></td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.INSAMT,8,2))%>&nbsp;</td>
   </tr> 
 <%ENDIF%>  
<!--Others/Remarks Text -->
      <% IF !EMPTY(_CRG.OTHERS) %>
   <tr>
     <td width="74%"><%=ALLTRIM(_CRG.OTHERS)%>&nbsp;</td>
     <td width="26%" ALIGN="RIGHT"></td>
  </tr>
      <% ENDIF %>
      <% IF !EMPTY(_CRG.OTHERS1) %>
   <tr>
     <td width="74%"><%=ALLTRIM(_CRG.OTHERS1)%>&nbsp;</td>
     <td width="26%" ALIGN="RIGHT"></td>
  </tr>
      <% ENDIF %>        
      <% IF !EMPTY(_CRG.OTHERS2) %>
   <tr>
     <td width="74%"><%=ALLTRIM(_CRG.OTHERS2)%>&nbsp;</td>
     <td width="26%" ALIGN="RIGHT"></td>
   </tr>
      <% ENDIF %>        
<!--end Others Text -->
        <% IF _CRG.MATTOTAL > 0 %> 
    <tr>
      <td width="74%">Packing Materials</td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.MATTOTAL,8,2))%>&nbsp;</td>
   </tr>
      <% ENDIF %>
      <% IF _CRG.MATTAXAMT > 0 %> 
    <tr>
      <td width="74%">Materials Sales Tax:&nbsp;<%=ALLT(STR(_CRG.MATTAX,5,3))%>%</td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.MATTAXAMT,8,2))%>&nbsp;</td>
   </tr>
      <% ENDIF %>                            
    <% IF _CRG.PTOTAL > 0 %>  
    <tr>
      <td width="74%">Pack:&nbsp;<% IF _CRG.PHRS > 0%><%=ALLT(STR(_CRG.PMEN))%>
      &nbsp;Packers,&nbsp;<%=ALLT(STR(_CRG.PHRS,6,2))%>&nbsp;hrs,&nbsp;$<%=ALLT(STR(_CRG.PPERHRS,7,2))%>&nbsp;/hrs&nbsp;<% ENDIF %></td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.PTOTAL,8,2))%>&nbsp;</td>
   </tr>
    <% ENDIF %>     
    <% IF _CRG.UTOTAL > 0 %>         
    <tr>
      <td width="74%">Unpack:&nbsp;<% IF _CRG.UHRS > 0%><%=ALLT(STR(_CRG.UMEN))%>
      &nbsp;Packers,&nbsp;<%=ALLT(STR(_CRG.UHRS,6,2))%>&nbsp;hrs,&nbsp;$<%=ALLT(STR(_CRG.UPERHRS,7,2))%>&nbsp;/hrs&nbsp;<% ENDIF %></td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.UTOTAL,8,2))%>&nbsp;</td>
   </tr>
    <% ENDIF %>
<!--Discount  -->
  <%SELECT _ESTD
    pnRECS=RECCOUNT() 
    SCAN %> 
   <tr> 
     <td width="74%"><font color="#FF0000"><%=ALLT(_ESTD.CNAME)%></font>&nbsp;</td>
     <td width="26%" ALIGN="RIGHT"><FONT color="#FF0000">-<%='$'+ALLT(STR(_ESTD.PRC,8,2))%>&nbsp;</td>
  </tr>        
   <%ENDSCAN %>
<!--end Discount  -->
   <% IF pcTYPE='D' %>
    <tr>
      <td width="74%">Basic Valuation Protection:<br>$0.60 per lbs. per article</td>
      <td width="26%" ALIGN="RIGHT"><br>$0.00&nbsp;</td>
   </tr>
   <%ENDIF%> 
    <tr> 
      <td width="74%">Total Moving Estimate</td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_EST.SUBTOTAL,8,2))%>&nbsp;</td>
   </tr>
      <% IF pnPAYAMT <> 0 %>
    <tr> 
      <td width="74%"><font COLOR="#FF0000">Customer Payment:</font></td>
      <td width="26%" ALIGN="RIGHT"><font color="#FF0000"><%='$'+ALLT(STR(pnPAYAMT,8,2))%></font>&nbsp;</td>
        </tr>                
     <% ENDIF %>
      <% IF pnCOLEVEL=7 AND _CRG.SPERMONTH > 0 %>
    <tr> 
      <td width="74%">Estimated Monthly Storage Rate:</td>
      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.SPERMONTH,8,2))%>&nbsp;</td>
    </tr>   
     <% ENDIF %>     
                                   
<% ELSE %>
          
 <%IF pcTYPE='D' and plCALCTARIF AND _CRG.TARIFF>0 %>       
   <tr> 
     <td width="74%">Total Tariff</td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.TARIFF,8,2))%>&nbsp;</td>
  </tr>        
   <tr> 
     <td width="74%"><font COLOR="#FF0000">Tariff Discount: <%=ALLT(STR(_CRG.TARIFDISCP,8,2))%>%</font></td>
     <td width="26%" ALIGN="RIGHT"><font color="#FF0000">-<%='$'+ALLT(STR(_CRG.TARIFDISC,8,2))%></font>&nbsp;</td>
  </tr>        
 <%ENDIF%>
 <%IF pcTYPE='D' %>        
   <tr> 
     <td width="74%">Basic Estimate Price</td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.I1TOTAL,8,2))%>&nbsp;</td>
  </tr>        
 <% ENDIF %>
<% IF pcTYPE='L' OR pcTYPE='R' %>     
    <% IF plFLATRATE OR plVIEWFLAT %>  
   <tr>
     <td width="74%">Flat Rate:</td>
     <td width="26%" ALIGN="RIGHT"><%=IIF(_CRG.LTOTAL+_CRG.FTTOTAL > 0,'$'+ALLT(STR(_CRG.LTOTAL+_CRG.FTTOTAL,8,2)),'')%>&nbsp;</td>
  </tr>         
  <% ELSE %>
   <tr>
     <td width="74%"><%=IIF(_CRG.LVAN >0,ALLT(STR(_CRG.LVAN))+' Truck/s,','')%>&nbsp;<%=ALLT(STR(_CRG.LMEN))%>&nbsp;Workers,
     <%='$'+ALLT(STR(_CRG.LPERHRS,7,2))%>/hrs <%=ALLT(STR(_CRG.LHRS,6,2))%>&nbsp;hours</td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.LTOTAL,8,2))%>&nbsp;</td>
  </tr>
    <%IF _CRG.FTTOTAL > 0 %>
   <tr>
     <td width="74%">Estimated Travel Time: <%=IIF(_CRG.FTVAN >0,ALLT(STR(_CRG.FTVAN))+' Truck/s','')%>,&nbsp;<%=ALLT(STR(_CRG.FTMEN))%>&nbsp;Workers,&nbsp;
     <%=ALLT(STR(_CRG.FTHRS,6,2))%>&nbsp;hours,&nbsp;<%='$'+ALLT(STR(_CRG.FTPERHRS,7,2))%>/hrs</td>
     <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.FTTOTAL,8,2))%>&nbsp;</td>
  </tr>
    <% ENDIF %>
  <% ENDIF %>
    <%IF _CRG.OTOTAL > 0 %>        
   <tr>
     <td width="74%">Fuel & Mileage</td>
