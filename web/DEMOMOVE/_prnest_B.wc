<% IF plFV=.T. AND pcTYPE='D' AND _EST.SSTATE<>_EST.RSTATE %><!-- VFP  -->
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:6px;border: 1px solid #000D46;overflow:hidden;" bordercolor="#111111" width="800">
  <tr>
    <td width="100%" BGCOLOR="#000D46" height="25" colspan="7">&nbsp;&nbsp;&nbsp;<b><font face="Arial" color="#FFFFFF">Full Value Protection Amount of Liability: <%=pcFVPVALUE%><%IF _CRG.INSAMT < 100%> (Optional)<%ENDIF%></font></b></td>
 </tr>
  <tr style="line-height:23px;">
    <td width="23%" style="border-bottom: 1px solid #000D46;">&nbsp;<b><font face="Arial" size="2">Deductible Levels:</font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">
	$<%=_DEDUCT.D0TXT%></font></b> <font size="1" color="#C90000"><%=IIF(ALLT(_CRG.FVPDEDUCT)=ALLT(_DEDUCT.D0TXT) AND _CRG.INSAMT > 0,'(selected)','')%></font></td>
    <td width="15%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=_DEDUCT.D1TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D1TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></font></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=_DEDUCT.D2TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D2TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="11%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=_DEDUCT.D3TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D3TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=_DEDUCT.D4TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D4TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
    <td width="12%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">
	<%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=_DEDUCT.D5TXT%></font></b> <font size="1" color="#C90000"><%=IIF(_CRG.FVPDEDUCT=_DEDUCT.D5TXT AND _CRG.INSAMT>0,'(selected)','')%><%ENDIF%></td>
 </tr>
  <tr style="line-height:23px;">
    <td width="23%" style="border-bottom: 1px solid #000D46;">&nbsp;<b><font face="Arial" size="2">Valuation Charge:</font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">$<%=ALLT(STR(_CRG.D0,9,2))%></font></b></td>
    <td width="15%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=ALLT(STR(_CRG.D1,9,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=ALLT(STR(_CRG.D2,9,2))%><%ENDIF%></font></b></td>
    <td width="11%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=ALLT(STR(_CRG.D3,9,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=ALLT(STR(_CRG.D4,9,2))%><%ENDIF%></font></b></td>
    <td width="12%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=ALLT(STR(_CRG.D5,9,2))%><%ENDIF%></font></b></td>
 </tr>
  <tr style="line-height:23px;">
    <td width="23%" style="border-bottom: 1px solid #000D46;">&nbsp;<b><font face="Arial" size="2">Estimate 
    with Valuation:</font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2">$<%=ALLT(STR(_CRG.D0+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%></font></b></td>
    <td width="15%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>$<%=ALLT(STR(_CRG.D1+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>$<%=ALLT(STR(_CRG.D2+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="11%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>$<%=ALLT(STR(_CRG.D3+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>$<%=ALLT(STR(_CRG.D4+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
    <td width="12%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><b><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>$<%=ALLT(STR(_CRG.D5+(_EST.SUBTOTAL-_CRG.INSAMT),10,2))%><%ENDIF%></font></b></td>
 </tr> 
  <tr style="line-height:23px;">
    <td width="23%" style="border-bottom: 1px solid #000D46;">&nbsp;<b><font face="Arial" size="2">Customer's Initials:</font></b></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><font face="Arial" size="2">x_________</font></td>
    <td width="15%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D1TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D2TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="11%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D3TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="13%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D4TXT) > 0 %>x_________<%ENDIF%></font></td>
    <td width="12%" style="border-left: 1px solid #000D46;border-bottom: 1px solid #000D46;" align="center"><font face="Arial" size="2"><%IF VAL(_DEDUCT.D5TXT) > 0 %>x_________<%ENDIF%></font></td>
 </tr>
  <tr>
    <td width="100%" colspan="7"><p class="fvp">
    <font style="font-family:Arial;font-size:10pt;"><b>WARNING:</b> 
	If a moving company loses or damages your goods, there are 2 different standards for the company`s 
	liability based on the types of rates you pay. <b>BY FEDERAL LAW, THIS FORM MUST CONTAIN A FILLED-IN 
	ESTIMATE OF THE COST OF A MOVE FOR WHICH THE MOVING COMPANY IS LIABLE FOR THE FULL (REPLACEMENT) VALUE OF YOUR GOODS</b>
	in the event of loss of, or damage to, the goods. This form may also contain an estimate of the cost of a move in which the 
	moving company is liable for <b>FAR LESS</b> than the replacement value of your goods, typically at a 
	lower cost to you. You will select the liability level later, on the bill of lading (contract) for your move. 
	Before selecting a liability level, please read <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/RightsandResponsibilitiesBooklet_2022Update.pdf" target="_blank">Your Rights and Responsibilities When You Move</a>, 
	and <a href="https://www.fmcsa.dot.gov/sites/fmcsa.dot.gov/files/ReadytoMoveBrochure_2022Update.pdf" target="_blank">Ready to Move Brochure</a> provided by the 
	moving company, and seek further information at the government website
	<a href="http://www.protectyourmove.gov">www.protectyourmove.gov</a></font></p></td>
 </tr>   
</table>
<%ENDIF%>
