      <td width="26%" ALIGN="RIGHT"><%='$'+ALLT(STR(_CRG.PTOTAL,8,2))%>&nbsp;</td>
   </tr>
    <% ENDIF %>     
    <% IF _CRG.UTOTAL > 0 %>         
