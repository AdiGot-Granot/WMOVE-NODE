<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Printed Estimate</title>

<style>
p.fvp {text-align:justify;}
</style>

</head>
<body>
    <%=lcEMAILHEADER%>
<table border="0" cellpadding="0" cellspacing="0" align="center" style="border-collapse: collapse" width="700">
  <tr>
    <td width="100%" align="center"><img border="0" src="https://eagle.hellomoving.com<%=pcIMG%>" alt="" width="100%" height="100"></td>
 </tr>
</table>
<table border="0" width="700" ALIGN="CENTER" style="border-radius:20px;border: 1px solid #083484;">
  <tr> 
   <td><BR>
<table border="0" width="98%" align="center" cellspacing="0" style="border-radius:12px;border: 1px solid #083484;" cellpadding="0">
  <tr>
	<td width="100%" colspan="2">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="100%">
  <tr style="border-bottom: 1px solid #083484;">
    <td width="20%" height="25" align="center">&nbsp;</td>
    <td width="50%" height="25" align="center"><b><font face="Verdana" color="#000084" size="4"><%=pcBINDING%> <%=IIF(_EST.STATUS='F','Moving Estimate','Moving Estimate - Booked')%></font></b></td>
    <td width="30%" height="25" align="right"><b><font face="Verdana" size="2">Job No: <font color="#FF0000"><%=pcORDNO1%></font></font></b>&nbsp;</td>
 </tr>
</table>
   </td>
 </tr>
  <tr>
	<td width="48%" valign="top">
<table border="0" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="100%" cellpadding="3">
  <tr>
    <td width="100%"><font face="Arial"><b><%=pcCOMPANY%></b></font></td>
  </tr>
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=pcADD1%></b></font></td>
  </tr>
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=pcADD2%></b></font></td>
  </tr>  
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=IIF(EMPTY(pcDOT),"","US DOT: "+pcDOT+"&nbsp;&nbsp;&nbsp;")%><%=IIF(EMPTY(pcICC),"","MC: "+pcICC)%></b></font></td>
 </tr>
  <tr>
    <td width="100%"><font face="Arial" size="2"><b><%=IIF(!EMPTY(pcREGISTER),"Registration #: "+pcREGISTER,"")%></b></font></td>
 </tr> 
</table>	
	</td>
	<td width="52%" valign="top" style="border-left: 1px solid #083484;">
<table border="0" cellspacing="1" style="border-collapse: collapse" bordercolor="#111111" width="100%" cellpadding="3">
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Customer<br>Rep:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcREP%></b></font></td>
  </tr>
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Phone:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcTOLLFREE%>&nbsp;<%=pcPHONEEXT%></b></font></td>
  </tr>
  <% IF !EMPTY(pcUSERPHONE)%>
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Direct:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcUSERPHONE%></b></font></td>
  </tr>
  <%ENDIF%>  
 <%IF !EMPTY(pcFAX)%> 
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Fax:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><b><%=pcFAX%></b></font></td>
  </tr>
 <%ENDIF%>     
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Email:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><a href="mailto:<%=pcOUREMAIL%>" style="text-decoration:none;"><%=pcOUREMAIL%></a></font></td>
  </tr>
  <%IF !EMPTY(pcOURWEB)%>
  <tr>
    <td width="21%"><font face="Arial" size="2"><b>Web:</b></font></td>
    <td width="79%"><font face="Arial" size="2"><a href="<%=pcOURWEB%>" style="text-decoration:none;" target="_blank"><%=pcOURWEB%></a></font></td>
  </tr>
  <%ENDIF%>  
</table>	
	</td>
 </tr>
</table>
<br>
<table border="0" align="center" cellpadding="1" cellspacing="1" style="border-radius:12px;border: 1px solid #083484;" width="98%">
  <tr>
    <td width="47%" valign="top">
<table border="0" width="100%" cellspacing="1" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td align="center"><font face="Verdana" color="#000080"><b><u>Pick-Up</u></b></font></td>
 </tr>
  <tr>
    <td><b><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.SNAME))%>&nbsp;</b></font></td>
 </tr>
  <%IF !EMPTY(_EST.SADD1)%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(_EST.SADD1)%>&nbsp;<%=ALLT(_EST.SADD2)%></font></td>
 </tr>
  <%ENDIF%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.SLEVEL))%><%=IIF(EMPTY(_EST.SSUBLEVEL),'',' / '+ALLT(_EST.SSUBLEVEL))%><%=IIF(EMPTY(_EST.SFLOOR),'',', Floor: '+ALLT(STR(_EST.SFLOOR)))%>
	    <%IF !EMPTY(_EST.SAPT) AND _EST.RC='C'%>
	    <%=', Unit #: '+ALLT(_EST.SAPT)%>
        <%ELSE%>
	    <%=IIF(EMPTY(_EST.SAPT),'',', Apt. #: '+ALLT(_EST.SAPT))%>
	    <%ENDIF%></font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.SCITY))+', '+(_EST.SSTATE)%>&nbsp;<%=ALLT(_EST.SZIP)%>&nbsp;</font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2">Phone: <%=ALLT(_EST.STELH)%></font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.STELO),'','Phone: '+ALLT(_EST.STELO))%></font></td>
 </tr>
  <tr>
   <td><font face="Verdana" size="2"><a href="mailto:<%=ALLT(_EST.EMAIL)%>" style="text-decoration:none;"><%=ALLT(_EST.EMAIL)%></a></font></td>
 </tr>
</table>
<hr color="#083484"></hr>
<table border="0" width="100%" cellspacing="1" cellpadding="2" style="border-collapse: collapse" bordercolor="#111111">
  <tr>
    <td align="center"><font face="Verdana" color="#000080"><b><u>Delivery</u></b></font></td>
 </tr>
  <tr>
    <td><b><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.RNAME))%></b></font></td>
 </tr>
  <%IF !EMPTY(_EST.RADD1)%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(_EST.RADD1)%>&nbsp;<%=ALLT(_EST.RADD2)%></font></td>
 </tr>
  <%ENDIF%>  
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.RLEVEL))%><%=IIF(EMPTY(_EST.RSUBLEVEL),'',' / '+ALLT(_EST.RSUBLEVEL))%><%=IIF(EMPTY(_EST.RFLOOR),'',', Floor: '+ALLT(STR(_EST.RFLOOR)))%>
	    <%IF !EMPTY(_EST.RAPT) AND _EST.RC='C'%>
	    <%=', Unit #: '+ALLT(_EST.RAPT)%>
        <%ELSE%>
	    <%=IIF(EMPTY(_EST.RAPT),'',', Apt. #: '+ALLT(_EST.RAPT))%>
	    <%ENDIF%></font></td>
 </tr>
  <tr>
    <td><font face="Verdana" size="2"><%=ALLT(PROPER(_EST.RCITY))+', '+(_EST.RSTATE)%>&nbsp;<%=ALLT(_EST.RZIP)%></font></td>
 </tr>
  <tr>
	<td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.RTELH),'','Phone: '+ALLT(_EST.RTELH))%></font></td>
 </tr>
  <tr>
	<td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.RTELO),'','Phone: '+ALLT(_EST.RTELO))%></font></td>
 </tr> 
  <tr>
    <td><font face="Verdana" size="2"><%=IIF(EMPTY(_EST.SFAX),'','Fax: '+ALLT(_EST.SFAX))%></font></td>
 </tr>
</table>    
    </td>
    <td width="52%" valign="top" style="border-left: 1px solid #083484;padding:3.5px;"><b><font face="Verdana" size="2">
	<% IF pcTYPE='D'%>
	This is an all inclusive Cf/Lbs, it includes all packing materials.<BR><BR>
	There are no hidden fees and no extra charges!!!!<BR><BR>
	This is a Cf/Lbs based estimate, for any change of Cf/Lbs more/less than estimated,  the customer will be charged accordingly.<BR><BR>
	The minimum charge will be 300cf/1800LBS.	
	<%ELSE%>
	  <% IF plVIEWFLAT=.F. %>
	This is an all inclusive hourly rate, it includes all packing materials.<BR><BR>There are no hidden fees and no extra charges!!!!<BR><BR>
	This is a time based estimate, for any hour more/less than the estimated labor time the customer will be charged accordingly.<BR><BR>
	Our minimum charge will be 3 hours of labor plus 1 hour of travel.
	  <%ELSE%>
	This is a Flat Rate estimate for your move.<br><br> 
	The Flat Rate is based on the <I><U>scope of work</U></I> listed and the <I><U>inventory</U></I> included on this estimate.<br><br>
	Changes to the scope of work and/or additional inventory may affect the cost. 	
	  <%ENDIF%>
	<%ENDIF%>
    </font></b></td>
 </tr> 
</table>
<%IF !EMPTY(_ESTMEMO.EXTSTOP)%>
<br>
<table border="0" align="center" width="98%" style="border-radius:12px;border: 1px solid #083484;" cellspacing="1">
  <tr>
    <td align="center" height="25" style="border-bottom: 1px solid #083484;"><font face="Verdana" color="#000080"><b>Extra Stop / Notes</b></font></td>
 </tr>
  <tr>
    <td valign="top"><%=ALLT(_ESTMEMO.EXTSTOP)%></td>
 </tr>
</table>
<%ENDIF%>
<br>
<table border="0" align="center" cellpadding="0" cellspacing="0" style="border-radius:12px;border: 1px solid #083484;" width="98%">
  <tr>
    <td width="48%" valign="top">
<table border="0" cellspacing="1" style="border-collapse: collapse" width="100%" cellpadding="2">
  <tr>
    <td width="100%" ALIGN="CENTER" colspan="2" style="border-bottom: 1px solid #BDBEC6;"><b><font color="#000080" face="Verdana">Relocation Details</font></b></td>
 </tr> 
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Job No:</font></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="4" color="#FF0000"><%=pcORDNO1%></font></b>&nbsp;</td>
 </tr>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Estimate Date:</font></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=DATE()%></font></b>&nbsp;</td>
 </tr>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Representative:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=pcREP%></font></b>&nbsp;</td>
 </tr>     
  <%IF !EMPTY(_EST.ESTIMDTE)%>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Visual On:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=CDOW(_EST.ESTIMDTE)%><br><%=(_EST.ESTIMDTE)%>&nbsp;<%=(_EST.ESTIMTME)%></font></b></td>
 </tr>
 <%ENDIF%> 
 <%IF _EST.VISUALTYPE > 0 %>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Visual Type:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=pcVISUALTYPE%></font></b>&nbsp;</td>
 </tr>
      <%IF _EST.VISUALTYPE=3 %>
  <tr>
    <td width="100%" style="border-bottom: 1px solid #BDBEC6;" colspan="2"><font face="Arial" size="2">The shipper has elected to waive the physical and virtual survey and signed the waiver agreement 
    before the shipment is loaded in accordance with 49 CFR 375.401 (a).</FONT></td>
 </tr>
     <%ENDIF%>
 <%ENDIF%>      
 <%IF !EMPTY(_EST.ESTIMATOR)%>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Estimator:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=PROPER(_EST.ESTIMATOR)%></font></b>&nbsp;</td>
 </tr>
 <%ENDIF%>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><b>Move Type: <font size="1"><%=pcRC%></font></font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">
    <%=IIF(pcTYPE='D','Long Distance, ','Local Move, ')%><%=IIF(_CRG.MILES > 0,ALLT(STR(_CRG.MILES))+' miles','')%></font></b>&nbsp;</td>
 </tr> 
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font size="2" face="Arial">Estimated Volume:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">
    <%=IIF(plCALCCF,ALLT(STR(_EST.TOTALCF))+' cf. ('+ALLT(STR(_EST.TOTALLBS))+' lbs)',ALLT(STR(_EST.TOTALLBS))+' lbs. ('+ALLT(STR(_EST.TOTALCF))+' cf.)')%>
    </font></b>&nbsp;</td>
 </tr>
<%IF pcTYPE='D'%>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Estimated Rate:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=IIF(plCALCCF,'$'+ ALLT(STR(_CRG.I1PERCF,8,2))+' per cf','$'+ALLT(STR(_CRG.I1PERLBS,8,2))+' per lbs')%></font></b></td>
 </tr>
<%ENDIF%>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Move Day:</font>&nbsp;</td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="3" color="#FF0000"><%=CDOW(_EST.LBOOKDTE)%><%=IIF(EMPTY(_EST.LBOOKDTE1),'','/'+CDOW(_EST.LBOOKDTE1))%></font></b>&nbsp;</td>
  </tr>   
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Move Date:</font>&nbsp;</td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="3" color="#FF0000">
    <%=_EST.LBOOKDTE%><%=IIF(EMPTY(_EST.LBOOKDTE1),'','-'+DTOC(_EST.LBOOKDTE1))%></font></b>&nbsp;</td>
  </tr>
 <%IF !EMPTY(_EST.LBOOKTME)%> 
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Move Time:</font>&nbsp;</td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=ALLT(_EST.LBOOKTME)%></font></b>&nbsp;</td>
  </tr>
 <%ENDIF%>   
  <%IF !EMPTY(_EST.BOXDTE)%>
  <tr>
    <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Box Delivery:</font></b></td>
    <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=_EST.BOXDTE%>&nbsp;<%=(_EST.BOXTME)%></font></b></td>
 </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.PBOOKDTE)%>
    <tr>
     <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Pack Day:</font></b></td>
     <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=(_EST.PBOOKDTE)%>&nbsp;<%=(_EST.PBOOKTME)%></font></b></td>
    </tr>
  <%ENDIF%> 
  <%IF !EMPTY(_EST.DLVDTE)%> 
    <tr>
     <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">1<u><sup>st</sup></u> Available Delivery:</font></b></td>
     <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=_EST.DLVDTE%><%=IIF(EMPTY(_EST.DLVDTE1),'','-'+DTOC(_EST.DLVDTE1))%></font></b>&nbsp;</td>
    </tr>
   <%ENDIF%>
 <%IF !plBLKREF %> 
    <tr>
     <td width="48%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2">Reference By:</font></b></td>
     <td width="52%" style="border-bottom: 1px solid #BDBEC6;"><b><font face="Arial" size="2"><%=_EST.REF%></font></b>&nbsp;</td>
    </tr>
 <%ENDIF%>
    <tr>
     <td width="48%"><b><font face="Arial" size="2">Created on:</font></b></td>
     <td width="52%"><b><font face="Arial" size="2"><%=TTOD(_EST.OPENDTE)%></font></b>&nbsp;</td>
    </tr>
</table>
 <%IF plVEHICLE=.T. %>  
 <br>
<table border="0" align="center" bordercolor="#111111" width="100%">
  <tr>
    <td colspan="2" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><b>Optional Service: Auto Transport</b></font></td>
 </tr>
  <%SELECT _INVAUTO 
    SCAN %>
  <tr>
    <td width="59%"><font face="Arial" size="2"><b><%=ALLT(STR(QTY))+' '+ALLT(MAKE)+' '+ALLT(MODEL)+' '+ALLT(YEAR)%>&nbsp;<%=IIF(RUN,'','(not running)')%><%=IIF(COVER,' (enclosed)','')%></b></font></td>
    <td width="25%" align="right"><font face="Arial" size="2"><b><%='$'+ALLT(STR(UPRC*QTY))%></b></font>&nbsp;</td>
 </tr>
  <%ENDSCAN%>
</table>
  <%ENDIF%>    
    </td>
    <td width="52%" valign="top" style="border-left: 1px solid #083484;">
<table border="0" width="100%" style="border-collapse: collapse" cellspacing="1" cellpadding="2">
   <tr> 
     <td colspan="2" align="center" width="100%" style="border-bottom: 1px solid #BDBEC6;"><font color="#000080" face="Verdana"><b><%=IIF(pcTYPE<>'D','Relocation Rate','Relocation Estimate')%></b></font>&nbsp;</td>
  </tr>          
 <%IF pcTYPE='D' and plCALCTARIF AND _CRG.TARIFF>0 %>       
   <tr> 
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B>Total Tariff</B></font></td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><B><FONT face="Arial" size="2">&nbsp;<%='$'+ALLT(STR(_CRG.TARIFF,8,2))%></FONT></B></td>
  </tr>        
   <tr> 
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><B><font face="Arial" size="2" COLOR="#FF0000">Tariff Discount: <%=ALLT(STR(_CRG.TARIFDISCP,8,2))%>%</b></font></td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><b><font face="Arial" size="2" color="#FF0000">-<%='$'+ALLT(STR(_CRG.TARIFDISC,8,2))%></font></b></td>
  </tr>        
 <%ENDIF%>
 <%IF pcTYPE='D' %>        
   <tr> 
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><B><font face="Arial" size="2">Basic Estimate Price</font></B></td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><B><font face="Arial" size="2">&nbsp;<%='$'+ALLT(STR(_CRG.I1TOTAL,8,2))%></FONT></B></td>
  </tr>        
 <% ENDIF %>
<% IF pcTYPE='L' OR pcTYPE='R' %>     
    <% IF plFLATRATE OR plVIEWFLAT %>  
   <tr>
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B>Flat Rate:</B></font>&nbsp;</td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><B><font face="Arial" size="2">&nbsp;<%=IIF(_CRG.LTOTAL+_CRG.FTTOTAL > 0,'$'+ALLT(STR(_CRG.LTOTAL+_CRG.FTTOTAL,8,2)),'')%></FONT></B></td>
  </tr>         
  <% ELSE %>
   <tr>
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><B><font face="Arial" size="2"><%=IIF(_CRG.LVAN >0,ALLT(STR(_CRG.LVAN))+' Truck/s','')%>,&nbsp;<%=ALLT(STR(_CRG.LMEN))%>&nbsp;Workers,
     <%='$'+ALLT(STR(_CRG.LPERHRS,7,2))%>/hrs <%=ALLT(STR(_CRG.LHRS,6,1))%>&nbsp;hours</font></B></td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><B><font face="Arial" size="2"><%='$'+ALLT(STR(_CRG.LTOTAL,8,2))%></FONT></B></td>
  </tr>
    <%IF _CRG.FTTOTAL > 0 %>
   <tr>
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B>Estimated Travel Time:
     <%=IIF(_CRG.FTVAN >0,ALLT(STR(_CRG.FTVAN))+' Truck/s','')%>,&nbsp;<%=ALLT(STR(_CRG.FTMEN))%>&nbsp;Workers,&nbsp;
     <%=ALLT(STR(_CRG.FTHRS,6,2))%>&nbsp;hours,&nbsp;<%='$'+ALLT(STR(_CRG.FTPERHRS,7,2))%>/hrs</B></font></td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><B><font face="Arial" size="2"><%='$'+ALLT(STR(_CRG.FTTOTAL,8,2))%></FONT></B></td>
  </tr>
    <% ENDIF %>
  <% ENDIF %>
    <%IF _CRG.OTOTAL > 0 %>        
   <tr>
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><B>Fuel & Mileage</B></font></td>
     <td width="76" style="border-bottom: 1px solid #BDBEC6;" ALIGN="RIGHT"><B><font face="Arial" size="2">&nbsp;<%='$'+ALLT(STR(_CRG.OTOTAL,8,2))%></FONT></B></td>
  </tr>
    <% ENDIF %>
<% ENDIF %>        
      <%IF _CRG.DIESEL > 0 %>   
   <tr>
     <td width="275" style="border-bottom: 1px solid #BDBEC6;"><font face="Arial" size="2"><b>Fuel Surcharge:&nbsp;<%=ALLT(STR(_CRG.DIESELP,6,2))+' %'%></B></font></td>
