<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>wMove — Sign In</title>
  <style>
    body { margin:0; font-family:Arial,Helvetica,sans-serif; background:#efefec; color:#1c1c1c; }
    .wrap { max-width:360px; margin:8% auto; background:#fff; border:1px solid #d4d0c8; }
    .bar { height:5px; background:#1c1c1c; }
    .pad { padding:28px 30px 32px; }
    h1 { font-size:18px; margin:0 0 18px; }
    label { display:block; font-size:12px; margin:12px 0 4px; }
    input[type=text],input[type=password] { width:100%; box-sizing:border-box; padding:9px; border:1px solid #999; font-size:14px; }
    button { margin-top:20px; width:100%; padding:10px; background:#1c1c1c; color:#fff; border:0; font-size:14px; cursor:pointer; }
    .err { background:#fde2e1; border:1px solid #f5a6a1; color:#9b1c17; padding:9px 11px; font-size:13px; margin-bottom:6px; }
    .hint { font-size:11px; color:#888; margin-top:14px; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="bar"></div>
    <div class="pad">
      <h1>Sign in to wMove</h1>
      <% if (error) { %><div class="err"><%= error %></div><% } %>
      <% if (company) { %><div class="hint" style="margin:0 0 10px;">Company: <b><%= company %></b></div><% } %>
      <form method="post" action="/mplogin">
        <input type="hidden" name="next" value="<%= next %>">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" value="<%= username %>" autocomplete="username" autofocus>
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password">
        <% if (company) { %>
          <input type="hidden" name="company" value="<%= company %>">
        <% } else { %>
          <label for="company">Company code</label>
          <input type="text" id="company" name="company" autocomplete="off">
        <% } %>
        <button type="submit">Sign In</button>
      </form>
      <% if (process.env.DATA_MODE !== 'db') { %>
        <div class="hint">Demo mode — use <b>demo</b> / <b>demo123</b>.</div>
      <% } %>
    </div>
  </div>
</body>
</html>
