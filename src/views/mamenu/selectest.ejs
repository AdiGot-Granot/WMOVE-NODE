<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Select Estimate</title>
<SCRIPT LANGUAGE="JAVASCRIPT">
function DEPT(){
<% if (plDEPT) { %>
	var frm = document.theForm;
	if (frm.DEPT[frm.DEPT.selectedIndex].text=='') { alert("Please select department"); frm.DEPT.focus(); return false; }
	return true;
<% } else { %>
	return true;
<% } %>
}
function SubmitEst(i) {
  if (DEPT()) {
    if (i==1) { document.theForm.action="/mamenu/selectestret"; document.theForm.submit(); }
    if (i==2) { document.theForm.action="/mamenu/selectestret/INT"; document.theForm.submit(); }
    if (i==3) { document.theForm.action="/mamenu/selectestret/AUTO"; document.theForm.submit(); }
    if (i==4) { document.theForm.action="/mamenu/selectestret/BROKER"; document.theForm.submit(); }
  }
}
</SCRIPT>
<STYLE TYPE="text/css">
	.txtoff { color:#000080; font-size:11pt; font-family:Verdana; cursor:pointer; }
	.txton  { color:#000080; font-size:11pt; text-align:left; font-family:Verdana; cursor:pointer; text-decoration:underline; }
	A:hover { text-decoration:nounderline; color:red; }
	A       { text-decoration:underline; color:blue; }
</style>
</head>
<body BGCOLOR="#4E6699">
<table border="0" cellpadding="0" cellspacing="0" style="border-collapse: collapse" width="500" align="center">
  <tr><td width="100%"><IMG ALT="" SRC="/zz/images/topBar.gif" width="500" height="14"></td></tr>
  <tr><td width="100%" BGCOLOR="#008000" align="center"><b><font face="Verdana" size="4" color="#FFFFFF">Select Estimate</font></b></td></tr>
  <tr>
    <td width="100%" bgcolor="#FFFFFF"><br>
  <form name="theForm" method="post">
<table border="0" cellpadding="0" cellspacing="0" width="80%" align="center" style="border-collapse: collapse">
  <% if (plDEPT) { %>
  <tr>
    <td width="8%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
    <td width="92%" height="30"><b><font face="Verdana" style="font-size: 11pt;" color="#000080">Department</font></b>
     <select size="1" name="DEPT" style="background-color: #FFFFCC; font-size:10pt">
      <option value="" selected></option>
      <% depts.forEach(function (d) { %>
	  <OPTION VALUE="<%= (d.DEPT||'').trim() %>"><%= (d.DEPT||'').trim() %>&nbsp;-&nbsp;<%= (d.DEPTNAME||'').trim() %></OPTION>
      <% }); %>
	</select></td>
  </tr>
  <% } %>
  <tr>
    <td width="8%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
    <td width="92%" height="30"><font class="txtoff" onclick="SubmitEst(1)" onmouseover="this.className='txton'" onmouseout="this.className='txtoff'">Local / Long Distance</font></td>
  </tr>
  <tr>
    <td width="8%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
    <td width="92%" height="30"><font class="txtoff" onclick="SubmitEst(2)" onmouseover="this.className='txton'" onmouseout="this.className='txtoff'">International</font></td>
  </tr>
  <tr>
    <td width="8%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
    <td width="92%" height="30"><font class="txtoff" onclick="SubmitEst(3)" onmouseover="this.className='txton'" onmouseout="this.className='txtoff'">Auto Transport</font></td>
 </tr>
 <% if (plDMAIN) { %>
  <tr>
    <td width="8%" height="30" align="center"><img border="0" src="/zz/images/n-point.gif" width="10" height="10"></td>
    <td width="92%" height="30"><font class="txtoff" onclick="SubmitEst(4)" onmouseover="this.className='txton'" onmouseout="this.className='txtoff'">Booked Job from Broker (Skip Tariff)</font></td>
  </tr>
 <% } %>
</table>
	 </FORM>
    </td>
  </tr>
  <tr><td width="100%" bgcolor="#993366">&nbsp;<font size="2" color="white">User: <%= userName %></font></td></tr>
  <tr><td width="100%"><IMG SRC="/zz/images/botBar.gif" width="500" height="14"></td></tr>
</table>
</body>
</html>
