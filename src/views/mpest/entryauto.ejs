<html>
<head>
<META NAME="ROBOTS" CONTENT="NOINDEX, NOFOLLOW">
<META NAME="ROBOTS" CONTENT="NOARCHIVE">
<title>Auto Transport Entry Form</title>
<script language="JavaScript" src="/zz/util/formcheck.js"></script>
<link type="text/css" rel="stylesheet" href="/zz/util/dropdown.css">
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script type="text/javascript">
  $(document).ready(function() { $('.ref-select').select2({ placeholder: 'Select Reference', allowClear: true }); });
</script>
<SCRIPT LANGUAGE="JAVASCRIPT">
function sf(){ window.theForm.SNAME.focus(); }
function FindZip(par) {
   var frm = document.theForm, cCITY, cSTATE, cSR;
   if (par=='SZIP'){ cCITY=frm.SCITY.value; cSTATE=frm.SSTATE.value; cSR='S'; }
   else { cCITY=frm.RCITY.value; cSTATE=frm.RSTATE.value; cSR='R'; }
   window.open('/wc.dll?mputil~ZipWc~&SR='+cSR+'&cSTATE='+cSTATE+'&cCITY='+cCITY,'EANITHING','toolbar=no,location=no,status=no,menubar=no,resizable=no,scrollbars=yes,width=550,height=500');
   self.name="main";
}
<% if (level>0 && !flags.blkRefer) { %>
function CHKREF(){
   var frm = document.theForm;
   if (frm.REF[frm.REF.selectedIndex].text=='') { alert("Please select how did you hear about us?"); frm.REF.focus(); return false; }
   return true;
}
<% } %>
<% if (coLevel===3) { %>
function DEPT(){
   <% if (showDeptPicker) { %>
   var frm = document.theForm;
   if (frm.DEPT[frm.DEPT.selectedIndex].text=='') { alert("Please select department"); frm.DEPT.focus(); return false; }
   return true;
   <% } else { %>
   return true;
   <% } %>
}
<% } %>
function checkData(){
   var frm = document.theForm;
   return  lengthValid(frm.SNAME, 2,"full name")
         && lengthValid(frm.STELH, 1,"phone number")
         && lengthValid(frm.EMAIL, 1,"email")
<% if (est.STATUS==='F' || est.STATUS==='C') { %>
         && lengthValid(frm.LBOOKDTE, 1,"transport date");
<% } %>
   return true;
}
function SubmitEntry() {
   if (checkData()<% if (level>0 && !flags.blkRefer) { %> && CHKREF()<% } %><% if (coLevel===3 && showDeptPicker) { %> && DEPT()<% } %>) {
      document.theForm.action="/wc.dll?mpest~entryret~<%= scr %>~AUTO";
      document.theForm.submit();
   }
}
</SCRIPT>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
<script type="text/javascript">
   jQuery.noConflict();
   jQuery(document).ready(function($){ $("#Date1").datepicker({ numberOfMonths:[1,2] }); });
</script>
<STYLE TYPE="text/css">
   .TDTOP1   { text-align:left; color:White; font-size:10pt; font-family:Arial; background-color:#993366; font-weight:bold; }
   .TDBODY1  { text-align:center; color:white; font-size:10pt; font-family:Arial; background-color:#993366; font-weight:bold; border-style:none; border-color:#CCCCCC; }
   .SUBOFF1  { color:white; font-weight:bold; font-family:Arial; text-align:center; width:110px; background-color:#5A79A5; font-size:10pt; cursor:pointer; }
</style>
</head>
