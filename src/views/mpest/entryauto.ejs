 <BR>
<table border="1" width="98%" cellspacing="0" align="center" style="border-collapse: collapse" bordercolor="#CCCCCC">
  <tr>
    <td valign="top" width="70%">
<table border="0" width="602" align="center" cellspacing="0" style="border-collapse: collapse;line-height:27px;font-family:Arial;font-size:10pt;" bordercolor="#111111" cellpadding="0">
<% if (coLevel===3 && showDeptPicker) { %>
  <tr>
    <td colspan="3" width="602"><b>Department:</b>
     <select size="1" name="DEPT" style="background-color: #FFFFCC;">
      <option value="" selected></option>
      <% depts.forEach(function (d) { %>
      <OPTION VALUE="<%= fox.allt(d.DEPT) %>"><%= fox.allt(d.DEPT) %>&nbsp;-&nbsp;<%= fox.allt(d.DEPTNAME) %></OPTION>
      <% }); %>
    </select>
    </td>
 </tr>
<% } %>
<% if (isBooked && level>0) { %>
  <tr>
    <td colspan="3" width="602"><b>Job No:&nbsp;<FONT size="3" color="red"><%= fox.allt(est.DEPT) + fox.allt(est.ORDNO) %></font></b></td>
 </tr>
<% } %>
  <tr>
    <td width="172"><font face="Arial" size="2" color="#0000FF">Transport Date:</font><font color="#FF0000">*</font></td>
    <td width="115">
    <% if (est.STATUS!=='F' && est.STATUS!=='C') { %>
        <font face="Arial" color="#<%= bookDtePast ? 'FF0000' : '008000' %>" size="3"><B><%= est.LBOOKDTE ? fox.fmtDate(est.LBOOKDTE) : '' %></b></font>
    <% } else { %>
       <input type="text" autocomplete="off" id="Date1" name="LBOOKDTE" size="20" value="<%= est.LBOOKDTE ? fox.fmtDate(est.LBOOKDTE) : '' %>" style="width: 100px; max-width: 100%;background-color:#FFFFCC;font-weight:bold;" tabindex="27">
    <% } %>
    </td>
    <td width="315"><font face="Arial" size="2">Time:</font>
    <input type="text" name="LBOOKTME" size="10" value="<%= fox.allt(est.LBOOKTME) %>" style="cursor:pointer;" onclick="window.open('/wc.dll?mputil~timetablewc~theForm~LBOOKTME','EANITHING','toolbar=no,location=no,directories=no,status=no,menubar=no,resizable=no,copyhistory=no,scrollbars=yes,width=650,height=600')" tabindex="28" maxlength="20"></td>
 </tr>
<% if (level>0 && !flags.blkRefer) { %>
  <tr>
    <td width="172"><font face="Arial" size="2" color="#0000FF">How did you hear about us?</font><font color="#FF0000">*</font></td>
    <td colspan="2" width="430">
    <select size="1" name="REF" class="ref-select" style="width: 220px;background-color: #FFFFCC;" tabindex="33">
      <option><%= fox.allt(est.REF) %></option>
      <% referrals.forEach(function (t) { %><OPTION><%= (t.RNAME||'').trim() %></OPTION><% }); %>
    </select>
    </td>
 </tr>
<% } %>
  <tr>
    <td colspan="3" width="602"><b><font color="#FF0000"><%= msg %></font></b></td>
 </tr>
</table>
    </td>
    </tr>
</table>
 <% if (est.STATUS !== 'D' && est.STATUS !== 'C') { %>
 <center><br><input type="button" CLASS="SUBOFF1" name="B31" onclick="SubmitEntry()" onmouseover="this.style.background='#993366'" onmouseout="this.style.background='#5A79A5'" value="Submit">
 <% } %>
</form>
