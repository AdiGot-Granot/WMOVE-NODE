<SCRIPT LANGUAGE="JAVASCRIPT">
function sf(){ window.theForm.SNAME.focus(); }
function FindZip(par) {
   var frm = document.theForm, cCITY, cSTATE, cSR;
   if (par=='SZIP'){ cCITY=frm.SCITY.value; cSTATE=frm.SSTATE.value; cSR='S'; }
   else { cCITY=frm.RCITY.value; cSTATE=frm.RSTATE.value; cSR='R'; }
   window.open('/wc.dll?mputil~ZipWc~&SR='+cSR+'&cSTATE='+cSTATE+'&cCITY='+cCITY,'EANITHING','toolbar=no,location=no,status=no,menubar=no,resizable=no,scrollbars=yes,width=550,height=500');
   self.name="main";
}
function checkData(){
<% if (est.TYPE !== 'I') { %>
	var frm = document.theForm;
	return lengthValid(frm.SNAME, 2,"full name")
		&& zipValid(frm.SZIP, 5, "origin zip code - US only")
		&& zipValid(frm.RZIP, 5, "destination zip code - US only")
		&& lengthValid(frm.STELH, 1,"phone number")
		&& lengthValid(frm.EMAIL, 1,"email")
<% if (est.STATUS==='F' || est.STATUS==='C') { %>
		&& lengthValid(frm.LBOOKDTE, 1,"expected date of move");
<% } %>
<% } else { %>
	return true;
<% } %>
}
<% if (level>0 && !flags.blkRefer) { %>
function CHKREF(){
	var frm = document.theForm;
	if (frm.REF[frm.REF.selectedIndex].text=='') { alert("Please select how did you hear about us?"); frm.REF.focus(); return false; }
	return true;
}
<% } %>
function SubmitEntry(i) {
  if (checkData()<% if (level>0 && !flags.blkRefer) { %> && CHKREF()<% } %>) {
    if (i==1) { document.theForm.CONTINUEINV.style.visibility="hidden"; document.theForm.action="/wc.dll?mpest~entryret~<%= scr %>~INV"; }
    if (i==2) { document.theForm.CONTINUECRG.style.visibility="hidden"; document.theForm.action="/wc.dll?mpest~entryret~<%= scr %>~CHARGES"; }
    document.theForm.submit();
  }
}
</SCRIPT>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>
<link type="text/css" rel="Stylesheet" href="/zz/util/datepicker.css?v=3.1.2" media="screen">
