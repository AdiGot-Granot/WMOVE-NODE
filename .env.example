# ─── Runtime ────────────────────────────────────────────────────────────
PORT=6000
NODE_ENV=development

# ─── HTTPS (PFX bundle, same convention as the noms app) ─────────────────
HTTPS_ENABLED=true
PFX_FILE=./certs/localhost.pfx
PFX_PASSWORD=
# ⚠️ Browsers (Chrome/Firefox) block port 6000 as UNSAFE (ERR_UNSAFE_PORT).
#    For browser access use e.g. PORT=6443. Port 6000 still works with curl -k.

# DATA_MODE controls where the app reads data from:
#   demo  → built-in fixtures in data/demo (runs with NO database; great for first boot)
#   db    → live SQL Server (GMOVE) using the connection below
DATA_MODE=demo

# Safety gate for data-mutating endpoints (creating estimates, etc.).
# Keep false until verified against a non-prod tenant (e.g. DEMOPRO).
ESTIMATE_WRITES=false

# ─── SQL Server (used when DATA_MODE=db) ────────────────────────────────
# Mirrors the legacy WM.INI Sqlconnectstring / GMOVE connection.
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=GMOVE
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true
DB_POOL_MAX=10
DB_POOL_MIN=0

# ─── Session ────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production
# Legacy West Wind cookie name — keep identical so sessions interop during cutover.
SESSION_COOKIE_NAME=wwWebSessionId

# ─── Legacy / cutover ───────────────────────────────────────────────────
# Static front-end assets (the old D:\web tree: /zz/js, /zz/images, ...).
# Bundled into this repo at ./web so a clone is standalone. Path is resolved
# relative to the project root.
WEB_ASSET_DIR=./web
