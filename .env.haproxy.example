# Profile for running nodeWmove on noms31 (192.168.1.83) behind HAProxy.
# HAProxy routes wmove.ranusha.com -> this app and re-encrypts to it (ssl verify none),
# so the app serves HTTPS on 6443 using the bundled self-signed cert (fine — HAProxy
# doesn't verify it; the public-facing cert is granot.pem at HAProxy).
# Copy to .env on noms31:  cp .env.haproxy.example .env

NODE_ENV=production
DATA_MODE=db

# Serve HTTPS on the internal port HAProxy forwards to.
HTTPS_ENABLED=true
PORT=6443
PFX_FILE=./certs/localhost.pfx
PFX_PASSWORD=

# Trust HAProxy so req.ip / req.protocol reflect the real client (X-Forwarded-For).
# HAProxy (balance31) is on a different host, so trust the private network.
TRUST_PROXY=192.168.0.0/16
SECURE_COOKIES=true

# Database (GMOVE)
DB_SERVER=
DB_DATABASE=GMOVE
DB_USER=
DB_PASSWORD=

SESSION_SECRET=change-me
